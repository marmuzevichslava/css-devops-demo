							 "LockManager2",
							 CMN_ARCH_PARMS, 
							 FndGenRC);

	}



    return CMN_SUCCESS;
}  /* end of DZLM001XUnlockPbClk */




/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZLM001XLockReposFldChg
**
**  DESCRIPTION      : This callback is invoked during the FIELD CHANGE event of the 
**                     Lock Repository Combo Box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : IPEREZAR
**
**  DATE CREATED     : 10/25/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/25/96    IPEREZAR            Creation
**
***************************************************************************/

WCBPROC( DZLM001XLockReposFldChg )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
	CHAR GenDecode2Temp[BaseDecodeLength],
	     LockRepository[BaseDecodeLength];
    USHORT FndGenRC = 0;

	/* Initialize the temporary working storage strings */
	memset(GenDecode2Temp, 0, sizeof(GenDecode2Temp) );
	memset(LockRepository, 0, sizeof(LockRepository) );

    FndFieldQueryValue (CBI_hwnd,
                        "TxGenDecode2",
                        sizeof(GenDecode2Temp),
                        GenDecode2Temp,
                        &FndGenErrorBlock);

	/* If the deocde is a null-string, the combo is null-string or invalid.
	** It therefore becomes necessary to manually set the status and message
	** for the null.
	**/

	if (strcmp(GenDecode2Temp,"") == 0)
	{
		FndFieldQueryValue (CBI_hwnd,
                        "TxLockRepository",
                        sizeof(LockRepository),
                        LockRepository,
                        &FndGenErrorBlock);

		if (strcmp(LockRepository,"") == 0)
		{
			FndFieldSetStatus(CBI_hwnd,
			                  "TxLockRepository",
							  STS_INCOMPLETE,
							  &FndGenErrorBlock);

			FndFieldSetMsg(CBI_hwnd,
			               "TxLockRepository",
						   STSM_FIELD_REQUIRED,
						   &FndGenErrorBlock);
		}

	}
	else
	{
			FndFieldSetStatus(CBI_hwnd,
			                  "TxLockRepository",
							  STS_VALID,
							  &FndGenErrorBlock);

			FndFieldSetMsg(CBI_hwnd,
							"TxLockRepository",
							MF_NO_MSG,
							&FndGenErrorBlock);

	}

    return CMN_SUCCESS;
}  /* end of DZLM001XLockReposFldChg */



