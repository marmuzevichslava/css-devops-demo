/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZLM001XTxGenDec1FldChg
**
**  DESCRIPTION      : This callback is invoked during the FIELD CHANGE event of
**                     the TxGenDec1 field.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : IPEREZAR
**
**  DATE CREATED     : 10/25/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/25/96    IPEREZAR            Creation
**
***************************************************************************/

WCBPROC( DZLM001XTxGenDec1FldChg )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
	CHAR GenDecode1Temp[BaseDecodeLength],
	     ObjectType[BaseDecodeLength];
    USHORT FndGenRC = 0;

	/* Initialize the temporary working storage strings */
	memset(GenDecode1Temp, 0, sizeof(GenDecode1Temp) );
	memset(ObjectType, 0, sizeof(ObjectType) );

    FndFieldQueryValue (CBI_hwnd,
                        "TxGenDecode1",
                        sizeof(GenDecode1Temp),
                        GenDecode1Temp,
                        &FndGenErrorBlock);

	/* If the deocde is a null-string, the combo is null-string or invalid.
	** It therefore becomes necessary to manually set the status and message
	** for the null.
	**/

	if (strcmp(GenDecode1Temp,"") == 0)
	{
		FndFieldQueryValue (CBI_hwnd,
                        "TxLockObjectType",
                        sizeof(ObjectType),
                        ObjectType,
                        &FndGenErrorBlock);

		/* If the code is a null, the field's status is set to INCOMPLETE, and 
		** the object name field is disabled.
		**/

		if (strcmp(ObjectType,"") == 0)
		{
			FndFieldSetStatus(CBI_hwnd,
			                  "TxLockObjectType",
							  STS_INCOMPLETE,
							  &FndGenErrorBlock);

			FndFieldSetMsg(CBI_hwnd,
			               "TxLockObjectType",
						   STSM_FIELD_REQUIRED,
						   &FndGenErrorBlock);

			CmnFieldDisable( "LockObjectName",
                              CMN_ARCH_PARMS);

		}

	}
	else  /* Otherwise, the field's status is set to valid, and the next field is enabled */
	{
			FndFieldSetStatus(CBI_hwnd,
			                  "TxLockObjectType",
							  STS_VALID,
							  &FndGenErrorBlock);

			FndFieldSetMsg(CBI_hwnd,
		                  "TxLockObjectType",
			    		   MF_NO_MSG,
				    	   &FndGenErrorBlock);


			FndFieldEnable(CBI_hwnd,
			               "LockObjectName",
							&FndGenErrorBlock);


            DZLM001XObjNmFldChg( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);


	}


    return CMN_SUCCESS;
}  /* end of DZLM001XTxGenDec1FldChg */


