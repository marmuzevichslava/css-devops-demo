WCBPROC( DZLM001XUnlockPbClk )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT		FndGenRC = 0,
	            i = 0,
     		    SelectedButton = 0;


   _FND_STANDARD_PB	    FndStandardPB;
   _MSG_PARM_BLOCK	    ParmBlock;
   _ST_FMT_DATA_BLOCK   FormatDataBlock;
   _DESCR               ApplDescrDataBlock;

	_DZLM001INPUT *pMessageInput;
	_DZLM001OUTPUT	*pMessageOutput;


	/* Allocate and initialize memory for message structure */
    pMessageInput = (_DZLM001INPUT *) calloc (CallocNumElems, sizeof(_DZLM001INPUT));
    pMessageOutput = (_DZLM001OUTPUT *) calloc (CallocNumElems, sizeof(_DZLM001OUTPUT));

    memset(&FndStandardPB, 0, sizeof(FndStandardPB));
	memset(&ParmBlock, 0, sizeof(ParmBlock) );

	/* Populate the message structure from the window fields TxGenDecode1, LockObjectName
	** TxLockRepository and LockRefCheck. 
	**/

    FndFieldQueryValue (CBI_hwnd,
                        "TxGenDecode1",
                        sizeof(pMessageInput->DZLM001Message.DZLM001Keys.TxLockObjectType),
                        pMessageInput->DZLM001Message.DZLM001Keys.TxLockObjectType,
                        &FndGenErrorBlock);

    FndFieldQueryValue (CBI_hwnd,
                        "LockObjectName",
                        sizeof(pMessageInput->DZLM001Message.DZLM001Keys.LockObjectName),
                        pMessageInput->DZLM001Message.DZLM001Keys.LockObjectName,
                        &FndGenErrorBlock);

	i = 0;
	while ( i < LOCKOBJECTNAME_LEN )  
	{
	    if (pMessageInput->DZLM001Message.DZLM001Keys.LockObjectName[i] == UNIVERSAL_CHAR )
		{
			pMessageInput->DZLM001Message.DZLM001Keys.LockObjectName[i] = LIKE_CHAR;
		}

		i++;

	}

    FndFieldQueryValue (CBI_hwnd,
                        "TxLockRepository",
                        sizeof(pMessageInput->DZLM001Message.DZLM001Keys.TxLockRepository),
                        pMessageInput->DZLM001Message.DZLM001Keys.TxLockRepository,
                        &FndGenErrorBlock);

    FndFieldQueryValue (CBI_hwnd,
                        "LockRefCheck",
                        sizeof(pMessageInput->DZLM001Message.DZLM001Keys.LockRefCheck),
                        pMessageInput->DZLM001Message.DZLM001Keys.LockRefCheck,
                        &FndGenErrorBlock);

	/* Flag transaction as unlock */
	CmnStrCopy(	pMessageInput->DZLM001Message.DZLM001Keys.LockProcessType,
	            UNLOCK_ELEMENT,
				sizeof(pMessageInput->DZLM001Message.DZLM001Keys.LockProcessType),
				CMN_ARCH_PARMS);


   /* The pMessageInput has been formatted, now populate the MsgParmBlock */

    memcpy(FndStandardPB.ver,FND_MSG_VER,_VER_LEN);

    MSGInitPB(&FndStandardPB,
	     &ParmBlock,
	     pEAIA,
	     LUW_APPL_ID,
	     LUW_SRVC_ID,
	     SRVC_VER,
	     pABHI);

    memcpy(ParmBlock.commarea.ver,FND_MSG_VER,_VER_LEN);

    ParmBlock.actual_length_recv = sizeof(_DZLM001OUTPUT);
    ParmBlock.actual_length_send = sizeof(_DZLM001INPUT);
    ParmBlock.src.language = FND_LANGUAGE_C;
    ParmBlock.buffer_size = sizeof(_DZLM001INPUT);
    ParmBlock.dest.service_id.appl = LUW_APPL_ID;
    ParmBlock.dest.service_id.srvc = LUW_SRVC_ID;

    memcpy(ParmBlock.translation.map_name, LUW_SRVC_MAP, _FND_MAP_NAME_LEN);
    memcpy(ParmBlock.translation.map_version,SRVC_VER, _VER_LEN);


   /* The MsgParmBlock has been formatted, now send the message */

    FndGenRC = MSGConvUI( &ParmBlock, (_MSG_SEND_AREA) pMessageInput,
                      (_MSG_RECV_AREA) pMessageOutput, pABHI );

   /* There is a reply for the sent message. Check for messaging erros. If none
   ** are found, populate the message box. If errors are found, populate the 
   ** error information into an error message box.
   **/

    if( ((FndGenRC == MSGIO_SUCCESS) || (FndGenRC == MSGIO_SMALLBUFF)) 
        	&&    (ParmBlock.appl_status.explan_code == FND_SUCCESS) )
    {

		if (strcmp (pMessageOutput->DZLM001Message.DZLM001Data.LockProcessType,
		            MSG_RET_SUCCESS) == 0)
		{

			CmnMsgBoxDisplay(MX_UNLOCK_MSG,
							 &SelectedButton,
							 "LockManager2",
							 CMN_ARCH_PARMS, 
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsLocked,
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsPrevLocked,
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsProcessed);

		}
		else
		{
        /* An error occurred at the database, format the Session Transcript */

            memset(&FndStandardPB , 0, sizeof(_FND_STANDARD_PB) );
            memset(&FormatDataBlock , 0, sizeof(_ST_FMT_DATA_BLOCK) );
            memset(&ApplDescrDataBlock , 0, sizeof(_DESCR) );


            /* Specify ST version  */
            memcpy(FndStandardPB.ver, FND_ST_VER, _VER_LEN);

            /* Copy application default data (supplied by the architecture) into
            ** formatted data block.
            **/
            memcpy(&FormatDataBlock.ApplErrorBlock, pABHI, sizeof(_ABHI) );

            /* copy application specific error info into formatted data block */
            memcpy(&FormatDataBlock.ApplErrorBlock.abhi_monitor_data_block.fnd_win_name,
                   CBI_WindowName,
                   _WINDOW_NAME_LEN);

            FormatDataBlock.ApplErrorBlock.abhi_error_type_code = FND_ERR_TYPE_INFO;

            memcpy(&FormatDataBlock.ApplErrorBlock.abhi_error_tag_data,
                   "INFORMIX Error",
                   _ERROR_TAG_DATA_LEN);

            /* In a situation where an error occurred, the 'objectslocked' element
            ** will return the error number, or sql code.
            **/
            FormatDataBlock.ApplErrorBlock.abhi_error_msg_num = 
                                    pMessageOutput->DZLM001Message.DZLM001Data.ObjsLocked;

            memcpy(&FormatDataBlock.ApplErrorBlock.abhi_error_msg_area,
                   "Error Ocurred Accessing INFORMIX Repository.",
                   _DEP_MSG_AREA_LEN);

            FormatDataBlock.ApplErrorBlock.abhi_return_code = FND_SEVERITY_ERROR;

            FormatDataBlock.ApplErrorBlock.abhi_explanation_code = 
                                    pMessageOutput->DZLM001Message.DZLM001Data.ObjsLocked;

            ApplDescrDataBlock.data_pointer = "Error on Database";

            ApplDescrDataBlock.desc_length = strlen(ApplDescrDataBlock.data_pointer);

            /* Log this information to the error trascript */ 
            STLogAndDisplay (&FndStandardPB,
                             pABHI,
                             &FormatDataBlock,
                             ApplDescrDataBlock);


        /* Indicate to the user that an error occurred */
			CmnMsgBoxDisplay(MX_FND_ERROR,
							 &SelectedButton,
							 "LockManager2",
							 CMN_ARCH_PARMS, 
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsLocked,
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsPrevLocked,
							 pMessageOutput->DZLM001Message.DZLM001Data.ObjsProcessed);

