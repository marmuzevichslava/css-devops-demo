/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZLM001XCheckPbEnable
**
**  DESCRIPTION      : This callback is invoked on the FIELD CHANGE event of all
**                     fields in this window except the Check References Check
**                     box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  AUTHOR           : IPEREZAR
**
**  DATE CREATED     : 10/25/96
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/25/96    IPEREZAR            Creation
**
***************************************************************************/

WCBPROC( DZLM001XCheckPbEnable )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
	CHAR LockObjectTypeStatuss,
	     LockObjectNameStatuss,
		 LockRepositoryStatuss;
    USHORT FndGenRC = 0;

	/* Query the status of all three main single line entry fields */
    FndFieldQueryStatus (CBI_hwnd,
	                     "TxLockRepository",
						 &LockRepositoryStatuss,
						 &FndGenErrorBlock);

    FndFieldQueryStatus (CBI_hwnd,
	                     "LockObjectName",
						 &LockObjectNameStatuss,
						 &FndGenErrorBlock);

    FndFieldQueryStatus (CBI_hwnd,
	                     "TxLockObjectType",
						 &LockObjectTypeStatuss,
						 &FndGenErrorBlock);

	/* If all three fields have a valid status, set either by the application or by
	** WES, then the command pushbuttons are enabled. Otherwise, disablement is their
	** lot.
	**/ 

	if ( ((LockRepositoryStatuss == STS_VALID) || (LockRepositoryStatuss == STS_WESVALID)) &&
	     ((LockObjectNameStatuss == STS_VALID) || (LockObjectNameStatuss == STS_WESVALID)) &&
		 ((LockObjectTypeStatuss == STS_VALID) || (LockObjectTypeStatuss == STS_WESVALID)) )
	{
		/* Enable the two command buttons */
		FndCommandEnable ( CBI_hwnd,
                        "LockPB",
                        &FndGenErrorBlock);

		FndCommandEnable ( CBI_hwnd,
                        "UnlockPB",
                        &FndGenErrorBlock);

	}
	else
	{
		/* Disable the two command buttons */
		FndCommandDisable ( CBI_hwnd,
                        "LockPB",
                        &FndGenErrorBlock);

		FndCommandDisable ( CBI_hwnd,
                        "UnlockPB",
                        &FndGenErrorBlock);

	}


    return CMN_SUCCESS;
}  /* end of DZLM001XCheckPbEnable */


