/***********************************************************************
**
**               CUSTOMER SERVICE SYSTEM CSR FUNCTION
**
**  FUNCTION         :  CsrGetPBAndMessage
**
**  DESCRIPTION      :  This function reads the Message Parm Block and
**                      Service Message Layout supplied by the modified CSR
**                      in the directory: TABTEST_CSR_DUMP_FILE_PATH.
**
**  INPUTS           :
**
**  OUTPUTS          :
**
**  AUTHOR           :  ANDERSEN CONSULTING & FLORIDA POWER CORP.
**
**  DATE CREATED     :  07/22/94
**
**  REVISION HISTORY
**
**  DATE        REVISED BY      SIR #      DESCRIPTION OF CHANGE
**  --------    ----------      -----      ---------------------
**  07/22/94    J. Looney                  Original Code
**
************************************************************************/

SHORT CsrGetPBAndMessage( _MSG_PARM_BLOCK *pMsgPB, 
						 BYTE **ppMessage, 
						 CHAR *CSRDumpFilePathAndName)
{
    FILE                *fptr;
   	SHORT               FndGenRC = CMN_SUCCESS;
   	BYTE                *pMessage = *(ppMessage);

    /* 
    ** Open the CSR dump file designated by the Second Aurgument,
    **/
    if (( fptr = fopen( CSRDumpFilePathAndName, "rb" )) != NULL )
    {

        /* Read the MsgParmBlock from the file */
        fread( pMsgPB, sizeof( _MSG_PARM_BLOCK ), 1, fptr );
        
        /* Read the Message to file */
        //fread( (VOID *)pMessage,(size_t) pMsgPB->actual_length_send, 1, fptr );
        
        fread( pMessage,(size_t) pMsgPB->actual_length_send, 1, fptr );
        
        /* Close the file */
        fclose( fptr );

    }  /* end of if:  Successful fopen */

    else /* Error from fopen */
    {
        FndGenRC = CMN_FAIL;

    } /* end of else:  Error from fopen */

    
    return FndGenRC;

} /* End of CsrGetPBAndMessage */

/***********************************************************************
**
**               CUSTOMER SERVICE SYSTEM CSR FUNCTION
**
**  FUNCTION         :  DZSF002GetElemCfg
**
**  DESCRIPTION      : 
**
**  INPUTS           :
**
**  OUTPUTS          :
**
**  AUTHOR           :  ANDERSEN CONSULTING & FLORIDA POWER CORP.
**
**  DATE CREATED     :  07/22/94
**
**  REVISION HISTORY
**
**  DATE        REVISED BY      SIR #      DESCRIPTION OF CHANGE
**  --------    ----------      -----      ---------------------
**
************************************************************************/
SHORT DZSF002GetElemCfg( CHAR ElemCfgStr[DZSF002_ELEM_CFG_STR_NUM][DZSF002_ELEM_CFG_STR_LEN], 
						CHAR * TranMapID,
						CHAR * DialogID,
						USHORT *NumElements,
						FILE *fp )
{
	CHAR               Line[DZSF002_ELEM_CFG_STR_LEN];
	SHORT              i = 0;

	memset(Line, 0, DZSF002_ELEM_CFG_STR_LEN);


	/*
	** Locate file pointer at correct paragraph
	*/
	while (( strstr(Line, TranMapID) == NULL ) || (strstr(Line, DialogID) == NULL))
	{
		memset(Line, 0, DZSF002_ELEM_CFG_STR_LEN);
		if (fgets(Line, DZSF002_ELEM_CFG_STR_LEN, fp) == NULL)
		{
			return CMN_FAIL;
		}
	}
	
	/*
	** read the element configuration for this translation map
	*/
	i = 0;
	if( fgets(ElemCfgStr[i], DZSF002_ELEM_CFG_STR_LEN, fp) == NULL)
	{
			return CMN_FAIL;
	}

	while (strcmp( ElemCfgStr[i], DZSF002_NT_CARRIAGE_RTRN) != 0)
	{

		if (strncmp( ElemCfgStr[i], DZSF002_ELEM_KEY_WORD, 
									DZSF002_ELEM_KEY_WORD_LEN) == 0)
		{
			++(*NumElements);
		}

		++i;

		if( fgets(ElemCfgStr[i], DZSF002_ELEM_CFG_STR_LEN, fp) == NULL)
		{
			if( feof(fp) )
			{
				break;
			}
			return CMN_FAIL;
		}
		
	}
	
	return( CMN_SUCCESS );

}/*end of DZSF002GetElemCfg */

/***********************************************************************
**
**               CUSTOMER SERVICE SYSTEM TABLOAD FUNCTION
**
**  FUNCTION         :  DZSF002BusVerifyDir
**
**  DESCRIPTION      :  This function tests for a vallid directory path.
**
**  INPUTS           :
**
**  OUTPUTS          :
**
**  AUTHOR           :  ANDERSEN CONSULTING 
**
**  DATE CREATED     :  01/27/98
**
**  REVISION HISTORY
**
**  DATE        REVISED BY      SIR #      DESCRIPTION OF CHANGE
**  --------    ----------      -----      ---------------------
**  01/27/98    M. Conner                     Original Code
**
************************************************************************/
WCBPROC( DZSF002BusVerifyDir )
{
  FILE *Stream;
  _FND_ERROR_BLOCK  FndGenErrorBlock;
  short FndGenRC = 0;
  CHAR FileNm[TABLOAD_FILENAME_LEN] = "";
  CHAR sPath[_PATH_LEN + 1] = "";


   FndFieldQueryValue(CBI_hwnd,
                     DZSF002_OUTPUT_FIELD,
                     _PATH_LEN,
                     (void *) sPath,
                     &FndGenErrorBlock);
 
  /* Obtain file name */
  FndGenRC = CmnStrCat( CMN_ARCH_PARMS,
                        FileNm,
                        TABLOAD_FILENAME_LEN,
                        3,
                        sPath,
                        "\\",
                        TABLOAD_TMP_FILE );

  if (( Stream = fopen( FileNm,"w" )) == NULL )
  {


     FndFieldSetStatus( CBI_hwnd,
                        DZSF002_OUTPUT_FIELD,
                        STS_INVALID,
                        &FndGenErrorBlock );


     return( CMN_FAIL );

  }
  else
  {
     FndFieldSetStatus( CBI_hwnd,
                        DZSF002_OUTPUT_FIELD,
                        STS_VALID,
                        &FndGenErrorBlock );

    
     fclose( Stream );
     remove( FileNm );
  }

  return(CMN_SUCCESS);

}/*end of DZSF002BusVerifyDir */

/***********************************************************************
**
**               CUSTOMER SERVICE SYSTEM TABLOAD FUNCTION
**
**  FUNCTION         :  DZSF002BusVerifyDataFile
**
**  DESCRIPTION      :  This function tests for a valid data file.
**
**  INPUTS           :
**
**  OUTPUTS          :
**
**  AUTHOR           :  ANDERSEN CONSULTING 
**
**  DATE CREATED     :  01/27/98
**
**  REVISION HISTORY
**
**  DATE        REVISED BY      SIR #      DESCRIPTION OF CHANGE
**  --------    ----------      -----      ---------------------
**  01/27/98    M. Conner                     Original Code
**
************************************************************************/
WCBPROC( DZSF002BusVerifyDataFile )
{
  _FND_ERROR_BLOCK  ErrorBlock;
  USHORT FndGenRC = 0;
  CHAR FullNm[TABLOAD_FILENAME_LEN + _PATH_LEN + 1] = ""; 

  FILE *Stream;


   FndFieldQueryValue(CBI_hwnd,
                      DZSF002_DATA_FIELD,
                      _PATH_LEN,
                      (void *) FullNm,
                      &ErrorBlock);


  if ( strcmp(FullNm, "") != 0)
  {

      if (( Stream = fopen( FullNm,"r" )) == NULL )
      {
         FndFieldSetStatus( CBI_hwnd,
                            DZSF002_DATA_FIELD,
                            STS_INVALID,
                            &ErrorBlock );

         return( CMN_FAIL );

      }
      else
      {
         FndFieldSetStatus( CBI_hwnd,
                            DZSF002_DATA_FIELD,
                            STS_VALID,
                            &ErrorBlock );


         fclose( Stream );
      }
  } /*end of if ( strcmp(FullNm, "") != 0)*/


  return(CMN_SUCCESS);


}/*end of DZSF002BusVerifyDataFile */

