/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusNewMnClk
**
**  DESCRIPTION      : This function is activated by the New Menu Item Click
**		       event
**
**  INPUTS	     : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS	     : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusNewMnClk )
{

    USHORT FndGenRC = 0;
    USHORT i = 0;


    FndGenRC = DZIO01CommandDisable(MNTSAVEAS,
				    CMN_ARCH_PARMS);

    strcpy(pBFCD->DZIO01Hdr.SrcTyp,IOMODULE);

    strcpy(pBFCD->DZIO01Hdr.FuncNm, NEWMOD);

    strcpy(pBFCD->DZIO01Hdr.Iomodnm,NULL_STR);
    strcpy(pBFCD->DZIO01Hdr.Alrcbook,NULL_STR);
    strcpy(pBFCD->DZIO01Hdr.PrimTab,NULL_STR);

    strcpy(pBFCD->DZIO01Luw.Dz00713,NULL_STR);
    strcpy(pBFCD->DZIO01Hdr.PrimTabNm,NULL_STR);

    FndGenRC = DZIO01CommandDisable(MNTSAVE,
				    CMN_ARCH_PARMS);


    FndGenRC = CmnWindowCreate( DZIO005X,
				INST1,
				NULL,
				NULL,
				CMN_ARCH_PARMS);

    return FndGenRC;
}

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusMnGenClk
**
**  DESCRIPTION      : This function is activated by the New Menu Item Click
**		       event
**
**  INPUTS	     : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS	     : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusMnGenClk )
{

   _DZCR001OUTPUT  MessageOutReturn;
   _DZCR001INPUT   MessageInReturn;

   _DZCR001OUTPUT  *MessageOutput;
   _DZCR001INPUT   *MessageInput;


    _FND_ERROR_BLOCK FndGenErrorBlock;

    USHORT FndGenRC = 0,
           NumberOfRows = 1;

    memset(&(MessageOutReturn) , 0, sizeof(MessageOutReturn) );
    memset(&(MessageInReturn) , 0, sizeof(MessageInReturn) );


    MessageInput = (_DZCR001INPUT *) calloc (1, sizeof(_DZCR001INPUT));
    MessageOutput = (_DZCR001OUTPUT *) calloc (1, sizeof(_DZCR001OUTPUT));


    FndGenRC = FndMsgBoxDisplayMdlssText( TITLE8,
				   BOX_TITLE4,
				   CBI_hwnd,
				   FND_MSGBOX_NOBUTTONS,
				   FND_MSGBOX_INFORMATION,
				   FND_MSGBOX_IDNOBUTTON,
				   BOX_TITLE4,
				   &FndGenErrorBlock);


	MessageOutput->StandardHeader.StndrdHeadSubgrp.KySpt	= 10;

    CmnCodesGetDecodes( "DEV00707",			   /* Table name  */
                        CMN_CTB_LANGUAGE_DEFAULT,	   /* Language	  */
			            "R",
			            sizeof("R"),
			            MessageInput->StandardHeader.KyUserid2,	   /* Decode	  */
			            sizeof(MessageInput->StandardHeader.KyUserid2),	   /* Decode size */
			            &NumberOfRows,			   /* # of rows   */
			            CMN_ARCH_PARMS );


    FndGenRC = DZIO01ServiceCall(CMN_ARCH_PARMS,
				 (void *) GENMOD,
				 (void *) &(pBFCD->DZIO01Hdr.Iomodnm),
					 &MessageOutReturn,
                     &MessageInReturn);


    DZIO01MsgBoxDestroy(BOX_TITLE4,
				   CMN_ARCH_PARMS);



    memcpy(MessageOutput, &(MessageOutReturn),sizeof(MessageOutReturn));

    if (MessageOutput->StandardHeader.StndrdHeadSubgrp.KySpt	== 0)
    {
					DZIO01MsgBoxDisplay(TITLE9,
									BOX_TITLE4,
									CBI_hwnd,
									FND_MSGBOX_OK,
									FND_MSGBOX_INFORMATION,
									FND_MSGBOX_IDOK,
									BOX_TITLE4,
									CMN_ARCH_PARMS);


     }
     else
     {
					DZIO01MsgBoxDisplay(TITLE10,
									BOX_TITLE4,
									CBI_hwnd,
									FND_MSGBOX_OK,
									FND_MSGBOX_WARNING,
									FND_MSGBOX_IDOK,
									BOX_TITLE4,
									CMN_ARCH_PARMS);


      }


    return FndGenRC;
}



