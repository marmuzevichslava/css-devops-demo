**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusAlrFindPbClk )
{

    USHORT FndGenRC = 0;



    FndGenRC = DZIO01FieldQueryValue( ALRCBOOK,
				     pBFCD->DZIO01Hdr.Alrcbook,
				     sizeof(pBFCD->DZIO01Hdr.Alrcbook),
				     CMN_ARCH_PARMS);


    strcpy(pBFCD->DZIO01Hdr.SrcTyp,ALRCOPYB);

    FndGenRC = CmnWindowCreate(DZIO002X,
			       NULL,
			       NULL,
			       NULL,
			       CMN_ARCH_PARMS);



    return FndGenRC;
}





