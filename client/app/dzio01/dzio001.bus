/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusAlrFldChg
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - SolutionWorks
**
**  DATE CREATED     : 07/21/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 08/29/95	IPEREZAR	   Creation
**
***************************************************************************/

WCBPROC( DZIO001BusAlrFldChg )
{

    USHORT FndGenRC = 0;
    char TempStr[9];


    FndGenRC = DZIO01FieldQueryValue(ALRCBOOK,
				     TempStr,
				     sizeof(TempStr),
				     CMN_ARCH_PARMS);


    if (strcmp(TempStr,NULL_STR) == 0)
    {
       FndGenRC = DZIO01CommandDisable( FINDPB2,
					CMN_ARCH_PARMS);

       FndGenRC = DZIO01CommandDisable( VIEWPB2,
					CMN_ARCH_PARMS);

    }

    return CMN_SUCCESS;
}


