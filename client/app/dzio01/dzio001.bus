/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : Dzio001busprdis
**
**  DESCRIPTION      : This sets up the parent window
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusPrdis )
{

	CHAR   szWinTitle[50],
	       CdReposOrg[9];
    USHORT FndGenRC = 0, 
           NumberOfRows = 1;
    _FND_ERROR_BLOCK FndGenErrorBlock;


    memset(pBFCD,  0,sizeof(_BFCD) );

    memset(&(pBFCD->DZIO014Luw), 0, sizeof(pBFCD->DZIO014Luw) );

	memset(CdReposOrg, 0, sizeof(CdReposOrg) );

    CmnCodesGetDecodes( "DEV00707",			   /* Table name  */
                        CMN_CTB_LANGUAGE_DEFAULT,	   /* Language	  */
			            "R",
			            sizeof("R"),
			            CdReposOrg,	   /* Decode	  */
			            sizeof(CdReposOrg),	   /* Decode size */
			            &NumberOfRows,			   /* # of rows   */
			            CMN_ARCH_PARMS );

	memset(szWinTitle, 0, sizeof(szWinTitle) );

    sprintf(szWinTitle,"I/O Module Generator (%s)", CdReposOrg);

	FndWindowSetText( CBI_hwnd,
	                  szWinTitle,
					  &FndGenErrorBlock);




    return FndGenRC;
}

