/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusSumButClk
**
**  DESCRIPTION      : This function is activated by the Exit Menu Item Click
**		       event
**
**  INPUTS	     : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS	     : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusSumButClk  )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;


    if (SumData[0] == CHECKED)
    {
	FndGenRC = DZIO01FieldEnable(SUMCOL,
				     CMN_ARCH_PARMS);

	FndGenRC = FndFieldSetStatus(CBI_hwnd,
				     SUMCOL,
				     STS_INCOMPLETE,
				     &FndGenErrorBlock );
    }
    else
    {
	FndGenRC = FndFieldSetValue( CBI_hwnd,
				     SUMCOL,
				     sizeof(SumColData),
				     NULL_STR,
				     &FndGenErrorBlock);


	FndGenRC = DZIO01FieldDisable(SUMCOL,
				      CMN_ARCH_PARMS);

    }


    return FndGenRC;
}




/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusSaveMnClk
**
**  DESCRIPTION      : This function is activated by the Open Menu Item Click
**		       event
**
**  INPUTS	     : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS	     : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO001BusSaveMnClk )
{

    USHORT FndGenRC = 0, 
           NumberOfRows = 1;
    USHORT i = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

   _DZCL001OUTPUT  *MessageOutput;
   _DZCL001INPUT *MessageInput;

   _FND_STANDARD_PB	FndStandardPB;
   _MSG_PARM_BLOCK	ParmBlock;

    MessageInput = (_DZCL001INPUT *) calloc (1, sizeof(_DZCL001INPUT));
    MessageOutput = (_DZCL001OUTPUT *) calloc (1, sizeof(_DZCL001OUTPUT));


    FndGenRC = DZIO01CommandEnable(MNTSAVEAS,
				   CMN_ARCH_PARMS);


    FndGenRC = FndMsgBoxDisplayMdlssText( TITLE6,
				   BOX_TITLE2,
				   CBI_hwnd,
				   FND_MSGBOX_NOBUTTONS,
				   FND_MSGBOX_INFORMATION,
				   FND_MSGBOX_IDNOBUTTON,
				   BOX_TITLE3,
				   &FndGenErrorBlock);


    CmnCodesGetDecodes( "DEV00707",			   /* Table name  */
                        CMN_CTB_LANGUAGE_DEFAULT,	   /* Language	  */
			            "R",
			            sizeof("R"),
			            MessageInput->StandardHeader.KyUserid2,	   /* Decode	  */
			            sizeof(MessageInput->StandardHeader.KyUserid2),	   /* Decode size */
			            &NumberOfRows,			   /* # of rows   */
			            CMN_ARCH_PARMS );



    FndGenRC = DZIO01FieldQueryValue(PRIMTAB,
				     MessageInput->Hdr_DZ0202.PrimTab,
				     sizeof(MessageInput->Hdr_DZ0202.PrimTab),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(ALRCBOOK,
				     MessageInput->Hdr_DZ0101.Alrcbook,
				     sizeof(MessageInput->Hdr_DZ0101.Alrcbook),
				     CMN_ARCH_PARMS);


    FndGenRC = DZIO01FieldQueryValue( FETCH,
				     MessageInput->Hdr_DZ0101.Fetch,
				     sizeof(MessageInput->Hdr_DZ0101.Fetch),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue( INSERT,
				     MessageInput->Hdr_DZ0101.Insert,
				     sizeof(MessageInput->Hdr_DZ0101.Insert),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue( UPDATE,
				     MessageInput->Hdr_DZ0101.Update,
				     sizeof(MessageInput->Hdr_DZ0101.Update),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(SUM,
				     MessageInput->Hdr_DZ0101.Sum,
				     sizeof(MessageInput->Hdr_DZ0101.Sum),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(COUNT,
				     MessageInput->Hdr_DZ0101.Count,
				     sizeof(MessageInput->Hdr_DZ0101.Count),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(DEL,
				     MessageInput->Hdr_DZ0101.Delete,
				     sizeof(MessageInput->Hdr_DZ0101.Delete),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(FETNX,
				     MessageInput->Hdr_DZ0101.FetNx,
				     sizeof(MessageInput->Hdr_DZ0101.FetNx),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(INSSET,
				     MessageInput->Hdr_DZ0101.InsSet,
				     sizeof(MessageInput->Hdr_DZ0101.InsSet),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(UPDSET,
				     MessageInput->Hdr_DZ0101.UpdSet,
				     sizeof(MessageInput->Hdr_DZ0101.UpdSet),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(UNIQUE,
				     MessageInput->Hdr_DZ0101.Unique,
				     sizeof(MessageInput->Hdr_DZ0101.Unique),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(CSTFUN,
				     MessageInput->Hdr_DZ0101.CstFun,
				     sizeof(MessageInput->Hdr_DZ0101.CstFun),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(DELSET,
				     MessageInput->Hdr_DZ0101.DelSet,
				     sizeof(MessageInput->Hdr_DZ0101.DelSet),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(SUMMUL,
				     MessageInput->Hdr_DZ0101.SumMul,
				     sizeof(MessageInput->Hdr_DZ0101.SumMul),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(CNTMUL,
				     MessageInput->Hdr_DZ0101.CntMul,
				     sizeof(MessageInput->Hdr_DZ0101.CntMul),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(RENAME,
				     MessageInput->Hdr_DZ0101.Rename,
				     sizeof(MessageInput->Hdr_DZ0101.Rename),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(DYNSCR,
				     MessageInput->Hdr_DZ0101.DynScr,
				     sizeof(MessageInput->Hdr_DZ0101.DynScr),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(FETPREV,
				     MessageInput->Hdr_DZ0101.FetPrev,
				     sizeof(MessageInput->Hdr_DZ0101.FetPrev),
				     CMN_ARCH_PARMS);

    FndGenRC = DZIO01FieldQueryValue(SUMCOL,
				     MessageInput->Hdr_DZ0101.SumCol,
				     sizeof(MessageInput->Hdr_DZ0101.SumCol),
				     CMN_ARCH_PARMS);


/**************************************************************************
*									  *
*   Formatting the Table Names and ALR Prefix			  *
*									  *
***************************************************************************/


    strncpy(MessageInput->Hdr_DZ0202.PrimTabNm,
            pBFCD->DZIO01Hdr.PrimTabNm,
			sizeof(MessageInput->Hdr_DZ0202.PrimTabNm));

    strncpy(MessageInput->Hdr_DZ0101.Vw_Nm,
            pBFCD->DZIO01Luw.Dz00713,
			sizeof(MessageInput->Hdr_DZ0101.Vw_Nm));

    strncpy(MessageInput->Hdr_DZ0202.SecTabB ,
            pBFCD->DZIO012Luw.SecTabB,
			sizeof(MessageInput->Hdr_DZ0202.SecTabB ));

    strncpy(MessageInput->Hdr_DZ0202.SecTabBNm ,
            pBFCD->DZIO012Luw.SecTabBNm ,
			sizeof(MessageInput->Hdr_DZ0202.SecTabBNm ));

    strncpy(MessageInput->Hdr_DZ0202.SecTabC ,
            pBFCD->DZIO012Luw.SecTabC,
			sizeof(MessageInput->Hdr_DZ0202.SecTabC ));

    strncpy(MessageInput->Hdr_DZ0202.SecTabCNm ,
            pBFCD->DZIO012Luw.SecTabCNm ,
			sizeof(MessageInput->Hdr_DZ0202.SecTabCNm ));


/**************************************************************************
*		                                     							  *
* Formatting the parameters of tables DZ01TB03 and DZ01TB04               *
*                                                                         *
***************************************************************************/


    memcpy( &(MessageInput->DZIO013Luw), &(pBFCD->DZIO013Luw), sizeof(_DZIO013LUW) );

    memcpy( &(MessageInput->DZIO014Luw), &(pBFCD->DZIO014Luw), sizeof(_DZIO014LUW) );


/**************************************************************************
*									  *
*   Formatting and Sending a message with the MsgConvUI			  *
*									  *
***************************************************************************/



    strncpy(MessageInput->Hdr_DZ0101.Iomodnm, pBFCD->DZIO01Luw.Iomodnm,
	       sizeof(MessageInput->Hdr_DZ0101.Iomodnm) );




    for(i=0; i<5; i++)
    {
       if( strcmp(pBFCD->DZIO01Luw.Order_By[i].DescKey,NULL_STR) != 0)
       {
	   strncpy(MessageInput->Order_By[i].DescKey,
		     pBFCD->DZIO01Luw.Order_By[i].DescKey,
		       sizeof(MessageInput->Order_By[i].DescKey) );
       }
    }

    memcpy(FndStandardPB.ver,FND_MSG_VER,_VER_LEN);

    i = sizeof (MessageOutput->StandardHeader);
    MSGInitPB(&FndStandardPB,
	     &ParmBlock,
	     pEAIA,
	     LUW_APPL_ID,
	     LUW_SRVC_ID,
	     SRVC_VER,
	     pABHI);

    memcpy(ParmBlock.commarea.ver,FND_MSG_VER,_VER_LEN);

    ParmBlock.actual_length_send = sizeof(_DZCL001INPUT);
    ParmBlock.src.language = FND_LANGUAGE_C;
    ParmBlock.buffer_size = sizeof(_DZCL001OUTPUT);
    ParmBlock.dest.service_id.appl = LUW_APPL_ID;
    ParmBlock.dest.service_id.srvc = LUW_SRVC_ID;

    memcpy(ParmBlock.translation.map_name, LUW_SRVC_MAP, _FND_MAP_NAME_LEN);
    memcpy(ParmBlock.translation.map_version,SRVC_VER, _VER_LEN);

    CmnCodesGetDecodes( "DEV00707",			   /* Table name  */
                        CMN_CTB_LANGUAGE_DEFAULT,	   /* Language	  */
			            "R",
			            sizeof("R"),
			            MessageInput->StandardHeader.KyUserid2,	   /* Decode	  */
			            sizeof(MessageInput->StandardHeader.KyUserid2),	   /* Decode size */
			            &NumberOfRows,			   /* # of rows   */
			            CMN_ARCH_PARMS );


    FndGenRC = MSGConvUI(&ParmBlock,
			(_MSG_SEND_AREA) MessageInput,
			(_MSG_RECV_AREA) MessageOutput,
			pABHI);

    FndGenRC = DZIO01MsgBoxDestroy(BOX_TITLE2,
				   CMN_ARCH_PARMS);


    if (strcmp(MessageOutput->Hdr_DZ0101.Alrcbook, PASSED) == 0)
    {

	FndGenRC = DZIO01CommandEnable(MNTMGEN,
					 CMN_ARCH_PARMS);

	FndGenRC = DZIO01MsgBoxDisplay(TITLE1,
				       BOX_TITLE,
				       CBI_hwnd,
				       FND_MSGBOX_OK,
				       FND_MSGBOX_WARNING,
				       FND_MSGBOX_IDOK,
				       BOX_TITLE,
				       CMN_ARCH_PARMS);

    }
    else if (strcmp(MessageOutput->Hdr_DZ0101.Alrcbook, FOUND) == 0)
    {
	FndGenRC = DZIO01MsgBoxDisplay(TITLE2 ,
				       BOX_TITLE,
				       CBI_hwnd,
				       FND_MSGBOX_OK,
				       FND_MSGBOX_ERROR,
				       FND_MSGBOX_IDOK,
				       BOX_TITLE,
				       CMN_ARCH_PARMS);

    }

    return FndGenRC;
}



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO001BusAlrFindPbClk
**
**  DESCRIPTION      : This function is activated by the Open Menu Item Click
**		       event
**
**  INPUTS	     : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS	     : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     : 07/23/95
