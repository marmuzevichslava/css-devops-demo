/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Pnihokjr1155_List_Select
 * 
 *   WidgetName:    ReposDataLB
 *
 *   Event Name:    LIST_SELECT
 *
 *
 ***************************************************************************/
static WCBPROC(Pnihokjr1155_List_Select)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    FndCrDz00751 = 0;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

FndGenRC = FndCommandEnable(CBI_hwnd,
                            "AddPB",
                            &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                             "DeletePB",
                             &FndGenErrorBlock);

for ( FndCrDz00751 = 0;
      FndCrDz00751 < NUMDZ00751ROWS;
      FndCrDz00751++)
   {

   Dz00751SelIndData[FndCrDz00751] = SIN_NOTSELECTED;

   } /* end for */

strncpy(CdOperandB1Data,LT_Asc,9);

FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CdOperandB1",
                             &FndGenErrorBlock);

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
