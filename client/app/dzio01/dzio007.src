/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Pnihokjr0699_List_Select
 * 
 *   WidgetName:    DZ00751
 *
 *   Event Name:    LIST_SELECT
 *
 *
 ***************************************************************************/
static WCBPROC(Pnihokjr0699_List_Select)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    FndCrReposDataLB = 0;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

FndGenRC = FndCommandEnable(CBI_hwnd,
                            "DeletePB",
                            &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                             "AddPB",
                             &FndGenErrorBlock);

for ( FndCrReposDataLB = 0;
      FndCrReposDataLB < NUMREPOSDATALBROWS;
      FndCrReposDataLB++)
   {

   ReposDataLBSelIndData[FndCrReposDataLB] = SIN_NOTSELECTED;

   } /* end for */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
