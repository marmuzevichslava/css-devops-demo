**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO012xSecElmSlct )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    OpenWindow = SECTABB_Char;

    FndFieldQueryValue (CBI_hwnd,
                        "SecTabB",
                        sizeof(pBFCD->DZIO012Luw.SecTabB),
                        pBFCD->DZIO012Luw.SecTabB,
                        &FndGenErrorBlock);

    strcpy(pBFCD->DZIO01Hdr.SrcTyp,SECTABB);

    FndFieldQueryValue (CBI_hwnd,
                        "SecTabBNm",
                        sizeof(pBFCD->DZIO012Luw.SecTabBNm),
                        pBFCD->DZIO012Luw.SecTabBNm,
                        &FndGenErrorBlock);

    FndGenRC = CmnWindowCreate( DZIO013X,
				INST1,
				NULL,
				NULL,
				CMN_ARCH_PARMS);



    return FndGenRC;
}







