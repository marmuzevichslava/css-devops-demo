/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO012xOkPbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC( DZIO012xOkPbClk )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    memset(&(pBFCD->DZIO012Luw), 0, sizeof(pBFCD->DZIO012Luw) );

    FndFieldQueryValue (CBI_hwnd,
                        "SecTabC",
                        sizeof(pBFCD->DZIO012Luw.SecTabC),
                        pBFCD->DZIO012Luw.SecTabC,
                        &FndGenErrorBlock);


    FndFieldQueryValue (CBI_hwnd,
                        "SecTabCNm",
                        sizeof(pBFCD->DZIO012Luw.SecTabCNm),
                        pBFCD->DZIO012Luw.SecTabCNm,
                        &FndGenErrorBlock);


    FndFieldQueryValue (CBI_hwnd,
                        "SecTabB",
                        sizeof(pBFCD->DZIO012Luw.SecTabB),
                        pBFCD->DZIO012Luw.SecTabB,
                        &FndGenErrorBlock);

    FndFieldQueryValue (CBI_hwnd,
                        "SecTabBNm",
                        sizeof(pBFCD->DZIO012Luw.SecTabBNm),
                        pBFCD->DZIO012Luw.SecTabBNm,
                        &FndGenErrorBlock);

    return FndGenRC;
}


