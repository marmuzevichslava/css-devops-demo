WCBPROC( DZIO012xElemJoin )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;


    CmnStrCopy(pBFCD->DZIO012Luw.PrimTabNm,
               pBFCD->DZIO01Hdr.PrimTabNm,
               sizeof(pBFCD->DZIO012Luw.PrimTabNm),
               CMN_ARCH_PARMS);


    FndFieldQueryValue (CBI_hwnd,
                        "SecTabC",
