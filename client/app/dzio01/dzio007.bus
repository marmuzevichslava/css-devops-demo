**
***************************************************************************/


WCBPROC( DZIO007BusDelPbClk )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT LRowNumber = 0;
    char OrdFlg[4] = NULL_STR;

    FndGenRC = FndCommandEnable(CBI_hwnd,
	                            "OKPB",
								&FndGenErrorBlock);

  //  Place Application Business Logic here

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
					  DZ00751,
					  FND_LSTBOX_START,
					  &LRowNumber,
					  &FndGenErrorBlock);

    FndGenRC = FndLstBoxRowDelete(CBI_hwnd,
				  DZ00751,
				  LRowNumber,
				  &FndGenErrorBlock);



    return CMN_SUCCESS;
}


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO007BusPbOkClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - SolutionWorks
**
**  DATE CREATED     : 07/23/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    07/23/95	IPEREZAR	      Original code.
**
***************************************************************************/

WCBPROC( DZIO007BusPbOkClk )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT RowNumber = 0;
    char OrdFlg[4] = NULL_STR;

    _Dz00751Row RowData;

    memset(RowData._Dz00751Dz00799Data,' ',36);
    memset(RowData._Dz00751KeyTypData,' ',8);


//  Establish addressability



    for (RowNumber=0; RowNumber < 5; RowNumber++)
    {

	FndGenRC = FndLstBoxRowQueryData (CBI_hwnd,
			   DZ00751,
			   RowNumber,
			   sizeof(pBFCD->DZIO01Luw.Order_By[RowNumber].DescKey),
			   (void *) &(RowData),
			   &FndGenErrorBlock);


	strncpy(pBFCD->DZIO01Luw.Order_By[RowNumber].DescKey,
	    RowData._Dz00751Dz00799Data,
	    sizeof(pBFCD->DZIO01Luw.Order_By[RowNumber].DescKey) );


    }

    return CMN_SUCCESS;
}
