/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO014xDeletePbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO014xDeletePbClk )
{

    USHORT FndGenRC = 0;
    USHORT RowNumber = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
				                           "MainJoinLB",
                                           FND_LSTBOX_START,
				                           &RowNumber,
                                           &FndGenErrorBlock );
            
    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
    			                      "MainJoinLB",
	    		                      RowNumber,
                                      sizeof( DeleteMainJoinLBRow ),
                                      (VOID *) &DeleteMainJoinLBRow,
                                      &FndGenErrorBlock );

    FndGenRC = FndLstBoxRowDelete( CBI_hwnd,
    			                   "MainJoinLB",
	    		                    RowNumber,
                                    &FndGenErrorBlock );

    MainJoinLBCounter = MainJoinLBCounter - 1;

	FndCommandEnable( CBI_hwnd,
	                   "OKPB",
					   &FndGenErrorBlock);

	FndCommandEnable( CBI_hwnd,
	                   "UndeletePB",
					   &FndGenErrorBlock);


    return FndGenRC;
}






/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO014xUndelPbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO014xUndelPbClk )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
				                "MainJoinLB",
				                MainJoinLBCounter,
                                sizeof( DeleteMainJoinLBRow ),
                                (VOID *) &DeleteMainJoinLBRow,
                                &FndGenErrorBlock );

    MainJoinLBCounter = MainJoinLBCounter + 1;

    memset(&DeleteMainJoinLBRow, 0, sizeof(DeleteMainJoinLBRow) );

	FndCommandDisable( CBI_hwnd,
	                   "UndeletePB",
					   &FndGenErrorBlock);



    return FndGenRC;
}
