/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO014xPredisplay
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**                      DZIO014xPredisplay
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO014xPredisplay )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _MainJoinLBRow MainJoinLBRowData;


    FndGenRC = FndCommandDisable(CBI_hwnd,
	                            "ApplyPB",
								&FndGenErrorBlock);

	FndCommandDisable( CBI_hwnd,
	                   "OKPB",
					   &FndGenErrorBlock);


	FndCommandDisable( CBI_hwnd,
	                   "UndeletePB",
					   &FndGenErrorBlock);

	FndCommandDisable( CBI_hwnd,
	                   "DeletePB",
					   &FndGenErrorBlock);


    JoinTable1Counter = 0; 
    JoinTable2Counter = 0; 
    MainJoinLBCounter = 0;

    /* Initialize the left combo box */

    FndValueInit( CBI_hwnd,
                  "PrimTblLst",
                  1,
                  2,
                  9,
                  &FndGenErrorBlock);

    /* Populate the left combo box with the available table data */

    if (strcmp(pBFCD->DZIO012Luw.PrimTab, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "PrimTblLst",
                         1,
                         FND_VALUE_START,
                         "A",
                         pBFCD->DZIO012Luw.PrimTab,
                         &FndGenErrorBlock);

    }
    if (strcmp(pBFCD->DZIO012Luw.SecTabB, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "PrimTblLst",
                         1,
                         FND_VALUE_END,
                         "B",
                         pBFCD->DZIO012Luw.SecTabB,
                         &FndGenErrorBlock);

    }
    if (strcmp(pBFCD->DZIO012Luw.SecTabC, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "PrimTblLst",
                         1,
                         FND_VALUE_END,
                         "C",
                         pBFCD->DZIO012Luw.SecTabC,
                         &FndGenErrorBlock);

    }



    /* Initialize the second combo box */

    FndValueInit( CBI_hwnd,
                  "SecTblLst",
                  1,
                  2,
                  9,
                  &FndGenErrorBlock);



    /* Populate the right combo box with the available table data */

    if (strcmp(pBFCD->DZIO012Luw.PrimTab, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "SecTblLst",
                         1,
                         FND_VALUE_START,
                         "A",
                         pBFCD->DZIO012Luw.PrimTab,
                         &FndGenErrorBlock);

    }
    if (strcmp(pBFCD->DZIO012Luw.SecTabB, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "SecTblLst",
                         1,
                         FND_VALUE_END,
                         "B",
                         pBFCD->DZIO012Luw.SecTabB,
                         &FndGenErrorBlock);

    }
    if (strcmp(pBFCD->DZIO012Luw.SecTabC, "") != 0)
    {
        FndValueAddItem( CBI_hwnd,
                         "SecTblLst",
                         1,
                         FND_VALUE_END,
                         "C",
                         pBFCD->DZIO012Luw.SecTabC,
                         &FndGenErrorBlock);

    }

    /*
     | After the drop down listboxes have been initialized, populated and sent off to
     | school, the main listbox is populated with any pertaining data in storage.
     */

    MainJoinLBCounter = 0;

    while (strcmp(pBFCD->DZIO014Luw.DZIO014AJoin[MainJoinLBCounter].JoinElmTblNm, "") != 0)
    {
        memset(&MainJoinLBRowData , 0, sizeof(MainJoinLBRowData) );

        CmnStrCopy( MainJoinLBRowData._MainJoinLBSecTabBNmData,
                    pBFCD->DZIO014Luw.DZIO014AJoin[MainJoinLBCounter].JoinElmTblNm,
                    sizeof(MainJoinLBRowData._MainJoinLBSecTabBNmData),
                    CMN_ARCH_PARMS);

        CmnStrCopy( MainJoinLBRowData._MainJoinLBElmIdData,
                    pBFCD->DZIO014Luw.DZIO014AJoin[MainJoinLBCounter].JoinElmId,
                    sizeof(MainJoinLBRowData._MainJoinLBElmIdData),
                    CMN_ARCH_PARMS);

        CmnStrCopy( MainJoinLBRowData._MainJoinLBSecTabCNmData,
                    pBFCD->DZIO014Luw.DZIO014BJoin[MainJoinLBCounter].JoinElmTblNm,
                    sizeof(MainJoinLBRowData._MainJoinLBSecTabCNmData),
                    CMN_ARCH_PARMS);

        CmnStrCopy( MainJoinLBRowData._MainJoinLBJoinElmIdData,
                    pBFCD->DZIO014Luw.DZIO014BJoin[MainJoinLBCounter].JoinElmId,
                    sizeof(MainJoinLBRowData._MainJoinLBJoinElmIdData),
                    CMN_ARCH_PARMS);

        CmnStrCopy(MainJoinLBRowData._MainJoinLBDotFill1Data,
                   DotFill,
                   sizeof(MainJoinLBRowData._MainJoinLBDotFill1Data),
                   CMN_ARCH_PARMS);

        CmnStrCopy(MainJoinLBRowData._MainJoinLBDotFill2Data,
                   DotFill,
                   sizeof(MainJoinLBRowData._MainJoinLBDotFill2Data),
                   CMN_ARCH_PARMS);

        CmnStrCopy(MainJoinLBRowData._MainJoinLBRelationalOperatorData,
                   RelatEq,
                   sizeof(MainJoinLBRowData._MainJoinLBRelationalOperatorData),
                   CMN_ARCH_PARMS);

        FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
				                "MainJoinLB",
				                MainJoinLBCounter,
                                sizeof( MainJoinLBRowData ),
                                (VOID *) &MainJoinLBRowData,
                                &FndGenErrorBlock );

        MainJoinLBCounter = MainJoinLBCounter + 1;


    	FndCommandEnable( CBI_hwnd,
	                   "DeletePB",
					   &FndGenErrorBlock);


    }


    return FndGenRC;
}






/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO014xJoinTbl1LstSlct
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO014xJoinTbl1LstSlct )
{

    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    JoinTable1Counter = 1;

    if (JoinTable2Counter == 1)
    {
        FndGenRC = FndCommandEnable(CBI_hwnd,
	                            "ApplyPB",
								&FndGenErrorBlock);
    }



    return FndGenRC;
}






