                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "DelSet",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "DynScr",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "FetPrev",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "InsSet",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Rename",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Sum",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "SumMul",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "UpdSet",
                             &FndGenErrorBlock);

   } /* end if */

if ( strcmp(FunctData, LT_NonStd) == 0 )
   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "CntMul",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Unique",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Count",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "CstFun",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Delete",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "DelSet",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "DynScr",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Fetch",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "FetNx",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "FetPrev",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Insert",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "InsSet",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Rename",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Sum",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "SumMul",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Update",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "UpdSet",
                            &FndGenErrorBlock);

   } /* end if */

if ( strcmp(FunctData, LT_Limit) == 0 )
   {

   DeleteData[0] = 'Y';

   FetchData[0] = 'Y';

   FetNxData[0] = 'Y';

   UpdateData[0] = 'Y';

   InsertData[0] = 'Y';

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CntMul",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Unique",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Count",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CstFun",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "DelSet",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "DynScr",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "FetPrev",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "InsSet",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Rename",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Sum",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "SumMul",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "UpdSet",
                             &FndGenErrorBlock);

   } /* end if */

return 0;


}
