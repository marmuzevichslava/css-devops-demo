/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Ncqnrdhl9475_Field_Change
 * 
 *   WidgetName:    PrimTab
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Ncqnrdhl9475_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

if (strcmp( PrimTabData, "" ) != 0)
   {

   FndGenRC = FndCommandEnable(CBI_hwnd,
                            "FolderPB",
                            &FndGenErrorBlock);

   if (strcmp( AlrcbookData, "" ) != 0)
      {

      FndGenRC = FndCommandEnable(CBI_hwnd,
                            "MntSave",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Funct",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "TaskList",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Fetch",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Delete",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "FetNx",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Insert",
                            &FndGenErrorBlock);

      FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Update",
                            &FndGenErrorBlock);

      } /* end if */

   FndGenRC = FndCommandEnable(CBI_hwnd,
                            "FindPB1",
                            &FndGenErrorBlock);

   FndGenRC = FndCommandEnable(CBI_hwnd,
                            "VIEW1",
                            &FndGenErrorBlock);

   } /* end if */

return 0;


}
