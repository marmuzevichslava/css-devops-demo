static WCBPROC(Ncqnrdhl0571_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

if ( strcmp(FunctData, LT_Std) == 0 )
   {

   DeleteData[0] = 'N';

   FetchData[0] = 'N';

   FetNxData[0] = 'N';

   InsertData[0] = 'N';

   UpdateData[0] = 'N';

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CntMul",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Unique",
                             &FndGenErrorBlock);

