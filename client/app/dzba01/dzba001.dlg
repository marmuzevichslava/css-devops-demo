Begin
"P",1004,CONTROL,VIRTKEY
"X",1005,CONTROL,VIRTKEY
VK_DELETE,3001,SHIFT,VIRTKEY
VK_INSERT,3002,CONTROL,VIRTKEY
VK_INSERT,3003,SHIFT,VIRTKEY
"X",1006,ALT,VIRTKEY
End


