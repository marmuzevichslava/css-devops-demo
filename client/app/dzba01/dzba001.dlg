DZBA001MenuID MENU PRELOAD
Begin  /*  menus  */
     POPUP "&Account"
Begin
     MENUITEM "&Process\tCtrl+P",1004
     MENUITEM "E&xit\tCtrl+X",1005
End
     POPUP "&Edit"
Begin
     MENUITEM "Cu&t\tShift Del",3001
     MENUITEM "&Copy\tCtrl Ins",3002
     MENUITEM "&Paste\tShift Ins",3003
End
     POPUP "&Options"
Begin
     MENUITEM "Export / Import Dtl...\tAlt+X",1006
End
     POPUP "&Help"
Begin
     MENUITEM "&Help for Help...",1007
     MENUITEM "&Extended Help...",1008
     MENUITEM "&Keys Help...",1009
     MENUITEM "Help &Index...",1010
     MENUITEM SEPARATOR     MENUITEM "&About...",1011
End
End  /*  menus  */


