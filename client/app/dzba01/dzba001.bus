/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA001BusProcessMNEnable
**
**  DESCRIPTION      : This function is invoked whenever the process menu
**                     item is clicked. It formats the LUW layout with the
**                     window fields.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : CmnStrCopy
**                     CmnCsrCall
**                     FndFieldQueryValue
**
**  AUTHOR           : iperezar
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

WCBPROC( DZBA001BusProcessMNEnable )
{

    USHORT             NumRows = 0,
	                   FndGenRC = 0;
	CHAR               cStatusInsDb;
	CHAR               cStatusInsOwn;
	CHAR               cStatusInsPw;
	CHAR               cStatusExtDb;
	CHAR               cStatusExtOwn;
	CHAR               cStatusExtPw;
    CHAR               CdExtractInsertAct[3];

    _FND_ERROR_BLOCK   FndGenErrorBlock;

    memset(CdExtractInsertAct, 0 , sizeof(CdExtractInsertAct) );

    FndFieldQueryValue(CBI_hwnd,
                    "CdExtractInsertAct",
                    sizeof(CdExtractInsertAct),
                    CdExtractInsertAct,
                    &FndGenErrorBlock);


	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxExtractDbId",
						  &cStatusExtDb,
						  &FndGenErrorBlock);

	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxExtractOwnerId",
						  &cStatusExtOwn,
						  &FndGenErrorBlock);

	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxExtractPsswdId",
						  &cStatusExtPw,
						  &FndGenErrorBlock);

	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxInsertDbId",
						  &cStatusInsDb,
						  &FndGenErrorBlock);

	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxInsertPsswdId",
						  &cStatusInsPw,
						  &FndGenErrorBlock);

	FndFieldQueryStatus ( CBI_hwnd,
		                  "TxInsertOwnerId",
						  &cStatusInsOwn,
						  &FndGenErrorBlock);

	/* if extract-insert */
	if (strcmp(CdExtractInsertAct, LT_Ext_Ins_Mode) == 0)
	{
	
    if ( ( (cStatusExtDb == STS_VALID) || (cStatusExtDb == STS_WESVALID) ) &&
		 ( (cStatusInsPw == STS_VALID) || (cStatusInsPw == STS_WESVALID) ) &&
		 ( (cStatusExtPw == STS_VALID) || (cStatusExtPw == STS_WESVALID) ) &&
	     ( (cStatusInsOwn == STS_VALID) || (cStatusInsOwn == STS_WESVALID) ) &&
		 ( (cStatusInsDb == STS_VALID) || (cStatusInsDb == STS_WESVALID) ) &&
		 ( (cStatusExtOwn == STS_VALID) || (cStatusExtOwn == STS_WESVALID) ) )
    {


		if ( NumberOfRows > 0 )
		{

              CmnWindowSetApplValid ( CMN_ARCH_PARMS );

		}
		else
		{
              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

		}
	}
	else
	{
              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

	}

    } /* if extract-insert */

	/* if extract */
	else if (strcmp(CdExtractInsertAct, LT_Extract_Mode) == 0)
	{
	
    if ( ( (cStatusExtDb == STS_VALID) || (cStatusExtDb == STS_WESVALID) ) &&
		 ( (cStatusExtPw == STS_VALID) || (cStatusExtPw == STS_WESVALID) ) &&
		 ( (cStatusExtOwn == STS_VALID) || (cStatusExtOwn == STS_WESVALID) ) )
    {


		if ( NumberOfRows > 0 )
		{

              CmnWindowSetApplValid ( CMN_ARCH_PARMS );

		}
		else
		{

              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

		}
	}
	else
	{
              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

	}

    } /* if extract */
	 

	else if (strcmp(CdExtractInsertAct, LT_Insert_Mode) == 0)
   	{
	
        if ( ( (cStatusInsDb == STS_VALID) || (cStatusInsDb == STS_WESVALID) ) &&
		     ( (cStatusInsPw == STS_VALID) || (cStatusInsPw == STS_WESVALID) ) &&
		    ( (cStatusInsOwn == STS_VALID) || (cStatusInsOwn == STS_WESVALID) ) )
        {


		    if ( NumberOfRows > 0 )
		    {

              CmnWindowSetApplValid ( CMN_ARCH_PARMS );

		    }
		    else
		    {

              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

		    }

	    }
	    else
	    {
              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

	    }

    } /* if insert */
	else if (strcmp(CdExtractInsertAct, LT_Export_Mode) == 0) 
	{
	
		    if ( NumberOfRows > 0 )
		    {

              CmnWindowSetApplValid ( CMN_ARCH_PARMS );

		    }
		    else
		    {

              CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

		    }

    } /* if export */
	else if (strcmp(CdExtractInsertAct, LT_Import_Mode) == 0) 
	{
	
              CmnWindowSetApplValid ( CMN_ARCH_PARMS );

    } /* if export */

    return CMN_SUCCESS;

}	/* end DZBA001BusProcessMNEnable */





/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA001MnExpClk
**
**  DESCRIPTION      : This function is invoked whenever the process menu
**                     item is clicked. It formats the LUW layout with the
**                     window fields.
**
