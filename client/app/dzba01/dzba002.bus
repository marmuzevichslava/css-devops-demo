/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusWindowPredisp 
**
**  DESCRIPTION      : This function is executed when the window is
**					   originally opened.  It will malloc the
**					   pointer to the WCD
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusWindowPredisp )
{

    USHORT             FndGenRC = 0,
                       i = 0;
	CHAR                KyBaStrMask[KYEXTRACTNOA_LEN]; /* Masked String Format */
	long              KyPremNo;	/* Used as target in atol from String Format */
	long              KyBldgNo;	/* Used as target in atol from String Format */

    /* Pointer to Input Layout  SWAT01BI */
    _SWAT01BINPUT      *pSWAT01BInput; 
    _FND_ERROR_BLOCK    FndGenErrorBlock;


    /* Allocate memory for the working storage area */
    pWindContextData->pWorkingStorageData =
        (CHAR *) malloc(sizeof(_WindowData));

	/* Set up a pointer to the value of CBI_pInitData */
    pSWAT01BInput = (_SWAT01BINPUT *) CBI_pInitData;

    /* initialize the Request area of the WCD */
    memset(&WCD_SWAT01BRqst, 0, sizeof(WCD_SWAT01BRqst));

    /*
     | Set GlobalMode with the type of account involved.
     */

    memset(GlobalMode, 0, sizeof(GlobalMode));

    CmnStrCopy(GlobalMode,
               pSWAT01BInput->SWAT01BData.CdExtractInsertAct,
               sizeof(GlobalMode),
               CMN_ARCH_PARMS);

    if ((strcmp(GlobalMode, LT_Insert_Mode) == 0) ||
        (strcmp(GlobalMode, LT_Export_Mode) == 0))
    {
	    
        FndFieldSetStatus( CBI_hwnd,
                         "TsKyExtract",
                          STS_INCOMPLETE,
                          &FndGenErrorBlock);

        FndFieldSetMsg(CBI_hwnd,
		               "TsKyExtract",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


    }



    /* 
     | Disable the timestamp field and the FIND pushbutton when the access type is 
     | not Insert 
     */


	if ((strcmp(pSWAT01BInput->SWAT01BData.CdExtractInsertAct, LT_Insert_Mode) == 0)
	||  (strcmp(pSWAT01BInput->SWAT01BData.CdExtractInsertAct, LT_Export_Mode) == 0))
	{
		FndFieldEnable (CBI_hwnd,
		                "TsKyExtract",
						&FndGenErrorBlock);

	}
	else
	{
		FndFieldDisable (CBI_hwnd,
		                "TsKyExtract",
						&FndGenErrorBlock);


	   /*  Set appropriate Status for each of the 3 fields. If the mode is
	    |  Insert mode, then a timestamp is sufficient input and the other fields
		|  need not be required
		*/

       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

       FndFieldSetMsg(CBI_hwnd,
			          "KyBa",
					   MF_NO_MSG,
					   &FndGenErrorBlock);

       FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBldgNo",,
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyPremNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


	}

    /* Check to see if there is data in the IN layout */
    if( strlen (pSWAT01BInput->SWAT01BData.KyExtractNoA) > 0)
    {

   	    if ( strcmp(pSWAT01BInput->SWAT01BData.CdAccessType, LT_Acct_A) == 0)
		{
            /* Set Access Type to 'Account' */
            FndFieldSetValue(CBI_hwnd,
                        "CdAccessType",
                         2,
                         LT_Acct_01,
                         &FndGenErrorBlock);

	        /* Call Function to Validate correct fields to display */
					   
            FndGenRC = DZBA002BusCDRbAccessTypeFC( pEventInfo,
                                                   pEAIA,
                                                   pBFCD,
                                                   pWesMap,
                                                   pWindContextData,
                                                   pABHI);


 	        /*Format KyBaStrMask */
            CmnStrCopy (KyBaStrMask,
                         pSWAT01BInput->SWAT01BData.KyExtractNoA,
                         KYEXTRACTNOA_LEN,
                         CMN_ARCH_PARMS);
 

		/* Format in Masked Field Format */
        for( i = 5; (i < (sizeof(KyBaStrMask))); i++)
        {
            KyBaStrMask[i] = pSWAT01BInput->SWAT01BData.KyExtractNoA[i+1];
        }

		    /* Load the Value for KyBa */
            FndFieldSetValue(CBI_hwnd,
                                "KyBa",
                                sizeof(KyBaStrMask),
                                KyBaStrMask,
                                &FndGenErrorBlock);



		} /* END: Access Type = Account */

		else if(strcmp(pSWAT01BInput->SWAT01BData.CdAccessType, LT_Prem_P) == 0)

		{
            /* Set Access Type to 'Premise' */
            FndFieldSetValue(CBI_hwnd,
                        "CdAccessType",
                         2,
                         LT_Prem_02,
                         &FndGenErrorBlock);

	        /* Call Function to Validate correct fields to display */
            FndGenRC = DZBA002BusCDRbAccessTypeFC( pEventInfo,
                                                   pEAIA,
                                                   pBFCD,
                                                   pWesMap,
                                                   pWindContextData,
                                                   pABHI);

			/* Convert from String To Long */
			KyPremNo = atol(pSWAT01BInput->SWAT01BData.KyExtractNoA);

		    /* Load the Value for KyPremNo */
            FndFieldSetValue( CBI_hwnd,
                            "KyPremNo",
                            sizeof(KyPremNo),
                            &KyPremNo,
                            &FndGenErrorBlock);

		} /* END: Access Type = Premise */

		else if(strcmp(pSWAT01BInput->SWAT01BData.CdAccessType, LT_Bldg_B) == 0)

		{
            /* Set Access Type to 'Building' */
            FndFieldSetValue(CBI_hwnd,
                        "CdAccessType",
                         2,
                         LT_Bldg_03,
                         &FndGenErrorBlock);

	        /* Call Function to Validate correct fields to display */
            FndGenRC = DZBA002BusCDRbAccessTypeFC( pEventInfo,
                                                   pEAIA,
                                                   pBFCD,
                                                   pWesMap,
                                                   pWindContextData,
                                                   pABHI);

			/* Convert from String To Long */
			KyBldgNo = atol(pSWAT01BInput->SWAT01BData.KyExtractNoA);

		    /* Load the Value for KyPremNo */
            FndFieldSetValue( CBI_hwnd,
                            "KyBldgNo",
                            sizeof(KyBldgNo),
                            &KyBldgNo,
                            &FndGenErrorBlock);


		} /* END: Access Type = Building */


        /* Load the Value for TsKyExtract */
        FndFieldSetValue( CBI_hwnd,
                     "TsKyExtract",
                     sizeof(pSWAT01BInput->SWAT01BData.TsKyExtract),
                     &pSWAT01BInput->SWAT01BData.TsKyExtract,
                     &FndGenErrorBlock);

        /* Load the Value for TxExtractRemarks2 */
        FndFieldSetValue( CBI_hwnd,
                         "TxExtractRemarks2",
                         sizeof(pSWAT01BInput->SWAT01BData.TxExtractRemarks2),
                         &pSWAT01BInput->SWAT01BData.TxExtractRemarks2,
                         &FndGenErrorBlock);

	} /* END: Check to see if there is data in the IN layout */
	else
	{ /* No Data in IN Layout -> Add Mode */

        /* Default the Access Type to 'Account' */
        FndFieldSetValue(CBI_hwnd,
                    "CdAccessType",
                     2,
                     LT_Acct_01,
                     &FndGenErrorBlock);

        /* Call Function to Validate correct fields to display */
        FndGenRC = DZBA002BusCDRbAccessTypeFC( pEventInfo,
                                               pEAIA,
                                               pBFCD,
                                               pWesMap,
                                               pWindContextData,
                                               pABHI);

        /* Check to see if there is data in the Remarks Area */
        if( pSWAT01BInput->SWAT01BData.TxExtractRemarks2 != NULL)
	    {
            /* Load the Value for TxExtractRemarks2 */
            FndFieldSetValue( CBI_hwnd,
                         "TxExtractRemarks2",
                         sizeof(pSWAT01BInput->SWAT01BData.TxExtractRemarks2),
                         &pSWAT01BInput->SWAT01BData.TxExtractRemarks2,
                         &FndGenErrorBlock);

	    } /* END: Check to see if there is data in the Remarks Area of INPUT */

	} /* END: No Data in IN Layout -> Add Mode */

  
	/* Build the Actual window title */
    CmnWindowTitleCreate( "Details",
                          "",
                          "Extract/Insert",
                          CMN_DEFAULT_WINDOW_TITLE_MAX,
                          CMN_ARCH_PARMS );


	FndCommandDisable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);


    /* Show the actual window */
    FndWindowShow( CBI_hwnd,
                   &FndGenErrorBlock);


    return CMN_SUCCESS;

}  /* end DZBA002BusWindowPredisp */

