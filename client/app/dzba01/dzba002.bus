                      &FndGenErrorBlock);

			FndFieldSetMsg(CBI_hwnd,
			               "KyBldgNo",
						   MF_NO_MSG,
						   &FndGenErrorBlock);


	        cStatus = STS_INCOMPLETE;
       }

	}

	memset (szTxKyExtract, 0 ,sizeof(szTxKyExtract));

    FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(szTxKyExtract),
                      szTxKyExtract,
                      &FndGenErrorBlock);


    if ( (strcmp(szTxKyExtract, EMPTY_STR) != 0) || (cStatus == STS_VALID) )
