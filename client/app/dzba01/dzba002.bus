/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Dzba002bustxusernmfc
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC(Dzba002bustxusernmfc)
{
    _FND_ERROR_BLOCK    FndGenErrorBlock;
	CHAR			   szTxUserNm[9],
                       szTxKyExtract[26];
    USHORT             FndGenRC = 0;

	memset (szTxUserNm, 0 ,sizeof(szTxUserNm) );
    memset (szTxKyExtract, 0, sizeof(szTxKyExtract) );

    FndFieldQueryValue(CBI_hwnd,
                      "TxUserNm",
                      sizeof(szTxUserNm),
                      szTxUserNm,
                      &FndGenErrorBlock);

    FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(szTxKyExtract),
                      szTxKyExtract,
                      &FndGenErrorBlock);


    if (strcmp(szTxKyExtract, EMPTY_STR) == 0) 
	{


    if ( strcmp(szTxUserNm, EMPTY_STR) != 0 )
	{
		/* Enable the command pushbuttons */


		FndGenRC = FndFieldQueryEnabled(CBI_hwnd,
		                                "TsKyExtract",
						                &FndGenErrorBlock);

        if (FndGenRC == FND_SUCCESS)
        {
		    FndCommandEnable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);
        }

        FndFieldSetStatus( CBI_hwnd,
                         "TxUserNm",
                          STS_VALID,
                          &FndGenErrorBlock);

		FndFieldSetMsg(CBI_hwnd,
			           "TxUserNm",
					   MF_NO_MSG,
					   &FndGenErrorBlock);


	}
	else
	{
		/* Disable the command pushbuttons */

		FndCommandDisable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);

	}

    }  /* if (strcmp(szTxKyExtract, EMPTY_STR) == 0) */
    else
    {
		FndCommandEnable(CBI_hwnd,
	                     "ValidPB",
					     &FndGenErrorBlock);

    }  /*  else  */
   

    return CMN_SUCCESS;


}  /* End of Dzba002bustxusernmfc */


