		FndGenRC = FndFieldQueryEnabled(CBI_hwnd,
		                                "TsKyExtract",
						                &FndGenErrorBlock);

        if (FndGenRC == FND_SUCCESS)
        {
		    FndCommandEnable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);
        }

	}
	else
	{

		FndCommandDisable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);


	}


    return CMN_SUCCESS;

}  /* End of DZBA002BusKyBldgNoFC  */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusKyBaFC
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusKyBaFC )
{
	CHAR               KyBaStr[11];
    USHORT             FndGenRC = 0;
    _FND_ERROR_BLOCK    FndGenErrorBlock;
	CHAR               cStatus;
	CHAR			   szTxKyExtract[23];

	memset (KyBaStr, 0 ,sizeof(KyBaStr));

	memset (szTxKyExtract, 0 ,sizeof(szTxKyExtract));

    FndFieldQueryValue(CBI_hwnd,
                          "KyBa",
                          sizeof(KyBaStr),
                          KyBaStr,
                          &FndGenErrorBlock);


	if ( ( KyBaStr[0] >= '0' ) && ( KyBaStr[0] <= '9') )
	     
	{
       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
		              "KyBa",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


	   cStatus = STS_VALID;

	}
	else
	{
       if ((strcmp(GlobalMode, LT_Insert_Mode) != 0) &&
           (strcmp(GlobalMode, LT_Export_Mode) != 0))
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_INCOMPLETE,
                      &FndGenErrorBlock);

            FndFieldSetMsg(CBI_hwnd,
		               "KyBa",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


	       cStatus = STS_INCOMPLETE;
       }
       else
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

		   FndFieldSetMsg(CBI_hwnd,
			              "KyBa",
						   MF_NO_MSG,
						   &FndGenErrorBlock);


	       cStatus = STS_INCOMPLETE;
       }

	}



    FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(szTxKyExtract),
                      szTxKyExtract,
                      &FndGenErrorBlock);


    if ( (strcmp(szTxKyExtract, EMPTY_STR) != 0) || (cStatus == STS_VALID) )
	{

		FndGenRC = FndFieldQueryEnabled(CBI_hwnd,
		                                "TsKyExtract",
						                &FndGenErrorBlock);

        if (FndGenRC == FND_SUCCESS)
        {
		    FndCommandEnable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);
        }

	}
	else
	{
		FndCommandDisable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);


	}


    return CMN_SUCCESS;

}  /* End of DZBA002BusKyBaFC */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusKyTsKyExtFC
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusKyTsKyExtFC )
{
    _FND_ERROR_BLOCK    FndGenErrorBlock;
	CHAR			   szTxKyExtract[23];
    USHORT             FndGenRC = 0;

	memset (szTxKyExtract, 0 ,sizeof(szTxKyExtract));


    FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(szTxKyExtract),
                      szTxKyExtract,
                      &FndGenErrorBlock);


    if ( strcmp(szTxKyExtract, EMPTY_STR) != 0 )
	{
		/* Enable the command pushbuttons */


		FndGenRC = FndFieldQueryEnabled(CBI_hwnd,
		                                "TsKyExtract",
						                &FndGenErrorBlock);

        if (FndGenRC == FND_SUCCESS)
        {
		    FndCommandEnable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);
        }

        FndFieldSetStatus( CBI_hwnd,
                         "TsKyExtract",
                          STS_VALID,
                          &FndGenErrorBlock);

		FndFieldSetMsg(CBI_hwnd,
			           "TsKyExtract",
					   MF_NO_MSG,
					   &FndGenErrorBlock);


	}
	else
	{
		/* Disable the command pushbuttons */

		FndCommandDisable(CBI_hwnd,
	                  "ValidPB",
					  &FndGenErrorBlock);

        FndFieldSetStatus( CBI_hwnd,
                         "TsKyExtract",
                          STS_INCOMPLETE,
                          &FndGenErrorBlock);

        FndFieldSetMsg(CBI_hwnd,
		               "TsKyExtract",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


	}

	   /* Set appropriate Status for each of the 3 fields */
       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBa",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBldgNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
	                  "KyPremNo",
	   			      MF_NO_MSG,
					  &FndGenErrorBlock);


       FndGenRC = DZBA002BusKyBldgNoFC( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

	   FndGenRC = DZBA002BusKyPremNoFC( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

       FndGenRC = DZBA002BusKyBaFC( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

       FndGenRC = Dzba002bustxusernmfc( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);


	   /*  Set appropriate Status for each of the 3 fields. If the mode is
	    |  Insert mode, then a timestamp is sufficient input and the other fields
		|  need not be required
		*/

       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBa",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBldgNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);

       FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

  	   FndFieldSetMsg(CBI_hwnd,
		              "KyPremNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);



    return CMN_SUCCESS;

}  /* End of DZBA002BusKyTsKyExtFC */



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusValidatePBClick
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusValidatePBClick )
{
    USHORT             FndGenRC = 0;
    _DZBA003INPUT      pDZBA003INPUT;
	CHAR               CdAccessType[3];
	CHAR               KyExtractNoStr[KYEXTRACTNOA_LEN];
	CHAR               KyBaStr[KYEXTRACTNOA_LEN];
	ULONG              KyBldgNo = 0;
	ULONG              KyPremNo = 0;
	CHAR			   szTxKyExtract[23];
	CHAR		       szTxExtractRemarks2[78];
    USHORT	           SelectedButton = 0;
	CHAR               szTempString[12];
    CHAR               szTxnUsrId[11], 
	                   szTxnUsrId2[7];

    _FND_ERROR_BLOCK    FndGenErrorBlock;

    memset(szTxnUsrId, 0, sizeof(szTxnUsrId));

    memset(szTxnUsrId2, 0, sizeof(szTxnUsrId2));

	memset(KyBaStr, 0, sizeof(KyBaStr));

	memset(szTempString, 0, sizeof(szTempString) );

	memset(&pDZBA003INPUT, 0, sizeof(_DZBA003INPUT) );

    memset(szTxKyExtract, 0, sizeof(szTxKyExtract) );

    memset(szTxExtractRemarks2, 0, sizeof(szTxExtractRemarks2) );

	CmnStrCopy( CdAccessType,
		        WCD_SWAT01BRqst.SWAT01BData.CdAccessType,
			    sizeof(CdAccessType),
			    CMN_ARCH_PARMS); 


   /* If RB AccessType is Account */
   if (strcmp ( CdAccessType, LT_Acct_01) == 0) 
   {

       
	   /* Query Account Value and load into KyExtractNo */
       FndFieldQueryValue(CBI_hwnd,
                          "KyBa",
                          sizeof(KyBaStr),
                          KyBaStr,
                          &FndGenErrorBlock);

	   /* Convert the KyExtractNoA to DOUBLE and load into OUTPUT */
	   pDZBA003INPUT.DZCBA03Keys.KyBa = atof(KyBaStr);


       /* Make the code A rather than 01 for Cd Access Type */
       CmnStrCopy( pDZBA003INPUT.DZCBA03Keys.CdAccessType,
                   "A",
                   sizeof(pDZBA003INPUT.DZCBA03Keys.CdAccessType),
                   CMN_ARCH_PARMS );
 
   }
   /* If RB AccessType is Premise */
   else if (strcmp ( CdAccessType, LT_Prem_02) == 0) 
   {

	   /* Query Account Value and load into KyPremNo	*/
       FndFieldQueryValue(CBI_hwnd,
                          "KyPremNo",
                          sizeof(KyPremNo),
                          &KyPremNo,
                          &FndGenErrorBlock);

	   /* Convert Long Integer to a String */
       CmnStrFromInt( KyExtractNoStr,
                      sizeof(KyExtractNoStr),
                      KyPremNo,
                      CMN_LEADING_ZEROES_NO,
                      CMN_ARCH_PARMS );

	   /* Populate the output DOUBLE Numeric field from converted String*/
	   pDZBA003INPUT.DZCBA03Keys.KyPremNo = atoi (KyExtractNoStr);
	   pDZBA003INPUT.DZCBA03Keys.KyBa = atof(KyExtractNoStr);

       /* Make the code P rather than 03 for Cd Access Type */
       CmnStrCopy( pDZBA003INPUT.DZCBA03Keys.CdAccessType,
                   "A",
                   sizeof(pDZBA003INPUT.DZCBA03Keys.CdAccessType),
                   CMN_ARCH_PARMS );
 

   }
   /* If RB AccessType is Building */
   else if (strcmp ( CdAccessType, LT_Bldg_03) == 0) 
   {

	   /* Query Account Value and load into KyPremNo	*/
       FndFieldQueryValue(CBI_hwnd,
                          "KyBldgNo",
                          sizeof(KyBldgNo),
                          &KyBldgNo,
                          &FndGenErrorBlock);

	   /* Convert Long Integer to a String */
       CmnStrFromInt( KyExtractNoStr,
                      sizeof(KyExtractNoStr),
                      KyBldgNo,
                      CMN_LEADING_ZEROES_NO,
                      CMN_ARCH_PARMS );

	   /* Populate the output DOUBLE Numeric field from converted String*/
	   pDZBA003INPUT.DZCBA03Keys.KyBldgNo = atoi (KyExtractNoStr);
	   pDZBA003INPUT.DZCBA03Keys.KyBa = atof(KyExtractNoStr);

       /* Make the code B rather than 02 for Cd Access Type */
       CmnStrCopy( pDZBA003INPUT.DZCBA03Keys.CdAccessType,
                   "A",
                   sizeof(pDZBA003INPUT.DZCBA03Keys.CdAccessType),
                   CMN_ARCH_PARMS );
 

   }

   /* Query TimeStamp Value and load into TsKyExtract */
   FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(szTxKyExtract),
                      szTxKyExtract,
                      &FndGenErrorBlock);

   /* Build the "like%" string */
   if ( strcmp(szTxKyExtract,NULL_STR) != 0 )
   {

		CmnStrCat( CMN_ARCH_PARMS,
				pDZBA003INPUT.DZCBA03Keys.TsKyExtract,
				sizeof(pDZBA003INPUT.DZCBA03Keys.TsKyExtract),
				4,
				Begin_Qt,
				szTxKyExtract,
				Like_Str,
				End_Qt );


   }              


   /* Query Remarks and load into TxExtractRemarks2 */
   FndFieldQueryValue(CBI_hwnd,
                      "TxExtractRemarks2",
                      sizeof(szTxExtractRemarks2),
                      szTxExtractRemarks2,
                      &FndGenErrorBlock);

   /* Set the last character of this string to NULL to accomodate the '%' */
   szTxExtractRemarks2[79] = '\n';

   /* Concatenate the "like" string */
   if ( strcmp(szTxExtractRemarks2,NULL_STR) != 0 )
   {
		CmnStrCat( CMN_ARCH_PARMS,
              pDZBA003INPUT.DZCBA03Keys.TxExtractRemarks2,
			  sizeof(pDZBA003INPUT.DZCBA03Keys.TxExtractRemarks2),
			  2,
			  szTxExtractRemarks2,
			  Like_Str );              
   }


   /* Query User Id field */
   FndFieldQueryValue(CBI_hwnd,
                      "TxUserNm",
                      sizeof(szTxnUsrId),
                      szTxnUsrId,
                      &FndGenErrorBlock);



   /* Concatenate the "like" string */

   if ( strcmp(szTxnUsrId,NULL_STR) != 0 )
   {
		memcpy(szTxnUsrId2, szTxnUsrId, sizeof(szTxnUsrId2) );

		CmnStrCat( CMN_ARCH_PARMS,
				pDZBA003INPUT.DZCBA02Data.TxnUsrId,
				sizeof(pDZBA003INPUT.DZCBA02Data.TxnUsrId),
				4,
				Begin_Qt,
				szTxnUsrId2,
				Like_Str,
				End_Qt );


   }              
								 
   FndGenRC =  CmnWindowCreate ( "DZBA003X",
				                   NULL,
				                   NULL,
				                   &pDZBA003INPUT,
				                   CMN_ARCH_PARMS);


    return CMN_SUCCESS;

}  /* End of DZBA002BusValidatePBClick */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusOkPBClick 
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusOkPBClick )
{
    USHORT             FndGenRC = 0;
    _FND_ERROR_BLOCK    FndGenErrorBlock;
	CHAR               CdAccessType[3];
	CHAR               KyExtractNoStr[KYEXTRACTNOA_LEN];
	CHAR               KyBaStr[KYEXTRACTNOA_LEN];
	ULONG              KyBldgNo = 0;
	ULONG              KyPremNo = 0;

    /* Set up pointer to child window OUT layout _SWAT01BOUTPUT */
    _SWAT01BOUTPUT *pSWAT01BOutput;

    /* Setup the pointer to the value of EAB_pWdtOutData */
    pSWAT01BOutput = EAB_pWdtOutData;

    memset(pSWAT01BOutput, 0, sizeof(_SWAT01BOUTPUT));

/* QUERY THE WINDOW TO PASS THE FIELDS TO THE OUTPUT LAYOUT */


	CmnStrCopy( CdAccessType,
		        WCD_SWAT01BRqst.SWAT01BData.CdAccessType,
			    sizeof(CdAccessType),
			    CMN_ARCH_PARMS); 



   /* If RB AccessType is Account */
   if (strcmp ( CdAccessType, LT_Acct_01) == 0) 
   {

       
	   /* Query Account Value and load into KyExtractNo */
       FndFieldQueryValue(CBI_hwnd,
                          "KyBa",
                          sizeof(KyBaStr),
                          KyBaStr,
                          &FndGenErrorBlock);

	   /* Convert the KyExtractNoA to DOUBLE and load into OUTPUT */
	   pSWAT01BOutput->SWAT01BData.KyExtractNo = atof(KyBaStr);

       /* load the String Value of KyBa into KyExtractNoA */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.KyExtractNoA,
                   KyBaStr,
                   sizeof(pSWAT01BOutput->SWAT01BData.KyExtractNoA),
                   CMN_ARCH_PARMS );
 

       /* Make the code A rather than 01 for Cd Access Type */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.CdAccessType,
                   "A",
                   sizeof(pSWAT01BOutput->SWAT01BData.CdAccessType),
                   CMN_ARCH_PARMS );
 
   }
   /* If RB AccessType is Premise */
   else if (strcmp ( CdAccessType, LT_Prem_02) == 0) 
   {

	   /* Query Account Value and load into KyPremNo	*/
       FndFieldQueryValue(CBI_hwnd,
                          "KyPremNo",
                          sizeof(KyPremNo),
                          &KyPremNo,
                          &FndGenErrorBlock);

	   /* Convert Long Integer to a String */
       CmnStrFromInt( KyExtractNoStr,
                      sizeof(KyExtractNoStr),
                      KyPremNo,
                      CMN_LEADING_ZEROES_NO,
                      CMN_ARCH_PARMS );

	   /* Populate the output DOUBLE Numeric field from converted String*/
	   pSWAT01BOutput->SWAT01BData.KyExtractNo = atof (KyExtractNoStr);

       /* Copy the String Formatted KyExtractNoA into the Output */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.KyExtractNoA,
                   KyExtractNoStr,
                   sizeof(pSWAT01BOutput->SWAT01BData.KyExtractNoA),
                   CMN_ARCH_PARMS );
 
       /* Make the code P rather than 03 for Cd Access Type */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.CdAccessType,
                   "P",
                   sizeof(pSWAT01BOutput->SWAT01BData.CdAccessType),
                   CMN_ARCH_PARMS );
 

   }
   /* If RB AccessType is Building */
   else if (strcmp ( CdAccessType, LT_Bldg_03) == 0) 
   {

	   /* Query Account Value and load into KyPremNo	*/
       FndFieldQueryValue(CBI_hwnd,
                          "KyBldgNo",
                          sizeof(KyBldgNo),
                          &KyBldgNo,
                          &FndGenErrorBlock);

	   /* Convert Long Integer to a String */
       CmnStrFromInt( KyExtractNoStr,
                      sizeof(KyExtractNoStr),
                      KyBldgNo,
                      CMN_LEADING_ZEROES_NO,
                      CMN_ARCH_PARMS );

	   /* Populate the output DOUBLE Numeric field from converted String*/
	   pSWAT01BOutput->SWAT01BData.KyExtractNo = atof (KyExtractNoStr);

       /* Copy the String Formatted KyExtractNoA into the Output */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.KyExtractNoA,
                   KyExtractNoStr,
                   sizeof(pSWAT01BOutput->SWAT01BData.KyExtractNoA),
                   CMN_ARCH_PARMS );

       /* Make the code B rather than 02 for Cd Access Type */
       CmnStrCopy( pSWAT01BOutput->SWAT01BData.CdAccessType,
                   "B",
                   sizeof(pSWAT01BOutput->SWAT01BData.CdAccessType),
                   CMN_ARCH_PARMS );
 
 

   }

   /* Query TimeStamp Value and load into TsKyExtract */
   FndFieldQueryValue(CBI_hwnd,
                      "TsKyExtract",
                      sizeof(pSWAT01BOutput->SWAT01BData.TsKyExtract),
                      &pSWAT01BOutput->SWAT01BData.TsKyExtract,
                      &FndGenErrorBlock);

   /* Query Remarks and load into TxExtractRemarks2 */
   FndFieldQueryValue(CBI_hwnd,
                      "TxExtractRemarks2",
                      sizeof(pSWAT01BOutput->SWAT01BData.TxExtractRemarks2),
                      &pSWAT01BOutput->SWAT01BData.TxExtractRemarks2,
                      &FndGenErrorBlock);


    return CMN_SUCCESS;

}  /* End of DZBA002BusOkPBClick  */


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA002BusCDRbAccessTypeFC
**
**  DESCRIPTION      : This function free the memory of the typedef,
**                     declared in SWAT01B.h file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  K.Chase                Original code.
**
***************************************************************************/

WCBPROC( DZBA002BusCDRbAccessTypeFC )
{
    USHORT             FndGenRC = 0;
    _FND_ERROR_BLOCK   FndGenErrorBlock;
	CHAR               CdAccessType[3];
	DOUBLE             DfltKyBa = 0;
	LONG               DfltKyBldgNo = 0;
	LONG               DfltKyPremNo = 0;


	memset(CdAccessType, 0 , sizeof(CdAccessType));

    FndFieldQueryValue(CBI_hwnd,
                       "CdAccessType",
                       sizeof(CdAccessType),
                       &CdAccessType,
                       &FndGenErrorBlock);

	CmnStrCopy( WCD_SWAT01BRqst.SWAT01BData.CdAccessType,
			    CdAccessType,
			    sizeof(CdAccessType),
			    CMN_ARCH_PARMS); 

   /* If RB AccessType is Account */
   if (strcmp ( CdAccessType, LT_Acct_01) == 0) 
   {

       /* Display KY_BA and Hide the other 2 fields */

    
       FndFieldShow(CBI_hwnd,
                    "KyBa",
                    &FndGenErrorBlock);

       FndFieldHide(CBI_hwnd,
                    "KyBldgNo",
                    &FndGenErrorBlock);

	   FndFieldHide(CBI_hwnd,
                    "KyPremNo",
                    &FndGenErrorBlock);


	   /* Initialize the 2 hidden fields */
       FndFieldSetValue( CBI_hwnd,
                        "KyBldgNo",
                        sizeof(LONG),
                        &DfltKyBldgNo,
                        &FndGenErrorBlock);

       FndFieldSetValue( CBI_hwnd,
                        "KyPremNo",
                        sizeof(LONG),
                        &DfltKyPremNo,
                        &FndGenErrorBlock);




	   /* Set appropriate Status for each of the 3 fields */

       if ((strcmp(GlobalMode, LT_Insert_Mode) != 0) &&
           (strcmp(GlobalMode, LT_Export_Mode) != 0))
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_INCOMPLETE,
                      &FndGenErrorBlock);

           FndFieldSetMsg(CBI_hwnd,
		               "KyBa",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


       }
       else
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

		   FndFieldSetMsg(CBI_hwnd,
			              "KyBa",
						  MF_NO_MSG,
						  &FndGenErrorBlock);


       }

       FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBldgNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyPremNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


 
   }
   /* If RB AccessType is Premise */
   else if (strcmp ( CdAccessType, LT_Prem_02) == 0) 
   {

       /* Display KY_PREM_NO and Hide the other 2 fields */
       FndFieldShow(CBI_hwnd,
                    "KyPremNo",
                    &FndGenErrorBlock);

       FndFieldHide(CBI_hwnd,
                    "KyBldgNo",
                    &FndGenErrorBlock);

       FndFieldHide(CBI_hwnd,
                    "KyBa",
                    &FndGenErrorBlock);

	   /* Initialize the 2 hidden fields */
       FndFieldSetValue( CBI_hwnd,
                        "KyBldgNo",
                        sizeof(LONG),
                        &DfltKyBldgNo,
                        &FndGenErrorBlock);

       FndFieldSetValue( CBI_hwnd,
                        "KyBa",
                        sizeof(DOUBLE),
                        &DfltKyBa,
                        &FndGenErrorBlock);


	   /* Set appropriate Status for each of the 3 fields */
       if ((strcmp(GlobalMode, LT_Insert_Mode) != 0) &&
           (strcmp(GlobalMode, LT_Export_Mode) != 0))
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_INCOMPLETE,
                      &FndGenErrorBlock);

           FndFieldSetMsg(CBI_hwnd,
		               "KyPremNo",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


       }
       else
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

		   FndFieldSetMsg(CBI_hwnd,
			              "KyPremNo",
						  MF_NO_MSG,
						  &FndGenErrorBlock);


       }

       FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBldgNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBa",
					  MF_NO_MSG,
					  &FndGenErrorBlock);



   }
   /* If RB AccessType is Building */
   else if (strcmp ( CdAccessType, LT_Bldg_03) == 0) 
   {

       /* Display KY_BLDG_NO and Hide the other 2 fields */
       FndFieldShow(CBI_hwnd,
                    "KyBldgNo",
                    &FndGenErrorBlock);

       FndFieldHide(CBI_hwnd,
                    "KyPremNo",
                    &FndGenErrorBlock);

       FndFieldHide(CBI_hwnd,
                    "KyBa",
                    &FndGenErrorBlock);


	   /* Initialize the 2 hidden fields */
       FndFieldSetValue( CBI_hwnd,
                        "KyBa",
                        sizeof(DOUBLE),
                        &DfltKyBa,
                        &FndGenErrorBlock);

       FndFieldSetValue( CBI_hwnd,
                        "KyPremNo",
                        sizeof(LONG),
                        &DfltKyPremNo,
                        &FndGenErrorBlock);


 	   /* Set appropriate Status for each of the 3 fields */

       if ((strcmp(GlobalMode, LT_Insert_Mode) != 0) &&
           (strcmp(GlobalMode, LT_Export_Mode) != 0))
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_INCOMPLETE,
                      &FndGenErrorBlock);

           FndFieldSetMsg(CBI_hwnd,
		               "KyBldgNo",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);

       }
       else
       {
           FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_VALID,
                      &FndGenErrorBlock);

		   FndFieldSetMsg(CBI_hwnd,
			              "KyBldgNo",
						  MF_NO_MSG,
						  &FndGenErrorBlock);


       }

       FndFieldSetStatus(CBI_hwnd,
                      "KyPremNo",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
	                  "KyPremNo",
					  MF_NO_MSG,
					  &FndGenErrorBlock);


       FndFieldSetStatus(CBI_hwnd,
                      "KyBa",
                      STS_VALID,
                      &FndGenErrorBlock);

	   FndFieldSetMsg(CBI_hwnd,
			          "KyBa",
					  MF_NO_MSG,
					  &FndGenErrorBlock);



   }


    return CMN_SUCCESS;

}  /* End of DZBA002BusCDRbAccessTypeFC */


