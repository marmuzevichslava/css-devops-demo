	   FndFieldSetMsg(CBI_hwnd,
	                  "KyBldgNo",
	    			  MF_NO_MSG,
					  &FndGenErrorBlock);


	   cStatus = STS_VALID;

	}
	else
	{
       if ((strcmp(GlobalMode, LT_Insert_Mode) != 0) &&
           (strcmp(GlobalMode, LT_Export_Mode) != 0))
       {
            FndFieldSetStatus(CBI_hwnd,
                      "KyBldgNo",
                      STS_INCOMPLETE,
                      &FndGenErrorBlock);

            FndFieldSetMsg(CBI_hwnd,
		               "KyBldgNo",
					   STSM_FIELD_REQUIRED,
					   &FndGenErrorBlock);


	        cStatus = STS_INCOMPLETE;
       }
       else
       {
            FndFieldSetStatus(CBI_hwnd,
