/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA003BusOkPBClick
**
**  DESCRIPTION      : This function is executed when the window is
**					   originally opened.  It will malloc the
**					   pointer to the WCD
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : iperezar
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 08/12/95    iperezar             Creation
**
***************************************************************************/

WCBPROC( DZBA003BusOkPBClick )
{

    USHORT             FndGenRC = 0;
	USHORT            index = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;
	_ExtractInsertHdrLbRow RowData;

	_DZBA003OUTPUT * pDZBA003OUTPUT;

	pDZBA003OUTPUT = EAB_pWdtOutData;

//	memset(&pDZBA003OUTPUT , 0 , sizeof(_DZBA003OUTPUT) );

    FndLstBoxRowQuerySelection ( CBI_hwnd,
	                          "ExtractInsertHdrLb",
							  StartRowNum,
							  &index,
							  &FndGenErrorBlock);

    FndLstBoxRowQueryData ( CBI_hwnd,
                            "ExtractInsertHdrLb",
							index,
							sizeof( _ExtractInsertHdrLbRow ),
							(VOID *) &(RowData),
							&FndGenErrorBlock);

	CmnStrCopy(pDZBA003OUTPUT->DZCBA02Data.TsKyExtract ,
	     	   RowData._ExtractInsertHdrLbTsKyExtractData ,
			   sizeof(pDZBA003OUTPUT->DZCBA02Data.TsKyExtract ),
               CMN_ARCH_PARMS);

	pDZBA003OUTPUT->DZCBA02Data.KyBa =
	     	   RowData._ExtractInsertHdrLbKyBaData;

	CmnStrCopy(pDZBA003OUTPUT->DZCBA02Data.TxExtractRemarks2 ,
	     	   RowData._ExtractInsertHdrLbTxExtractRemarks2Data ,
			   sizeof(pDZBA003OUTPUT->DZCBA02Data.TxExtractRemarks2 ),
               CMN_ARCH_PARMS);




    return CMN_SUCCESS;
}


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DZBA003BusLBSelect
**
**  DESCRIPTION      : This function is executed when the window is
**					   originally opened.  It will malloc the
**					   pointer to the WCD
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
