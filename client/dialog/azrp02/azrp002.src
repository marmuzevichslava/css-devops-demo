/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Xaqpbnyd8074_Field_Change
 * 
 *   WidgetName:    PrintDest
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Xaqpbnyd8074_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if (strcmp( PrintDestData, "P" ) == 0)
   {

   strncpy(PrintFileData,"",1);

   FndGenRC = FndFieldSetStatus(CBI_hwnd,
                        "PrintFile",
                        STS_VALID,
                        &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "PrintFile",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "Duplex",
                            &FndGenErrorBlock);

   DuplexData[0] = 'Y';

   }
else
   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "PrintFile",
                            &FndGenErrorBlock);

   DuplexData[0] = 'N';

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "Duplex",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldSetCursor( CBI_hwnd,
                             "PrintFile",
                             CUR_MAKECURRENT,
                             &FndGenErrorBlock);

   if (strcmp( PrintFileData, "" ) == 0)
      {

      FndGenRC = AZRP002BUSSetPrintFileStatus( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

      } /* end if */

   } /* end if */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Xaqpbnyd5422_Field_Change
 * 
 *   WidgetName:    PrintFile
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Xaqpbnyd5422_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if (strcmp( PrintDestData, "F" ) == 0)
   {

   if (strcmp( PrintFileData, "" ) == 0)
      {

      FndGenRC = AZRP002BUSSetPrintFileStatus( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

      } /* end if */

   } /* end if */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
