  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //  Declare an instance of the child's output data layout.
  //
  //    <CUFFnnnOUTPUT>  CUFFnnnOutput;
  //
  //    .
  //    .  Move the needed data to the instance of the output layout
  //    .
  //
  //  Call the function CmnElbAssignDeleteData.
  //
  //    CmnElbAssignDeleteData (&CUFFnnnOutput,
  //                            sizeof (<_CUFFnnnOUTPUT>),
  //                            CMN_ARCH_PARMS);
  //


    return CMN_SUCCESS;

} /* End of ExitElb1BuildDelData */

