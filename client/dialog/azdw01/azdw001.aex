  //  {
  //      /* Declare a pointer to the Client Data area */
  //      <_CUFFnnL> *p<CUFFnnL>;
  //
  //      /* Change the pointer to point to your <CuffnnL> Record Group. */
  //      p<CUFFnnL> = &(BFCD_<CUFFnnL>);
  //
  //      /* Handle a successful update. */
  //      if( p<CUFFnnL>->CdMsgioStatus == 0 )
  //      {
  //          CmnMsgBoxDisplay( p<CUFFnnL>->CdServErrMsg,
  //                            CMN_NULL_RETURN_BUTTON,
  //                            CMN_NULL_MSGBOX_NAME,
  //                            CMN_ARCH_PARMS );
  //
  //          CMN_WN_CL_AFTER_SUCCESS_PROCESS
  //      }
  //
  //      /* Handle an unsuccessful update. */
  //      else
  //      {
  //          CmnMsgBoxDisplay( p<CUFFnnL>->CdServErrMsg,
  //                            CMN_NULL_RETURN_BUTTON,
  //                            CMN_NULL_MSGBOX_NAME,
  //                            CMN_ARCH_PARMS);
  //      }
  //  }
  //
  //  /* Handle CSR reply for request <CUFFnnnR> */
  //  else if( strcmp( EAB_CsrRequestId, "<CUFFnnnR>" ) == 0 )
  //  {

  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  In some cases, it may be necessary to examine additional fields
  //  to determine if the request was successful.  For example, when
  //  the request results in a Generic Service call, the number of
  //  rows returned (QyAlrAclCnt) should be used to determine the
  //  success of the request.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //      /* Handle a successful reply. */
  //      if( WCD_<CUFFnnn>Rqst.CdMsgioStatus == 0 )
  //      {
  //          /* Populate the window fields with the data in <CUFFnnnR> */
  //
  //--------------------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following shell code applies to loading an enterable
  //    list box with data from the CSR.  If this is not the case,
  //    remove the shell code.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------------------
  //             for (each row of data in the CSR reply layout <CUFFnnnR>)
  //             {
  //
  //                 /* Format the enterable list box row typedef structure
  //                 **    _<LB>Row found in the WESmap with the data from
  //                 **    the CSR replay layout <CUFFnnnR>
  //                 */
  //
  //               if (<exp. to determine if override chg window required>)
  //               {
  //                   CmnElbAssignRowData ( <ELB Widget Name>,
  //                                         <row number to load data to>,
  //                                         &<LbRowDataName>,
  //                                         <override chg window name>,
  //                                         CMN_ARCH_PARMS );
  //               }
  //               else
  //               {
  //                   CmnElbAssignRowData ( <ELB Widget Name>,
  //                                         <row number to load data to>,
  //                                         &<LbRowDataName>,
  //                                         NULL,  /*use default chg window*/
  //                                         CMN_ARCH_PARMS );
  //               }
  //             }
  //
  //
  //          /* Format working storage fields with the data in <CUFFnnnR> */
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following code applies to a child window that is
  //  receiving its initial data.  The modifications made during
  //  previous OKs from this same window need to overlay the
  //  data returned by the CSR.  These modifications are contained
  //  in the OUT layout for the window.
  //
  //  Note that if this is not the request for initial data,
  //  this logic should be removed.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //
  //  If the this child window contains an enterable list box,
  //     uncomment this code to load the window data tracking
  //     data to the enterable list box in the window.
  //     If this is not the case, remove the code.
  //
  //          for (<each ELB in the window>)
  //          {
  //               CmnElbLoadWdtData ( <ELB Widget Name>,
  //                                   CMN_ELB_NOT_MEGA_SCROLL,
  //                                   CMN_ARCH_PARMS );
  //          }
  //
  //------------------------------------------------------
  //
  //          /* Check to see if there is data in the OUT layout */
  //          if( EAB_pWdtOutData != NULL)
  //          {
  //              /* Set up a pointer to the OUT layout <CUFFnnnOUTPUT> */
  //              <_CUFFnnnOUTPUT> *p<CUFFnnnOutput>;
  //
  //              p<CUFFnnnOutput> = EAB_pWdtOutData;
  //
  //              /* Overlay window fields from OUT layout <CUFFnnnOutput> */
  //
  //          }
  //
  //
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following code is used to handle a Mega-scrolling
  //  reply.
  //
  //  Note that if this is not the reply from the Mega-
  //  scrolling service request, this logic should be removed.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //          {
  //
  //              USHORT   i          = 0; /* Loop counter */
  //              USHORT   DataLength = 0; /* Length of Row Data */
  //              _<LB>Row RowData;        /* Data row */
  //
  //----------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following shell code pertains exclusively to windows
  //    that contain mega-scrolling enterable list boxes.  If this
  //    is not the case, remove the code.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //-----------------------------------------------------
  //
  //             /* Clear the contents of the mega-enterable list box */
  //
  //             CmnElbInit ( <ELB Widget Name>,
  //                           CMN_ARCH_PARM_TYPES );
  //
  //             /*
  //             **   Load the enterable list box with the data from the
  //             **   CSR replay data layout <CUFFnnnR>
  //             */
  //
  //             for (each row of data in the CSR replay layout <CUFFnnnR>)
  //             {
  //
  //                 /* Format the enterable list box row typedef structure
  //                 **    _<LB>Row found in the WESmap with the data from
  //                 **    the CSR replay layout <CUFFnnnR>
  //                 */
  //
  //               if (<exp. to determine if override chg window required>)
  //               {
  //                   CmnElbAssignRowData ( <ELB Widget Name>,
  //                                         <row number to load data to>,
  //                                         &<LbRowDataName>,
  //                                         <override chg window name>,
  //                                         CMN_ARCH_PARMS );
  //               }
  //               else
  //               {
  //                   CmnElbAssignRowData ( <ELB Widget Name>,
  //                                         <row number to load data to>,
  //                                         &<LbRowDataName>,
  //                                         NULL,  /*use default chg window*/
  //                                         CMN_ARCH_PARMS );
  //               }
  //             }
  //
  //             /*
  //             **  After all rows have been loaded with data, load the
  //             **  the previously saved data from window data tracking
  //             */
  //
  //             CmnElbLoadWdtData ( <ELB Widget Name>,
  //                                 CMN_ELB_MEGA_SCROLL,
  //                                 CMN_ARCH_PARMS );
  //
  //-----------------------------------------------------------------
  //   S H E L L   I N S T R U C T I O N S
  //
  //    The following shell code pertains to non-Enterable List Boxes.
  //
  //   REMOVE THIS COMMENT BLOCK WHEN DONE
  //
  //------------------------------------------------------------------
  //
  //
  //              /* Clear the contents of the mega-listbox */
  //              FndLstBoxRowDeleteAll( CBI_hwnd,
  //                                     <ListBoxName>,
  //                                     &FndGenErrorBlock );
  //
  //              /* Add rows to the listbox using the data in <CUFFnnnR> */
  //              for( i = 0; i < pClientData->QyAlrAclCnt; i++ )
  //              {
  //                  /*
  //                  ** Format the columns in the mega-listbox row using
  //                  ** data from <CUFFnnnR> using the structure RowData.
  //                  */
  //
  //                  /* Add the row to the mega-listbox */
  //                  FndLstBoxRowAdd( CBI_hwnd,
  //                                   <ListBoxName>,
  //                                   i,
  //                                   sizeof(_<LB>Row),
  //                                   &RowData,
  //                                   &FndGenErrorBlock );
  //              }
  //
  //------------------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Perform the following for any type of mega-scrolling list box
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE
  //
  //-------------------------------------------------------------
  //
  //              /* You may need to change <CUCG003Output>  */
  //              if( <CUCG003Output>.DataAbove == CMN_NO )
  //              {
  //                  /* Disable the ListPageUp Control. */
  //                  FndLstBoxUpDisable( CBI_hwnd,
  //                                      <ListBoxName>,
  //                                      &FndGenErrorBlock );
  //              }
  //              else
  //              {
  //                  /* Enable the ListPageUp Control. */
  //                  FndLstBoxUpEnable( CBI_hwnd,
  //                                     <ListBoxName>,
  //                                     &FndGenErrorBlock );
  //              }
  //
  //              /* You may need to change <CUCG003Output>  */
  //              if( <CUCG003Output>.DataBelow == CMN_NO )
  //              {
  //                  /* Disable the ListPageDown Control. */
  //                  FndLstBoxDownDisable( CBI_hwnd,
  //                                        <ListBoxName>,
  //                                        &FndGenErrorBlock );
  //              }
  //              else
  //              {
  //                  /* Enable the ListPageDown Control. */
  //                  FndLstBoxDownEnable( CBI_hwnd,
  //                                       <ListBoxName>,
  //                                       &FndGenErrorBlock );
  //              }
  //
  //          } /* End of MegaScrolling block */
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Perform the following for all windows.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //          /* Set the window title */
  //          CmnWindowTitleCreate( "<Action>",
  //                                "<ObjectType>",/* CMN_NULL_OBJECT_TYPE */
  //                                "<Object>",    /* no quotes if variable*/
  //                                CMN_DEFAULT_WINDOW_TITLE_MAX,
  //                                CMN_ARCH_PARMS);
  //
  //          /* Make the window visible */
  //          FndWindowShow( CBI_hwnd,
  //                         &FndGenErrorBlock);
  //
  //      } /* if( WCD_<CUFFnnn>Rqst.CdMsgioStatus == 0 )
  //
  //      else /* CdMsgioStatus is non-zero */
  //      {
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If the structure chart specifies that the window
  //  should be destroyed when the MsgioStatus is non-
  //  zero, then include the following Overrides,
  //  otherwise remove it.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //          /* Set Logging Flag to Yes. */
  //          CmnMsgBoxOverrides( CMN_LOGGING_YES,
  //                              CMN_ARCH_PARMS );
  //
  //          /* Display the problem to the user. */
  //          CmnMsgBoxDisplay( <message>,
  //                            CMN_NULL_RETURN_BUTTON,
  //                            CMN_NULL_MSGBOX_NAME,
  //                            CMN_ARCH_PARMS );
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If the structure chart specifies that the window
  //  should be destroyed when the MsgioStatus is non-
  //  zero, then include the following WindowDestroy,
  //  otherwise remove it.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //          FndWindowDestroy( CBI_hwnd,
  //                            &FndGenErrorBlock );
  //
  //      } /* end of else CdMsgioStatus is non-zero */
  //
  //  } /* end of if( strcmp( EAB_CsrRequestId, "<CUFFnnnR>" ) == 0 ) */
  //
  //  /* Handle CSR reply for request <CUFFnnnR> */
  //  else if( ... )
  //  {
  //  }
  //

    return CMN_SUCCESS;

} /* End of ExitCsrNotification */


