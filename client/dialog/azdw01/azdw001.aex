**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitCsrNotification )
{
  //
  //  USHORT FndGenRC = 0;
  //  _FND_ERROR_BLOCK FndGenErrorBlock;
  //
  //  if the window contains a list box (or ELB) declare the following:
  //  _<LB>Row  <LbRowDataName>;
  //
  //
  //  /* Handle LUW Process reply */
