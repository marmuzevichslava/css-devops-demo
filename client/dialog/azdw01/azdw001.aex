/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElbRegister
**
**  DESCRIPTION      : This exit occurs during the PREDISPLAY callback (via
**                     CmnArchInit) to allow the application to register
**                     each enterable list box (and its associations) with
**                     the architecture.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElbRegister )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit to register EACH enterable list box
  //    contained in this window.
  //
  //  To register the ELB perform the following steps:
  //
  //        1. Declare an instance of the ELB registration
  //           parameters structure, _CMNELBREGPARMS
  //
  //        2. Initialize the members of the structures as
  //           required for the application's use of the ELB
  //           control.
  //
  //        3. Call the function CmnELbRegister passing the
  //           the address of the ELB registration parameter
  //           structure.
  //
  //        4. The function will return CMN_SUCCESS if the ELB
  //           was successfully registered with the architecture,
  //           otherwise, the function returns CMN_FAIL.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------


  //
  //  Declare an instance of the ELB registration parameter
  //    structure, _CMNELBREGPARMS, as follows:
  //
  //    _CMNELBREGPARMS     ElbRegParms;
  //
  //  Initialize the members of the structure as follows:
  //    (ALL STRINGS MUST BE NULL-TERMINATED STRINGS)
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbWidgetName,
  //         "<your ELB widget name>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    ElbRegParms.nElbSeqNum = <a value from 1 to 5, inclusive>;
  //
  //    ElbRegParms.nElbRowLen = sizeof (<ELB row typedef in the WESmap>)
  //
  //    ElbRegParms.nElbMaxTxnCount = <max # of txns allowed for this ELB>;
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddWinName,
  //         "<add child window name or CMN_NULL_SOURCE_STR>",
  //          CMN_WINDOWNAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbChgWinName,
  //         "<default change child window name or CMN_NULL_SOURCE_STR>",
  //         CMN_WINDOWNAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddPbName,
  //         "<add pushutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddUsingPbName,
  //         "<add using pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbChangePbName,
  //         "<change pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbDeletePbName,
  //         "<delete pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbUndeletePbName,
  //         "<undelete pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbUpPbName,
  //         "<move row up pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbDownPbName,
  //         "<move row down pushbutton widget name or CMN_NULL_SOURCE_STR>",
  //         CMN_WIDGET_NAME_LEN);
  //
  //    CmnElbRegister (&ElbRegParms, CMN_ARCH_PARMS);
  //

    return CMN_SUCCESS;

} /* End of ExitElbRegister */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1CloseAfterSave
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit is called to allow the application to load
**                     saved data to an enterable list box row.  This exit
**                     is called during one of the following events:
**                       1.  The OK pushbutton on an ELB child window was
**                           clicked.
**                       2.  A row is to be added or updated while loading
**                           previously saved data from window data tracking
**                           via the function CmnElbLoadWdtData.
**                       3.  A row is being added to an enterable list box
**                           from its child window using the function
**                           CmnElbAddFromChild.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1CloseAfterSave )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit routine to place the data saved in a child window
  //    of an ELB into a row of the ELB.
  //
  //  There are several macro names that are available that identify the
  //    the name of the ELB, the row being processed, the operation
  //    that is occuring and the child data itself.  They are as follows:
  //
  //    EAB_CurrElbWidgetName:  Identifies the name of the current ELB
  //                            being processed.
  //
  //    EAB_CurrElbRowNumber:   Identifies the current ELB row being
  //                            processed.
  //
  //    CMN_ELB_CHILD_DATA:     A pointer to the child's window data
  //                            tracking output data.
  //
  //    CMN_ELB_CHILD_DATA_STATUS:  The status of the child's window data
  //                                tracking output data.
  //
  //    To update data in a row in the enterable list box, perform the
  //        following steps:
  //
  //        1.  Declare a pointer to the child's window data tracking
  //            output structure.
  //
  //        2.  Declare an instance of the ELB row typedef structure found
  //            in the WESmap.
  //
  //        3.  Establish addressability to the child's output data.
  //
  //        4.  Move the child data to the row structure.
  //
  //        5.  Perform any additional processing as needed for derived
  //            columns in the row.
  //
  //        6.  Determine if an override change window is required for
  //            the row.
  //
  //        7.  Call the function CmnElbAssignRowData passing a void pointer
  //            to the row structure and the override change window name.
  //            If no override change window name is required and you wish
  //            the architecture to assign the default change window name,
  //            pass a NULL parameter as the override change window name.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------


  //  Declare a pointer to the child's window data tracking output layout.
  //
  //    <CUFFnnnOUTPUT>  *pCUFFnnnOutput;
  //
  //  Declare an instance of the ELB row typedef
  //
  //    <WESmap ELB ROW TYPEDEF>     ElbRowData;
  //    .
  //    .  Declare additional variables as needed.
  //    .
  //
  //  Establish addressability to the child data.
  //
  //    pCUFFnnnOutput = CMN_ELB_CHILD_DATA;
  //
  //  Move the child data to the row structure.
  //
  //    ElbRowData.<member> = pCUFFnnnOutput-><member>;
  //    CmnStrCopy (ElbRowData.<member>,
  //                pCUFFnnnOutput-><member>,
  //                <length of pCUFFnnnOutput-><member>,
  //                CMN_ARCH_PARMS);
  //    .
  //    .  Any additional processing as required for the ELB row data
  //    .
  //
  //  If an override change window is required, call CmnElbAssignRowData
  //    passing the name of the override change window and a pointer
  //    to the row structure.  Otherwise, call CmnElbAssignRowData setting
  //    the override change window parameter to a NULL.  A NULL override
  //    change window name will tell the architecture to use the default
  //    change window name specified when the ELB was registered.
  //
  //    if (<expression determining if an override change window is needed>)
  //    {
  //        CmnElbAssignRowData
  //                    (EAB_CurrElbWidgetName,
  //                     EAB_CurrElbRowNumber,
  //                     &ElbRowData,
  //                     "<override change window name>",
  //                     CMN_ARCH_PARMS);
  //    }
  //    else
  //    {
  //        CmnElbAssignRowData
  //                    (EAB_CurrElbWidgetName,
  //                     EAB_CurrElbRowNumber,
  //                     &ElbRowData,
  //                     NULL,          /* SPECIFIES NO OVERRIDE WINDOW */
  //                     CMN_ARCH_PARMS);
  //    }
  //



    return CMN_SUCCESS;

} /* End of ExitElb1CloseAfterSave */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1CloseAfterCncl
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit is called to allow the application to
**                     perform any application specific processing when a
**                     child window of an enterable list box is cancelled.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1CloseAfterCncl )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
