  //        in some cases, there may not be enough
  //        information available to determine what the
  //        attributes of one or more rows should be.
  //        If this is the case, defer the call to
  //        FndLstBoxRowSetAttr until ExitCsrNotification.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //  USHORT            FndGenRC     = 0;
  //  _FND_ERROR_BLOCK  FndGenErrorBlock;
  //  _TaskListRow      TaskListData = 0;
  //  USHORT            RowNumber    = 0;
  //
  //-- --------------------------------------------------
  //
  //  /* Set Task List Row status to UNCHANGED */
  //  TaskListData._TaskListCdStatusIconicData = CMN_LBROW_STATUS_UNCHANGED;
  //
  //  /* Set Window Title of Task List child window */
  //  CmnStrCopy( TaskListData._TaskListWnWindowTitleData,
  //              "<WindowTitle>",
  //              sizeof(TaskListData._TaskListWnWindowTitleData),
  //              CMN_ARCH_PARMS );
  //
  //  /* Set Window Name of Task List child window */
  //  CmnStrCopy( TaskListData._TaskListWktWindowNameData,
  //              "<WindowName>",
  //               sizeof(TaskListData._TaskListWktWindowNameData),
  //               CMN_ARCH_PARMS );
  //
  //  /* Add Task List row to Task List */
  //  FndLstBoxRowAdd( CBI_hwnd,
  //                   CMN_LB_TLB_CONTROL_NAME,
  //                   RowNumber,
  //                   sizeof(_TaskListRow),
  //                   &TaskListData,
  //                   &FndGenErrorBlock );
  //
  //  /* Set attributes of new Task List row */
  //  FndLstBoxRowSetAttr( CBI_hwnd,
  //                       CMN_LB_TLB_CONTROL_NAME,
  //                       RowNumber,
  //                       < AT_REQUIRED or AT_OPTIONAL or AT_UNAVAILABLE >,
  //                       &FndGenErrorBlock );
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If there is another row to add, then increment the
  //  row counter, and copy the above shell code.
  //  Continue for as many rows as there are.
