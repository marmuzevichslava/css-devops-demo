  //  0 in the following line of code with:
  //
  //    sizeof(<_CUFFnnnOUTPUT>)
  //
  //  where <CUFFnnnOUTPUT> is the name of the window's
  //  output layout.  If the window has no output
  //  layout, do not modify the shell.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

    /* Set EAB_OutDataLength to the sizeof the OUT layout for this window */
    EAB_OutDataLength = 0;

    return CMN_SUCCESS;

} /* End of ExitWdtSetDataLength */


