/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWktCloseAfterSave
**
**  DESCRIPTION      : This exit occurs when a child of this window closes
**                     after pressing OK.  This exit is REQUIRED for ALL
**                     parent windows.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitWktCloseAfterSave )
{

  //  USHORT FndGenRC = 0;
  //  _FND_ERROR_BLOCK FndGenErrorBlock;

      SHORT sRC;

    if( strcmp( EAB_ChildWindowName, "AZDW005" ) == 0 )
      {

      /*
      ** Call function to write out the data
      */
         sRC = AZDW001BusWriteSaveFile(pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI);
      }


    return CMN_SUCCESS;

} /* End of ExitWktCloseAfterSave */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
