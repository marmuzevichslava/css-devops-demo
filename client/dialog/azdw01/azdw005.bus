    return CMN_SUCCESS;
 }


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW005BusValidateSaveFile
**
**  DESCRIPTION      : This function
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/18/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/18/93  C. Crampton              Original code.
**
***************************************************************************/

WCBPROC( AZDW005BusValidateSaveFile )
 {

 _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC = 0;

  SHORT sRC=0;
  FILE *fptrFile;

    /*
    ** Try and open the file
    */

    fptrFile = fopen(SaveDirData, "w+");

    /*
    ** NULL means not able to open file, so filename is not valid.
    **  Set the field status to STS_INVALID.
    **  Return CMN_FAIL.
    */

    if (!fptrFile)
       {
        FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                      "SaveDir",
                                      STS_INVALID,
                                      &FndGenErrorBlock);

        return(CMN_FAIL);
       }
    /*
    ** Close the file. We are only trying to validate the field
    */

    fclose(fptrFile);

    return CMN_SUCCESS;


 }
