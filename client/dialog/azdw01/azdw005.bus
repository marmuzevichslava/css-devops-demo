/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW005BusPredisplay
**
**  DESCRIPTION      : This function handles any preprocessing before the window
**                      is actually painted.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/18/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/18/93  C. Crampton              Original code.
**
***************************************************************************/

WCBPROC( AZDW005BusPredisplay )
 {

  /*  _FND_ERROR_BLOCK FndGenErrorBlock; */
  /*  USHORT FndGenRC = 0; */

  SHORT sRC=0;

    /*
    ** If the pointer is defined move the current saved value into WES.
    */

    if (BFCD_AZCD01)
       {
        strcpy(SaveDirData ,BFCD_AZCD01->szSaveFileName);
       }

    return CMN_SUCCESS;
 }



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW005BusSaveDirFldExit
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/18/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/18/93  C. Crampton              Original code.
**
***************************************************************************/

WCBPROC( AZDW005BusSaveDirFldExit )
 {

/* _FND_ERROR_BLOCK FndGenErrorBlock; */
  USHORT FndGenRC = 0;

  SHORT sRC=0;

  FndGenRC = AZDW005BusValidateSaveFile(pEventInfo,
                                        pEAIA,
                                        pBFCD,
                                        pWesMap,
                                        pWindContextData,
                                        pABHI);

  if (FndGenRC != CMN_SUCCESS)
      {
       return(CMN_FAIL);
      }


  return CMN_SUCCESS;


 }




