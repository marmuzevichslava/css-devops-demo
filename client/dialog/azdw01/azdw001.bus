/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW001BusPredisplay
**
**  DESCRIPTION      : This function handles any predisplay processing for
**                      window AZDW001.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : malloc
**                     AZDW001BusOpenPipe
**                     AZDW001BusReadPipe
**                     AZDW001BusFillMsgBox
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/10/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/10/93  C. Crampton           Original code.
**
**    12/07/93  C. Crampton           Added Semaphore DosSemClear for each semaphore type.
**
**    01/19/94  C. Crampton           Added call to CmnWindowDataModNotReqd to Predisplay.
***************************************************************************/

WCBPROC( AZDW001BusPredisplay )
 {

   _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT usSelectedButton;
    HSYSSEM hssem;

  /*
  ** Set this window to not modifiable
  */

  CmnWindowDataModNotReqd( CMN_ARCH_PARMS );

  /*
  ** Allocate space for the BFCD data structure
  */

  pBFCD->pCSRDiagBFCD = malloc(sizeof(_AZCD01Global));

  if ( pBFCD->pCSRDiagBFCD == NULL )
  {
     FndMsgBoxDisplayText( "Unable to allocate memory for BFCD ...",
                           NULL,
                           CBI_hwnd,
                           FND_MSGBOX_OK,
                           FND_MSGBOX_ERROR,
                           FND_MSGBOX_IDOK,
                           CSR_DIAG_APPL_NAME,
                           &usSelectedButton,
                           &FndGenErrorBlock );

      return( CMN_FAIL );
   }

   /*
   ** Initialize BFCD to zeros
   */
   memset( pBFCD->pCSRDiagBFCD, 0, sizeof( _AZCD01Global ));

   /*
   ** Free any outstanding semaphore locks for the csr
   */

   FndGenRC = DosOpenSem( &hssem, CSR_REQUEST_SEM_NAME );
   if ( FndGenRC == 0 )
   {
       FndGenRC = DosSemClear( hssem );
   }

   FndGenRC = DosOpenSem( &hssem, CSR_SERVICE_SEM_NAME );

   if ( FndGenRC == 0 )
   {
      FndGenRC = DosSemClear( hssem );
   }

   FndGenRC = DosOpenSem( &hssem, CSR_DETAIL_SEM_NAME );

   if ( FndGenRC == 0 )
   {
      FndGenRC = DosSemClear( hssem );
   }

   /*
   ** Tell the CSR to go into debug mode
   */
   FndGenRC = AZDW001BusOpenPipe( pEventInfo,
                                  pEAIA,
                                  pBFCD,
                                  pWesMap,
                                  pWindContextData,
                                  pABHI );

   if ( FndGenRC != CMN_SUCCESS )
   {
      return( CMN_FAIL );
   }

   /*
   ** Default the directory name for the log files
   */
   strcpy( BFCD_AZCD01->szLogDirName,"C:\\DATA\\MAPS" );

   return CMN_SUCCESS;
 }  /* end of function AZDW001BusPredisplay */



