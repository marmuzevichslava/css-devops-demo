/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW001BusWindowClose
**
**  DESCRIPTION      : This function notifies the CSR that the CSR diagnostic
**                       window application is terminating.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 10/06/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/06/93  C. Crampton              Original code.
**
***************************************************************************/


WCBPROC (AZDW001BusWindowClose)
{
   USHORT usRC;
   USHORT usCounter;

   _CONTROL_BLOCK CsrControlBlock; /* The input buffer */
   _CSR_CALL_REPLY *pCsrCallReply; /* The output buffer */
   SEL sel;
   USHORT usBytesRead;

   FILE *fptrTemp;
   USHORT FndGenRC = 0;
   HSYSSEM hssem;

   /*
   ** Initialize and populate the CsrControlBlock
   **  Copy the string into the requestid member.
   **  Pass the window handle in the hwnd member.
   */
   strcpy( CsrControlBlock.RequestId, "NODEBUG" );
   CsrControlBlock.hwnd = CBI_hwnd;

   /* Allocate gettable memory for the client data area */
   usRC = DosAllocSeg( sizeof( _CSR_CALL_REPLY ) + sizeof( _CONTROL_BLOCK ),
                       &sel,
                       SEG_GETTABLE );

   /* Convert selector to pointer */
   CsrControlBlock.pGettableMem = MAKEP( sel, 0 );

   /* If the memory allocated successfully... */
   if ( usRC == CMN_SUCCESS )
   {
      /* Clear the CsrControlBlock.pGettableMem area. */
      memset( CsrControlBlock.pGettableMem,
              '\0',
              (size_t)( sizeof(_CSR_CALL_REPLY) + sizeof(_CONTROL_BLOCK) ));

      pCsrCallReply = (_CSR_CALL_REPLY *)CsrControlBlock.pGettableMem;

      /* Copy the Pointer to pClientArea and pGettableMem into
       * CsrCallReply.
       */

      pCsrCallReply->pGettableMem = CsrControlBlock.pGettableMem;
      pCsrCallReply->GettableSel  = sel;

      /* Copy the CsrControlBlock into Gettable Memory */
      memcpy( CsrControlBlock.pGettableMem + sizeof(_CSR_CALL_REPLY),
              &CsrControlBlock,
              ( size_t )( sizeof( _CONTROL_BLOCK )));

      /*
      ** Send the pointer to Gettable Memory
      ** down the named pipe to the CSR.
      */

      usRC = DosCallNmPipe( CSR_PIPE_NAME,
                            ( PVOID )  &CsrControlBlock.pGettableMem,
                            sizeof( BYTE * ),
                            (PVOID) pCsrCallReply,
                            sizeof( _CSR_CALL_REPLY ),
                            &usBytesRead,
                            CSR_DIAG_PIPE_TIMEOUT );

      /*
      ** Free any outstanding semaphore locks for the csr
      */

      FndGenRC = DosOpenSem( &hssem, CSR_REQUEST_SEM_NAME );
      if ( FndGenRC == 0 )
      {
         FndGenRC = DosSemClear( hssem );
      }

      FndGenRC = DosOpenSem( &hssem, CSR_SERVICE_SEM_NAME );
      if ( FndGenRC == 0 )
      {
         FndGenRC = DosSemClear( hssem );
      }

      FndGenRC = DosOpenSem( &hssem, CSR_DETAIL_SEM_NAME );
      if ( FndGenRC == 0 )
      {
         FndGenRC = DosSemClear( hssem );
      }

      /*
      ** if return code from call to csr was bad return fail
      */

      if ( usRC )
      {
          return( CMN_FAIL );
      }
   } /* end of allocated memory cleanly */

   /*
   ** Free the memory for the Request Detail Messages
   */
   DosFreeSeg( SELECTOROF( BFCD_AZCD01->pRequestSeg ));

   fptrTemp = BFCD_AZCD01->fptrRequestLog;
   if ( BFCD_AZCD01->fptrRequestLog )
   {
      fclose( BFCD_AZCD01->fptrRequestLog );
   }

   /*
   **  Free the memory for the Service Detail Messages
   */
   for ( usCounter = 0; usCounter < BFCD_AZCD01->usNumServices; usCounter++ )
   {
       DosFreeSeg( SELECTOROF(BFCD_AZCD01->Service[usCounter].pServiceSeg ));
       fclose( BFCD_AZCD01->Service[usCounter].fptrServiceLog );
   }
} /* end of function AZDW001BusWindowClose */



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW001BusOtherGui
**
**  DESCRIPTION      : This function handles any messages that come in thru
**                      Other Gui event. It can be used to trap Help manager
**                      inform messages.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 10/06/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/06/93  C. Crampton              Original code.
**
***************************************************************************/


WCBPROC (AZDW001BusOtherGui)
{
 SHORT sRC=0;
 USHORT usPanelID = 0;

 switch ( CBI_ApplMsg )
     {

      case HM_INFORM:  /* Help Manager INFORM message */
           usPanelID = SHORT1FROMMP( CBI_ApplParm1 );
           if ( usPanelID > 0 )
           {
               sRC = CmnHlpMgrDispPanelId( usPanelID,
                                           CMN_ARCH_PARMS );
           }
           break; /* break out of case HM_INFORM logic */

     } /* End of switch */

 return ( CMN_SUCCESS );
} /* end of function AZDW001Bus_Gui */
