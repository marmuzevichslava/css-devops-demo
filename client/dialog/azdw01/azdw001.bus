/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZDW001BusAmnprntpClick
**
**  DESCRIPTION      : This function handles printing of the error messages
**                      to the printer.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/10/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/10/93  C. Crampton              Original code.
**
***************************************************************************/

WCBPROC( AZDW001BusAmnprntpClick )
 {

  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC = 0;

  FILE *fhndFilePtr;
  char szErrorMsg[255];
  char szTitle[80];
  USHORT usIndex;
  BOOL bMore=TRUE;
  _TranscriptLBRow ListBox;
  USHORT usSelectedButton;
  time_t tCurrentTime;
  int nPad=43;

/*
** Open a file handle for the printer
*/

   fhndFilePtr = fopen("LPT1", "w");

   if (fhndFilePtr == NULL)
   {
      strcpy(szErrorMsg, "Unable to open LPT1 for printing");

      FndMsgBoxDisplayText( szErrorMsg,
                            NULL,
                            CBI_hwnd,
                            FND_MSGBOX_OK,
                            FND_MSGBOX_ERROR,
                            FND_MSGBOX_IDOK,
                            CSR_DIAG_APPL_NAME,
                            &usSelectedButton,
                            &FndGenErrorBlock );
      return( CMN_FAIL );
   }
/*
** Set the printer to landscape mode
*/

  FndGenRC = fprintf( fhndFilePtr, SET_LANDSCAPE );

/*
** Get the title of the list box to use as a heading on the printout
*/

  FndLstBoxTitleQuery( CBI_hwnd,
                       "TranscriptLB",
                       sizeof( szTitle ),
                       szTitle,
                       &FndGenErrorBlock );


/*
** Tell the user whats going on, whats going on
*/

  sprintf(szErrorMsg, "Printing %s ", szTitle);
  FndMsgBoxDisplayMdlssText( szErrorMsg,
                             "PrintMsgBox",
                             CBI_hwnd,
                             FND_MSGBOX_NOBUTTONS,
                             FND_MSGBOX_INFORMATION,
                             FND_MSGBOX_IDNOBUTTON,
                             CSR_DIAG_APPL_NAME,
                             &FndGenErrorBlock );

/*
** Print out a heading with Normal font
*/
 nPad = ( 106 - strlen( szTitle )) / 2;
 FndGenRC = fprintf( fhndFilePtr,"%*c%s\n",' ', nPad, szTitle );

 time( &tCurrentTime );
 nPad = (106 - strlen(ctime(&tCurrentTime)) ) / 2;
 FndGenRC = fprintf(fhndFilePtr,"%*c%s\n\n",' ',nPad ,ctime(&tCurrentTime));

/*
** Set the font to line printer (smaller font)
*/

  FndGenRC = fprintf( fhndFilePtr, LINE_PRINTER );

/*
** Set the line spacing to smaller
*/

  FndGenRC = fprintf( fhndFilePtr, VMI );


/*
** Loop thru the list box and read each line.
**  Then write it out to the printer.
*/

 usIndex = 0;
 bMore = TRUE;

 while ( bMore )
 {
    CmnErrOverrides( NULL,
                     CMN_OVERRIDE_FATAL,
                     CMN_ERR_LOGGING_DEFAULT,
                     CMN_RC_CONTINUE_PROCESSING,
                     CMN_ARCH_PARMS );

    FndLstBoxRowQueryData( CBI_hwnd,
                           "TranscriptLB",
                           usIndex,
                           sizeof( _TranscriptLBRow ),
                           &ListBox,
                           &FndGenErrorBlock );

  if ( FndGenRC != FND_SUCCESS && FndGenRC != LBOX_ROW_EMPTY )
  {
      return( CMN_FAIL );
  }
  else if ( FndGenRC == LBOX_ROW_EMPTY )
  {
      bMore = FALSE;
  }
  else
  {
      fprintf(fhndFilePtr, "%s\n", ListBox._TranscriptLBDataBufferData);
      usIndex++;
  }
  } /* end of while more rows in list box */

/*
** reset the printer to defaults
*/

  FndGenRC = fprintf(fhndFilePtr, RESET_PRINTER);
/*
** Close the file handle to the printer
*/
  fclose(fhndFilePtr);

/*
** Take it easy for awhile to let the user read the message box.
** Then kill it.
*/

  FndGenRC = DosSleep(2000L);

  FndMsgBoxDestroy( "PrintMsgBox",
                    &FndGenErrorBlock );
  return CMN_SUCCESS;

 } /* end of function AZDW001BusAmnprntpClick */



