#define DLG_BOX
#define INCL_AGRWN01
#define INCL_C1CBASE
#define INCL_C1CCALLBACK

#include <C1C.H>     /*  CUSTOMER/1-Cooperative standard header file  */

#define _STANDARDHEADER void

#define PB_TYPE_OK                 0
#define PB_TYPE_OK_CANCEL          1
#define PB_TYPE_RETRY_CANCEL       2
#define PB_TYPE_ABORT_RETRY_IGNORE 3
#define PB_TYPE_YES_NO             4
#define PB_TYPE_YES_NO_CANCEL      5
#define PB_TYPE_CANCEL             6
#define PB_TYPE_ENTER              7
#define PB_TYPE_ENTER_CANCEL       8

#define ICON_TYPE_QUERY            0   /* ? */
#define ICON_TYPE_WARNING          1   /* ! */
#define ICON_TYPE_INFORMATION      2   /* i */
#define ICON_TYPE_CRITICAL         3   /* stop sign */
#define ICON_TYPE_ERROR            4   /* no icon (but still a stop sign) */

#define DEF_PB_1                   0
#define DEF_PB_2                   1
#define DEF_PB_3                   2

typedef struct __ERR_MSG_TABLE
{
   _ERR_CODE_KEY CodeKey;
   _CMN_ERROR_DECODE ErrorDecode;
} _ERR_MSG_TABLE;

typedef struct __ERR_MSG_INIT_DATA
{
    _AWHINITIALDATA WinHndlTrkInfo;
              short ErrMsgPassed;
              short ErrMsgAction;
} _ERR_MSG_INIT_DATA;


/*  Begin Source Code Section ***********************************************
                         Window Level Event Callbacks                       *
*****************************************************************************/

static WCBPROC (WINPRDIS)
/****************************************************************************

        Control/Events which call this callback:

                     WINDOW - PREDISPLAY


     Description: Enter description for WINPRDIS

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    CMN_WDT_VARS

    _ERR_MSG_INIT_DATA *pErrMsgInitData;
        _ERR_MSG_TABLE  ErrMsgTbl;
      _CODE_PARM_BLOCK  CodeParmBlock;
         _ERR_CODE_KEY  StrtKey;
                  char  Msg[100];
                 short  rc=0;

    /*
        Initialize Window Context Data Architecture variables.
    */
    memset(&(WCD_ArchData), 0, sizeof(_ARCHDATA));

    /*
        Initialize CmnErrBlock
    */
    CMN_INIT_ERR_BLK

    CMN_FORMAT_ERR_BLK("WINPRDIS", "AZCD002X")

    /*
        Initialize the Architecture Window Handle Tracking Array.
    */
    CMN_INIT_WIN_HWND_TRACK(CMN_NO)
    CMN_INIT_WIN_DATA_TRACK(CMN_NO)
    WCD_ArchData.WnMsgType = CMN_MSG_WIN_CLOSE_AFTER_CANCEL;

    /*
        Callback Logic
    */
    pErrMsgInitData=(_ERR_MSG_INIT_DATA *) CBI_pInitData;
    sprintf(WindowTitle,
            "Inquiry on Error Message: %u",
            pErrMsgInitData->ErrMsgPassed);
    /*
          Initialize the window
    */
    memset(&TxErrorMsgTitleData,0,30);
    memset(&TxErrorMsgData,0,123);
    memset(&CdErrorSeverityData,0,3);
    memset(&TxPushbuttonTypeData,0,50);
    memset(&TxIconTypeData,0,50);
    memset(&TxDefaultPushbuttonData,0,50);

    /*
          Retrieve error message data from the Error Codes Table
    */

    StrtKey.ErrMsgNum = pErrMsgInitData->ErrMsgPassed;
    StrtKey.Lang='E';
    strncpy(StrtKey.SeqNum,"001",_SEQ_NUM_LEN);

    memset(&CodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));
    memset(&ErrMsgTbl,0,sizeof(_ERR_MSG_TABLE));

    memcpy(&CodeParmBlock.Code_Parm_Block_Version,
           FND_CTS_VER,
           _VER_LEN);

    memcpy(&CodeParmBlock.Code_Function_Code,
           _CTIO_GET_UNIQUE,
           _CTS_FUNCTION_LEN);

    memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_Id,
           ERROR_CODE_TABLE,
           _CTB_TABLE_LEN);

    memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_User_Key,
           &StrtKey,
           sizeof(_ERR_CODE_KEY));

    CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Requested=1;

/*
      Retrieve the error message from the codes table
*/

    WFNDCODE(&CodeParmBlock, pABHI, &ErrMsgTbl);

/*
      Check to see if retrieval was successful
*/

    if (CodeParmBlock.Code_Explanation_Code == FND_SUCCESS)
    {
        memcpy(&TxErrorMsgTitleData,&ErrMsgTbl.ErrorDecode.TxErrorMsgTitle,29);
        memcpy(&TxErrorMsgData,&ErrMsgTbl.ErrorDecode.TxErrorMsg,122);
        memcpy(&CdErrorSeverityData,&ErrMsgTbl.ErrorDecode.CdErrorSeverity,2);
        switch (ErrMsgTbl.ErrorDecode.CdPushbuttonType)
        {
            case PB_TYPE_OK:
                 strcpy (TxPushbuttonTypeData, "OK");
                 break;
            case PB_TYPE_OK_CANCEL:
                 strcpy (TxPushbuttonTypeData, "OK and CANCEL");
                 break;
            case PB_TYPE_RETRY_CANCEL:
                 strcpy (TxPushbuttonTypeData, "RETRY and CANCEL");
                 break;
            case PB_TYPE_ABORT_RETRY_IGNORE:
                 strcpy (TxPushbuttonTypeData, "ABORT, RETRY and IGNORE");
                 break;
            case PB_TYPE_YES_NO:
                 strcpy (TxPushbuttonTypeData, "YES and NO");
                 break;
            case PB_TYPE_YES_NO_CANCEL:
                 strcpy (TxPushbuttonTypeData, "YES, NO and CANCEL");
                 break;
            case PB_TYPE_CANCEL:
                 strcpy (TxPushbuttonTypeData, "CANCEL");
                 break;
            case PB_TYPE_ENTER:
                 strcpy (TxPushbuttonTypeData, "ENTER");
                 break;
            case PB_TYPE_ENTER_CANCEL:
                 strcpy (TxPushbuttonTypeData, "ENTER and CANCEL");
                 break;
            default:
                 sprintf(TxPushbuttonTypeData,
                         "Unknown Pushbutton Type: %u",
                         ErrMsgTbl.ErrorDecode.CdPushbuttonType);
                 break;
        }


        switch (ErrMsgTbl.ErrorDecode.CdIconType)
        {
            case ICON_TYPE_QUERY:
                 strcpy (TxIconTypeData, "QUERY (?)");
                 break;
            case ICON_TYPE_WARNING:
                 strcpy (TxIconTypeData, "WARNING (!)");
                 break;
            case ICON_TYPE_INFORMATION:
                 strcpy (TxIconTypeData, "INFORMATION (i)");
                 break;
            case ICON_TYPE_CRITICAL:
                 strcpy (TxIconTypeData, "CRITICAL (stop sign)");
                 break;
            case ICON_TYPE_ERROR:
                 strcpy (TxIconTypeData, "ERROR (no icon)");
                 break;
            default:
                 sprintf (TxIconTypeData,
                          "Unknown Icon Type: %u",
                          ErrMsgTbl.ErrorDecode.CdIconType);
                 break;
        }

        switch (ErrMsgTbl.ErrorDecode.CdDefaultPushbutton)
        {
            case DEF_PB_1:
                 strcpy (TxDefaultPushbuttonData, "1st Pushbutton");
                 break;
            case DEF_PB_2:
                 strcpy (TxDefaultPushbuttonData, "2nd Pushbutton");
                 break;
            case DEF_PB_3:
                 strcpy (TxDefaultPushbuttonData, "3rd Pushbutton");
                 break;
            default:
                 sprintf(TxDefaultPushbuttonData,
                         "Unknown Default Pushbutton: %u",
                         ErrMsgTbl.ErrorDecode.CdDefaultPushbutton);
                 break;
        }

    }
    else
    {
       if (CodeParmBlock.Code_Explanation_Code == CTS_KEY_NOT_FOUND)
       {
           rc=FpsDisplayChoiceBoxText(CBI_hwnd,
                                   "Requested message was not found, please refresh Message List",
                                   "SORRY!",
                                    FPS_OK|FPS_WARNING,
                                    FPS_DEFBUTTON1);
           rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
       }
       else
       {
          sprintf(Msg,
                  "A problem occurred while processing the request..."
                  "  The error code was: %u...  Please see FCP TRG",
                  CodeParmBlock.Code_Explanation_Code);
          rc=FpsDisplayChoiceBoxText(CBI_hwnd,
                                  Msg,
                                  "ERROR!",
                                  FPS_OK|FPS_CRITICAL,
                                  FPS_DEFBUTTON1);
          rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
       }
    }

    return (CMN_CALLBACK_RC);

}   /*  End WINPRDIS   */


