                     Pushbutton and Menu Event Callbacks                    *
*****************************************************************************/

static WCBPROC (SPBVIEW)
/****************************************************************************

        Control/Events which call this callback:

                     VIEW_CMD - CLICK


     Description: Enter description for SPBVIEW

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    short PBtype=0, IconType=0, ChoiceOpts=0, DefPB=0, rc=0;

    /*
        Initialize CmnErrBlock with SPBVIEW
    */
    CMN_UPDATE_CB_IN_ERR_BLK("SPBVIEW")


    /*
        Callback Logic
    */
    if (strcmp(TxPushbuttonTypeData, "OK")==0)
       PBtype=FPS_OK;
    if (strcmp(TxPushbuttonTypeData, "OK and CANCEL")==0)
       PBtype=FPS_OKCANCEL;
    if (strcmp(TxPushbuttonTypeData, "RETRY and CANCEL")==0)
       PBtype=FPS_RETRYCANCEL;
    if (strcmp(TxPushbuttonTypeData, "ABORT, RETRY and IGNORE")==0)
       PBtype=FPS_ABORTRETRYIGNORE;
    if (strcmp(TxPushbuttonTypeData, "YES and NO")==0)
       PBtype=FPS_YESNO;
    if (strcmp(TxPushbuttonTypeData, "YES, NO and CANCEL")==0)
       PBtype=FPS_YESNOCANCEL;
    if (strcmp(TxPushbuttonTypeData, "CANCEL")==0)
       PBtype=FPS_CANCEL;
    if (strcmp(TxPushbuttonTypeData, "ENTER")==0)
       PBtype=FPS_ENTER;
    if (strcmp(TxPushbuttonTypeData, "ENTER and CANCEL")==0)
       PBtype=FPS_ENTERCANCEL;

    if (strcmp(TxIconTypeData, "QUERY (?)")==0)
       IconType=FPS_QUERY;
    if (strcmp(TxIconTypeData, "WARNING (!)")==0)
       IconType=FPS_WARNING;
    if (strcmp(TxIconTypeData, "INFORMATION (i)")==0)
       IconType=FPS_INFORMATION;
    if (strcmp(TxIconTypeData, "CRITICAL (stop sign)")==0)
       IconType=FPS_CRITICAL;
    if (strcmp(TxIconTypeData, "ERROR (no icon)")==0)
       IconType=FPS_ERROR;

    if (strcmp(TxDefaultPushbuttonData, "1st Pushbutton")==0)
       DefPB=FPS_DEFBUTTON1;
    if (strcmp(TxDefaultPushbuttonData, "2nd Pushbutton")==0)
       DefPB=FPS_DEFBUTTON2;
    if (strcmp(TxDefaultPushbuttonData, "3rd Pushbutton")==0)
       DefPB=FPS_DEFBUTTON3;
    ChoiceOpts = PBtype|IconType;
    rc=FpsDisplayChoiceBoxText(CBI_hwnd,
                               TxErrorMsgData,
                               TxErrorMsgTitleData,
                               ChoiceOpts,
                               DefPB);


    return (CMN_CALLBACK_RC);

} /* End SPBVIEW */


