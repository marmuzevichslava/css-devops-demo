#define _STANDARDHEADER void
#define ERR_MSG_RANGE_BOTTOM 10000
#define ERR_MSG_RANGE_TOP    19999

typedef struct __ERR_MSG_TABLE
{
   _ERR_CODE_KEY CodeKey;
   _CMN_ERROR_DECODE ErrorDecode;
} _ERR_MSG_TABLE;

typedef struct __ERR_MSG_INIT_DATA
{
    _AWHINITIALDATA WinHndlTrkInfo;
              short ErrMsgPassed;
               char ErrMsgAction;
} _ERR_MSG_INIT_DATA;

short CTGetMult(_ERR_MSG_TABLE  ErrMsgTbl [],
              _CODE_PARM_BLOCK *pCodeParmBlock,
                         _ABHI *pABHI,
                        USHORT  ErrMsgNbr);

short CTSrchMult(_ERR_MSG_TABLE ErrMsgTbl [],
              _CODE_PARM_BLOCK *pCodeParmBlock,
                        USHORT  ErrMsgNbr,
             struct WESMAPNAME *pWesMap,
                         _ABHI *pABHI,
                          char *pSrchText);

void LoadLB (_ERR_MSG_TABLE  ErrMsgTbl[],
           _CODE_PARM_BLOCK *pCodeParmBlock,
          struct WESMAPNAME *pWesMap);

void SetCmds (short  RowsRtrnd,
     WINCONTEXTNAME *pWindContextData);


