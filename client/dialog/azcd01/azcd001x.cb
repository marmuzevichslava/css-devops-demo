static WCBPROC (APBFIND)
/****************************************************************************

        Control/Events which call this callback:

                     FindPB_CMD - CLICK


     Description: Enter description for APBFIND

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    _ERR_MSG_TABLE   ErrMsgTable[NUMERRMSGLBROWS];
    _CODE_PARM_BLOCK CodeParmBlock;
    short            i=0, rc=0;
    /*
        Initialize CmnErrBlock with APBFIND
    */
    CMN_UPDATE_CB_IN_ERR_BLK("APBFIND")


    /*
        Callback Logic
    */

    rc=CmnDisableCommand(FindPB_CMD,pCmnErrBlock);

    for (i=0;i<400;i++)
    {
       WCD_KyErrorMessage[i]=0;
    }
    WCD_NoPageNbr=0;

    rc=CmnDisableCommand(PageUpPB_CMD,pCmnErrBlock);
    rc=CmnDisableCommand(PageDownPB_CMD,pCmnErrBlock);
    for (i=0;i<NUMERRMSGLBROWS;i++)
    {
       memset(&ErrMsgTable[i],0,sizeof(_ERR_MSG_TABLE));
    }
    memset(&CodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));
    CmnStrPadNull(TxErrorMsgData,123);

    if (((KyErrorMessageData < ERR_MSG_RANGE_BOTTOM)
          ||
         (KyErrorMessageData > ERR_MSG_RANGE_TOP)))
    {
       if (strcmp(TxErrorMsgData,"") ==0)
       {
          rc=CTGetMult(ErrMsgTable,&CodeParmBlock,pABHI,ERR_MSG_RANGE_BOTTOM);
          LoadLB(ErrMsgTable,&CodeParmBlock,pWesMap);
          SetCmds(CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned,
                  pWindContextData);
       }
       else
       {
          rc=CTSrchMult(ErrMsgTable,
                        &CodeParmBlock,
                        ERR_MSG_RANGE_BOTTOM,
                        pWesMap,
                        pABHI,
                        TxErrorMsgData);
          LoadLB(ErrMsgTable,&CodeParmBlock,pWesMap);
          SetCmds(CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned,
                  pWindContextData);
       }
    }

    if (((KyErrorMessageData >= ERR_MSG_RANGE_BOTTOM)
          &&
         (KyErrorMessageData <= ERR_MSG_RANGE_TOP)))
    {
       if (strcmp(TxErrorMsgData,"") == 0)
       {
          rc=CTGetMult(ErrMsgTable,&CodeParmBlock,pABHI,KyErrorMessageData);
          LoadLB(ErrMsgTable,&CodeParmBlock,pWesMap);
          SetCmds(CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned,
                  pWindContextData);
       }
       else
       {
          rc=CTSrchMult(ErrMsgTable,
                        &CodeParmBlock,
                        KyErrorMessageData,
                        pWesMap,
                        pABHI,
                        TxErrorMsgData);
          LoadLB(ErrMsgTable,&CodeParmBlock,pWesMap);
          SetCmds(CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned,
                  pWindContextData);
       }
    }

    if (CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned==0)
    {
       strcpy(TxErrorMessageData, "No Data Found Matching Search Criteria");
    }
    else
    {
       strcpy(TxErrorMessageData,"Search Complete...");
    }

    rc=CmnEnableCommand(FindPB_CMD,pCmnErrBlock);

    return (CMN_CALLBACK_RC);

} /* End APBFIND */


static WCBPROC (APBPGUP)
/****************************************************************************

        Control/Events which call this callback:

                     PageUpPB_CMD - CLICK


     Description: Enter description for APBPGUP

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    _ERR_MSG_TABLE  ErrMsgTbl[NUMERRMSGLBROWS];
    _CODE_PARM_BLOCK CodeParmBlock;
    short rc=0, i=0;


    /*
        Initialize CmnErrBlock with APBPGUP
    */
    CMN_UPDATE_CB_IN_ERR_BLK("APBPGUP")


    /*
        Callback Logic
    */
    strcpy(TxErrorMessageData,"");


    /*
          Check to see if textual search
    */

    if (strcmp(TxErrorMsgData,"") == 0)
    {
       rc=CTGetMult(ErrMsgTbl,
                    &CodeParmBlock,
                    pABHI,
                    WCD_KyErrorMessage[WCD_NoPageNbr - 1]);
    }
    else
    {
       rc=CTSrchMult(ErrMsgTbl,
                     &CodeParmBlock,
                     WCD_KyErrorMessage[WCD_NoPageNbr - 1],
                     pWesMap,
                     pABHI,
                     TxErrorMsgData);
    }

    if (CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned == 0)
    {
       rc=CmnDisableCommand(PageDownPB_CMD,pCmnErrBlock);
       rc=CmnDisableCommand(PageUpPB_CMD,pCmnErrBlock);
       strcpy(TxErrorMessageData,"Data Error on Page Up");
    }
    else
    {
       LoadLB(ErrMsgTbl,&CodeParmBlock,pWesMap);
       WCD_NoPageNbr--;
       if (WCD_NoPageNbr ==0)
       {
          rc=CmnDisableCommand(PageUpPB_CMD,pCmnErrBlock);
          rc=CmnEnableCommand(PageDownPB_CMD,pCmnErrBlock);
          strcpy(TxErrorMessageData,"Beginning of List");
       }
       else
       {
          rc=CmnEnableCommand(PageUpPB_CMD,pCmnErrBlock);
          rc=CmnEnableCommand(PageDownPB_CMD,pCmnErrBlock);
       }
    }

    return (CMN_CALLBACK_RC);

} /* End APBPGUP */


static WCBPROC (APBPGDN)
/****************************************************************************

        Control/Events which call this callback:

                     PageDownPB_CMD - CLICK


     Description: Enter description for APBPGDN

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    _ERR_MSG_TABLE  ErrMsgTbl[NUMERRMSGLBROWS];
    _CODE_PARM_BLOCK CodeParmBlock;
    short rc=0, i=0;

    /*
        Initialize CmnErrBlock with APBPGDN
    */
    CMN_UPDATE_CB_IN_ERR_BLK("APBPGDN")


    /*
        Callback Logic
    */
    strcpy(TxErrorMessageData,"");


    /*
          Check to see if textual search
    */

    if (strcmp(TxErrorMsgData,"") == 0)
    {
       rc=CTGetMult(ErrMsgTbl,
                    &CodeParmBlock,
                    pABHI,
                    (ErrMsgLBKyErrorMessageData[NUMERRMSGLBROWS - 1]+1));
    }
    else
    {
       rc=CTSrchMult(ErrMsgTbl,
                     &CodeParmBlock,
                     (ErrMsgLBKyErrorMessageData[NUMERRMSGLBROWS - 1]+1),
                     pWesMap,
                     pABHI,
                     TxErrorMsgData);
    }

    if (CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned == 0)
    {
       rc=CmnDisableCommand(PageDownPB_CMD,pCmnErrBlock);
       strcpy(TxErrorMessageData,"End of List");
    }
    else
    {
       WCD_KyErrorMessage[WCD_NoPageNbr] = ErrMsgLBKyErrorMessageData[0];
       WCD_NoPageNbr++;
       LoadLB(ErrMsgTbl,&CodeParmBlock,pWesMap);
       if (CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Returned == NUMERRMSGLBROWS)
       {
          rc=CmnEnableCommand(PageUpPB_CMD,pCmnErrBlock);
          rc=CmnEnableCommand(PageDownPB_CMD,pCmnErrBlock);
       }
       else
       {
          rc=CmnEnableCommand(PageUpPB_CMD,pCmnErrBlock);
          rc=CmnDisableCommand(PageDownPB_CMD,pCmnErrBlock);
          strcpy(TxErrorMessageData,"End of List");
       }
    }


    return (CMN_CALLBACK_RC);

} /* End APBPGDN */


static WCBPROC (AMNINQ)
/****************************************************************************

        Control/Events which call this callback:

                     InquireMN_CMD - CLICK


     Description: Enter description for AMNINQ

*****************************************************************************/
{
    /*
        Local Variable Declarations
    */
    short rc=0,i=0;
    _ERR_MSG_INIT_DATA ErrMsgInitData;

    /*
        Initialize CmnErrBlock with AMNINQ
    */
    CMN_UPDATE_CB_IN_ERR_BLK("AMNINQ")

    /*
        Callback Logic
    */

    /*
         Locate the row that is selected
    */
	for (i=0;((i<NUMERRMSGLBROWS)&&(ErrMsgLBSelIndData[i]!=SIN_SELECTED));i++);

    /*
         Create the window passing the selected error message
    */
    ErrMsgInitData.ErrMsgPassed=ErrMsgLBKyErrorMessageData[i];
    rc=CmnCreateWindow("CDINQWIN",AZCD002XID,NULL,&ErrMsgInitData,pCmnErrBlock);

	return (CMN_CALLBACK_RC);

} /* End AMNINQ */


