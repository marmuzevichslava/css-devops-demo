static WCBPROC (WINPRDIS)
/***************************************************************************/
/*                                                                         */
/*      Control/Events which call this callback:                           */
/*                                                                         */
/*                   WINDOW - PREDISPLAY                                   */
/*                                                                         */
/*                                                                         */
/*  Description: Enter description for WINPRDIS                            */
/*                                                                         */
/***************************************************************************/
{
    /*
       Local Variable Declarations
    */
    CMN_WDT_VARS

    short i=0,rc=0;

    /*
       Initialize Window Context Data Architecture variables.
    */
    memset(&(WCD_ArchData), 0, sizeof(_ARCHDATA));

    /*
       Initialize CmnErrBlock
    */
    CMN_INIT_ERR_BLK

    CMN_FORMAT_ERR_BLK("WINPRDIS", "AZCD001X")

    /*
        Initialize the Architecture Window Handle Tracking Array.
    */
    CMN_INIT_WIN_HWND_TRACK(CMN_YES)
    CMN_INIT_WIN_DATA_TRACK(CMN_YES)
    WCD_ArchData.WnMsgType = CMN_MSG_WIN_CLOSE_AFTER_CANCEL;

    /*
        Callback Logic
    */

    /*  Initialize all controls
    */

    WindowOriginX=30;
    WindowOriginY=20;

    KyErrorMessageData = 0;
    memset(TxErrorMsgData,0,123);
    FlMatchCaseData = FND_NO;
    for (i=0;i<NUMERRMSGLBROWS;i++)
    {
       ErrMsgLBKyErrorMessageData[i]=0;
       memset(ErrMsgLBTxErrorMsgData[i],0,123);
       ErrMsgLBSelIndCtl[i].Rights=RGT_DISABLED;
       ErrMsgLBSelIndData[i]=0;
    }
    memset(TxErrorMessageData,0,51);

    for (i=0;i<400;i++)
    {
       WCD_KyErrorMessage[i]=0;
    }
    WCD_NoPageNbr=0;

    rc=CmnDisableCommand(PageUpPB_CMD,pCmnErrBlock);
    rc=CmnDisableCommand(PageDownPB_CMD,pCmnErrBlock);

    rc=CmnEnableCommand(AddMN_CMD,pCmnErrBlock);

    /*
        Free shared memory retreived by window handle tracking.
    */
    CMN_FREE_SHARED_MEM
    return (CMN_CALLBACK_RC);

}   /*  End WINPRDIS   */


