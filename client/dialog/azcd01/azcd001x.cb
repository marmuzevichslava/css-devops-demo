    */
    CMN_UPDATE_CB_IN_ERR_BLK("E00185FC")


    /*
        Callback Logic
    */
    rc=CmnDisableCommand (PageUpPB_CMD,pCmnErrBlock);
    rc=CmnDisableCommand (PageDownPB_CMD,pCmnErrBlock);

    return (CMN_CALLBACK_RC);

} /* End E00185FC */



/*  Begin Source Code Section ***********************************************
                          Module Common Functions                           *
*****************************************************************************/

short CTGetMult(_ERR_MSG_TABLE    ErrMsgTbl[],
                _CODE_PARM_BLOCK *pCodeParmBlock,
                           _ABHI *pABHI,
                          USHORT  ErrMsg)
{
/*   This function will obtain NUMERRMSGLBROWS records from the Codes Table
|    file (KEHT0001) starting at the error message number provided.  It will
|    then load the records obtained to the array provided by the call.
*/

/*
      Local Variables
*/
	_ERR_CODE_KEY StrtKey;
	short i=0;

/*
      Function Logic
*/

/*
     Initialize the Codes Table Parm Block
*/

    StrtKey.ErrMsgNum = ErrMsg;
    StrtKey.Lang='E';
    strncpy(StrtKey.SeqNum,"001",_SEQ_NUM_LEN);

    memset(pCodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));

    memcpy(pCodeParmBlock->Code_Parm_Block_Version,
           FND_CTS_VER,
           _VER_LEN);

    memcpy(pCodeParmBlock->Code_Function_Code,
           _CTIO_GET_MULTIPLE,
           _CTS_FUNCTION_LEN);

    memcpy(pCodeParmBlock->Code_Detail_Parms.Code_Ctb_Id,
           ERROR_CODE_TABLE,
           _CTB_TABLE_LEN);

    memcpy(pCodeParmBlock->Code_Detail_Parms.Code_Ctb_User_Key,
           &StrtKey,
           sizeof(_ERR_CODE_KEY));

    pCodeParmBlock->Code_Detail_Parms.Code_Num_Rec_Requested=NUMERRMSGLBROWS;

/*
      Retrieve the error messages from the codes table
*/

    WFNDCODE(pCodeParmBlock, pABHI, (VOID FAR *) ErrMsgTbl);

/*
      Scan the error messages to make sure they are in the proper range
*/
    for(i=0;i<pCodeParmBlock->Code_Detail_Parms.Code_Num_Rec_Returned;i++)
    {
       if ((ErrMsgTbl[i].CodeKey.ErrMsgNum < ERR_MSG_RANGE_BOTTOM)
           ||
          (ErrMsgTbl[i].CodeKey.ErrMsgNum > ERR_MSG_RANGE_TOP))
       {
		  memset(&ErrMsgTbl[i],0,sizeof(_ERR_MSG_TABLE));
       }
    }
/*
      Count the number of messages within the range being returned
*/
    for(i=0;((i<NUMERRMSGLBROWS)&&(ErrMsgTbl[i].CodeKey.ErrMsgNum!=0));i++);

/*
      Adjust the parm block to indicate the number of messages being returned
*/

    pCodeParmBlock->Code_Detail_Parms.Code_Num_Rec_Returned = i;
    if (i<NUMERRMSGLBROWS)
    {
       pCodeParmBlock->Code_Explanation_Code = CTS_RET_LESS_THAN_REQ;
	}


    return (pCodeParmBlock->Code_Explanation_Code);
}


short CTSrchMult (_ERR_MSG_TABLE  ErrMsgTbl [],
                _CODE_PARM_BLOCK *pCodeParmBlock,
                          USHORT  ErrMsg,
               struct WESMAPNAME *pWesMap,
                           _ABHI *pABHI,
                            char *pSrchText)
{
/*   This function will retrieve error messages from the codes table starting
|    at a specified point in the table.  For each error message retrieved,
|    the error message text is searched for the specified text.  If the text
|    is found, that error message is loaded into the table passed to this
|    function.  Processing will end when either there are no more error
|    messages to process or the error message table passed to this function
|    is filled.
*/

/*
      Local Variables
*/
    _ERR_MSG_TABLE  ErrMsgScanTbl [NUMERRMSGLBROWS];
              char  CaseSrchText [123];
              char  CaseScanText [123];
            USHORT  NxtErrMsg;
             short  i=0, j=0, rc=0, DoneProcessing=0;

/*
      Function Logic
*/
    memset(CaseSrchText,0,123);
    memset(CaseScanText,0,123);

/*
      If a case sensitive search has been initiated...
*/
    if (FlMatchCaseData == FND_YES)
    {
        strcpy(CaseSrchText,pSrchText);
    }
    else
    {
        strcpy(CaseSrchText,pSrchText);
        strupr(CaseSrchText);
    }

/*
      Process error messages until either the error message table passed
      to this function is full or the are no more error messages to
      process.
*/
    NxtErrMsg = ErrMsg;
    while (DoneProcessing==0)
    {
       for (i=0; i<NUMERRMSGLBROWS; i++)
       {
           memset(&ErrMsgScanTbl[i],0,sizeof(_ERR_MSG_TABLE));
       }
       rc = CTGetMult(ErrMsgScanTbl,
                      pCodeParmBlock,
                      pABHI,
                      NxtErrMsg);

       switch (rc)
       {
           case FND_SUCCESS:
           case CTS_RET_LESS_THAN_REQ:
           case CTS_END_OF_ENTRIES:

              i=0;
              while ((i<NUMERRMSGLBROWS)
                      &&
                     (j<NUMERRMSGLBROWS)
                      &&
                     (ErrMsgScanTbl[i].CodeKey.ErrMsgNum != 0))
              {
                  if (FlMatchCaseData == FND_YES)
                  {
                     memcpy(CaseScanText,
                            ErrMsgScanTbl[i].ErrorDecode.TxErrorMsg,
                            123);
                     CmnStrPadNull(CaseScanText,123);
                  }
                  else
                  {
                     memcpy(CaseScanText,
                            ErrMsgScanTbl[i].ErrorDecode.TxErrorMsg,
                            123);
                     CmnStrPadNull(CaseScanText,123);
                     strupr(CaseScanText);
                  }
                  if (strstr(CaseScanText,CaseSrchText) != NULL)
                  {
                     memcpy(&ErrMsgTbl[j],
                            &ErrMsgScanTbl[i],
                            sizeof(_ERR_MSG_TABLE));
                     j++;
                  }
                  i++;
              }
              break;

           default:
              return (rc);
              break;
       }
       if ((j >= NUMERRMSGLBROWS)
           ||
          (ErrMsgScanTbl[i].CodeKey.ErrMsgNum == 0)
           ||
          (rc==CTS_RET_LESS_THAN_REQ)
           ||
          (rc==CTS_END_OF_ENTRIES))
       {
             DoneProcessing=1;
       }
       else
       {
          NxtErrMsg = ErrMsgScanTbl[i-1].CodeKey.ErrMsgNum;
       }

    }

    pCodeParmBlock->Code_Detail_Parms.Code_Num_Rec_Returned = j;
    return (rc);

}


void LoadLB (_ERR_MSG_TABLE  ErrMsgTbl [],
           _CODE_PARM_BLOCK *pCodeParmBlock,
          struct WESMAPNAME *pWesMap)
{
/*
|   This function takes the error messages in a table and loads them to the
|   WES map listbox.
*/

/*
      Local Variables
*/
    short i=0;

/*
      Function Logic
*/

/*
      Initialize the WES map listbox
*/
    for (i=0; i<NUMERRMSGLBROWS; i++)
    {
       ErrMsgLBKyErrorMessageData[i]=0;
       memset(ErrMsgLBTxErrorMsgData[i],0,123);
       ErrMsgLBSelIndCtl[i].Rights=RGT_DISABLED;
       ErrMsgLBSelIndCtl[i].Cursor=CUR_NOTCURRENT;
    }
/*
      Move data to the listbox
*/
   ErrMsgLBSelIndCtl[0].Cursor=CUR_SHOWLISTITEM;
   for (i=0; i<pCodeParmBlock->Code_Detail_Parms.Code_Num_Rec_Returned; i++)
   {
       ErrMsgLBKyErrorMessageData[i] = ErrMsgTbl[i].CodeKey.ErrMsgNum;
       memcpy(ErrMsgLBTxErrorMsgData[i], ErrMsgTbl[i].ErrorDecode.TxErrorMsg,123);
       ErrMsgLBSelIndCtl[i].Rights=RGT_STANDARD;
       if (ErrMsgLBSelIndData[i]==SIN_SELECTED)
           ErrMsgLBSelIndCtl[i].Cursor=CUR_SHOWLISTITEM;
   }


   return;

}

void SetCmds (short  RowsRtrnd,
     WINCONTEXTNAME *pWindContextData)
{
/*   This function enables or disables commandID's depending on the number
|    of rows loaded into the WES map Listbox.
*/

/*
      Local Variables
*/
    short rc=0;

/*
      Function Logic
*/

	if (RowsRtrnd == NUMERRMSGLBROWS)
    {
       rc=CmnEnableCommand (PageDownPB_CMD,pCmnErrBlock);
    }

    return;
}



