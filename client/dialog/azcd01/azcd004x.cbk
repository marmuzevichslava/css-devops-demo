} /* End WINREDIS */


static WCBPROC (WINOPMEV)
//***************************************************************************
//#
//#     Control/Events which call this callback:
//#
//#                  WINDOW - OTHER_GUI_EVENT
//#
//*
//*  Description: Enter description for WINOPMEV
//*
//***************************************************************************
{
    //*
    //* Local Variable Declarations
    //*
    RETINFO RetInfo;
    short rc1 = 0;
    short rc2 = 0;


    CMN_VARDECL_MSG_RECV
    void      *pSendData;

    //*
    //* Initialize CmnErrBlock with WINOPMEV if within CMN Message ID range
    //*
    if ((CBI_PMmsg > CMN_MSG_MIN) &&
        (CBI_PMmsg < CMN_MSG_MAX))
    {

        CMN_UPDATE_CB_IN_ERR_BLK("WINOPMEV")
    }

    //*
    //* Initialize the FOUNDATION Macros used in this callback
    //*
    CBI_Proc  = 0;
    CBI_PMret = 0;


    //*
    //* Process the Message Sent to the Callback
    //*
    switch (CBI_PMmsg)
    {
        case CMN_MSG_CONV_FAIL:
            pSendData = (_STANDARDHEADER *) (CMN_PVOIDFROMMP(CBI_PMmp1));
            pMsgPB = (_MSG_PARM_BLOCK *) (CMN_PVOIDFROMMP(CBI_PMmp2));

            CmnMsgConvFail(pMsgPB,
                           pSendData,
                           pEAIA,
                           pCmnErrBlock);

            CBI_Proc = 1;
            break;


        case CMN_MSG_CANCEL:
            pSendData = (_STANDARDHEADER *) (CMN_PVOIDFROMMP(CBI_PMmp1));
            pMsgPB = (_MSG_PARM_BLOCK *) (CMN_PVOIDFROMMP(CBI_PMmp2));

            //*
            //*  Process cancel for specific service call
            //*
            switch(pMsgPB->dest.service_id.srvc)
            {
//                case YOUR_SERVICE_ID(S):
//                    break;

                default:
                    break;
            }

            MEMFree(pMsgPB);
            MEMFree(pSendData);

            CBI_Proc = 1;
            break;


        case CMN_MSG_WIN_CREATED:
            CMN_UPDATE_WIN_HWND_TRACK
            CBI_Proc = 1;
            break;

        case CMN_MSG_WIN_CLOSE_AFTER_SAVE:
            CMN_DEL_WIN_FROM_WIN_HWND_TRACK
            CBI_Proc = 1;
            break;

        case CMN_MSG_WIN_CLOSE_AFTER_CANCEL:
            CMN_DEL_WIN_FROM_WIN_HWND_TRACK
            CBI_Proc = 1;
            break;

        case CMN_MSG_WIN_CLOSE_EXIT_PENDING:
            CMN_DEL_WIN_FROM_WIN_HWND_TRACK
            CBI_Proc = 1;
            break;

        case CMN_MSG_ACTIVATE_YOURSELF:
            //*
            //* Activate this window.
            //* If activation is unsuccessful, call the error handler.
            //* If the error handler logs the error, close this window.
            //*
            rc1 = FpsActivateWindow(CBI_WindowID,
                                    CBI_InstanceID,
                                    CBI_hwnd,
                                    NULL,
                                    NULL,
                                    &RetInfo);
            if (rc1 == 0) //* 0 is unsuccessful.
            {
                rc2 = CmnErrorHandler(CMN_FND_ERR_TYPE,
                                      pCmnErrBlock,
                                      rc1,
                                      "FpsActivateWindow");
                CMN_HANDLE_BAD_RC(rc1, CMN_RC_CLOSE_WINDOW)
            }
            CBI_Proc = 1;
            break;

        default:
            CBI_Proc  = 0;
            CBI_PMret = 0;
            break;
    }

    return (CMN_CALLBACK_RC);

} /* End WINOPMEV */


static WCBPROC (WINMSGNT)
//***************************************************************************
//#
//#     Control/Events which call this callback:
//#
//#                  WINDOW - MSG_NOTIFICATION
//#
//*
//*  Description: Enter description for WINMSGNT
//*
//***************************************************************************
{
    //*
    //* Local Variable Declarations
    //*
    CMN_VARDECL_MSG_RECV


    //*
    //* Dereference CBI_pMSGParmBlock
    //*
    pMsgPB = (_MSG_PARM_BLOCK *) CBI_pMSGParmBlock;


    //*
    //* Initialize CmnErrBlock with WINMSGNT
    //*
    CMN_UPDATE_MSGNOTF_IN_ERR_BLK("WINMSGNT", pMsgPB)



    //*
    //* Callback Logic
    //*

    return (CMN_CALLBACK_RC);

} /* End WINMSGNT */


static WCBPROC (WINPRDES)
//***************************************************************************
//#
//#     Control/Events which call this callback:
//#
//#                  WINDOW - PREDESTROY
//#
//*
//*  Description: Enter description for WINPRDES
//*
//***************************************************************************
{
    //*
    //* Local Variable Declarations
    //*

    //*
    //* Initialize CmnErrBlock with WINPRDES
    //*
    CMN_UPDATE_CB_IN_ERR_BLK("WINPRDES")

    //*
    //* Cleanup the Window Handle Tracking List
    //*
    CMN_FREE_WIN_HWND_TRACK(CMN_NO)


    //*
    //* Callback Logic
    //*


    //*
    //* Free memory allocated for this window's error block.
    //*
    free(pCmnErrBlock);
    return (CMN_CALLBACK_RC);

} /* End WINPRDES */



