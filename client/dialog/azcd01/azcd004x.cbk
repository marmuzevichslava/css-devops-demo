//*                      Window Level Event Callbacks                       *
//***************************************************************************

static WCBPROC (WINPRDIS)
//***************************************************************************
//#
//#     Control/Events which call this callback:
//#
//#                  WINDOW - PREDISPLAY
//#
//*
//*  Description: Enter description for WINPRDIS
//*
//***************************************************************************
{
    //*
    //* Local Variable Declarations
    //*

    //*
    //* If this window is the child of a window that includes a task list,
    //*   and this window requires initial data in addition to that required
    //*   for window handle tracking, set up the incoming initial data as
    //*   in the following example.
    //* NOTE: There are two fields required for window handle tracking.
    //*       1.  HWND Parent;
    //*       2.  char *Key;
    //*       If this window requires no other initial data, do not declare
    //*         an incoming initial data structure.
    //*
    /*
    typedef struct zWin1InitialDataStructure {
        HWND Parent;
        char *Key;
        //*  YOUR STUFF
        } _WIN1_INITIAL_DATA;

    _WIN1_INITIAL_DATA *pWin1InitialData;
    */

    //*
    //* Initialize Window Context Data Architecture variables.
    //*
    memset(&(WCD_ArchData), 0, sizeof(_ARCHDATA));

    //*
    //* Initialize CmnErrBlock
    //*
    CMN_INIT_ERR_BLK

    CMN_FORMAT_ERR_BLK("WINPRDIS", "AZCD004X")

    //*
    //* Initialize the Architecture Window Handle Tracking Array.
    //*
    CMN_INIT_WIN_HWND_TRACK(CMN_NO)
    WCD_ArchData.WnMsgType = CMN_MSG_WIN_CLOSE_AFTER_CANCEL;

    //*
    //* Callback Logic
    //*



    return (CMN_CALLBACK_RC);

}   //* End WINPRDIS


