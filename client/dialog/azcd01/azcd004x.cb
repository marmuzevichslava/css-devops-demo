        Initialize CmnErrBlock with WINPRDES
    */ 
    CMN_UPDATE_CB_IN_ERR_BLK("WINPRDES")

    /*
        Cleanup the Window Handle Tracking List
    */ 
    CMN_FREE_WIN_HWND_TRACK(CMN_NO)


    /*
        Callback Logic
    */ 


    /*
        Free memory allocated for this window's error block.
    */ 
    free(pCmnErrBlock);
    return (CMN_CALLBACK_RC);

} /* End WINPRDES */



/*  Begin Source Code Section ***********************************************
                     Pushbutton and Menu Event Callbacks                    *
*****************************************************************************/

static WCBPROC (APBOK)
/****************************************************************************
   
        Control/Events which call this callback:
   
                     OKPB_CMD - CLICK
   
   
     Description: Enter description for APBOK
   
*****************************************************************************/
{
    /* 
        Local Variable Declarations
    */
    short    rc=0;
    _ERR_MSG_INIT_DATA ErrMsgInitData;
    _CODE_PARM_BLOCK CodeParmBlock;
    _ERR_MSG_TABLE ErrMsgTbl;
    _ERR_CODE_KEY StrtKey;
    short i=0;
    char Msg[100];


    /* 
        Initialize CmnErrBlock with APBOK
    */ 
    CMN_UPDATE_CB_IN_ERR_BLK("APBOK")


    /* 
        Callback Logic
    */ 

    /* 
          Validate Message Entered does not exists
    */ 
    /* 
         Initialize the Codes Table Parm Block
    */ 

    StrtKey.ErrMsgNum = KyErrorMessageData;
    StrtKey.Lang='E';
    strncpy(StrtKey.SeqNum,"001",_SEQ_NUM_LEN);

    memset(&CodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));

    memcpy(&CodeParmBlock.Code_Parm_Block_Version,
           FND_CTS_VER,
           _VER_LEN);

    memcpy(&CodeParmBlock.Code_Function_Code,
           _CTIO_GET_UNIQUE,
           _CTS_FUNCTION_LEN);

    memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_Id,
           ERROR_CODE_TABLE,
           _CTB_TABLE_LEN);

    memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_User_Key,
           &StrtKey,
           sizeof(_ERR_CODE_KEY));

    CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Requested=1;

    /*
          Retrieve the error messages from the codes table
    */

    WFNDCODE(&CodeParmBlock, pABHI, &ErrMsgTbl);


    /*
          If message already exists... ask if user wishes to browse message
             else create window AZCD003X for add.
    */
    if (CodeParmBlock.Code_Explanation_Code == FND_SUCCESS)
    {
       sprintf(Msg,
           "Error message %u already exists... Do you wish to browse it?",
           KyErrorMessageData);
       rc=FpsDisplayChoiceBoxText(CBI_hwnd,
                                  Msg,
                                  "SORRY",
                                  FPS_YESNO|FPS_QUERY,
                                  FPS_DEFBUTTON1);
       if (rc==FPSID_YES)
       {
          ErrMsgInitData.ErrMsgPassed = KyErrorMessageData;
          rc=CmnCreateWindow("CDINQWIN",AZCD002XID,NULL,&ErrMsgInitData,pCmnErrBlock);
       }
    }
    else
    {
       if (CodeParmBlock.Code_Explanation_Code == CTS_KEY_NOT_FOUND)
       {
          ErrMsgInitData.ErrMsgPassed = KyErrorMessageData;
          ErrMsgInitData.ErrMsgAction = 'A';
          rc=CmnCreateWindow("CDUPDWIN",AZCD003XID,NULL,&ErrMsgInitData,pCmnErrBlock);
          rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
       }
       else
       {
          sprintf(Msg,
             "Unknown Error while validating error message number: %u"
             ".  Please see the FCP TRG error message section for the"
             " meaning of this error",
             CodeParmBlock.Code_Explanation_Code);
          rc=FpsDisplayChoiceBoxText (CBI_hwnd,
                                      Msg,
                                      "ERROR!",
                                      FPS_OK|FPS_WARNING,
                                      FPS_DEFBUTTON1);
          rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
       }
    }

    return (CMN_CALLBACK_RC);

} /* End APBOK */


