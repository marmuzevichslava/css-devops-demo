        Local Variable Declarations
    */
    CMN_VARDECL_MSG_RECV


    /* 
        Dereference CBI_pMSGParmBlock
    */ 
    pMsgPB = (_MSG_PARM_BLOCK *) CBI_pMSGParmBlock;


    /* 
        Initialize CmnErrBlock with WINMSGNT
    *  
    CMN_UPDATE_MSGNOTF_IN_ERR_BLK("WINMSGNT", pMsgPB)



    /* 
        Callback Logic
    */

    return (CMN_CALLBACK_RC);

} /* End WINMSGNT */


static WCBPROC (WINPRDES)
/****************************************************************************
   
        Control/Events which call this callback:
   
                     WINDOW - PREDESTROY
   
   
