/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : ATDW001BusPredisplay
**
**  DESCRIPTION      : This function handles any predisplay processing for
**                      window ATDW001.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : malloc
**                     ATDW001BusOpenPipe
**                     ATDW001BusReadPipe
**                     ATDW001BusFillMsgBox
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/10/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/10/93  C. Crampton           Original code.
**
**    12/07/93  C. Crampton           Added Semaphore DosSemClear for each semaphore type.
**
**    01/19/94  C. Crampton           Added call to CmnWindowDataModNotReqd to Predisplay.
**
**    08/04/95  CWoods                Hide menu option 'Print to Printer'.
**									  This option is no longer valid.
***************************************************************************/

WCBPROC( ATDW001BusPredisplay )
 {

   _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT usSelectedButton;

  /*
  ** Set this window to not modifiable
  */

  CmnWindowDataModNotReqd( CMN_ARCH_PARMS );

  /*
  ** Allocate space for the BFCD data structure
  */

  pBFCD->pCSRDiagBFCD = malloc(sizeof(_AZCD01Global));

  if ( pBFCD->pCSRDiagBFCD == NULL )
  {
     FndMsgBoxDisplayText( "Unable to allocate memory for BFCD ...",
                           NULL,
                           CBI_hwnd,
                           FND_MSGBOX_OK,
                           FND_MSGBOX_ERROR,
                           FND_MSGBOX_IDOK,
                           CSR_DIAG_APPL_NAME,
                           &usSelectedButton,
                           &FndGenErrorBlock );

      return( CMN_FAIL );
   }

   /*
   ** Initialize BFCD to zeros
   */
   memset( pBFCD->pCSRDiagBFCD, 0, sizeof( _AZCD01Global ));

   /* Initialize flag for CSRPipe to true */
   BFCD_AZCD01->CSRPipeConnected=TRUE;


   /*
   ** Tell the CSR to go into debug mode
   */
   FndGenRC = ATDW001BusOpenPipe( CSR_DEBUG, CMN_ARCH_PARMS);

   if ( FndGenRC != CMN_SUCCESS )
   {
     FndWindowDestroy( CBI_hwnd,
                      &FndGenErrorBlock );

     return( CMN_FAIL );
   }

   /*
   ** Default the directory name for the log files
   */
   strcpy( BFCD_AZCD01->szLogDirName,"C:\\DATA\\MAPS" );


   return CMN_SUCCESS;
 }  /* end of function ATDW001BusPredisplay */



