/****************************************************************************
*
*    FUNCTION: PrintToFile(HWND)
*
*    PURPOSE:  Invokes the common dialog function to save the current
*              buffer to a file.
*    COMMENTS:
*
*        This function initializes the OPENFILENAME structure for any
*        standard mode selected by the user.
*        It then calls the GetSaveFileName()
*        common dialog function.
*
*    RETURN VALUES:
*        TRUE - The file was saved successfully.
*        FALSE - The buffer was not saved to a file.
*
*    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
*    --------  -----------  -------  -------------------------------------
*    08/01/95  CWoods                Original Code - Modified from NT Example
*
****************************************************************************/
BOOL PrintToFile( HWND hWnd, CMN_ARCH_PARM_TYPES )
{
  HANDLE       hInst;
    CHAR        File[256]      = "\0";
  CHAR         FileTitle[256];
  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT       FndGenRC = 0;
  USHORT       SelectedButton;

// Filter specification for the OPENFILENAME struct
// This is portable for i386 and MIPS
// Leaving out the \0 terminator will cause improper DWORD alignment
// and cause a failure under MIPS
   CHAR Filter[] = "Text Files (*.TXT)\0*.TXT\0All Files (*.*)\0*.*\0";


   strcpy( File, "");
   strcpy( FileTitle, "");

   /* Populate structure that is used by the Window NT 'Save' Dialog box */
   OpenFileName.lStructSize       = sizeof(OPENFILENAME);
   OpenFileName.hwndOwner         = hWnd;
   OpenFileName.hInstance         = (HANDLE) hInst;
   OpenFileName.lpstrFilter       = Filter;
   OpenFileName.lpstrCustomFilter = (LPSTR) NULL;
   OpenFileName.nMaxCustFilter    = 0L;
   OpenFileName.nFilterIndex      = 1L;
   OpenFileName.lpstrFile         = File;
   OpenFileName.nMaxFile          = sizeof(File);
   OpenFileName.lpstrFileTitle    = FileTitle;
   OpenFileName.nMaxFileTitle     = sizeof(FileTitle);
   OpenFileName.lpstrInitialDir   = NULL;
   OpenFileName.lpstrTitle        = "Print to File";
   OpenFileName.nFileOffset       = 0;
   OpenFileName.nFileExtension    = 0;
   OpenFileName.lpstrDefExt       = "txt";
   OpenFileName.lCustData         = 0;
   OpenFileName.Flags = 0L;
   OpenFileName.lpfnHook = (LPOFNHOOKPROC)(FARPROC)NULL;
   OpenFileName.lpTemplateName = (LPSTR)NULL;
   
   /* Call GetSaveFileName to invoke Save dialog box - Pass OpenFileName structure */ 
   if (GetSaveFileName( &OpenFileName ) )
   {
       /* Call SaveToFile function to save listbox data to filename user entered */
       if (SaveToFile( hWnd, CMN_ARCH_PARMS ) != CMN_SUCCESS)
       {
  	        return CMN_FAIL;
       }
   }
   else
   {
       ULONG ReturnCode = 0;

       /* CommDlgExtendedError returns 0 if the user decides to cancel */
	   if ((ReturnCode = CommDlgExtendedError() ) != 0)
	   {
           FndMsgBoxDisplayText(  "An error occurred invoking the 'Save As' window",
                                  NULL,
                                  CBI_hwnd,
                                  FND_MSGBOX_OK,
                                  FND_MSGBOX_ERROR,
                                  FND_MSGBOX_IDOK,
                                  CSR_DIAG_APPL_NAME,
                                  &SelectedButton,
                                  &FndGenErrorBlock );
	   }

   }
			
 
   return CMN_SUCCESS;
}

/****************************************************************************
*
*    FUNCTION: SaveToFile( HWND )
*
*    PURPOSE:  Saves the listbox data to the file specified in OpenFileName 
*              structure.
*
*    COMMENTS:
*
*        This function will save the current text buffer into the file
*        specified from the GetSaveFileName() common dialog function.
*
*    RETURN VALUES:
*        TRUE - The file was saved successfully.
*        FALSE - The buffer was not saved to a file.
*
*    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
*    --------  -----------  -------  -------------------------------------
*    08/01/95  CWoods                Original Code - Modified from NT Example
*
****************************************************************************/
BOOL SaveToFile( HWND hWnd, CMN_ARCH_PARM_TYPES )
{
    _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT           FndGenRC = 0;   

  CHAR             ErrorMsg[255];
  CHAR             Title[80];
  time_t           CurrentTime;
  FILE             *fhndFilePtr;
  USHORT           Index;
  BOOL             More=TRUE;
  _TranscriptLBRow ListBox;
  SHORT            SelectedButton;

   /* open Filename for write access */
   if ( (fhndFilePtr = fopen((CHAR *) OpenFileName.lpstrFile, "w") ) == NULL)
   {
      sprintf( ErrorMsg, "Could not create file %s", OpenFileName.lpstrFile );

      FndMsgBoxDisplayText(  ErrorMsg,
                             NULL,
                             CBI_hwnd,
                             FND_MSGBOX_OK,
                             FND_MSGBOX_ERROR,
                             FND_MSGBOX_IDOK,
                             CSR_DIAG_APPL_NAME,
                             &SelectedButton,
                             &FndGenErrorBlock );
      return CMN_FAIL;
   }

   /*
  ** Get the title of the list box to use as a heading on the printout
  */

  FndLstBoxTitleQuery( CBI_hwnd,
                       "TranscriptLB",
                       sizeof( Title ),
                       Title,
                       &FndGenErrorBlock );

  /*
  ** Tell the user whats going on, whats going on
  */

  sprintf( ErrorMsg,
           "Saving CSR Messages to file %s",
            OpenFileName.lpstrFile );

  FndMsgBoxDisplayMdlssText( ErrorMsg,
                             "PrintMsgBox",
                             CBI_hwnd,
                             FND_MSGBOX_NOBUTTONS,
                             FND_MSGBOX_INFORMATION,
                             FND_MSGBOX_IDNOBUTTON,
                             CSR_DIAG_APPL_NAME,
                             &FndGenErrorBlock );

  /* Set error message in box because it did not display correctly */		     
  FndMsgBoxSetText("PrintMsgBox",
				   ErrorMsg,
	               &FndGenErrorBlock);
  /*
  ** Write out a heading with
  */

   FndGenRC = fprintf( fhndFilePtr,"%s\n",Title );
   time( &CurrentTime );
   FndGenRC = fprintf( fhndFilePtr,"%s\n\n",ctime( &CurrentTime ));

  /*
  ** Loop thru the list box and read each line.
  **  Then write it out to the file.
  */

  Index = 0;
  More  = TRUE;

  while ( More )
  {
     CmnErrOverrides( NULL,
                      CMN_OVERRIDE_FATAL,
                      CMN_ERR_LOGGING_DEFAULT,
                      CMN_RC_CONTINUE_PROCESSING,
                      CMN_ARCH_PARMS );

     FndLstBoxRowQueryData( CBI_hwnd,
                            "TranscriptLB",
                            Index,
                            sizeof( _TranscriptLBRow ),
                            &ListBox,
                            &FndGenErrorBlock );

     if ( FndGenRC != FND_SUCCESS && FndGenRC != LBOX_ROW_EMPTY )
     {
        return( CMN_FAIL );
     }
     else if ( FndGenRC == LBOX_ROW_EMPTY )
     {
        More = FALSE;
     }
     else
     {
	    
        FndGenRC = fprintf( fhndFilePtr,"%s\n",ListBox._TranscriptLBDataBufferData );
        Index++;
     }

  } /* end of while more rows in list box */

  
  FndGenRC = CmnOsSleep( 2000L, CMN_ARCH_PARMS );


  FndMsgBoxDestroy( "PrintMsgBox",
                    &FndGenErrorBlock );

  

   // close the file
   fclose( fhndFilePtr );

   return CMN_SUCCESS;
}


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : ATDW001BusAmnprntpClick
**
**  DESCRIPTION      : This function handles printing of the error messages
**                      to the printer.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 08/10/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    08/10/93  C. Crampton              Original code.
**
***************************************************************************/

WCBPROC( ATDW001BusAmnprntpClick )
 {

  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC = 0;

  FILE *fhndFilePtr;
  char szErrorMsg[255];
  char szTitle[80];
  USHORT usIndex;
  BOOL bMore=TRUE;
  _TranscriptLBRow ListBox;
  USHORT usSelectedButton;
  time_t tCurrentTime;
  int nPad=43;

  
/*
** Open a file handle for the printer
*/


   fhndFilePtr = fopen("LPT1", "w");

   if (fhndFilePtr == NULL)
   {
      strcpy(szErrorMsg, "Unable to open connection to network printer.");

      FndMsgBoxDisplayText( szErrorMsg,
                            NULL,
                            CBI_hwnd,
                            FND_MSGBOX_OK,
                            FND_MSGBOX_ERROR,
                            FND_MSGBOX_IDOK,
                            CSR_DIAG_APPL_NAME,
                            &usSelectedButton,
                            &FndGenErrorBlock );
      return( CMN_FAIL );
   }
/*
** Set the printer to landscape mode
*/


//  FndGenRC = fprintf( stdprn, SET_LANDSCAPE);
  FndGenRC = fprintf( fhndFilePtr, SET_LANDSCAPE );

/*
** Get the title of the list box to use as a heading on the printout
*/

  FndLstBoxTitleQuery( CBI_hwnd,
                       "TranscriptLB",
                       sizeof( szTitle ),
                       szTitle,
                       &FndGenErrorBlock );


/*
** Tell the user whats going on, whats going on
*/

  sprintf(szErrorMsg, "Printing %s ", szTitle);
  FndMsgBoxDisplayMdlssText( szErrorMsg,
                             "PrintMsgBox",
                             CBI_hwnd,
                             FND_MSGBOX_NOBUTTONS,
                             FND_MSGBOX_INFORMATION,
                             FND_MSGBOX_IDNOBUTTON,
                             CSR_DIAG_APPL_NAME,
                             &FndGenErrorBlock );

/*
** Print out a heading with Normal font
*/
 nPad = ( 106 - strlen( szTitle )) / 2;
 FndGenRC = fprintf( fhndFilePtr,"%*c%s\n",' ', nPad, szTitle );

 time( &tCurrentTime );
 nPad = (106 - strlen(ctime(&tCurrentTime)) ) / 2;
 FndGenRC = fprintf(fhndFilePtr,"%*c%s\n\n",' ',nPad ,ctime(&tCurrentTime));

/*
** Set the font to line printer (smaller font)
*/

  FndGenRC = fprintf( fhndFilePtr, LINE_PRINTER );

/*
** Set the line spacing to smaller
*/

  FndGenRC = fprintf( fhndFilePtr, VMI );


/*
** Loop thru the list box and read each line.
**  Then write it out to the printer.
*/

 usIndex = 0;
 bMore = TRUE;

 while ( bMore )
 {
    CmnErrOverrides( NULL,
                     CMN_OVERRIDE_FATAL,
                     CMN_ERR_LOGGING_DEFAULT,
                     CMN_RC_CONTINUE_PROCESSING,
                     CMN_ARCH_PARMS );

    FndLstBoxRowQueryData( CBI_hwnd,
                           "TranscriptLB",
                           usIndex,
                           sizeof( _TranscriptLBRow ),
                           &ListBox,
                           &FndGenErrorBlock );

  if ( FndGenRC != FND_SUCCESS && FndGenRC != LBOX_ROW_EMPTY )
  {
      return( CMN_FAIL );
  }
  else if ( FndGenRC == LBOX_ROW_EMPTY )
  {
      bMore = FALSE;
  }
  else
  {
      fprintf(fhndFilePtr, "%s\n", ListBox._TranscriptLBDataBufferData);
      usIndex++;
  }
  } /* end of while more rows in list box */

/*
** reset the printer to defaults
*/

  FndGenRC = fprintf(fhndFilePtr, RESET_PRINTER);
/*
** Close the file handle to the printer
*/
  fclose(fhndFilePtr);

/*
** Take it easy for awhile to let the user read the message box.
** Then kill it.
*/

  FndGenRC = CmnOsSleep(2000L, CMN_ARCH_PARMS);

  FndMsgBoxDestroy( "PrintMsgBox",
                    &FndGenErrorBlock );
  return CMN_SUCCESS;

 } /* end of function ATDW001BusAmnprntpClick */



