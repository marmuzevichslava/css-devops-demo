/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : ATDW001BusWindowClose
**
**  DESCRIPTION      : This function notifies the CSR that the CSR diagnostic
**                       window application is terminating.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 10/06/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    10/06/93  C. Crampton              Original code.
**
***************************************************************************/


WCBPROC (ATDW001BusWindowClose)
{
   USHORT usRC;
   USHORT usCounter;

   USHORT FndGenRC = 0;

/*
** Tell the CSR to get out of debug mode. Do not send any more messages
*/
   if (BFCD_AZCD01->CSRPipeConnected )
   {
       usRC = ATDW001BusOpenPipe(CSR_NODEBUG, CMN_ARCH_PARMS );
   }

   /*
   ** Free the memory for the Request Detail Messages
   */
   if ( BFCD_AZCD01->pRequestBlock )
   { 
       MEMFree( BFCD_AZCD01->pRequestBlock);
       fclose( BFCD_AZCD01->fptrRequestLog );
       BFCD_AZCD01->fptrRequestLog = NULL;
       strcpy( BFCD_AZCD01->szRequestLogName, "" );
   }

   for ( usCounter = 0; usCounter < BFCD_AZCD01->usNumServices; usCounter++ )
   {
       MEMFree( BFCD_AZCD01->Service[usCounter].pServiceBlock );
       fclose( BFCD_AZCD01->Service[usCounter].fptrServiceLog );
       BFCD_AZCD01->Service[usCounter].fptrServiceLog = NULL;
       strcpy( BFCD_AZCD01->Service[usCounter].szServiceLogName,"" );
   }


return(CMN_SUCCESS);
} /* end of function ATDW001BusWindowClose */



