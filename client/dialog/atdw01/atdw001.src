/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Epmicwrn3751_Field_Change
 * 
 *   WidgetName:    MsgLevel
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Epmicwrn3751_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

FndGenRC = ATDW001BusRBFldChg( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if ( MsgLevelData == LT_Service )

   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "ServicesLB",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "REQUESTID",
                             &FndGenErrorBlock);

   } /* end if */

if ( MsgLevelData == LT_Request )

   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "REQUESTID",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "ServicesLB",
                             &FndGenErrorBlock);

   } /* end if */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
