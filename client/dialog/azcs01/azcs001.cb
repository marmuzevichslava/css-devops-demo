/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001ChangeRPMH
**
**  DESCRIPTION      : This function changes the indexes for the Repeating Map
**                       relationship table.
**
**  INPUTS           : sServ - The current services index
**
**                     sIndex - Index to services saved relationship tables.
**
**                     sNewReposIx - Index to the services repository tables.
**
**                     pSTDParms - pointer to the standard parms data structure.
**                         This includes a pointer to BFCD and the calling programs window
**                         handle.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : FindFullName
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/15/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
**	03/22/96  mconner               Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001ChangeRPMH( SHORT sServ,
                  SHORT sIndex,
                  SHORT sNewReposIx,
                  _STDParms *pSTDParms )

{
    USHORT MsgID=0;
    SHORT FndGenRC;
    SHORT sClientx;
    SHORT sNewClientIndex;
    SHORT sNumTimes;
    CHAR MsgData[255];
    CHAR ClientName[255];
    CHAR ServiceName[255];
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _BFCD * pBFCD;
    HWND hwnd;

    /* Assign the input parameters to local variables */
    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    /* Assign BFCD variables to local variables for easier reading */
    pSavedLayout = pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable;

    /*
     * Copy the saved data using the old index to the new table
     * using the new index
     */
    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pRepeatingMaps[sNewReposIx] =
      pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedRepeatingMaps[sIndex];

    /* If a relationship exists see what the client indexes are */
	/*mdc 01/27/97 added single occurrence condition.  At this point
	some groups have 'Y' in their pRepeatingMaps structure although they no
	longer have occurring groups that are mapped.
	*/

    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
         pSavedRepeatingMaps[sIndex].ClientLayoutIndex > 0 || 
         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedRepeatingMaps[sIndex].
         SingleOccurence == 'Y')
    {
        /* Make sure the number of Occurs has not changed */
        /* If so and a relationship exists drop relationship and notify user */

        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pServiceLayoutTable[sIndex].ItemOccurs !=
            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pReposServiceLayoutTable[sNewReposIx].ItemOccurs )
        {
            sprintf( MsgData,                               /* 255 */
                     "The number of occurences for Group %s has changed !",
                     BuildFullName( sIndex,
                                    pBFCD->pCSRMapBFCD->
                                           ServiceInfoTable[sServ].
                                           pServiceLayoutTable) ); /* 70 */

            MsgID = CMN_MAPGEN_MSG_WARN;

            FndGenRC = LogMsg( MsgID, MsgData );

            sprintf( MsgData,                               /* 255 */
                     "Dropping relationships for Group %s.",
                     BuildFullName(sIndex,
                                   pBFCD->pCSRMapBFCD->
                                          ServiceInfoTable[sServ].
                                          pServiceLayoutTable) ); /* 70 */


            MsgID = CMN_MAPGEN_MSG_WARN;

            FndGenRC = LogMsg( MsgID, MsgData );

            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pRepeatingMaps[sNewReposIx].ClientLayoutIndex = -1;
 
		    /*mdc 01/28/97 added to remove occurrence data from the BFCD for this
			item
			*/
			if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pReposServiceLayoutTable[sNewReposIx].ItemOccurs <= 1)
			{
				pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedRepeatingMaps[sIndex].
                                SingleOccurence = 'N';
			}



            /*mdc 01/27/97 changed return
            return(CMN_FAIL);   */
            return(CMN_SUCCESS);
        }

        sClientx = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pSavedRepeatingMaps[sIndex].ClientLayoutIndex;

        /* Find the new Client index */
        sNumTimes = FindFullName(sClientx,
                                 pSavedLayout,
                                 pReposLayout,
                                 pBFCD->pCSRMapBFCD->ClientInfo.
                                        NumReposClientRows,
                                 &sNewClientIndex );

        switch(sNumTimes)
        {
            case 0:
            {
                sprintf( MsgData,                               /* 255 */
                         "Client Group %s no longer exists in the "
                         "repository layout. "
                         "Any previous relationships will be dropped",
                         BuildFullName(sClientx, pSavedLayout) );  /* 70 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                FndGenRC = LogMsg( MsgID, MsgData );

                Azcs001DropClient(sClientx, sServ, 5, pSTDParms);

                /*mdc removed return and added break
                return(CMN_FAIL);                   */
                break;

            } /* end of case 0 */

            case 1:
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                     pRepeatingMaps[sNewReposIx].ClientLayoutIndex =
                                                           sNewClientIndex;

                strncpy( ClientName,
                         BuildFullName(sClientx, pSavedLayout),
                         sizeof( ClientName ));

                strncpy( ServiceName,
                         BuildFullName( sIndex,
                                        pBFCD->pCSRMapBFCD->
                                               ServiceInfoTable[sServ].
                                               pServiceLayoutTable ),
                         sizeof( ServiceName ));

                sprintf(MsgData,                        /* 255 */
                        "Remapping RPMH Relationship between Client "
                        "Group %s and Service Group %s.",
                        ClientName ,                    /* 255 */
                        ServiceName );                  /* 255 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                FndGenRC = LogMsg( MsgID, MsgData );

                break;

            } /* end of case 1 */

        } /* end of switch */

    } /* end of if a relationship is defined */


    return (CMN_SUCCESS);

} /* end of function Azcs001ChangeRPMH */



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001DropClient
**
**  DESCRIPTION      : This function drops any relationships that involved this
**                      client index. It only searches the tables defined by the process argument.
**
**  INPUTS           : sClientx - Client saved index to drop.
**                     sServ - Service index.
**                     Process - Flag of which tables to process (i.e. LK, CK)
**                     pSTDParms - pointer to STDParms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : FindFullName
**                     Azcs001DropClientLK
**                     Azcs001DropClientCK
**                     Azcs001DropClientLD
**                     Azcs001DropClientRD
**                     Azcs001DropClientRPMH
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/08/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
**	03/22/96   mconner              Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001DropClient( SHORT sClientx,
                  SHORT sServ,
                  SHORT Process,
                  _STDParms *pSTDParms )
{
    USHORT MsgID=0;
    SHORT FndGenRC;
    SHORT sNumTimes;
    SHORT sIndex;
    SHORT sNewServIndex;
    _BFCD * pBFCD;
    HWND hwnd;


    pBFCD = pSTDParms->pBFCD;
    hwnd  = pSTDParms->hwnd;

    /* Loop thru each row of the relationships tables */
    for ( sIndex = 0;
          sIndex < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                          NumServiceRows;
          sIndex++ )
    {
        /* Find the repository index for this service row */

        sNumTimes = FindFullName( sIndex,
                                  pBFCD->pCSRMapBFCD->
                                      ServiceInfoTable[sServ].
                                      pServiceLayoutTable,
                                  pBFCD->pCSRMapBFCD->
                                      ServiceInfoTable[sServ].
                                      pReposServiceLayoutTable,
                                  pBFCD->pCSRMapBFCD->
                                      ServiceInfoTable[sServ].
                                      NumReposServiceRows,
                                  &sNewServIndex );
        /*
         * If the service does not exist in the repository just
         * skip this row.
         */
        if ( sNumTimes == 0 )
        {
            continue;
        }

        /* Do any load keys exist */
        if ( Process == 1 && pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pLoadKeys )
        {
            /* Does the argument index match the saved client layout index */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pSavedLoadKeys[sIndex].ClientLayoutIndex == sClientx )
            {
                FndGenRC = Azcs001DropClientLK( sServ,
                                         sIndex,
                                         sNewServIndex,
                                         pSTDParms );

            } /* end of if a relationship is defined */

        } /* End of Load Keys logic */

        /* Do any compare keys exist */
        if( Process == 2 &&
            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pCompareKeys )
        {
            /* Does the argument index match the saved client layout index */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                pSavedCompareKeys[sIndex].ClientLayoutIndex == sClientx )
            {
                FndGenRC = Azcs001DropClientCK( sServ,
                                         sIndex,
                                         sNewServIndex,
                                         pSTDParms );

            } /* end of if a relationship is defined */

        } /* End of Compare Keys logic */

        /* Do any load data relationships exist */
        if ( Process == 3 &&
             pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadData )
        {
            /* Does the argument index match the saved client layout index */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                pSavedLoadData[sIndex].ClientLayoutIndex == sClientx )
            {
                FndGenRC = Azcs001DropClientLD( sServ,
                                         sIndex,
                                         sNewServIndex,
                                         pSTDParms );

            } /* end of if a relationship is defined */

        } /* End of Load Data logic */

        /* Do any return data relationships exist */
        if( Process == 4 &&
            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pReturnData )
        {
            /* Does the argument index match the saved client layout index */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                pSavedReturnData[sIndex].ClientLayoutIndex == sClientx )
            {
                FndGenRC = Azcs001DropClientRD( sServ,
                                         sIndex,
                                         sNewServIndex,
                                         pSTDParms );
            }    /* end of if a relationship is defined */

        }  /* End of Return Data logic */

        /* Do any Repeating Map relationships exist */
        if( Process == 5 &&
            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pRepeatingMaps )
        {
            /* Does the argument index match the saved client layout index */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                pSavedRepeatingMaps[sIndex].ClientLayoutIndex == sClientx )
            {
                FndGenRC = Azcs001DropClientRPMH( sServ,
                                           sIndex,
                                           sNewServIndex,
                                           pSTDParms );
            }    /* end of if a relationship is defined */

        }  /* End of Return Data logic */

    } /* End of for loop for each row */


    return CMN_SUCCESS;

} /* End of function Azcs001DropClient */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001DropClientLK
**
**  DESCRIPTION      : This function does the actual details of dropping a relationship.
**                      It initializes all varaibles in the relationship data structure.
**                      Also it posts the message to the message box.
**
**  INPUTS           : sServ - Service index.
**                     sIndex - Saved layout index.
**                     sNewServIndex - Repository layout index.
**                     pSTDParms - Pointer to STDParms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/08/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
**  03/22/96  mconner               Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001DropClientLK( SHORT sServ,
                    SHORT sIndex,
                    SHORT sNewServIndex,
                    _STDParms *pSTDParms )
{
    CHAR MsgData[255];
    CHAR ClientName[255];
    CHAR ServiceName[255];
    USHORT MsgID=0;
    USHORT FndGenRC = 0;
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _BFCD * pBFCD;
    HWND hwnd;


    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    pSavedLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                          pServiceLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                          pReposServiceLayoutTable;

    strncpy( ClientName,
             BuildFullName( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                                    pSavedLoadKeys[sIndex].ClientLayoutIndex,
                            pBFCD->pCSRMapBFCD->ClientInfo.
                                    pClientLayoutTable),
             sizeof( ClientName ));

    strncpy( ServiceName,
             BuildFullName( sIndex,
                            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                                   pServiceLayoutTable ),
             sizeof( ServiceName ));

    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
           pLoadKeys[sNewServIndex].ClientLayoutIndex = -1;
    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
           pLoadKeys[sNewServIndex].LiteralUsed = 'N';

    strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                    pLoadKeys[sNewServIndex].LiteralValue,
             "",
             sizeof ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      pLoadKeys[sNewServIndex].LiteralValue));

    sprintf( MsgData,                               /* 255 */
             "Dropping LK Relationship between Client Element %s and "
             "Service Element %s",
             ClientName,                            /* 255 */
             ServiceName );                         /* 255 */

    MsgID = CMN_MAPGEN_MSG_WARN;

    FndGenRC = LogMsg( MsgID, MsgData );


    return CMN_SUCCESS;

} /* end of function Azcs001DropClientLK */

