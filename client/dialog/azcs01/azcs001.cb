/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : OpnAZCS2
**
**  DESCRIPTION      : This function creates window 2.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/14/94  J. Looney             Clean up.
**
***************************************************************************/
static WCBPROC(OpnAZCS2)
{

    CHAR WindowName[]   = "AZCS002";
    CHAR InstanceName[] = "REQUEST";
    SHORT nRC      = CMN_SUCCESS;
    SHORT FndGenRC = CMN_SUCCESS;
    USHORT usSelectedButton;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _REQUESTINFO DummyInput;

    HEAP_CHECK

    /* Check the ChangeFlag to see if changes have been made to the
     * current map
     */
    if (pBFCD->pCSRMapBFCD->ChangeFlag == 'Y')
    {
        FndGenRC = FndMsgBoxDisplayText( "The Current map has changed !\n\n"
                                         "Do you want to save it ?",
                                         NULL,
                                         CBI_hwnd,
                                         FND_MSGBOX_YESNO,
                                         FND_MSGBOX_QUERY,
                                         FND_MSGBOX_IDYES,
                                         CMN_MAPGEN_NAME,
                                         &usSelectedButton,
                                         &FndGenErrorBlock );

        /* Save Map */
        if ( usSelectedButton == FND_MSGBOX_IDYES )
        {
            FndGenRC = AZCS001BusAmnSaveClk( pEventInfo,
                                             pEAIA,
                                             pBFCD,
                                             pWesMap,
                                             pWindContextData,
                                             pABHI );

            pBFCD->pCSRMapBFCD->ChangeFlag = 'N';
        } /* Save Map */

    } /* end of if:  Changes were made to map */

    /* Create the Open Request Information window */
    nRC = CmnWindowCreate( WindowName,
                           InstanceName,
                           NULL,
                           &DummyInput,
                           CMN_ARCH_PARMS );

    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of OpnAZCS2 */

