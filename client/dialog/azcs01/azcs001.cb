/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : InitErrorFile
**
**  DESCRIPTION      : This function opens the gloal error file for mass
**                     generation.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : M. Conner
**
**  DATE CREATED     : 11/21/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/21/96  mconner               Created
**
***************************************************************************/
USHORT InitErrorFile( CMN_ARCH_PARM_TYPES )
{
    USHORT FndGenRC = CMN_SUCCESS;
    CHAR sErrorFileNm[_CSR_MAP_FILENAME_LEN];
    int rc = 0;
    struct _stat buf;
    CHAR szErrorMsg[255];
    USHORT usSelectedButton;
    _FND_ERROR_BLOCK ErrorBlock;


    memset( sErrorFileNm, 0, _CSR_MAP_FILENAME_LEN);
    memset( szErrorMsg, 0, 255);
  
    FndGenRC = CmnStrCat( CMN_ARCH_PARMS,
                          sErrorFileNm,
                          _CSR_MAP_FILENAME_LEN,
                          3,
                          BFCD_pCSRMapBFCD->CsrMapGenPath,
                          "\\",
                          ERR_FILE_NM );
    
   
    rc = _stat(sErrorFileNm, &buf);
    if( rc == 0 )
    {
        sprintf(szErrorMsg, "The Mass Generation Error File,\n"
                            "%s, already exists in \n%s!\n\n"
                            "Replace it?", ERR_FILE_NM,
                            BFCD_pCSRMapBFCD->CsrMapGenPath);

         FndMsgBoxDisplayText( szErrorMsg,
                                         NULL,
                                         CBI_hwnd,
                                         FND_MSGBOX_YESNO,
                                         FND_MSGBOX_WARNING,
                                         FND_MSGBOX_IDYES,
                                         CMN_MAPGEN_NAME,
                                         &usSelectedButton,
                                         &ErrorBlock );
         
         if ( usSelectedButton != FND_MSGBOX_IDYES )
         {
             return CMN_FAIL;
         }
    }


    fpError = fopen(sErrorFileNm, "w" );

    if (fpError == NULL)
    {
        sprintf(szErrorMsg, "The Mass Generation Error File,\n"
                            "%s, could not be opened in \n"
                            "%s", ERR_FILE_NM, 
                             BFCD_pCSRMapBFCD->CsrMapGenPath);

         FndMsgBoxDisplayText( szErrorMsg,
                                         NULL,
                                         CBI_hwnd,
                                         FND_MSGBOX_OK,
                                         FND_MSGBOX_ERROR,
                                         FND_MSGBOX_IDOK,
                                         CMN_MAPGEN_NAME,
                                         &usSelectedButton,
                                         &ErrorBlock );
         return CMN_FAIL;
    }

 
    return CMN_SUCCESS;
}/*End of InitErrorFile()*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : InitCompLog
**
**  DESCRIPTION      : This function opens the log file for mass
**                     generation.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : M. Conner
**
**  DATE CREATED     : 11/21/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/21/96  mconner               Created
**
***************************************************************************/
USHORT InitCompLog( CMN_ARCH_PARM_TYPES, char * sCsmNm )
{
    USHORT FndGenRC = 0;
    CHAR sLogFileNm[_CSR_MAP_FILENAME_LEN];
    CHAR szErrorMsg[255];

    memset( sLogFileNm, 0,  _CSR_MAP_FILENAME_LEN );
    memset( szErrorMsg, 0, 255 );
  
    FndGenRC = CmnStrCat( CMN_ARCH_PARMS,
                          sLogFileNm,
                          _CSR_MAP_FILENAME_LEN,
                          5,
                          BFCD_pCSRMapBFCD->CsrMapGenPath,
                          "\\",
                          sCsmNm,
                          ".",
                          CSR_MAP_MASS_GEN_LOG_EXT);
    
   


    fpLog = fopen(sLogFileNm, "w" );

    if (fpLog == NULL)
    {
        sprintf(szErrorMsg, "The Mass Generation Log File,"
                            "%s, could not be opened in %s.\n",
                             sLogFileNm,
                             BFCD_pCSRMapBFCD->CsrMapGenPath);


        FndGenRC = LogError( szErrorMsg );

        return CMN_FAIL;
    }

 
    return CMN_SUCCESS;
}/*End of InitCompLog()*/



/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001MassGenWrapUp
**
**  DESCRIPTION      : This function closes the log file for mass
**                     generation.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : M. Conner
**
**  DATE CREATED     : 11/22/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/22/96  mconner               Created
**
***************************************************************************/
USHORT Azcs001MassGenWrapUp(  char * sCsmNm, BOOL bOK, CMN_ARCH_PARM_TYPES )
{
    CHAR sErrorMsg[255];
    CHAR sSuccessMsg[255];

    sprintf(sErrorMsg, "****%s: Generation Failed.****\n\n", sCsmNm);
    sprintf(sSuccessMsg, "%s: Generation Complete\n", sCsmNm );
  
    if (bOK == FALSE )
    {
        LogError( sErrorMsg );
    }
    else
    {
        LogError( sSuccessMsg );
    }
    
    memset(sCsmNm, 0, _PATH_LEN + 1);
    fclose(fpLog);

    return CMN_SUCCESS;
}/*End of Azcs001MassGenWrapUp*/


