/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : ChkTLStatus
**
**  DESCRIPTION      : This function checks the task list status.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC(ChkTLStatus)
{
    USHORT FndGenRC          = FND_SUCCESS;
    SHORT  RowNumber         = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    if ( strncmp( RequestTypeData, "Inquiry", sizeof( RequestTypeData)) == 0)
    {
        /* Compare Key */
        if ( TaskListCdStatusIconicData[TL_CK_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_CK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if: Compare Key */

        /* Return Data */
        if ( TaskListCdStatusIconicData[TL_RD_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if: Return Data */

        /* Load Keys  */
        if ( TaskListCdStatusIconicData[TL_LK_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Load Keys */

        /* Load Data */
        FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                        CMN_LB_TLB_CONTROL_NAME,
                                        TL_LD_ROW_NUM,
                                        AT_UNAVAILABLE,
                                        &FndGenErrorBlock );

        /* Search and Destroy */
        FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                        CMN_LB_TLB_CONTROL_NAME,
                                        TL_SD_ROW_NUM,
                                        AT_UNAVAILABLE,
                                        &FndGenErrorBlock );

        /* Repeating Maps */
        if ( TaskListCdStatusIconicData[TL_RM_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RM_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );

        } /* end of if:  Repeating Maps */

    } /* end of if RequestTypeData is Inquiry */

    else if (strncmp(RequestTypeData, "LUW", sizeof( RequestTypeData )) == 0)
    {
        /* Compare Key */
        if ( TaskListCdStatusIconicData[TL_CK_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_CK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Compare Key */

        /* Return Data */
        if ( TaskListCdStatusIconicData[TL_RD_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Return Data */

        /* Load Keys  */
        if ( TaskListCdStatusIconicData[TL_LK_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Load Keys */

        /* Load Data */
        if ( TaskListCdStatusIconicData[TL_LD_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Load Data */

        /* Search and Destroy */
        if ( TaskListCdStatusIconicData[TL_SD_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_SD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of if:  Search and Destroy */

        /* Repeating Maps */
        if ( TaskListCdStatusIconicData[TL_RM_ROW_NUM] !=
             CMN_LBROW_STATUS_COMPLETED )
        {

            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RM_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );

        } /* end of if:  Repeating Maps */

    } /* end of else if:  LUW */

    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of ChkTLStatus */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : SetupBFCD
**
**  DESCRIPTION      : This function initializes the BFCD data structure.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC (SetupBFCD)
{

    USHORT FndGenRC;
    _FND_ERROR_BLOCK ErrorBlock;
    FILE *Stream;
    CHAR CurLine[_CSR_MAX_MAP_LINE_LEN] = "";
    CHAR dummy[_PATH_LEN] = "";

    HEAP_CHECK

    /* Allocate memory for the BFCD Global Structure */
    pBFCD->pCSRMapBFCD =
                 (_BFCD_GLOBAL_DATA *) malloc(sizeof(_BFCD_GLOBAL_DATA));

    memset(pBFCD->pCSRMapBFCD, 0, sizeof(_BFCD_GLOBAL_DATA) );
    pBFCD->pCSRMapBFCD->NumServices = 0;

    /* Allocate memory for the Client Main Layout Table */
    pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable =
                 (_LAYOUT_REC *) malloc(sizeof(_LAYOUT_REC));
    memset( pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable,
            0,
            sizeof(_LAYOUT_REC) );
    

    strncpy(dummy, CSR_MAP_CFG_FILE, sizeof(dummy));

    /* JLL: 07/16/93 ADDED */
    /* Open the csrmap.cfg to determine the save and generate directories. */
    if (( Stream = fopen( CSR_MAP_CFG_FILE,"r" )) == NULL )
    {
        return CMN_FAIL;
    }

    /* Read in the Save Directory */
    fgets( CurLine,_CSR_MAX_MAP_LINE_LEN, Stream );
    sscanf( CurLine,
            "%s %s",
            dummy,
            BFCD_pCSRMapBFCD->CsrMapSavePath );

    /* Read in the Generate Directory */
    fgets( CurLine,_CSR_MAX_MAP_LINE_LEN, Stream );
    sscanf( CurLine,
            "%s %s",
            dummy,
            BFCD_pCSRMapBFCD->CsrMapGenPath );

    /* Close the csrmap.cfg file */
    fclose( Stream );

    /* To control the enabling of non-preemptive
     * controls we have added a hidden field to the
     * window. Usually the task list is used for
     * purpose. But in this application until the
     * user has identified the map and at least one
     * service we make the task list unavailable.
     * Once they have identified the map and service
     * we make this hidden field valid and let the
     * task list take over the status processing.
     *
     * At predisplay we make the hidden field
     *   STS_INVALID.
     * At WktCloseAfterSave  if they get a saved map
     *    we make the field STS_VALID.
     * At ELB1CloseAfterSave we make the field
     *   STS_VALID.
     */

    FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                  "GenerateStatus",
                                  STS_INVALID,
                                  &ErrorBlock);

    /* Set the ChangeFlag to No. */
    BFCD_pCSRMapBFCD->ChangeFlag = 'N';

    FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "AMNDUMP",
                                 &ErrorBlock);

    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of SetupBFCD */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS001BusAmnGenerateClk
**
**  DESCRIPTION      : This function controls the generating and saving of maps.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC(AZCS001BusAmnGenerateClk)
{
    USHORT FndGenRC = FND_SUCCESS;
    SHORT  i        = 0;
    SHORT  servx;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    /* Set pointer to wait */
    FndGenRC = FndWindowSetPointer( CBI_hwnd,
                                    FNDSYSPTR_WAIT,
                                    &FndGenErrorBlock );

    /* JLL: 07/06/93 ADDED */
    for ( i = 0; i < pBFCD->pCSRMapBFCD->NumServices; i++ )
    {
       servx = GetServiceIndex(Rlb01ELBServerData[i],
                               Rlb01ELBServiceIDData[i],
                               Rlb01ELBTranMapData[i],
                               CMN_ARCH_PARMS);


       if (( Rlb01ELBCdStatusIconicData[i] == LT_UnchgDelIconValue ) ||
           ( Rlb01ELBCdStatusIconicData[i] == LT_AddDelIconValue ) ||
           ( Rlb01ELBCdStatusIconicData[i] == LT_ChgDelIconValue))
       {
          pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].DeleteFlag = TRUE;
       }
       else
       {
          pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].DeleteFlag = FALSE;
       }

    } /* end of for */

    /*mdc 12/12/96 added to check for occurring groups errors in data*/
    FndGenRC = CheckOccurGrps ( CMN_ARCH_PARMS );
    if ( FndGenRC != CMN_SUCCESS )
    {
        return( CMN_FAIL );
    }

    FndGenRC = GenerateMap( CMN_ARCH_PARMS );

    /*md c12/10/96 Changed for Mass Generation
    * If the task is NOT Mass Generation call AZCS001BusAmnSaveClk
    * to get the window task list status before writing the 
    * saved map file.  For Mass Generation, just write the map file.
    */
    if ( BFCD_pCSRMapBFCD->CsrFLMassGen != CMN_YES )
    {
        FndGenRC = AZCS001BusAmnSaveClk( pEventInfo,
                                         pEAIA,
                                         pBFCD,
                                         pWesMap,
                                         pWindContextData,
                                         pABHI );
    }
    else
    {
        FndGenRC = CsrMapWriteMapFile( CMN_ARCH_PARMS );
    }

    /* Change the pointer back to an arrow */
    FndGenRC = FndWindowSetPointer(CBI_hwnd,
                                   FNDSYSPTR_ARROW,
                                   &FndGenErrorBlock);

    HEAP_CHECK

    return CMN_SUCCESS;
} /* end of AZCS001BusAmnGenerateClk */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : Azcs001BusAmnMassGenClk
**
**  DESCRIPTION      : This function controls the mass generating and saving of maps.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : Mike Conner
**
**  DATE CREATED     : 10/01/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**
***************************************************************************/
static WCBPROC( Azcs001BusAmnMassGenClk )
{
    CHAR FileNm[_PATH_LEN + 1];
    FILE *ifp;
    USHORT FndGenRC = CMN_SUCCESS;
    CHAR sCsmNm[_PATH_LEN + 1] = "";
    CHAR sSaveDir[_PATH_LEN + 1] = "";
    CHAR sGenDir[_PATH_LEN + 1] = "";
    BOOL bMassGenOK;
    CHAR sMessage[MESSAGE_LEN];
    USHORT usSelectedButton, MsgID;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    char *s;
    DOUBLE           VersionNum     = 0;


    /*mdc 11/21/96 Open the error file*/
    FndGenRC = InitErrorFile( CMN_ARCH_PARMS );
    if (FndGenRC != CMN_SUCCESS) 
    {
        memset(sMessage, 0, MESSAGE_LEN );
        sprintf( sMessage, "Unable to open Mass Generation Error file.\n"
            "%s NOT FOUND!\n"
            "Mass Generation Terminating!"
            , ERR_FILE_NM );

        FndMsgBoxDisplayText( sMessage,
                                     NULL,
                                     CBI_hwnd,
                                     FND_MSGBOX_ENTER,
                                     FND_MSGBOX_ERROR,
                                     FND_MSGBOX_IDENTER,
                                     CMN_MAPGEN_NAME,
                                     &usSelectedButton,
                                     &FndGenErrorBlock);
     
        return CMN_FAIL;
    }

    /*mdc 10/29/96 Get the directories and file names*/
    strcpy(FileNm, BFCD_pCSRMapBFCD->CsrMapLstFile);
    strcpy(sGenDir, BFCD_pCSRMapBFCD->CsrMapGenPath);
    strcpy(sSaveDir, BFCD_pCSRMapBFCD->CsrMapSavePath);

    /*mdc 10/29/96 Open the map list file for read */
    ifp = fopen(FileNm, "r");
    if (ifp == NULL ) 
    {
        memset(sMessage, 0, MESSAGE_LEN );
        sprintf( sMessage, "Unable to open Mass Generation List file.\n"
            "%s NOT FOUND!\n"
            "Mass Generation Terminating!"
            , BFCD_pCSRMapBFCD->CsrMapLstFile );

        FndMsgBoxDisplayText( sMessage,
                                     NULL,
                                     CBI_hwnd,
                                     FND_MSGBOX_ENTER,
                                     FND_MSGBOX_ERROR,
                                     FND_MSGBOX_IDENTER,
                                     CMN_MAPGEN_NAME,
                                     &usSelectedButton,
                                     &FndGenErrorBlock);

        LogError( sMessage );

        fclose(fpError);
        return (CMN_FAIL);
    }

     /*mdc 11/26/96 Notify user that map is generating*/
        memset(sMessage, 0, MESSAGE_LEN );
        sprintf(sMessage, "Preparing to Mass Generate....\n");

        FndMsgBoxDisplayMdlssText( sMessage,
                         "MGBox",
                         CBI_hwnd,
                         FND_MSGBOX_NOBUTTONS,
                         FND_MSGBOX_INFORMATION,
                         FND_MSGBOX_IDNOBUTTON,
                         CMN_MAPGEN_NAME,
                         &FndGenErrorBlock );


    /*mdc 10/29/96 Loop until there are no more csm names in the map
                   list file to process */
    while (fgets(sCsmNm, _PATH_LEN, ifp) != NULL)
    {
       
        /*mdc 10/29/96 Strip all but base file name*/
        s = sCsmNm;
        while (*s)
        {
            if (*s == '.') *s = '\0';
            if (*s) ++s;
        }
        
        /*Notify user which map is generating */
        memset(sMessage, 0, MESSAGE_LEN);
        sprintf(sMessage, "%s: Generating .........\n", sCsmNm);
        LogError( sMessage );
        FndMsgBoxSetText( "MGBox",
                           sMessage,
                           &FndGenErrorBlock );

        /*mdc 10/30/96 Clean up the BFCD*/
        FndGenRC = AZCS001BusCleanupBFCD( pEventInfo,
                                        pEAIA,
                                        pBFCD,
                                        pWesMap,
                                        pWindContextData,
                                        pABHI);

        /*mdc 10/29/96 process data in save file. This also populates
                       the BFCD*/
        FndGenRC = ExtractSavedData( CMN_ARCH_PARMS,
                                     sCsmNm);


        /*mdc 10/29/96 if the save file was not found go to the 
        next iteration of the while loop and process the next file*/
        if (FndGenRC != CMN_SUCCESS) 
        {
            memset(sMessage, 0, MESSAGE_LEN);
            sprintf( sMessage, "%s: Saved file not found.\n"
                               "****%s: Generation Failed.****\n\n", 
                               sCsmNm, sCsmNm );
            LogError( sMessage );
            memset(sCsmNm, 0, _PATH_LEN + 1);
            continue; 
        }

        /*mdc 10/30/96 Read the rest of the save file data */
        FndGenRC = CsrMapReadMapFile( CMN_ARCH_PARMS );

      /* If successfull, proceed. 
       */
      if ( FndGenRC == CMN_SUCCESS )
      {

           /* Get the Repository version of the service layout */
           FndGenRC =  GetServiceReposData( pEventInfo,
                                     pEAIA,
                                     pBFCD,
                                     pWesMap,
                                     pWindContextData,
                                     pABHI );

           /*mdc 10/30/96 If get service data error */
           if (FndGenRC != CMN_SUCCESS )
           {
                FndGenRC = AZCS001BusCleanupBFCD( pEventInfo,
                                                  pEAIA,
                                                  pBFCD,
                                                  pWesMap,
                                                  pWindContextData,
                                                  pABHI );
               
                memset(sMessage, 0, MESSAGE_LEN );
                sprintf(sMessage, "%s: Failed to get service data.\n"
                    "****%s: Generation Failed.****\n\n", 
                    sCsmNm, sCsmNm );

                LogError( sMessage );
                memset(sCsmNm, 0, _PATH_LEN + 1);

                continue;

           } /* end of if:  Error from GetServiceReposData */


      }  /* end of if:  Successfull call to CsrMapReadMapFile */
      else 
      {
            memset(sMessage, 0, MESSAGE_LEN);
            sprintf( sMessage, "%s: CsrMapReadMapFile Failed.\n"
                               "****%s: Generation Failed.****\n\n", 
                               sCsmNm, sCsmNm );
            LogError( sMessage );
            memset(sCsmNm, 0, _PATH_LEN + 1);

            continue; 
      }



      pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows = MAXCLIENTROWS;

      /* Get the Repository version of request layout */
      FndGenRC = CsrMapRetrieveLayout(
                  pBFCD->pCSRMapBFCD->ClientInfo.ClientLayoutName,
                  MAP_GEN_CLIENT_LAYOUT,
                  &(pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable),
                  &(pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows),
                  &VersionNum,
                  CMN_ARCH_PARMS );

      /* A bad return code from the call to retrieve the repository
       * Reset all of the client BFCD stuff and return.
       */
      if (FndGenRC != CMN_SUCCESS)
      {
          FndGenRC = AZCS001BusCleanupBFCD( pEventInfo,
                                            pEAIA,
                                            pBFCD,
                                            pWesMap,
                                            pWindContextData,
                                            pABHI );

            memset(sMessage, 0, MESSAGE_LEN);
            sprintf( sMessage, "%s: CsrMapRetrieveLayout Failed.\n"
                               "%s: Generation Failed.", sCsmNm, sCsmNm );
            LogError( sMessage );
            memset(sCsmNm, 0, _PATH_LEN + 1);

          continue;

      } /* end of if:  Error from CsrMapRetrieveLayout */

      else /* Successful CsrMapRetrieveLayout */
      {
          pBFCD->pCSRMapBFCD->ClientInfo.Version = VersionNum;

      } /* end of else: Successful CsrMapRetrieveLayout */

      /*Open the CSR Map Comaprison Log file*/
      FndGenRC = InitCompLog( CMN_ARCH_PARMS, sCsmNm );
      if (FndGenRC != CMN_SUCCESS ) 
      {
          memset(sMessage, 0, MESSAGE_LEN );
          sprintf(sMessage, "%s: Comaprison Log failed to open for write.\n"
              "****%s: Generation Failed.****\n\n", sCsmNm, sCsmNm );
          LogError( sMessage );
          memset(sCsmNm, 0, _PATH_LEN + 1);
          
          continue;
      }

       /* Compare the client layout from saved map vs.
        * the current repository
        */
        FndGenRC = MGCompLayouts( CMN_ARCH_PARMS );
        if (FndGenRC != CMN_SUCCESS )
        {
             bMassGenOK = FALSE;
             memset( sMessage, 0, MESSAGE_LEN );
             sprintf(sMessage, "%s: Comparison Failed!\n", sCsmNm);
             MsgID = CMN_MAPGEN_MSG_ERROR; 
             LogMsg( MsgID, sMessage );
             LogError( sMessage );
             Azcs001MassGenWrapUp( sCsmNm, bMassGenOK, CMN_ARCH_PARMS );
             continue;
        }
        else
        {
             memset( sMessage, 0, MESSAGE_LEN );
             sprintf(sMessage, "%s: Comparison Succeeded!\n", sCsmNm);
             MsgID = CMN_MAPGEN_MSG_INFO; 
             LogMsg( MsgID, sMessage );
             LogError( sMessage );
        }


       /*mdc 10/30/96 Generate map */
       FndGenRC = AZCS001BusAmnGenerateClk( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
       
        if (FndGenRC != CMN_SUCCESS )
        {
             bMassGenOK = FALSE;
        }
        else
        {
       
            bMassGenOK = TRUE;
        }
        
        Azcs001MassGenWrapUp( sCsmNm, bMassGenOK, CMN_ARCH_PARMS );


    }/*end of while (fgets(sCsm, _PATH-LEN, ifp) != NULL)*/

    /*mdc Log end of Map List File in error file */
     memset( sMessage, 0, MESSAGE_LEN );
     sprintf(sMessage, "***End of Map List File***\n");
     LogError( sMessage );


    /*destroy User notification message box*/
    FndMsgBoxDestroy( "MGBox",
                       &FndGenErrorBlock );

  /*mdc 11/26/96 Notify user that Mass Generation is finished*/
  memset(sMessage, 0, MESSAGE_LEN );
  sprintf(sMessage, "***Generation complete!***\n"
                    "Check %s error file and log files in\n"
                    "%s\n", ERR_FILE_NM, sGenDir );
  
  FndMsgBoxDisplayText( sMessage,
                         NULL,
                         CBI_hwnd,
                         FND_MSGBOX_OK,
                         FND_MSGBOX_INFORMATION,
                         FND_MSGBOX_IDOK,
                         CMN_MAPGEN_NAME,
                         &usSelectedButton,
                         &FndGenErrorBlock );

 
 fclose(ifp);
 fclose(fpError);
 return(CMN_SUCCESS);

}

//**********************************************************************
//**
//**               CUSTOMER SERVICE SYSTEM Business Logic Function
//**
//**  FUNCTION         : ExtractSavedData
//*
//**  DESCRIPTION      : This function processes the saved map file data.
//**
//**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
//**
//**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
//**
//**
//**  CALLED FUNCTIONS : NONE
//**
//**  AUTHOR           : M. Conner
//**
//**  DATE CREATED     : 10/29/96
//**
//**  REVISION HISTORY :
//**
//**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
//**    --------  -----------  -------  -------------------------------------
//**    10/29/96  M. Conner           Original code.
//**
//*********************************************************************/

USHORT ExtractSavedData ( CMN_ARCH_PARM_TYPES, 
                        char *sCsmNm)
{
   USHORT          FndGenRC = CMN_SUCCESS;
   /*_FND_ERROR_BLOCK         FndGenErrorBlock;*/

    FILE                   *Stream;
    CHAR                    FileNm[_CSR_MAP_FILENAME_LEN] = "";
    CHAR                    ErrorFile[_CSR_MAP_FILENAME_LEN] = "";
    CHAR                    CurLine[_MAPGN_MAX_MAP_LINE_LEN] = "";
    CHAR                    d1[_DUMMY_LEN],d2[_DUMMY_LEN],d3[_DUMMY_LEN],
                            d4[_DUMMY_LEN],d5[_DUMMY_LEN],d6[_DUMMY_LEN],
                            d7[_DUMMY_LEN], d8[_DUMMY_LEN];

  

    /* Create map file name and path */
    FndGenRC = CmnStrCat( CMN_ARCH_PARMS,
                          FileNm,
                          _CSR_MAP_FILENAME_LEN,
                          5,
                          BFCD_pCSRMapBFCD->CsrMapSavePath,
                          "\\",
                          sCsmNm,
                          ".",
                          CSR_MAP_SAVE_FILE_EXT );

   
    if (( Stream = fopen( FileNm,"r" )) != NULL )
    {
       
        /* Format the Request Header */
        fgets( CurLine,_MAPGN_MAX_MAP_LINE_LEN,Stream );
        sscanf( CurLine,CSR_MAP_REQ_HEADER_FORMAT_STR,
                d1,d2,BFCD_pCSRMapBFCD->ClientInfo.ReqId,
                d3,BFCD_pCSRMapBFCD->ClientInfo.ClientLayoutName,
                d4,BFCD_pCSRMapBFCD->ClientInfo.ReqType,
                d5,&BFCD_pCSRMapBFCD->ClientInfo.NumSearchDestroy,
                d6,&BFCD_pCSRMapBFCD->ClientInfo.NumClientRows,
                d7,&BFCD_pCSRMapBFCD->NumServices,
                d8,&BFCD_pCSRMapBFCD->ClientInfo.Version );
         
        /* Close the file */
        fclose( Stream );

      }     

    else
    {  /* Saved Map Not Found */

        return ( CMN_FAIL );
    }

    return(CMN_SUCCESS);
       
}/*End of ExtractSavedData*/


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS001BusAmnSaveClk
**
**  DESCRIPTION      : This function controls the saving of a map.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean up.
**
***************************************************************************/
static WCBPROC( AZCS001BusAmnSaveClk )
{
    USHORT FndGenRC = FND_SUCCESS;
    SHORT  i        = 0;
    SHORT  servx;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    /* Set the pointer to wait */
    FndGenRC = FndWindowSetPointer(CBI_hwnd,
                                   FNDSYSPTR_WAIT,
                                   &FndGenErrorBlock);

    /* JLL: 07/01/93 ADDED */
    if ( TaskListCdStatusIconicData[TL_CK_ROW_NUM] ==
         CMN_LBROW_STATUS_COMPLETED )
    {
        BFCD_pCSRMapBFCD->CKTaskListComplete = 'Y';
    }
    else
    {
        BFCD_pCSRMapBFCD->CKTaskListComplete = 'N';
    }

    /* JLL: 07/02/93 ADDED */
    if ( TaskListCdStatusIconicData[TL_RD_ROW_NUM] ==
         CMN_LBROW_STATUS_COMPLETED )
    {
        BFCD_pCSRMapBFCD->RDTaskListComplete = 'Y';
    }
    else
    {
        BFCD_pCSRMapBFCD->RDTaskListComplete = 'N';
    }

    /* JLL: 07/02/93 ADDED */
    if ( TaskListCdStatusIconicData[TL_LK_ROW_NUM] ==
         CMN_LBROW_STATUS_COMPLETED )
    {
        BFCD_pCSRMapBFCD->LKTaskListComplete = 'Y';
    }
    else
    {
        BFCD_pCSRMapBFCD->LKTaskListComplete = 'N';
    }

    /* JLL: 07/02/93 ADDED */
    if ( TaskListCdStatusIconicData[TL_LD_ROW_NUM] ==
         CMN_LBROW_STATUS_COMPLETED )
    {
        BFCD_pCSRMapBFCD->LDTaskListComplete = 'Y';
    }
    else
    {
        BFCD_pCSRMapBFCD->LDTaskListComplete = 'N';
    }

    /* JLL: 07/12/93 ADDED */
    if ( TaskListCdStatusIconicData[TL_RM_ROW_NUM] ==
         CMN_LBROW_STATUS_COMPLETED )
    {
        BFCD_pCSRMapBFCD->RPMHTaskListComplete = 'Y';
    }
    else
    {
        BFCD_pCSRMapBFCD->RPMHTaskListComplete = 'N';
    }

    /* JLL: 07/06/93 ADDED */
    for ( i = 0; i < pBFCD->pCSRMapBFCD->NumServices; i++ )
    {
       servx = GetServiceIndex(Rlb01ELBServerData[i],
                               Rlb01ELBServiceIDData[i],
                               Rlb01ELBTranMapData[i],
                               CMN_ARCH_PARMS);

       if (( Rlb01ELBCdStatusIconicData[i] == LT_UnchgDelIconValue ) ||
           ( Rlb01ELBCdStatusIconicData[i] == LT_AddDelIconValue ) ||
           ( Rlb01ELBCdStatusIconicData[i] == LT_ChgDelIconValue))

       {
          pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].DeleteFlag = TRUE;
       }
       else
       {
          pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].DeleteFlag = FALSE;
       }

    } /* end of for */

    FndGenRC = CsrMapWriteMapFile( CMN_ARCH_PARMS );

    pBFCD->pCSRMapBFCD->ChangeFlag = 'N';

    /* Change to pointer back to an arrow */
    FndGenRC = FndWindowSetPointer(CBI_hwnd,
                                   FNDSYSPTR_ARROW,
                                   &FndGenErrorBlock);


    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of AZCS001BusAmnSaveClk */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : RestoreServiceLB
**
**  DESCRIPTION      : This function loads the Services List Box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC (RestoreServiceLB)
{
    SHORT  ix;
    SHORT  nRC;
    USHORT FndGenRC = FND_SUCCESS;
    _Rlb01ELBRow NewRow;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    /* Loop thru all of the services in BFCD and Add them to the List Box */
    for ( ix = 0; ix < pBFCD->pCSRMapBFCD->NumServices; ix++ )
    {
        NewRow._Rlb01ELBCdStatusIconicData = LT_AvailableIconValue;

        NewRow._Rlb01ELBServerData =
                  pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].Server;

        NewRow._Rlb01ELBServiceIDData =
               pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceId;

        NewRow._Rlb01ELBServiceAgeData =
          pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceAgeLimit;

        /* CSC: 07/12/94 Modify Flush */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].FlushFlag )
        {
            strncpy( NewRow._Rlb01ELBFlushData,
                     "Y",
                     sizeof( NewRow._Rlb01ELBFlushData ));
        }
        else
        {
            strncpy( NewRow._Rlb01ELBFlushData,
                     "N",
                     sizeof( NewRow._Rlb01ELBFlushData ));
        }

        strncpy( NewRow._Rlb01ELBTranMapData,
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceLayoutName,
                 sizeof( NewRow._Rlb01ELBTranMapData ));

        strncpy( NewRow._Rlb01ELBForceCallData,
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ForceCall,
                 sizeof( NewRow._Rlb01ELBForceCallData ));

        strncpy( NewRow._Rlb01ELBAnticModuleData,
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AnticCallModule,
                 sizeof( NewRow._Rlb01ELBAnticModuleData ));

        strncpy( NewRow._Rlb01ELBAltMapData,
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AlternateService,
                 sizeof( NewRow._Rlb01ELBAltMapData ));

        /* Populate row */
        nRC = CmnElbAssignRowData( MAPGEN_ELB_NAME,
                                   ix,
                                   (void *)&NewRow,
                                   NULL,
                                   CMN_ARCH_PARMS );

        /* Error from CmnElbAssignRowData */
        if ( nRC != CMN_SUCCESS )
        {
            return CMN_FAIL;
        } /* end of if:  Error fromCmnElbAssignRowData */

        /* Show the row */
        FndGenRC = FndLstBoxRowShow( CBI_hwnd,
                                     MAPGEN_ELB_NAME,
                                     ix,
                                     &FndGenErrorBlock );

        /* Error from FndLstBoxRowShow */
        if ( nRC != CMN_SUCCESS )
        {
            return CMN_FAIL;
        } /* end of if:  Error from FndLstBoxRowShow */

    } /* end of loop thru each BFCD service */

    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of RestoreServiceLB */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : RestoreTaskList
**
**  DESCRIPTION      : This function restores the Task List to its previous state.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC (RestoreTaskList)
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = FND_SUCCESS;
    SHORT  ix;

    /* Loop thru all of the services in BFCD and see if any relationships
     * have been completed.
     */
    for ( ix = 0; ix < pBFCD->pCSRMapBFCD->NumServices; ix++ )
    {
        /*
         *  See if any Compare Key relationships exist
         *  Should be unavailable for Updates
         */
        if ( strcmp( BFCD_pCSRMapBFCD->ClientInfo.ReqType,"2") == 0)
        {
            TaskListCdStatusIconicData[TL_CK_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_CK_ROW_NUM,
                                            AT_UNAVAILABLE,
                                            &FndGenErrorBlock );
        } /* end of if */

        else if ( BFCD_pCSRMapBFCD->CKTaskListComplete == 'Y' )
        {
            TaskListCdStatusIconicData[TL_CK_ROW_NUM] =
                                                  CMN_LBROW_STATUS_COMPLETED;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_CK_ROW_NUM,
                                            AT_REQUIRED_COMPLETE,
                                            &FndGenErrorBlock );
        } /* end of else if */

        else
        {
            TaskListCdStatusIconicData[TL_CK_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_CK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of else */

        /* See if any Return Data relationships exist */
        if ( BFCD_pCSRMapBFCD->RDTaskListComplete == 'Y' )
        {
            TaskListCdStatusIconicData[TL_RD_ROW_NUM] =
                                                  CMN_LBROW_STATUS_COMPLETED;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RD_ROW_NUM,
                                            AT_REQUIRED_COMPLETE,
                                            &FndGenErrorBlock );
        } /* end of if */

        else
        {
            TaskListCdStatusIconicData[TL_RD_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of else */

        /* See if any Load Keys relationships exist */
        if ( BFCD_pCSRMapBFCD->LKTaskListComplete == 'Y' )
        {
            TaskListCdStatusIconicData[TL_LK_ROW_NUM] =
                                                 CMN_LBROW_STATUS_COMPLETED;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LK_ROW_NUM,
                                            AT_REQUIRED_COMPLETE,
                                            &FndGenErrorBlock );
        } /* end of if */

        else
        {
            TaskListCdStatusIconicData[TL_LK_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LK_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of else */

        /* See if any Load Data relationships exist */
        if ( BFCD_pCSRMapBFCD->LDTaskListComplete == 'Y' )
        {
            TaskListCdStatusIconicData[TL_LD_ROW_NUM] =
                                                  CMN_LBROW_STATUS_COMPLETED;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LD_ROW_NUM,
                                            AT_REQUIRED_COMPLETE,
                                            &FndGenErrorBlock );
        } /* end of if */

        else if (strcmp(pBFCD->pCSRMapBFCD->ClientInfo.ReqType, "2") == 0)
        {
            TaskListCdStatusIconicData[TL_LD_ROW_NUM] =
                                                  CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LD_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of else if */

        else
        {
            TaskListCdStatusIconicData[TL_LD_ROW_NUM] =
                                                  CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_LD_ROW_NUM,
                                            AT_UNAVAILABLE,
                                            &FndGenErrorBlock );
        } /* end of else */

        /* See if any Search and Destroy references exist */
        if (strcmp(BFCD_pCSRMapBFCD->ClientInfo.ReqType,"2") == 0)
        {
            if (pBFCD->pCSRMapBFCD->ClientInfo.NumSearchDestroy > 0)
            {
                TaskListCdStatusIconicData[TL_SD_ROW_NUM] =
                                                  CMN_LBROW_STATUS_COMPLETED;
                FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                                CMN_LB_TLB_CONTROL_NAME,
                                                TL_SD_ROW_NUM,
                                                AT_REQUIRED_COMPLETE,
                                                &FndGenErrorBlock );

            } /* end of inner if */

            else
            {
                TaskListCdStatusIconicData[TL_SD_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
                FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                                CMN_LB_TLB_CONTROL_NAME,
                                                TL_SD_ROW_NUM,
                                                AT_OPTIONAL,
                                                &FndGenErrorBlock );
            } /* end of inner else */

        } /* end of if */

        else
        {
            TaskListCdStatusIconicData[TL_SD_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_SD_ROW_NUM,
                                            AT_UNAVAILABLE,
                                            &FndGenErrorBlock );
        } /* end of else */

        /* JLL:  07/12/93 ADDED */
        /* See if any Repeating Maps references exist */
        if ( pBFCD->pCSRMapBFCD->RPMHTaskListComplete == 'Y' )
        {
            TaskListCdStatusIconicData[TL_RM_ROW_NUM] =
                                                 CMN_LBROW_STATUS_COMPLETED;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RM_ROW_NUM,
                                            AT_REQUIRED_COMPLETE,
                                            &FndGenErrorBlock );
        } /* end of if */

        else
        {
            TaskListCdStatusIconicData[TL_RM_ROW_NUM] =
                                                 CMN_LBROW_STATUS_AVAILABLE;
            FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
                                            CMN_LB_TLB_CONTROL_NAME,
                                            TL_RM_ROW_NUM,
                                            AT_REQUIRED,
                                            &FndGenErrorBlock );
        } /* end of else */

    }  /* end of do loop for all BFCD services */

    FndGenRC = CmnTlCheckStatus(CMN_ARCH_PARMS);

    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of RestoreTaskList */


/************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : GetServiceReposData
**
**  DESCRIPTION      : This function controls the retrieving of repository data for
**                       each of the services in the saved map.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
static WCBPROC(GetServiceReposData)
{
    SHORT  ix;
    USHORT FndGenRC   = 0;
    DOUBLE VersionNum = 0. ;

    HEAP_CHECK

    /* Loop thru all of the services from the map and get the repository data */
    for ( ix = 0; ix < pBFCD->pCSRMapBFCD->NumServices; ix++)
    {
        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows =
                                                             MAXSERVICEROWS;

        /* Get the Service Layout from the Repository */
        FndGenRC = CsrMapRetrieveLayout(
                                  pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                                    ServiceLayoutName,
                                  MAP_GEN_SERVICE_LAYOUT,
                                  &(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                                    pReposServiceLayoutTable),
                                  &(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                                    NumReposServiceRows),
                                  &VersionNum,
                                  CMN_ARCH_PARMS );

        /* Error from CsrMapRetrieveLayout */
        if ( FndGenRC != FND_SUCCESS )
        {
            return FndGenRC;
        }

        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].Version = VersionNum;

    } /* end of for loop thru each of the services */

    HEAP_CHECK

    return CMN_SUCCESS;

} /* End of function GetServiceReposData */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS001BusCleanupBFCD
**
**  DESCRIPTION      : This function initializes the BFCD back to its pristine state.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/14/94  J. Looney             Clean Up.
*************************************************************************/
static WCBPROC( AZCS001BusCleanupBFCD )
{
    USHORT FndGenRC = 0;
    USHORT usRC     = 0;
    SHORT  ix       = 0;
    SHORT  sRC      = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    /*
     * Cleanup the Top Level stuff first
     */
    pBFCD->pCSRMapBFCD->ChangeFlag           = 'N';
    pBFCD->pCSRMapBFCD->CKTaskListComplete   = 'N';
    pBFCD->pCSRMapBFCD->RDTaskListComplete   = 'N';
    pBFCD->pCSRMapBFCD->LKTaskListComplete   = 'N';
    pBFCD->pCSRMapBFCD->LDTaskListComplete   = 'N';
    pBFCD->pCSRMapBFCD->RPMHTaskListComplete = 'N';

    /*
     * Cleanup the Client Info Stuff
     */
    strcpy(pBFCD->pCSRMapBFCD->ClientInfo.ReqId,"");
    strcpy(pBFCD->pCSRMapBFCD->ClientInfo.ClientLayoutName,"");
    strcpy(pBFCD->pCSRMapBFCD->ClientInfo.ReqType,"");

    pBFCD->pCSRMapBFCD->ClientInfo.NumSearchDestroy   = 0;
    pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows      = 0;
    pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows = 0;

    /* CSM Version of the Client Layout */
    if ( pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable )
    {
        free( pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable );
        pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable = NULL;
          
    }

    /* Repository Version of the Client Layout */
    if ( pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable )
    {
         free( pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable );
        pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable = NULL;

    }

    /*
     * Cleanup the Service stuff
     */

    for ( ix=0; ix < pBFCD->pCSRMapBFCD->NumServices; ix++ )
    {
        /* CSM Version of the Service Layout */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pServiceLayoutTable )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                  pServiceLayoutTable );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pServiceLayoutTable
                = NULL;
        }

        /* Repository Version of the Service Layout */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
             pReposServiceLayoutTable )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable = NULL;
        }

        /* RPMH */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps = NULL;
        }

        /* CK */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys = NULL;
        }

        /* LK */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadKeys )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadKeys );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadKeys = NULL;
        }

        /* LD */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData = NULL;
        }

        /* RD */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData )
        {
            free( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData );
            pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData = NULL;
        }

        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].DeleteFlag = FALSE;

    } /* end of for */

    pBFCD->pCSRMapBFCD->NumServices = 0;

    /* Clean up the Wes Map stuff for azcs001 */
    strcpy( RequestTypeData,  "" );
    strcpy( RequestIDData,    "" );
    strcpy( ClientLayoutData, "" );
      
    /* Clean up the Listbox stuff */
    sRC = CmnElbInit( "Rlb01ELB", CMN_ARCH_PARMS );
      
    /* Cleanup the Task list stuff */
    FndGenRC = FndLstBoxRowDeleteAll( CBI_hwnd,
                                      CMN_LB_TLB_CONTROL_NAME,
                                      &FndGenErrorBlock );
     
    /* Populate the TL with rows */
    FndGenRC = AZCS001ExitTlPopulateData( CMN_ARCH_PARMS );
     
    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of AZCS001BusCleanupBFCD */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : GetServiceIndex
**
**  DESCRIPTION      : This function finds the service index based on the
**                      Server, Service ID and Translation Map.
**
**  INPUTS           : unsigned long Server    - Server number
**                     unsigned long ServiceID - Service Id number
**                     char *        TranMap   - Translation Map name
**                     CMN_ARCH_PARMS          - Standard Architecture Pams
**
**  OUTPUTS          : Return Code - SHORT - Valid index or -1 if not found.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
**
***************************************************************************/
SHORT GetServiceIndex( ULONG Server,
                       USHORT ServiceID,
                       CHAR *TranMap,
                       CMN_ARCH_PARM_TYPES )
{
    SHORT index = 0;

    HEAP_CHECK

    for ( index = 0; index < pBFCD->pCSRMapBFCD->NumServices; index++ )
    {
        if( Server == pBFCD->pCSRMapBFCD->ServiceInfoTable[index].Server &&
            ServiceID == (USHORT) pBFCD->pCSRMapBFCD->ServiceInfoTable[index].
                         ServiceId &&
            (strcmp(TranMap,pBFCD->pCSRMapBFCD->ServiceInfoTable[index].
                    ServiceLayoutName ) == 0) )
        {
           HEAP_CHECK

           return( index );
        }
    }

    HEAP_CHECK

    return(-1);

} /* end of function GetServiceIndex */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS001BusAMNDumpClk
**
**  DESCRIPTION      : This function Dumps the internal map generator tables
**                       to the line printer.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean up.
**
***************************************************************************/
WCBPROC(AZCS001BusAMNDumpClk)
{
    #define LAYOUT1 "%-5.2d %-8.8s %-4.1c  %-31.31s  %-5.1c  %-6.1c  %-5.1i  %-6.1i  %-8.1i  %-6.1i\n"
    #define LAYOUT_HD1 "               Data                                   Elmnt                                  Parent\n"
    #define LAYOUT_HD2 "Index Item Id  Type  C Name                           Type   Format  Level  Offset  C Length Index\n"
    #define LAYOUT_HD3 "===== ======== ====  ===============================  =====  ======  =====  ======  ======== ======\n"

    SHORT sIndex;
    SHORT sServ;
    SHORT FndGenRC;
    USHORT usSelectedButton;
    FILE *fptrFileName;
    CHAR szFileName[255];
    CHAR szMsgBuff[255];
    CHAR szMsgBuff2[33];
    CHAR szMsgInfo[255];
    _FND_ERROR_BLOCK  FndGenErrorBlock;

    HEAP_CHECK

    /*
     * Start with the Layout Tables
     */

    sprintf( szFileName, "%s\\%s.DMP",
             pBFCD->pCSRMapBFCD->CsrMapSavePath,        /* 70 */
             pBFCD->pCSRMapBFCD->ClientInfo.ReqId );    /*  9 */

    fptrFileName = fopen(szFileName, "w");

    sprintf( szMsgInfo,
             "Internal Tables will be written to file:\n\n %s",  /* ~44 */
             szFileName );                                       /* 255 */

    /* Display message to user */
    FndGenRC = FndMsgBoxDisplayText( szMsgInfo,
                                     NULL,
                                     CBI_hwnd,
                                     FND_MSGBOX_OKCANCEL,
                                     FND_MSGBOX_INFORMATION,
                                     FND_MSGBOX_IDOK,
                                     CMN_MAPGEN_NAME,
                                     &usSelectedButton,
                                     &FndGenErrorBlock);

    if ( usSelectedButton != FND_MSGBOX_IDOK )
    {
        return CMN_SUCCESS;
    }

    /* set the font to line printer (smaller font) */
    FndGenRC = fprintf( fptrFileName, LINE_PRINTER );

    /* set the line spacing to smaller */
    FndGenRC = fprintf( fptrFileName, VMI );

    fprintf( fptrFileName, "Dumping Repository Client Layout\n\n" );
    fprintf( fptrFileName, LAYOUT_HD1 );
    fprintf( fptrFileName, LAYOUT_HD2 );
    fprintf (fptrFileName, LAYOUT_HD3 );


    for( sIndex = 0;
         sIndex < pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows;
         sIndex++ )
    {
        fprintf( fptrFileName,
                 LAYOUT1,
                 sIndex,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemId,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemType,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemCName,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ElementTypeCode,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].Format,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemLevel,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemOffset,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ItemCLength,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pReposClientLayoutTable[sIndex].ParentIndex);
    } /* end of for */

    fprintf( fptrFileName, "\n\n\nDumping Saved Client Layout\n\n" );
    fprintf( fptrFileName, LAYOUT_HD1 );
    fprintf( fptrFileName, LAYOUT_HD2 );
    fprintf( fptrFileName, LAYOUT_HD3 );

    for ( sIndex = 0;
          sIndex < pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows;
          sIndex++ )
    {
        fprintf( fptrFileName,
                 LAYOUT1,
                 sIndex,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemId,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemType,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemCName,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ElementTypeCode,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].Format,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemLevel,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemOffset,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ItemCLength,
                 pBFCD->pCSRMapBFCD->ClientInfo.
                     pClientLayoutTable[sIndex].ParentIndex);
    } /* end of for */

    fprintf( fptrFileName, "\n\n\nDumping Repository Service Layout \n\n" );

    for( sServ = 0; sServ < pBFCD->pCSRMapBFCD->NumServices; sServ++ )
    {
        fprintf( fptrFileName,
                 "\nService: %s\n\n",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                       ServiceLayoutName );
        fprintf( fptrFileName, LAYOUT_HD1 );
        fprintf( fptrFileName, LAYOUT_HD2 );
        fprintf( fptrFileName, LAYOUT_HD3 );

        for( sIndex = 0;
             sIndex < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      NumReposServiceRows;
             sIndex++ )
        {
            fprintf( fptrFileName,
                     LAYOUT1,
                     sIndex,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemId,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemType,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemCName,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ElementTypeCode,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].Format,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemLevel,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemOffset,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemCLength,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ParentIndex );

        } /* end of inner for */

    } /* end of outer for */

    fprintf( fptrFileName, "\n\n\nDumping Saved Service Layout \n\n" );

    for ( sServ = 0; sServ < pBFCD->pCSRMapBFCD->NumServices; sServ++ )
    {
        fprintf( fptrFileName,
                 "\nService: %s\n\n",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   ServiceLayoutName );
        fprintf( fptrFileName, LAYOUT_HD1 );
        fprintf( fptrFileName, LAYOUT_HD2 );
        fprintf( fptrFileName, LAYOUT_HD3 );

        for( sIndex = 0;
             sIndex < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      NumServiceRows;
             sIndex++ )
        {
            fprintf( fptrFileName,
                     LAYOUT1,
                     sIndex,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemId,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemType,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemCName,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ElementTypeCode,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].Format,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemLevel,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemOffset,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemCLength,
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ParentIndex );

        } /* end of inner for */

    } /* end of outer for */

    /*
     * Print out the relationships for each service
     */
    #define RELAT1 "%i %s %i %c"
    #define COMPKEYS "%-5.2d %-7.3c %-8.3c  "
    #define LOADKEYS "%-5.2d %-7.3c  "
    #define LOADDATA "%-5.2d %-7.3c  "
    #define RETURNDATA "%-5.2d"
    #define RELAT_HD1 "                                                             Compare Key          Load Key      Load Data     Return Data\n"
    #define RELAT_HD2 "Index  Item C Name                      Parent Ix Type  Index Literal WildCard  Index Literal  Index Literal    Index\n"
    #define RELAT_HD3 "=====  ===============================  ========= ====  ===== ======= ========  ===== =======  ===== =======  ===========\n"

    fprintf( fptrFileName, "\n\nDumping Saved Relationship Data\n\n" );

    for( sServ = 0; sServ < pBFCD->pCSRMapBFCD->NumServices; sServ++ )
    {
        fprintf( fptrFileName,
                 "\nService: %s\n\n",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                     ServiceLayoutName );
        fprintf( fptrFileName,RELAT_HD1 );
        fprintf( fptrFileName,RELAT_HD2 );
        fprintf( fptrFileName,RELAT_HD3 );

        for( sIndex = 0;
             sIndex < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      NumServiceRows;
             sIndex++ )
        {
            sprintf( szMsgBuff,                                   /* 255 */
                     "%-4.2i   %-31.31s  %-4.2i    %3.3c     ",
                     sIndex,                                      /*   4 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemCName,   /*  32 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ParentIndex, /*   4 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pServiceLayoutTable[sIndex].ItemType );  /*   1 */

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                    pSavedCompareKeys )
            {
                sprintf( szMsgBuff2,                                 /* 33 */
                         COMPKEYS,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedCompareKeys[sIndex].ClientLayoutIndex, /* 4 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedCompareKeys[sIndex].LiteralUsed,   /* 1 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedCompareKeys[sIndex].WildCardUsed );/* 1 */
            }

            else
            {
                sprintf( szMsgBuff2, COMPKEYS, -1, 'N', 'N' );

            }

            strcat( szMsgBuff, szMsgBuff2 );

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedLoadKeys )
            {
                sprintf( szMsgBuff2,                                /* 33 */
                         LOADKEYS,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedLoadKeys[sIndex].ClientLayoutIndex, /* 4 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedLoadKeys[sIndex].LiteralUsed );   /* 1 */
            }

            else
            {
                sprintf (szMsgBuff2, LOADKEYS, -1, 'N' );
            }

            strcat( szMsgBuff, szMsgBuff2 );

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedLoadData )
            {
                sprintf( szMsgBuff2,                                /* 33 */
                         LOADDATA,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedLoadData[sIndex].ClientLayoutIndex, /* 4 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pSavedLoadData[sIndex].LiteralUsed );  /* 1 */
            }
            else
            {
                sprintf( szMsgBuff2, LOADDATA, -1, 'N' );
            }

            strcat( szMsgBuff, szMsgBuff2 );

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedReturnData )
            {
                sprintf( szMsgBuff2,                                /* 33 */
                         RETURNDATA,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ]. /* 1 */
                             pSavedReturnData[sIndex].ClientLayoutIndex);
            }
            else
            {
                sprintf( szMsgBuff2, RETURNDATA, -1 );
            }

            strcat( szMsgBuff, szMsgBuff2 );

            fprintf( fptrFileName, "%s\n", szMsgBuff );

        } /* End of for each row in the service */

        /*
         * Print out the New Relationship data for this service
         */

        fprintf( fptrFileName, "\n\nDumping New Relationship Data\n\n" );
        fprintf( fptrFileName,
                 "\nService: %s\n\n",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                     ServiceLayoutName );
        fprintf( fptrFileName,RELAT_HD1 );
        fprintf( fptrFileName,RELAT_HD2 );
        fprintf( fptrFileName,RELAT_HD3 );

        for( sIndex = 0;
             sIndex < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      NumReposServiceRows;
             sIndex++ )
        {
            sprintf( szMsgBuff,                                     /* 255 */
                     "%-4.2i   %-31.31s  %-4.2i    %3.3c     ",
                     sIndex,                                        /*   4 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemCName,/*  32 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ParentIndex,/* 4 */
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReposServiceLayoutTable[sIndex].ItemType ); /* 1 */

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pCompareKeys )
            {
               sprintf( szMsgBuff2,                                 /* 33 */
                        COMPKEYS,
                        pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                            pCompareKeys[sIndex].ClientLayoutIndex, /*  4 */
                        pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                            pCompareKeys[sIndex].LiteralUsed,       /*  1 */
                        pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                            pCompareKeys[sIndex].WildCardUsed);     /*  1 */
            }
            else
            {
                sprintf( szMsgBuff2, COMPKEYS, -1, 'N', 'N' );

            }

            strcat( szMsgBuff, szMsgBuff2 );

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadKeys )
            {
                sprintf( szMsgBuff2,                                 /* 33 */
                         LOADKEYS,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pLoadKeys[sIndex].ClientLayoutIndex,    /*  4 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pLoadKeys[sIndex].LiteralUsed );        /*  1 */
            }
            else
            {
               sprintf(szMsgBuff2, LOADKEYS, -1, 'N');
            }

            strcat( szMsgBuff, szMsgBuff2 );

            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadData )
            {
                sprintf( szMsgBuff2,                                 /* 33 */
                         LOADDATA,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pLoadData[sIndex].ClientLayoutIndex,    /*  4 */
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                             pLoadData[sIndex].LiteralUsed);         /*  1 */
            }
            else
            {
                sprintf( szMsgBuff2, LOADDATA, -1, 'N' );
            }

            strcat( szMsgBuff, szMsgBuff2 );

            if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pReturnData )
            {
                sprintf( szMsgBuff2,                                 /* 33 */
                         RETURNDATA,
                         pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                         pReturnData[sIndex].ClientLayoutIndex );    /*  4 */
            }
            else
            {
                sprintf( szMsgBuff2, RETURNDATA, -1 );
            }

            strcat( szMsgBuff, szMsgBuff2 );

            fprintf( fptrFileName, "%s\n", szMsgBuff );

        } /* End of for each row in the service */

    } /* end of for each service defined */

    /* reset the printer to defaults */
    FndGenRC = fprintf( fptrFileName, RESET_PRINTER );

    fclose( fptrFileName );

    HEAP_CHECK

    return CMN_SUCCESS;

} /* End of function DumpTables */

/*************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : SetDeleteFlag
**
**  DESCRIPTION      : This function Sets the Delete Flag variable in BFCD.
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 07/13/94
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  07/13/94  C. Crampton           Original code.
**
**  10/17/94  J. Looney             Clean Up.
************************************************************************/
WCBPROC(SetDeleteFlag)
{
    SHORT sIndex;
    USHORT FndGenRC = FND_SUCCESS;
    USHORT usRow;
    _Rlb01ELBRow RowData;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    /*
     * Find out which row is being marked for deletion
     */

    FndGenRC = FndLstBoxRowQuerySelection ( CBI_hwnd,
                                            "Rlb01ELB",
                                            FND_LSTBOX_START,
                                            &usRow,
                                            &FndGenErrorBlock );

    /*
     * Get the Row information
     */
    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
                                      "Rlb01ELB",
                                      usRow,
                                      sizeof(RowData),
                                      (void *)&RowData,
                                      &FndGenErrorBlock);
    /*
     * Find out what the service Index is
     */
    sIndex = GetServiceIndex( RowData._Rlb01ELBServerData  ,
                              RowData._Rlb01ELBServiceIDData ,
                              RowData._Rlb01ELBTranMapData ,
                              CMN_ARCH_PARMS );

    /*
     * Set the flag in BFCD
     */
    if ( sIndex >= 0 )
    {
        pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].DeleteFlag =  TRUE;
    }

    HEAP_CHECK

    return CMN_SUCCESS;

}/* end of SetDeleteFlag */

/************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : ResetDeleteFlag
**
**  DESCRIPTION      : This function Resets the Delete Flag variable in BFCD.
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 07/13/94
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  07/13/94  C. Crampton           Original code.
**
************************************************************************/
WCBPROC(ResetDeleteFlag)
{
    SHORT sIndex;
    USHORT FndGenRC = FND_SUCCESS;
    USHORT usRow;
    _Rlb01ELBRow RowData;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    HEAP_CHECK

    /*
     * Find out which row is being marked for deletion
     */
    FndGenRC = FndLstBoxRowQuerySelection ( CBI_hwnd,
                                            "Rlb01ELB",
                                            FND_LSTBOX_START,
                                            &usRow,
                                            &FndGenErrorBlock );

    /*
     * Get the Row information
     */
    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
                                      "Rlb01ELB",
                                      usRow,
                                      sizeof(RowData),
                                      (void *)&RowData,
                                      &FndGenErrorBlock);
    /*
     * Find out what the service Index is
     */
    sIndex = GetServiceIndex(RowData._Rlb01ELBServerData  ,
                             RowData._Rlb01ELBServiceIDData ,
                             RowData._Rlb01ELBTranMapData ,
                             CMN_ARCH_PARMS);

    /*
     * Set the flag in BFCD
     */
    if ( sIndex >= 0 )
    {
        pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].DeleteFlag =  FALSE;
    }

    HEAP_CHECK

    return CMN_SUCCESS;

}/* end of ResetDeleteFlag */


//***************************************************************************
//**
//**               Customer Service System Business Logic Function
//**
//**  FUNCTION         : MGCompLayouts
//**					   
//**
//**  DESCRIPTION      : This function compares the old saved map layout with
//**                     new layout extracted from the FOUNDATION Repository.
//**
//**  INPUTS           : Standard Callback parameters.
//**
//**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
//**
//**
//**  CALLED FUNCTIONS : NONE
//**
//**  AUTHOR           : mconner
//**
//**  DATE CREATED     : 11/08/93
//**
//**  REVISION HISTORY :
//**
//**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
//**  --------  -----------  -------  -------------------------------------
//**
//***************************************************************************/

USHORT MGCompLayouts ( CMN_ARCH_PARM_TYPES )
{
    USHORT FndGenRC = 0;
    SHORT sIndex;
    _STDParms *pSTDParms;


    /* Allocate memory for the parms to be passed around 
     */
    pSTDParms = (_STDParms *) malloc(sizeof(_STDParms));
    pSTDParms->pBFCD = pBFCD;
    pSTDParms->hwnd = CBI_hwnd;

    /*
     * Set the AbortFlag to FALSE, it will be set to true if the 
     * comparison fails.
     */
    pBFCD->pCSRMapBFCD->AbortFlag = FALSE;

    /* Set the warning flag to false */
    bWarn = FALSE;

    /* Set the error flag to false */
    bError = FALSE;

    /* Set the remap flag to false */
    bRemap = FALSE;

    /*
     * Save the relationship structures in case you need to fall back to the
     * saved map data. If there is a difference between the repos and saved
     * data layouts some reordering may occur. You need a fall back copy in
     * case the user wants to go back to the saved map.
     */
    for( sIndex = 0; sIndex<pBFCD->pCSRMapBFCD->NumServices; sIndex++ )
    {
        /*
         * Save existing tables
         */

        /* Compare Keys */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pCompareKeys )
        {
            if( !pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                 pSavedCompareKeys )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                       pSavedCompareKeys =
                (_RELATE_CK *) malloc((sizeof(_RELATE_CK)*MAXSERVICEROWS));

                memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                       pSavedCompareKeys,
                       0,
                       sizeof(_RELATE_CK)*MAXSERVICEROWS );
            }

            memcpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pSavedCompareKeys,
                    pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pCompareKeys,
                    sizeof(_RELATE_CK)*MAXSERVICEROWS );

        } /* End of if pCompareKeys exists */

        /* Return Data */
        if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pReturnData )
        {
            if( !pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                        pSavedReturnData )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pSavedReturnData =
                    (_RELATE_RD *) malloc((sizeof(_RELATE_RD)*MAXSERVICEROWS));

                memset( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                               pSavedReturnData,
                        0,
                        sizeof(_RELATE_RD)*MAXSERVICEROWS );
            }

            memcpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pSavedReturnData,
                    pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pReturnData,
                    sizeof(_RELATE_RD)*MAXSERVICEROWS );
        } /* End of if pReturnData exists */

        /* Load Keys */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pLoadKeys )
        {
            if( !pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                 pSavedLoadKeys )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pSavedLoadKeys =
                (_RELATE_LK *) malloc((sizeof(_RELATE_LK)*MAXSERVICEROWS));

                memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                              pSavedLoadKeys,
                       0,
                       sizeof(_RELATE_LK)*MAXSERVICEROWS );
            }

            memcpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pSavedLoadKeys,
                    pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pLoadKeys,
                    sizeof(_RELATE_LK)*MAXSERVICEROWS );

        } /* End of if pLoadKeys exists */

        /* Load Data */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pLoadData )
        {
            if( !pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pSavedLoadData )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pSavedLoadData =
                (_RELATE_LD *) malloc((sizeof(_RELATE_LD)*MAXSERVICEROWS));

                memset( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                               pSavedLoadData,
                        0,
                        sizeof(_RELATE_LD)*MAXSERVICEROWS );
            }

            memcpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pSavedLoadData,
                    pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pLoadData,
                    sizeof(_RELATE_LD)*MAXSERVICEROWS );

        } /* End of if pLoadData exists */

        /* Repeating Maps */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pRepeatingMaps )
        {
            if( !pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                pSavedRepeatingMaps )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].pSavedRepeatingMaps =
                (_RELATE_RPMH *) malloc((sizeof(_RELATE_RPMH)*MAXSERVICEROWS));

                memset( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                               pSavedRepeatingMaps,
                        0,
                        sizeof(_RELATE_RPMH)*MAXSERVICEROWS );
            }

            memcpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pSavedRepeatingMaps,
                    pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].
                           pRepeatingMaps,
                    sizeof(_RELATE_RPMH)*MAXSERVICEROWS );

        } /* End of if pRepeatingMaps exists */

    } /* end of loop for number of services */


    FndGenRC = Azcs001BusCompareLayouts( pSTDParms );
    if (FndGenRC != CMN_SUCCESS ) 
    {
        return CMN_FAIL;
    }
    else
    {
        return CMN_SUCCESS;
    }
        
} /* end of function MGCompLayouts  */


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001BusCompareLayouts
**
**  DESCRIPTION      : This function is the controlling function for comparing a saved
**                      data layout with the current repository layout.
**
**  INPUTS           : pSTDParms - This is a pointer to the STDParms data structure.
**                                 It contains a pointer to BFCD and a pointer to the window
**                                 handle. You need this because the compare layouts runs
**                                 as a seperate thread spawned from the window.
**
**  OUTPUTS          : Return Code - VOID
**
**
**  CALLED FUNCTIONS : CheckIt
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/21/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/21/93  CCRAMPTO              Original code.
**
**  10/18/94  JLOONEY               Clean Up.
**
**  03/22/96  mconner               Changed all semaphore calls to CmnOs calls
**
**  03/22/96  mconner               Commented out all HEAP_CHECK_BEEP calls
**
**  07/29/96  JLOONEY				Clean up again.
***************************************************************************/
USHORT Azcs001BusCompareLayouts(_STDParms *pSTDParms)
{


    SHORT nServiceIndex;
    SHORT sNumRows;
	SHORT rc = 0;
    USHORT FndGenRC;
    USHORT MsgID;
    HWND hwnd;
    BOOL bMatch = TRUE;
    BOOL bInfo  = FALSE;
    BOOL bCritical = FALSE;
    CHAR MsgData[255];
    _LAYOUT_REC *pReposLayout;
    _LAYOUT_REC *pSavedLayout;
    _BFCD * pBFCD;
	LONG LastError = 0;

    /* Save off the STDParm values */
    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    /* Send a message to the window for the 1st message of the listbox */
    MsgID = CMN_MAPGEN_MSG_INFO;
    strncpy( MsgData,
             "***** Starting Comparison of Repository and Saved Map "
             "Data Layouts *****",
             sizeof( MsgData ));

    FndGenRC = LogMsg(MsgID, MsgData);

    if (FndGenRC != CMN_SUCCESS) return (CMN_FAIL);

    /* Check the Client map first */
    MsgID = CMN_MAPGEN_MSG_INFO;

    sprintf( MsgData,                                            /* 255 */
             "Checking Client Layout %s.",
             pBFCD->pCSRMapBFCD->ClientInfo.ClientLayoutName );  /*   9 */
   
    FndGenRC = LogMsg(MsgID, MsgData);
    if (FndGenRC != CMN_SUCCESS) return (CMN_FAIL);


    /* Error if the number of client rows have changed */
    if( pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows !=
        pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows )
    {
        bMatch = FALSE;

        MsgID = CMN_MAPGEN_MSG_ERROR;

        strncpy( MsgData,
                 "The number of Data Rows in the Repository is not the "
                 "same as in the Saved Map",
                 sizeof( MsgData ));
        
        FndGenRC = LogMsg(MsgID, MsgData);
        if (FndGenRC != CMN_SUCCESS) return (CMN_FAIL);

    } /* end of if:  Error, the number of client rows have changed */

    /* Populate local vars for easier use */
    pReposLayout = pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable;
    pSavedLayout = pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable;

    /* Use the lower of the two values as the maximum rows to check */
    if( pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows <
        pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows )
    {
        sNumRows = pBFCD->pCSRMapBFCD->ClientInfo.NumClientRows;
    }

    else
    {
        sNumRows = pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows;
    }

    FndGenRC = Azcs001CheckIt( MAP_GEN_CLIENT_LAYOUT,
							 0,
							 sNumRows,
							 pReposLayout,
							 pSavedLayout,
							 pSTDParms );

	if ( FndGenRC != CMN_SUCCESS ) 
    {
        return ( CMN_FAIL );
    }


    if( bRemap )
    {

        return CMN_SUCCESS;
    }

    MsgID = CMN_MAPGEN_MSG_INFO;
    sprintf( MsgData,                                              /* 255 */
             "Finished Checking Client Layout %s.",
             pBFCD->pCSRMapBFCD->ClientInfo.ClientLayoutName );    /*   9 */

    FndGenRC = LogMsg(MsgID, MsgData );
	if( FndGenRC != CMN_SUCCESS ) return CMN_FAIL;

    /* Check each of the service maps next */
    for( nServiceIndex = 0;
         nServiceIndex < pBFCD->pCSRMapBFCD->NumServices;
         nServiceIndex++ )
    {
        MsgID = CMN_MAPGEN_MSG_INFO;                                /* 255 */
        sprintf( MsgData,
                 "Checking Service Layout %s.",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                        ServiceLayoutName );                        /*  12 */

        FndGenRC = LogMsg(MsgID, MsgData );
		if ( FndGenRC != CMN_SUCCESS ) return CMN_FAIL;

        pReposLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                              pReposServiceLayoutTable;
        pSavedLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                              pServiceLayoutTable;

        /*
         * Check and make sure the size of the Service copy book has not
         * changed.  If it has changed they must regenerate or else small
         * buff problems will occur.
         */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
            NumReposServiceRows !=
            pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
            NumServiceRows )
        {
            MsgID = CMN_MAPGEN_MSG_ERROR;
            sprintf( MsgData,                                       /* 255 */
                     "Service Layout %s has changed in size."
                     " You must regenerate to correct this problem",
                     pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                            ServiceLayoutName );                    /*  12 */

            FndGenRC = LogMsg(MsgID, MsgData);
		    if ( FndGenRC != CMN_SUCCESS ) return CMN_FAIL;

        }

        /* Use the smaller of the two row sizes as the max rows to check */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                   NumReposServiceRows >
            pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                   NumServiceRows )
        {
            sNumRows = pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                              NumServiceRows;
        }
        else
        {
            sNumRows = pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                              NumReposServiceRows;
        }

        FndGenRC = Azcs001CheckIt( MAP_GEN_SERVICE_LAYOUT,
								 nServiceIndex,
								 sNumRows,
								 pReposLayout,
								 pSavedLayout,
								 pSTDParms );
  		 
		if ( FndGenRC != CMN_SUCCESS ) return CMN_FAIL;

        if ( bRemap )
        {

            return CMN_SUCCESS;
        }

        MsgID = CMN_MAPGEN_MSG_INFO;
        sprintf( MsgData,                                           /* 255 */
                 "***** Finished Checking Service Layout %s.",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[nServiceIndex].
                        ServiceLayoutName );                        /*  12 */

        FndGenRC = LogMsg( MsgID, MsgData );
		if ( FndGenRC != CMN_SUCCESS ) return CMN_FAIL;

    } /* end of for loop thru NumServices */

    return CMN_SUCCESS;

} /* end of Azcs001BusCompareLayouts */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001CheckIt
**
**  DESCRIPTION      : This function controls the comparision of 2 data layouts.
**
**  INPUTS           : cLayoutType - Flag to determine if this a client or service layout.
**                     sServiceIndex - Service Table index.
**                     sNumRows - Number of rows in the layouts.
**                     pReposLayout - pointer to the repository layout structure.
**                     pSavedLayout - pointer to the saved layout structure.
**                     pSTDParms - pointer to the stdparms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : Azcs001CheckIt
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/21/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/21/93  CCRAMPTO              Original code.
**
**  10/18/94  JLOONEY               Clean Up.
**
**  03/22/96  mconner               Changed all semaphore calls to CmnOs calls
**  03/22/96  mconner               Commented out all HEAP_CHAECK_BEEP calls
**
***************************************************************************/
static USHORT Azcs001CheckIt( CHAR cLayoutType,
                      SHORT sServiceIndex,
                      SHORT sNumRows,
                      _LAYOUT_REC *pReposLayout,
                      _LAYOUT_REC *pSavedLayout,
                      _STDParms *pSTDParms )
{
    SHORT sIndex;
    SHORT sRC = 0;
    USHORT    MsgID;
    USHORT FndGenRC;
    CHAR MsgData[255];
    BOOL bMatch = TRUE;
    BOOL bWarn = FALSE;
    BOOL bError = FALSE;
    BOOL bMisAligned = FALSE;
    _BFCD * pBFCD;
    HWND hwnd;

    /*HEAP_CHECK_BEEP*/

    /* Save off the STDParm values */
    pBFCD = pSTDParms->pBFCD;
    hwnd  = pSTDParms->hwnd;

    for ( sIndex = 0; sIndex < sNumRows; sIndex++ )
    {
        if( strncmp( pReposLayout[sIndex].ItemId,
                     pSavedLayout[sIndex].ItemId,
                     strlen(pSavedLayout[sIndex].ItemId )) != 0 )
        {
            if ( !bMisAligned )
            {
                MsgID  = CMN_MAPGEN_MSG_ERROR;
                bError = TRUE;

                sprintf( MsgData,                                /* 255 */
                /* 44 */ "Names do NOT match, The order of the layout "
                /* 78 */ "records has changed !! Saved map Row %d = %s "
                /* 56 */ "Repository Row %d = %s",
                         sIndex,
                         pSavedLayout[sIndex].ItemId,
                         sIndex,
                         pReposLayout[sIndex].ItemId );

                FndGenRC = LogMsg( MsgID, MsgData );

                bMisAligned = TRUE;
            }

            /* Try and remap the existing relationships */
            if ( !bRemap )
            {
                sRC = Azcs001Remap( pSTDParms );
				if (sRC != CMN_SUCCESS ) 
				{
					return CMN_FAIL;
				}
				else
				{
					bRemap = TRUE;
                    return CMN_SUCCESS;
				}
            }

            continue;
        }

        if( pReposLayout[sIndex].ItemType != pSavedLayout[sIndex].ItemType )
        {
            MsgID = CMN_MAPGEN_MSG_WARN;
            bError = TRUE;

            sprintf( MsgData,                                   /* 255 */
                     "The data type of item %s has changed !! Saved map ="
                     " %c Repository = %c",
                     pReposLayout[sIndex].ItemId,               /*  32 */
                     pSavedLayout[sIndex].ItemType,             /*   1 */
                     pReposLayout[sIndex].ItemType );           /*   1 */

            FndGenRC = LogMsg( MsgID, MsgData );

        }

        if( pReposLayout[sIndex].ItemType == 'E' &&
            pReposLayout[sIndex].Format != pSavedLayout[sIndex].Format )
        {
            MsgID = CMN_MAPGEN_MSG_WARN;
            bError = TRUE;

            sprintf( MsgData,                                    /* 255 */
                     "The data format of item %s has changed !! Saved map "
                     "= %c Repository = %c",
                     pReposLayout[sIndex].ItemId,                /*  32 */
                     pSavedLayout[sIndex].Format,                /*   1 */
                     pReposLayout[sIndex].Format);               /*   1 */

            FndGenRC = LogMsg( MsgID, MsgData );

        }

        if( pReposLayout[sIndex].ItemLength != pSavedLayout[sIndex].
                                               ItemLength )
        {
            MsgID = CMN_MAPGEN_MSG_WARN;
            bWarn = TRUE;

            sprintf( MsgData,                                   /* 255 */
                     "The data length of item %s has changed !! Saved map"
                     " = %d Repository = %d",
                     pReposLayout[sIndex].ItemId,               /*  32 */
                     pSavedLayout[sIndex].ItemLength,           /*   4 */
                     pReposLayout[sIndex].ItemLength);          /*   4 */

            FndGenRC = LogMsg( MsgID, MsgData );

        }

        if( pReposLayout[sIndex].ItemType == 'E' &&
            strcmp( pReposLayout[sIndex].Usage,
                    pSavedLayout[sIndex].Usage) != 0 )
        {
            MsgID = CMN_MAPGEN_MSG_WARN;
            bError = TRUE;

            sprintf( MsgData,                                   /* 255 */
                     "The data usage of item %s has changed !! Saved map"
                     " = %s Repository = %s",
                     pReposLayout[sIndex].ItemId,               /*  32 */
                     pSavedLayout[sIndex].Usage,                /*   3 */
                     pReposLayout[sIndex].Usage );              /*   3 */

            FndGenRC = LogMsg( MsgID, MsgData );

        }

        if ( 'G' == pReposLayout[sIndex].ItemType  &&
              pReposLayout[sIndex].ItemOccurs !=
              pSavedLayout[sIndex].ItemOccurs )
        {
              MsgID = CMN_MAPGEN_MSG_WARN;
              bError = TRUE;

              sprintf( MsgData,                                 /* 255 */
                       "The number of occurences of Group %s has changed "
                       "!! Saved map = %d Repository = %d",
                       pReposLayout[sIndex].ItemId,             /*  32 */
                       pSavedLayout[sIndex].ItemOccurs,         /*   4 */
                       pReposLayout[sIndex].ItemOccurs );       /*   4 */

              FndGenRC = LogMsg( MsgID, MsgData );

        }
    } /* END OF LOOP THRU ALL ROWS */


    return CMN_SUCCESS;

} /* end of Azcs001CheckIt() */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : LogMsg
**
**  DESCRIPTION      : This function logs a message to the comparison log file.
**
**  INPUTS           : usMsgID - Indicates the typoe of message.
**                     pzsMsgData - Literal message to print.
**                     pSTDParms - pointer to the stdparms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : 
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 11/12/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/13/96  mconner              Original code.
**
**
***************************************************************************/
USHORT LogMsg(USHORT usMsgID, char * pzsMsgData)
{
    char sMsgType[MSG_TYPE_LEN] = "";
    int rc;

    switch(usMsgID)
    {
    case CMN_MAPGEN_MSG_INFO:
        strcpy(sMsgType, "INFO");
        break;

    case CMN_MAPGEN_MSG_WARN:
        strcpy(sMsgType, "WARNING");
        break;

    case CMN_MAPGEN_MSG_ERROR:
        strcpy(sMsgType, "ERROR");
        break;
    }


    fprintf( fpLog, "%s:%s\n", sMsgType, pzsMsgData);
    if (rc < 0 ) return CMN_FAIL;

    return CMN_SUCCESS;
}/*end of LogMsg*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001Remap
**
**  DESCRIPTION      : This function trys to remap existing relationships when
**                       a saved data layouts and the repository data layouts do not match.
**
**  INPUTS           : pSTDParms - Pointer the the STDParms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : Azcs001ChangeIt
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/08/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
**  03/22/96  mconner               Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001Remap(_STDParms *pSTDParms)
{
    SHORT sOccurs=0;
    SHORT sNumTimes=0;
    SHORT sNewServIndex;
    SHORT sServx;
    SHORT sRowx;
    SHORT sRC=0;
    SHORT FndGenRC=0;
    USHORT MsgID=0;
    CHAR MsgData[255];
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _BFCD * pBFCD;
    HWND hwnd;

    /*HEAP_CHECK_BEEP*/

    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    /* Cleanup the layout tables */
    for ( sServx = 0; sServx < pBFCD->pCSRMapBFCD->NumServices; sServx++ )
    {
        for ( sRowx = 1;
              sRowx < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                        NumReposServiceRows;
              sRowx++ )
        {

            /* Compare Key */
            if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pCompareKeys )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                  pCompareKeys[sRowx].ClientLayoutIndex = -1;
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                  pCompareKeys[sRowx].LiteralUsed = 'N';
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                  pCompareKeys[sRowx].WildCardUsed = 'N';
            } /* end of if:  Compare Key */


            /* Load Key */
            if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pLoadKeys )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                  pLoadKeys[sRowx].ClientLayoutIndex = -1;
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                  pLoadKeys[sRowx].LiteralUsed = 'N';
            } /* end of if:  Load Key */


            /* Load Data */
            if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pLoadData )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pLoadData[sRowx].
                                              ClientLayoutIndex = -1;
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pLoadData[sRowx].
                                              LiteralUsed = 'N';
            } /* end of if:  Load Data */

            /* Return Data */
            if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pReturnData )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                     pReturnData[sRowx].ClientLayoutIndex = -1;

            } /* end of if:  Return Data */

            /* RPMH */
            if (pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].pRepeatingMaps )
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                   pRepeatingMaps[sRowx].ClientLayoutIndex = -1;
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                   pRepeatingMaps[sRowx].SingleOccurence = 'N';
            } /* end of if:  RPMH */

        } /* end of loop thru each row */

     } /* end of loop thru each service */

     /* Loop thru each of the services */
    for ( sServx = 0; sServx < pBFCD->pCSRMapBFCD->NumServices; sServx++ )
    {
        pSavedLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                                       pServiceLayoutTable;
        pReposLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                                  pReposServiceLayoutTable;

        sprintf( MsgData,
                 "Remapping Service Layout %s. ",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                     ServiceLayoutName );

        MsgID = CMN_MAPGEN_MSG_INFO;

        FndGenRC = LogMsg( MsgID, MsgData );

        /* Loop thru each of the rows in this service layout record */
        for ( sRowx = 1;
              sRowx < pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                             NumServiceRows;
              sRowx++ )
        {
            /* Find the service rows new index */
            sNumTimes = FindFullName( sRowx,
                                      pSavedLayout,
                                      pReposLayout,
                                      pBFCD->pCSRMapBFCD->
                                             ServiceInfoTable[sServx].
                                                 NumReposServiceRows,
                                      &sNewServIndex );

            /*
             * See if this group.element is unique.
             * if it is not unique you can not remap it so drop any
             * relationships.
             */
            switch( sNumTimes )
            {
                case 1:
                {
                    /*
                     * Change the relationhip indexs
                     */
                    sRC = Azcs001ChangeIt( sServx,
                                    sRowx,
                                    sNewServIndex,
                                    pSTDParms );

					if (sRC != CMN_SUCCESS ) return CMN_FAIL;

                    break;
                } /* end of case 1 */

                case 0:
                {
                    sprintf( MsgData,              /* 255 */
                             "Service Element %s no longer exists in the "
                              "repository layout. ",
                             BuildFullName(sRowx, pSavedLayout)); /* 255 */

                    MsgID = CMN_MAPGEN_MSG_INFO;

                    FndGenRC = LogMsg( MsgID, MsgData );

                    continue;
                }  /* end of case 0 */

            } /* end of switch(sNumTimes) */

        } /* end of loop thru each row in the service */

        sprintf( MsgData,                                       /* 255 */
                 "Done remapping Service Layout %s. ",
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sServx].
                                        ServiceLayoutName );

        MsgID = CMN_MAPGEN_MSG_INFO;

        FndGenRC = LogMsg( MsgID, MsgData );

    } /* end of for loop thru each of the services */

    /*HEAP_CHECK_BEEP*/

    return CMN_SUCCESS;

} /* End of Azcs001Remap() */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001ChangeIt
**
**  DESCRIPTION      : This function trys to remap existing any relationships for a
**                       specific row.
**
**  INPUTS           : sServ - The current services number.
**
**                     sIndex - The saved relationship tables row index.
**
**                     sNewReposIx - The repository tables row index.
**
**                     pSTDParms - pointer to the standard parms data structure.
**                         This includes a pointer to BFCD and the calling programs window
**                         handle.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : ChangeLK
**                     ChangeCK
**                     ChangeLD
**                     ChangeRD
**                     ChangeRPMH
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/08/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean Up.
**  03/22/96  mconner               Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001ChangeIt( SHORT sServ,
                SHORT sIndex,
                SHORT sNewReposIx,
                _STDParms *pSTDParms)
{
    USHORT MsgID=0;
    SHORT FndGenRC;
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _BFCD * pBFCD;
    HWND hwnd;

    /*HEAP_CHECK_BEEP*/

    /* Assign the input parameters to local variables */
    pBFCD = pSTDParms->pBFCD;
    hwnd  = pSTDParms->hwnd;

    /* Assign BFCD variables to local variables for easier reading */
    pSavedLayout = pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable;

    /* See if any Load Keys are defined for this service */
    if (pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadKeys)
    {
        FndGenRC = Azcs001ChangeLK( sServ, sIndex, sNewReposIx, pSTDParms );
        if ( FndGenRC != CMN_SUCCESS )
        {

           return FndGenRC;

        }
    } /* End of Load Keys logic */

    /* See if any Compare Keys are defined for this service */
    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pCompareKeys )
    {
        FndGenRC = Azcs001ChangeCK(sServ, sIndex, sNewReposIx, pSTDParms);

        if ( FndGenRC != CMN_SUCCESS )
        {
            return(FndGenRC);
        }

    } /* End of Compare Keys logic */

    /* See if any Load Data relationships are defined for this service */
    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadData )
    {
        FndGenRC = Azcs001ChangeLD(sServ, sIndex, sNewReposIx, pSTDParms);

        if ( FndGenRC != CMN_SUCCESS )
        {

            return(FndGenRC);
        }

    } /* End of Load Data logic */

    /* See if any Return Data relationships are defined for this service */
    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pReturnData )
    {
        FndGenRC = Azcs001ChangeRD( sServ, sIndex, sNewReposIx, pSTDParms );

        if ( FndGenRC != CMN_SUCCESS )
        {

            return(FndGenRC);

        }

    } /* End of Return Data logic */

    /* See if any Repeating Maps Header relationships are defined for this
     * service
     */
    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pRepeatingMaps )
    {
        FndGenRC = Azcs001ChangeRPMH( sServ, sIndex, sNewReposIx, pSTDParms );

        if ( FndGenRC != CMN_SUCCESS )
        {

            return( FndGenRC );

        }

    } /* End of Load Data logic */


    return CMN_SUCCESS;

} /* End of function Azcs001ChangeIt */


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : Azcs001ChangeLK
**
**  DESCRIPTION      : This function changes the indexes for the Load Key relationship table.
**
**  INPUTS           : sServ - The current services index
**
**                     sIndex - Index to services saved relationship tables.
**
**                     sNewReposIx - Index to the services repository tables.
**
**                     pSTDParms - pointer to the standard parms data structure.
**                         This includes a pointer to BFCD and the calling programs window
**                         handle.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : FindFullName
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/15/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean Up
**	03/22/96  mconner               Commented out HEAP_CHECK_BEEP
**
***************************************************************************/
SHORT Azcs001ChangeLK( SHORT sServ,
                SHORT sIndex,
                SHORT sNewReposIx,
                _STDParms *pSTDParms )

{
    USHORT MsgID=0;
    SHORT FndGenRC = 0;
    SHORT sClientx;
    SHORT sNewClientIndex;
    SHORT sNumTimes;
    CHAR MsgData[255];
    CHAR ClientName[255];
    CHAR ServiceName[255];
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _BFCD * pBFCD;
    HWND hwnd;

    /*HEAP_CHECK_BEEP*/

    /* Assign the input parameters to local variables */
    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    /* Assign BFCD variables to local variables for easier reading */
    pSavedLayout = pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable;

    /*
     * Copy the saved data using the old index to the new table using
     * the new index
     */
    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pLoadKeys[sNewReposIx] =
           pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedLoadKeys[sIndex];

    /* If a relationship exists see what the client indexes are */
    if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
        pSavedLoadKeys[sIndex].ClientLayoutIndex > 0 )
    {
        sClientx = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pSavedLoadKeys[sIndex].ClientLayoutIndex;

        /* Find the new Client index */
        sNumTimes = FindFullName( sClientx,
                                  pSavedLayout,
                                  pReposLayout,
                                  pBFCD->pCSRMapBFCD->ClientInfo.
                                       NumReposClientRows,
                                  &sNewClientIndex );

        switch(sNumTimes)
        {
            case 0:
            {
                sprintf( MsgData,           /* 255 */
                         "Client Element %s no longer exists in the "
                         "repository layout. "
                         "Any previous relationships will be dropped",
                         BuildFullName(sClientx, pSavedLayout) ); /* 255 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                FndGenRC = LogMsg( MsgID, MsgData );

                Azcs001DropClient( sClientx, sServ, 1, pSTDParms );

                /*mdc 011497 removed return added break
                return CMN_FAIL;            */
                break;
            } /* end of case 0 */

            case 1:
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                            pLoadKeys[sNewReposIx].ClientLayoutIndex =
                                                           sNewClientIndex;

                strncpy( ClientName,
                         BuildFullName(sClientx, pSavedLayout),
                         sizeof( ClientName ));

                strncpy( ServiceName,
                         BuildFullName( sIndex,
                                        pBFCD->pCSRMapBFCD->
                                               ServiceInfoTable[sServ].
                                               pServiceLayoutTable),
                         sizeof( ServiceName ));

                sprintf( MsgData,               /* 255 */
                         "Remapping LK Relationship between Client "
                         "Element %s and Service Element %s.",
                         ClientName,            /* 255 */
                         ServiceName );         /* 255 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                FndGenRC = LogMsg( MsgID, MsgData );

                break;

            } /* end of case 1 */

        } /* end of switch */

    } /* end of if a relationship is defined */


    return CMN_SUCCESS;

} /* end of function Azcs001ChangeLK */

