**  --------  -----------  -------  -------------------------------------
**  99/99/99  C. Crampton           Original code.
**
**  10/14/94  J. Looney             Clean up.
**
***************************************************************************/
static WCBPROC(OpnAZCS4)
{
    CHAR   WindowName[]   = "AZCS004";
    CHAR   InstanceName[] = "AZCS004";
    SHORT  nRC            = CMN_SUCCESS;
    USHORT FndGenRC       = CMN_SUCCESS;
    USHORT nSelectedRow   = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _Rlb01ELBRow ListBox;
    _AZCS004I InCpyBook;

    HEAP_CHECK

    /* Find out which row is selected in the service ELB */
    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                           "Rlb01ELB",
                                           FND_LSTBOX_START,
                                           &nSelectedRow,
                                           &FndGenErrorBlock );

    /* Get the data for the service row in the ELB */
    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
                                      "Rlb01ELB",
                                      nSelectedRow,
                                      sizeof(ListBox),
                                      &ListBox,
                                      &FndGenErrorBlock );

    /* Populate the name of the client layout in the input layout */
    strncpy( InCpyBook.ClientLayout,
             ClientLayoutData,
             sizeof( InCpyBook.ClientLayout ));

    InCpyBook.pRelate = NULL;

    /* Create the Copmpare Key window */
    FndGenRC = CmnWindowCreate( WindowName,
                                InstanceName,
                                NULL,
                                &InCpyBook,
                                CMN_ARCH_PARMS );

    HEAP_CHECK

    return CMN_SUCCESS;
} /* end of OpnAZCS4 */

