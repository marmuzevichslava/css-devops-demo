AZCS009ID DIALOG LOADONCALL MOVEABLE DISCARDABLE 0,0,200,79
    STYLE 0 
     | WS_CAPTION
     | DS_MODALFRAME
    CAPTION "Specify Directories"
    
Begin  /* controls */
   CONTROL "OK",1000,
              FND_PUSH_BUTTON,
              WS_VISIBLE  | WS_GROUP | WS_TABSTOP
              | BS_PUSHBUTTON
              ,6,63,32,12

   CONTROL "Cancel",1001,
              FND_PUSH_BUTTON,
              WS_VISIBLE  | WS_GROUP | WS_TABSTOP
              | BS_PUSHBUTTON
              ,46,63,32,12

   CONTROL "&Save Directory:",500,
              FND_STATICTEXT,
              WS_VISIBLE | SS_LEFT 
              ,14,17,63,8

   CONTROL "",100,
              FND_ENTRYFIELD,
              WS_VISIBLE | WS_TABSTOP
              ,80,13,0,0

   CONTROL "&Generation Directory:",501,
              FND_STATICTEXT,
              WS_VISIBLE | SS_LEFT 
              ,11,41,66,8

   CONTROL "",101,
              FND_ENTRYFIELD,
              WS_VISIBLE | WS_TABSTOP
              ,80,37,0,0

End /* controls */


