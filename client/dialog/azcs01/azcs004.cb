static WCBPROC(ChangeServiceType)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

int ix=0;

/*
** Unselect any client rows
*/

for (ix=0; ix < pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows; ix++)
    {
     Rlb01ELBSelIndData[ix] = FALSE;
    }
/*
** Enable Apply Pushbutton
*/

FndGenRC = FndCommandEnable(CBI_hwnd,
                            "ApplyPB",
                            &FndGenErrorBlock);

/*
** Disable Remove Pushbutton
*/
FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);


return(CMN_SUCCESS);
} /* END OF FUNCTION ChangeClientType */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : LookForClientName
**
**  DESCRIPTION      : This function looks for a matching Client name.
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(LookForClientName)

{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
char ReposName[ITEM_NAME_LEN];
short ix;
short ServiceNum = 0;
BOOL ServiceInCobol;
short ServiceElmnt;
short ServiceRow;

 ServiceNum = pWindContextData->WCD.CurrentServiceIndex;


/***************************************************************/
/* Find out what language the service is using.                */
/***************************************************************/

 FndGenRC = FndCommandQueryChecked( CBI_hwnd,
                                    "AMNSRVCB",
                                    &FndGenErrorBlock);


FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;


/***************************************************************/
/* Get the service name from the repository based on language. */
/***************************************************************/

 if (FndGenRC == FND_SUCCESS)
    {
     ServiceInCobol = TRUE ;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
    }
 else
    {
     ServiceInCobol = FALSE;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
    }

/***************************************************************/
/* Loop thru the client repository rows and try to find a match*/
/***************************************************************/

 for (ix=0; ix < pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows; ix++)
     {
      if (ServiceInCobol)  /* service name is in cobol */
         {
          if(strcmp(ReposName,
                    (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ix)->ItemCobolName) == 0)
            {
             return(ix);
            }
         }
      else
         {
          if(strcmp(ReposName,
             (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ix)->ItemCName) == 0)
            {
             return(ix);
            }
         }
     } /* end of for loop thru client repository rows */

return(CMN_FAIL);   /* Did not find a match so return fail */

}/* end of function  LookForClientName */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : LookForServiceName
**
**  DESCRIPTION      : This function looks for a matching Service name.
**
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(LookForServiceName)

{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
char ReposName[ITEM_NAME_LEN];
short ix;
short ServiceNum = 0;
BOOL ClientInC;
char TempName[ITEM_NAME_LEN];
short ClientRow;
short ClientElmnt;

 ServiceNum = pWindContextData->WCD.CurrentServiceIndex;

/***************************************************************/
/* Find out what language the client is using.                 */
/***************************************************************/

 FndGenRC = FndCommandQueryChecked( CBI_hwnd,
                                    "AMNCLTC",
                                    &FndGenErrorBlock);

 FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);

 ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


/***************************************************************/
/* Get the client name from the repository based on language. */
/***************************************************************/

 if (FndGenRC == FND_SUCCESS)
    {
     ClientInC = TRUE ;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
 else
    {
     ClientInC = FALSE;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
    }

/***************************************************************/
/* Loop thru the client repository rows and try to find a match*/
/***************************************************************/

 for (ix=0; ix < pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].NumReposServiceRows; ix++)
     {
      if (ClientInC)  /* Client name is in C */
         {
          strcpy(TempName,
             (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCName);

          if(strcmp(ReposName,
                    TempName) == 0)
            {
             return(ix);
            }
         }
      else
         {
          strcpy(TempName,
              (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCobolName);

          if(strcmp(ReposName,
              (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCobolName) == 0)
            {
             return(ix);
            }
         }
     } /* end of for loop thru client repository rows */

return(CMN_FAIL);   /* Did not find a match so return fail */

}/* end of function  LookForServiceName */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : ClientEmntToRow
**
**  DESCRIPTION      : This function calculates the Client LB row number
**                       based on the Element Number.
**
**  INPUTS           : short ServiceElmnt
**                     CMN_ARCH_PARMS
**
**  OUTPUTS          : Return Code - SHORT (Row Number).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static short ClientElmntToRow(short ClientElmnt, CMN_ARCH_PARM_TYPES)
{
 short ix;

 ix = ClientElmnt % NUMRLB01ELBROWS;

 return(ix);

} /* end of function ClientElmntToRow */


