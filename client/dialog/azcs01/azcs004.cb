/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSSaveToBFCD
**
**  DESCRIPTION      : This function controls the logic when data needs to
**                      be moved from WCD to BFCD.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(AZCS004BUSSaveToBFCD)
{
 SHORT ix;
 _RELATE_CK *pOldBFCD;
 _RELATE_CK *pTempBFCD;
 _RELATE_CK *pTempWCD;
 SHORT TempSize;


 for (ix=0; ix<pWindContextData->WCD.NumServices; ix++)
     {
      pOldBFCD = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys;

      pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys =
         (_RELATE_CK *) malloc(MAXSERVICEROWS * sizeof(_RELATE_CK) );

      memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys ,
             0,
             MAXSERVICEROWS * sizeof(_RELATE_CK));

      free(pOldBFCD);
      pTempBFCD = (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys);
      pTempWCD = (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys);
      TempSize = (MAXSERVICEROWS * sizeof(_RELATE_CK));

      pOldBFCD =memcpy((pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys),
             (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys),
             (MAXSERVICEROWS * sizeof(_RELATE_CK)) );

      free(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys);
     }

return(CMN_SUCCESS);

} /* end of function AZCS004BUSSaveToBFCD  */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FillStatusCK
**
**  DESCRIPTION      : This function controls the logic that fills the
**                      status icon column of the list boxes.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
****
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


/* CSC: 09/13/93 Modified for multi-page logic */

WCBPROC(FillStatusCK)
{

SHORT ix;
SHORT ServNum;
SHORT ClientRow;
SHORT ServiceRow;
SHORT ClientElmnt;

ServNum = pWindContextData->WCD.CurrentServiceIndex;

/* Clear out the Client Listbox */
for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     if (Rlb01ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb01ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }
/*
** Clear out the service Listbox
*/
for (ix=0; ix < NUMRLB02ELBROWS; ix++)
    {
     if (Rlb02ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb02ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }

/*
** Loop thru the Compare relationship table to find relationships
*/

for (ix=0;
     ix < pWindContextData->WCD.ServiceInfoTable[ServNum].NumReposServiceRows;
     ix++)
    {
     /*
     ** See if this service element has a relationship with a
     **   client element defined.
     */

     if (pWindContextData->WCD.ServiceInfoTable[ServNum].pCompareKeys[ix].ClientLayoutIndex > 0 )
        {
         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ServNum].pCompareKeys[ix].ClientLayoutIndex;

         /*
         ** If the row is in the Client or Service LB mark it completed
         */
         if (ClientElmnt >= pWindContextData->WCD.ClientLBOffset &&
             ClientElmnt <  pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS)
            {
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);
             Rlb01ELBCdStatusIconicData[ClientRow] = CMN_LBROW_STATUS_COMPLETED;
            }
         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
             ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }
        }
    /*
    ** If the service element has a literal relationship defined
    */
    else if (pWindContextData->WCD.ServiceInfoTable[ServNum].pCompareKeys[ix].LiteralUsed == 'Y')
        {
         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
             ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }
        }
    }  /* end of for loop thru all service CK rows */

return(CMN_SUCCESS);

} /* end of function FillStatusCK */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : InitClient1
**
**  DESCRIPTION      : This function initializes the Client LB fields and
**                      sets the controls to thier default position.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(InitClient1)
{

USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;

/*
** Enable the radio button elements
*/


FndGenRBValueShort = LT_ClntElementRB;
ClntTypeData = FndGenRBValueShort;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRBValueShort = LT_ClntLiteralRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRBValueShort = LT_ClntHvRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRBValueShort = LT_ClntLVRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

/*
** Disable the Entry fields
*/

strcpy(ClntElementData, "");
FndGenRC = FndFieldEnable(CBI_hwnd,
                          "CLNTELEMENT",
                          &FndGenErrorBlock);

strcpy(ClntLiteralData, "");
FndGenRC = FndFieldDisable(CBI_hwnd,
                           "CLNTLITERAL",
                           &FndGenErrorBlock);
/*
** Disable the pushbuttons
*/

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

return(CMN_SUCCESS);

} /* InitClient1 */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : InitService1
**
**  DESCRIPTION      : This function initializes the Service LB fields and
**                      sets the controls to thier default position.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
