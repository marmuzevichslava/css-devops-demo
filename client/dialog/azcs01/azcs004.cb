/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : ClntLng
**
**  DESCRIPTION      : This function changes the Client language check field from C
**                       to COBOL or vice versa.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (ClntLng)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

FndGenRC = FndCommandQueryChecked (CBI_hwnd,
                                   "AMNCLTC",
                                   &FndGenErrorBlock);

if (FndGenRC == FND_SUCCESS)
    {
     pWindContextData->WCD.ClientLanguage = C_LANGUAGE;
    }
else if (FndGenRC == CMD_COMMAND_NOT_CHECKED)
    {
     pWindContextData->WCD.ClientLanguage = COBOL_LANGUAGE;
    }
else
    {
     return(CMN_FAIL);
    }

FndGenRC = FillClientLB(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return(CMN_SUCCESS);
} /* end of function ClntLng */

