/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FillLayoutLB
**
**  DESCRIPTION      : This function controls the filling of the specified List Box.
**
**  INPUTS           :  char              *LBName
**                      _LAYOUT_REC       *pLayout
**                      unsigned short     NumRecords
**                      enum LANGUAGE_TYPE Language
**                      CMN_ARCH_PARM_TYPES
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


short FillLayoutLB(char              *LBName,
                   _LAYOUT_REC       *pLayout,
                   unsigned short     NumRecords,
                   enum LANGUAGE_TYPE Language,
                   CMN_ARCH_PARM_TYPES)

{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
_Rlb01ELBRow NewRow;
unsigned short index=0;
char padding[]="   ";
short index2=0;
 _LAYOUT_REC *pTemp;
char ControlName[34];
short SelectedRow;

/* See if the list box has a selected row */
FndGenRC = CmnErrOverrides(NULL,
                           CMN_OVERRIDE_FATAL,
                           CMN_ERR_LOGGING_DEFAULT,
                           CMN_RC_CONTINUE_PROCESSING,
                           CMN_ARCH_PARMS);

FndGenRC = FndLstBoxRowQuerySelection (CBI_hwnd,
                                       LBName,
                                       FND_LSTBOX_START,
                                       &SelectedRow,
                                       &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
   {
    SelectedRow = -1;
   }
/*
** Set the pointer to wait
*/

 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_WAIT,
                     &FndGenErrorBlock);


/* Clear out the ListBox */

FndLstBoxRowDeleteAll( CBI_hwnd, LBName, &FndGenErrorBlock);


for (index=0; index < NumRecords; index++)
    {
     pTemp = (_LAYOUT_REC *)(pLayout+index);

     NewRow._Rlb01ELBCdStatusIconicData = CMN_LBROW_STATUS_AVAILABLE;

     /* JSH: 07/08/93 MODIFIED */
     /* CSC: 09/20/93 MODIFIED TO CORRECT GROUP LENGTH PROBLEM */
     //NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemLength;
     NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemCLength;

     sprintf(NewRow._Rlb01ELBRecTypeData,"%c",toupper((pLayout+index)->ItemType));

     strcpy(NewRow._Rlb01ELBControlNameData,"");
     for (index2=0; index2 < (pLayout+index)->IndentLevel &&
                    (index2 * strlen(padding)) <
                             sizeof(ControlName); index2++)
         {
          strcat(NewRow._Rlb01ELBControlNameData, padding);
         }

     if (Language == C_LANGUAGE)
         strncat(NewRow._Rlb01ELBControlNameData,
                 (pLayout+index)->ItemCName,
                 sizeof(ControlName) - strlen(NewRow._Rlb01ELBControlNameData) - 1);
     else
        strncat(NewRow._Rlb01ELBControlNameData,
                (pLayout+index)->ItemCobolName,
                sizeof(ControlName) - strlen(NewRow._Rlb01ELBControlNameData) - 1);


     if (toupper((pLayout+index)->Format) == 'A')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Alpha");
         }
     else
      if (toupper((pLayout+index)->Format) == 'N')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Numeric");
         }
    else
          strcpy(NewRow._Rlb01ELBDataTypeData,"");

    FndGenRC = CmnErrOverrides(NULL,
                               CMN_OVERRIDE_FATAL,
                               CMN_ERR_LOGGING_DEFAULT,
                               CMN_RC_CONTINUE_PROCESSING,
                               CMN_ARCH_PARMS);

    FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
                            LBName,
                            index,
                            sizeof(_Rlb01ELBRow),
                            &NewRow,
                            &FndGenErrorBlock);

    if (FndGenRC != FND_SUCCESS)
        {
         FndWindowSetPointer(CBI_hwnd,
                             FNDSYSPTR_ARROW,
                             &FndGenErrorBlock);

         return(CMN_FAIL);
        }

     if ((pLayout+index)->ItemType != 'E')
        {
         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_GREYED,
                                         &FndGenErrorBlock);
        }
     else
         {

         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_NORMAL,
                                         &FndGenErrorBlock);
         }
    } /* end of for (index=0; index < NumRecords; index++) loop */


 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_ARROW,
                     &FndGenErrorBlock);


 return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : MoveClient1
**
**  DESCRIPTION      : This function moves the client data from the layout record to the WES
**                           fields.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(MoveClient1)
{

unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    FndGenRBValueShort = 0;
short ClientRow;
short ClientElmnt;

/*
** Enable the client radio button and entry field
*/

FndGenRBValueShort = LT_ClntElementRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRC = FndFieldEnable(CBI_hwnd,
                             "CLNTELEMENT",
                             &FndGenErrorBlock);

ClntTypeData = LT_ClntElementRB;

/*
** Find out what field is selected and calculate the element index
*/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);

ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Copy the layout field to the wes field depending on the selected language
*/

if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
    {
     strcpy(ClntElementData,
      (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
else
    {
     strcpy(ClntElementData,
      (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);

    }

/*
** Disable the literal entry field and other radio button groups
*/

FndGenRC = FndFieldDisable(CBI_hwnd,
                           "CLNTLITERAL",
                           &FndGenErrorBlock);
strcpy(ClntLiteralData, "");

if (Rlb01ELBCdStatusIconicData[ClientRow] == CMN_LBROW_STATUS_COMPLETED)
{
    FndGenRBValueShort = LT_ClntLiteralRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntHvRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntLVRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                                "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
}
else
{

    FndGenRBValueShort = LT_ClntLiteralRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntHvRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntLVRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                                "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
}

return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : MoveService1
**
**  DESCRIPTION      : This function moves the Service data from the layout record to the WES
**                           fields.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(MoveService1)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    ix;
short  ServiceRow;
short  ServiceElmnt;


WildcardData = FALSE;

FndGenRC = FndFieldDisable(CBI_hwnd,
                             "SRVCWLDCARD",
                             &FndGenErrorBlock);

ix = pWindContextData->WCD.CurrentServiceIndex;


FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;


if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
    }
else
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);

    }


return(CMN_SUCCESS);


}

