/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : LoadClientElmnt
**
**  DESCRIPTION      : This function control the loading of the Client LB.
**
**  INPUTS           : SHORT ClientElmnt
**                     CMN_ARCH_PARMS
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS OR CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static SHORT LoadClientElmnt(SHORT ClientElmnt, CMN_ARCH_PARM_TYPES)
{
 SHORT ix;
 USHORT           FndGenRC = FND_SUCCESS;
 _FND_ERROR_BLOCK         FndGenErrorBlock;

 ix = 0;

 /*
 ** Make sure the ClientElmnt parameter is valid
 */

 if (ClientElmnt < 0 ||
     ClientElmnt > pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
    {
     return(CMN_FAIL);
    }

 /*
 ** Calculate what the offset should be
 */

 while ((ix + NUMRLB01ELBROWS - 1) < ClientElmnt)
     {
      ix += NUMRLB01ELBROWS;
     }

 /*
 ** If the client element is not in the current offset reload the listbox
 */
 if (pWindContextData->WCD.ClientLBOffset != ix)
    {

      /*
      ** Set the BFCD offset
      */

      pWindContextData->WCD.ClientLBOffset = ix;

      /*
      ** Fill the listbox
      */
      FndGenRC =  AZCS004BUSFillClientLB (pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );
    }

 /*
 ** Select the row
 */
 FndGenRC = FndLstBoxRowSelect(CBI_hwnd,
                               MAPGEN_CLIENT_LB_NAME,
                               ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS),
                               &FndGenErrorBlock);


 return(CMN_SUCCESS);

} /* end of function LoadClientElmnt */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : LoadServiceElmnt
**
**  DESCRIPTION      : This function control the loading of the Service LB.
**
**  INPUTS           : SHORT ServiceElmnt
**                     CMN_ARCH_PARMS
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS OR CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static SHORT LoadServiceElmnt(SHORT ServiceElmnt, CMN_ARCH_PARM_TYPES)
{

 SHORT ix;
 USHORT           FndGenRC = FND_SUCCESS;
 _FND_ERROR_BLOCK         FndGenErrorBlock;
 USHORT usIndex;
 ix = 0;


 usIndex = pWindContextData->WCD.CurrentServiceIndex;


 /*
 ** Make sure the ServiceElmnt parameter is valid
 */

 if (ServiceElmnt < 0 ||
     ServiceElmnt > pBFCD->pCSRMapBFCD->ServiceInfoTable[usIndex].NumReposServiceRows)
    {
     return(CMN_FAIL);
    }

 /*
 ** Calculate what the offset should be
 */

 while ((ix + NUMRLB02ELBROWS - 1) < ServiceElmnt)
     {
      ix += NUMRLB02ELBROWS;
     }


 /*
 ** If the row is not in the current listbox reload the listbox
 */

 if (pWindContextData->WCD.ServiceLBOffset != ix)
    {
     /*
     ** Set the BFCD offset
     */

     pWindContextData->WCD.ServiceLBOffset = ix;

     /*
     ** Fill the listbox
     */

     FndGenRC =  FillServiceLB (pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );
    }

 /*
 ** Select the row
 */

 FndGenRC = FndLstBoxRowSelect(CBI_hwnd,
                               MAPGEN_SERVICE_LB_NAME,
                               ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS),
                               &FndGenErrorBlock);


 return(CMN_SUCCESS);

} /* end of function LoadServiceElmnt */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : Azcs004busrlb01elbpagedown
**
**  DESCRIPTION      : This function is invoked when the pagedown control is
**                       clicked on the Client LB.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/25/99  N.Eyde                Added megascrolling to the client list-
**                                    box to save the user's selected row.
**
***************************************************************************/

static WCBPROC(Azcs004busrlb01elbpagedown)
 {
  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC;

  /* NEYDE - 03/25/99 - Added variables to reference working storage, mega-
  **                    scrolling and selected row data.  
  */
  USHORT           RowNum = 0;
  _AZCS004_WINDOWDATA *pDataPointer;
  _AZCS01_KEYS Elb1MegaData;
  pDataPointer = (_AZCS004_WINDOWDATA *) WCD_pWorkingStorageData;

  /*
  ** Range check incrementing the offset for the client list box
  */
    if (( pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS) <
          pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
       {
        pWindContextData->WCD.ClientLBOffset += NUMRLB01ELBROWS;

        /* NEYDE - 03/25/99 - Added query of selected row (if any) and stored
		**                    (MegaScrollPush) in megascrolling data.
        */

        FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                               MAPGEN_CLIENT_LB_NAME,
                                               FND_LSTBOX_START,
                                               &RowNum,
                                               &FndGenErrorBlock);

        if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
            return(CMN_FAIL);
        }

	
        if (FndGenRC == LBOX_NO_MORE_ROWS_SELECTED)
        {
            Elb1MegaData.KySelectedRow = ROW_NOT_SELECTED;
        }
		else
        {
            Elb1MegaData.KySelectedRow = RowNum;
        }

		AZCS01MegaScrollPush(&pDataPointer->pClientMegaScroll,
			              (VOID *) &Elb1MegaData,
						  sizeof(_AZCS01_KEYS),
						  CMN_ARCH_PARMS);

        /* NEYDE - 03/25/99 - End of changes
        */

        FndGenRC = AZCS004BUSFillClientLB(pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );

       }
    else
       {
        FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                        MAPGEN_CLIENT_LB_NAME,
                                        &FndGenErrorBlock);
       }

  return(CMN_SUCCESS);
 }

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : Azcs004busrlb01elbpageup
**
**  DESCRIPTION      : This function is invoked when the page up control is
**                       clicked on the Client LB.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/25/99  N.Eyde                Added megascrolling to the client list-
**                                    box to save the user's selected row.
**
***************************************************************************/
static WCBPROC(Azcs004busrlb01elbpageup)
 {
  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC;

  /* NEYDE - 03/25/99 - Added variables to reference working storage and 
  **                    megascrolling data.  
  */
  _AZCS004_WINDOWDATA *pDataPointer;
  _AZCS01_KEYS *pElb1MegaData;
  pDataPointer = (_AZCS004_WINDOWDATA *) WCD_pWorkingStorageData;

  /*
  ** Range check incrementing the offset for the client list box
  */
    if (pWindContextData->WCD.ClientLBOffset > 0)
       {
        pWindContextData->WCD.ClientLBOffset -= NUMRLB01ELBROWS;

        FndGenRC = AZCS004BUSFillClientLB(pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );

        /* NEYDE - 03/25/99 - Re-select the row previously selected on this
		**                    page using megascrolling data and remove (pop)
		**					  the node from the megascrolling linked list.
        */

		if(pDataPointer->pClientMegaScroll != NULL)
		{
		   pElb1MegaData = (_AZCS01_KEYS *) pDataPointer->pClientMegaScroll->pKeys;
		}

        if (pElb1MegaData->KySelectedRow != ROW_NOT_SELECTED)
        {
            FndGenRC = FndLstBoxRowSelect( CBI_hwnd,
                                           MAPGEN_CLIENT_LB_NAME,
                                           pElb1MegaData->KySelectedRow,
                                           &FndGenErrorBlock);

        }


		AZCS01MegaScrollPop(&pDataPointer->pClientMegaScroll,
						  CMN_ARCH_PARMS);
								  
        /* NEYDE - 03/25/99 - End of changes
        */

       }
    else
       {
        FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      &FndGenErrorBlock);
       }


  return(CMN_SUCCESS);
 }

