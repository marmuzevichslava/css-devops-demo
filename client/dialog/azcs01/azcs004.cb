/***************************************************************************
**  04/23/96 mconner Receiving "segment too large" error in OS/2.  To overcome
**                   this error three functions were created to replace
**                   FndCommandSetDefaultButton
**                   FndFieldSetValue
**                   FndLstBoxRowQuerySelection
**                   This moves all the macro wrapping to one place thus
**                   reducing the size of the code at compile time.
****************************************************************************/

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSAboutMNClick}
**
**  DESCRIPTION      : This function creates the About window for the applicaition.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : Michael D. Conner
**
**  DATE CREATED     : 03/11/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  03/15/96  mconner                   Copied from AZCS001BUSAboutMNClick
**
***************************************************************************/
static WCBPROC(AZCS004BUSAboutMNClick)
{
    SHORT FndGenRC = CMN_SUCCESS;
    SHORT nRC      = CMN_SUCCESS;
    CHAR WindowName[]   = "AZCS014";
    CHAR InstanceName[] = "";

    HEAP_CHECK

    FndGenRC = CmnWindowCreate( WindowName,
                                InstanceName,
                                NULL,
                                NULL,
                                CMN_ARCH_PARMS );

    HEAP_CHECK

    return CMN_SUCCESS;

} /* End of AZCS004BUSAboutMNClick */


/**F*************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : UnLdAZCS4I
**
**  DESCRIPTION      : This function loads the data from the input data structure into WES.
**                      It also does all of the Predisplay stuff to set up WES.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/04/96  mconner               Added Architecture Valid field to window and call to
**                                        CmnWindowSetDataModified in this function so that
**                                        the default window entry state could be "OK".
**
**    03/04/96  mconner               Added FndCommandSetDefaultButton(OKPB) so that 
**                                        the window entry default state would be "OK".
**
**    03/04/96  mconner               Removed FndCommandSetDefaultButton(ApplyPB) from 
**                                        function. Do not want "Apply" default here.
**
**    03/05/96  mconner               Removed strcpy for OPERATOR field and added calls
**                                    to FndValueInit, FndValueAddItem and FndFieldSetValue
**                                    to populate the OPERATOR combo box and display
**                                    field.
**
**    03/06/96  mconner               Replaced strcpy to WES fields with
**                                        FndFieldSetValue
**
**    03/25/99  N.Eyde                Allocated working storage to window
**                                    in order to implement megascrolling
**                                    to client and service listboxes
**
***************************************************************************/


static WCBPROC (UnLdAZCS4I)
{
     SHORT           FndGenRC = FND_SUCCESS;
     _FND_ERROR_BLOCK         FndGenErrorBlock;
     SHORT ix=0;
     SHORT iy=0;
 
  _AZCS004I *pAzcs004i;

  /* NEYDE - 03/25/99 - Allocated window's working storage
  */
  WCD_pWorkingStorageData = (_AZCS004_WINDOWDATA *) malloc(sizeof(_AZCS004_WINDOWDATA));
  memset(WCD_pWorkingStorageData, 0, sizeof(_AZCS004_WINDOWDATA));

  pAzcs004i = (_AZCS004I *)CBI_pInitData;

/*********************************************************************/
/* Fill the WES fields for client and server layout names            */
/*********************************************************************/
/*mdc - 03/12/96 - Changed for standards compliance
strcpy(ClientLayoutData, pAzcs004i->ClientLayout);
*/

FndGenRC = AZCS004FndFieldSetValue( CBI_hwnd,
                                 "CLIENTLAYOUT",
                                 (USHORT)strlen(pAzcs004i->ClientLayout),
                                 (void *)pAzcs004i->ClientLayout,
                                 CMN_ARCH_PARMS);

/*mdc - 03/12/96 - Changed for standards compliance
 strcpy(ServiceLayoutNameData,pAzcs004i->Services[0].ServerLayout);
*/

FndGenRC = AZCS004FndFieldSetValue( CBI_hwnd,
                                 "ServiceLayoutName",
                                 (USHORT)strlen(pAzcs004i->Services[0].ServerLayout),
                                 (void *)pAzcs004i->Services[0].ServerLayout,
                                 CMN_ARCH_PARMS);



 
  pWindContextData->WCD.CurrentServiceIndex = 0;

/*********************************************************************/
/* Initialize the Service Layout Combo Box                           */
/*********************************************************************/

  FndGenRC = FndValueInit( CBI_hwnd,
                         "ServiceLayoutName",
                         1,
                         32,
                         32,
                         &FndGenErrorBlock);

  if (FndGenRC != FND_SUCCESS)
      {
       return (CMN_FAIL);
      }
/*********************************************************************/
/* Loop thru the Service names structure and load the combo box      */
/*********************************************************************/

    for (ix = 0; ix < pAzcs004i->NumServices; ix++)
       {

        FndGenRC = FndValueAddItem (CBI_hwnd,
                                    "ServiceLayoutName",
                                     1,
                                     FND_VALUE_END,
                                     pAzcs004i->Services[ix].ServerLayout,
                                     pAzcs004i->Services[ix].ServerLayout,
                                     &FndGenErrorBlock);

        if (FndGenRC != FND_SUCCESS)
            {
             return (CMN_FAIL);
            }

       } /* end of while loop for filling Services combo box */

      /* SET THE DEFAULTS */
      /*   1. WINDOW LANGUAGES IN WCD */
      /*   2. Number of services      */
      /*   3. Previous Good List_Select row */

      pWindContextData->WCD.ClientLanguage = C_LANGUAGE;
      pWindContextData->WCD.ServiceLanguage = COBOL_LANGUAGE;

      pWindContextData->WCD.NumServices = pBFCD->pCSRMapBFCD->NumServices;
      pWindContextData->WCD.PrevClientRow = 0;
      pWindContextData->WCD.PrevServiceRow = 0;

  /*********************************************************************/
  /* Loop thru and copy all the service stuff down from BFCD into WCD  */
  /*********************************************************************/
      for (ix=0; ix < pWindContextData->WCD.NumServices; ix++)
          {

           memcpy(&(pWindContextData->WCD.ServiceInfoTable[ix]),
                   &(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix]),
                   sizeof(_SERVICE_INFO) );

           pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys =
                 (_RELATE_CK *) malloc(MAXSERVICEROWS * sizeof(_RELATE_CK) );

           /*CSC: 9/2/93 */
           memset(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys,
                  0,
                  MAXSERVICEROWS * sizeof(_RELATE_CK) );

           /* JLL:  07/06/93 CHANGED FROM MAXSERVICEROWS TO NumReposServiceRows */
           if (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys)
           {
             memcpy((pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys),
                    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pCompareKeys),
                    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows
                     * sizeof(_RELATE_CK)) );
           }
           else
             {
              for(iy=0; iy < MAXSERVICEROWS; iy++)
                {
                 pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].ClientLayoutIndex = -1;
                 pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].LiteralUsed = 'N';

                 /* JLL: 06/30/93 CHANGED FROM "" to "NULL */
                 strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].LiteralValue, "NULL");

                 /* JLL: 06/30/93 ADDED */
                 pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].WildCardUsed = 'N';
                 strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].WildCardValue, "NULL");
                 strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].Operation, "EQ");

                }
             }
          } /* end of for loop */


   /* Make the apply pushbutton the default 
   FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);
** mdc - 03-04-96 - the apply pushbutton should not be available unless a row is
**                       selected
*/
 /*mdc - 03/05/96 - removed not up to standards */
 /* The following three APIs replace this line */
 /*strcpy(OperatorData, "EQ");*/

FndGenRC = FndValueInit( CBI_hwnd,
                         "OPERATOR",
                         1,
                         9,
                         20,
                         &FndGenErrorBlock);

FndGenRC = FndValueAddItem( CBI_hwnd,
                            "OPERATOR",
                            1,
                            FND_VALUE_END,
                            "EQUALS",
                            "EQUALS",
                            &FndGenErrorBlock);

FndGenRC = AZCS004FndFieldSetValue( CBI_hwnd,
                                 "OPERATOR",
                                 7,
                                 "EQUALS",
                                 CMN_ARCH_PARMS);

  /*
  ** Make the List Box Offsets 0
  */
     pWindContextData->WCD.ClientLBOffset = 0;
     pWindContextData->WCD.ServiceLBOffset = 0;

  /*
  ** Disable the List Box Pageing buttons
  */
  FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                MAPGEN_CLIENT_LB_NAME,
                                &FndGenErrorBlock);

  FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                MAPGEN_SERVICE_LB_NAME,
                                &FndGenErrorBlock);

  if (pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows < NUMRLB01ELBROWS)
      {
       FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                       MAPGEN_CLIENT_LB_NAME,
                                       &FndGenErrorBlock);
      }

  if (pBFCD->pCSRMapBFCD->ServiceInfoTable[0].NumReposServiceRows < NUMRLB02ELBROWS)
      {
       FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                       MAPGEN_SERVICE_LB_NAME,
                                       &FndGenErrorBlock);
      }

  /***************************************************************************************
   * Set the window to valid by calling CmnWindowSetDataModified
   * mdc - 03/04/96 - Added this because Architecture Validation field was added to
   *                  window.
   ***************************************************************************************/
   FndGenRC = CmnWindowSetDataModified ( CMN_ARCH_PARMS );

   if (FndGenRC != CMN_SUCCESS )
   {
	return(CMN_FAIL);
   }

 /* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          CMN_ARCH_PARMS);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }


  return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSPredestroy
**
**  DESCRIPTION      : This function controls the logic when the window is destroyed
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : N.Eyde
**
**  DATE CREATED     : 03/25/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/25/99  N.Eyde                Original code.
**
***************************************************************************/
static WCBPROC (AZCS004BUSPredestroy)
{
  USHORT           FndGenRC = FND_SUCCESS;

  /* NEYDE - 03/25/99 - Added a reference the window's working storage to access
  **                    megascrolling data.  Removed (pop) all nodes from linked
  **					list.
  */
  _AZCS004_WINDOWDATA *pDataPointer;
  pDataPointer = (_AZCS004_WINDOWDATA *) WCD_pWorkingStorageData;

  if(pDataPointer)
  {
	 AZCS01MegaScrollPopAll(&pDataPointer->pServiceMegaScroll,
	                        CMN_ARCH_PARMS);

	 free(pDataPointer);
  }

  return(CMN_SUCCESS);

} /* end of AZCS004BUSPredestroy() */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSMoveLB1
**
**  DESCRIPTION      : This function controls the logic when a row in List Box 1 has been selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (AZCS004BUSMoveLB1)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           RowNum;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT             CellAttr;
USHORT           CellData;
USHORT          *pCellData;

/***********************************/
/* Find out which row was selected */
/***********************************/

FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                       MAPGEN_CLIENT_LB_NAME,
                                       FND_LSTBOX_START,
                                       &RowNum,
                                       CMN_ARCH_PARMS);

/***********************************************/
/* Find out what the attributes of the row are */
/***********************************************/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                   MAPGEN_CLIENT_LB_NAME,
                                   RowNum,
                                   0,
                                   &CellAttr,
                                   &FndGenErrorBlock);

/*******************************************************/
/* Move the selected row into the relationship section */
/*   if the attribute is normal otherwise return.      */
/*******************************************************/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevClientRow = RowNum;
     FndGenRC = CellAttrNormC(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }
    }

/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {
     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteClient(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);

   }

return(CMN_SUCCESS);



} /* end of AZCS004BUSMoveLB1() */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSMoveLB2
**
**  DESCRIPTION      : This function controls the logic when a row in List Box 2 has been selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (AZCS004BUSMoveLB2)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           RowNum;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT             CellAttr;
USHORT           CellData;
USHORT          *pCellData;

/***********************************/
/* Find out which row was selected */
/***********************************/

FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                       MAPGEN_SERVICE_LB_NAME,
                            FND_LSTBOX_START,
                            &RowNum,
                            CMN_ARCH_PARMS);

/***********************************************/
/* Find out what the attributes of the row are */
/***********************************************/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      &CellAttr,
                                      &FndGenErrorBlock);

/*******************************************************/
/* Move the selected row into the relationship section */
/*******************************************************/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevServiceRow = RowNum;
     FndGenRC = CellAttrNormS(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );
    }

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }



/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {

     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteService(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSNewService
**
**  DESCRIPTION      : This function controls the logic when a new service is
**                       is loaded into the combo box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/25/99   N.Eyde               Removed all megascrolling linked list
**                                    nodes upon selecting a new service.
**
***************************************************************************/
static WCBPROC (AZCS004BUSNewService)
{
  SHORT index=0;
  SHORT ServiceIndex=-1;
  USHORT  nRC=0;

  /* NEYDE - 03/25/99 - Added a reference the window's working storage to access
  **                    megascrolling data.  Removed (pop) all nodes from linked
  **					list.
  */
  _AZCS004_WINDOWDATA *pDataPointer;
  pDataPointer = (_AZCS004_WINDOWDATA *) WCD_pWorkingStorageData;

  AZCS01MegaScrollPopAll(&pDataPointer->pServiceMegaScroll,
	                     CMN_ARCH_PARMS);

  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }

  if (ServiceIndex >= 0)
      {

      pWindContextData->WCD.ServiceLBOffset = 0;
      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);

     }

return(CMN_SUCCESS);

} /* end of AZCS004BUSNewService*/

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSRemoveRelationship
**
**  DESCRIPTION      : This function controls the logic when the remove pushbutton is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/04/96  mconner               Added FndCommandSetDefaultButton(OKPB) so that 
**                                        users could press enter to 'OK" window after a
**                                        "Remove".
**
***************************************************************************/


/* 09/09/93 CSC: ADDED Logic for Multi page listbox */

static WCBPROC (AZCS004BUSRemoveRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    ServiceRow;
SHORT                    ServiceElmnt;
SHORT                    ClientRow;
SHORT                    ClientElmnt;
SHORT                      CellData;
SHORT                    ix;
SHORT                    iy;
BOOL                     MultipleService;

ix = pWindContextData->WCD.CurrentServiceIndex;


FndGenRC = AZCS4FndLstBxRowQuerySelect(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      CMN_ARCH_PARMS);

if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

CellData = CMN_LBROW_STATUS_UNCHANGED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/* Is there a matching client row or is there a literal ? */

if (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed == 'N')
   {
    FndGenRC = AZCS4FndLstBxRowQuerySelect(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      CMN_ARCH_PARMS);
    if (FndGenRC != FND_SUCCESS)
        return(CMN_FAIL);

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    MultipleService = FALSE;
    for (iy=0;
         iy < pWindContextData->WCD.ServiceInfoTable[ix].NumReposServiceRows;
         iy++)
        {
         if (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].ClientLayoutIndex == ClientElmnt &&
             iy != ServiceElmnt)
            {
             MultipleService = TRUE;
            }

        }
    if (!MultipleService)
       {
        FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
        if (FndGenRC != FND_SUCCESS)
            return(CMN_FAIL);
       }

 /* De-Select the rows */
    Rlb01ELBSelIndData[ClientRow] = FALSE;
   }
else
   {
   pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,"NULL");

   /* JLL: 06/30/93 CHANGED FROM FALSE TO "N" */
   pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue,"NULL");

   }

Rlb02ELBSelIndData[ServiceRow] = FALSE;
pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex=-1;
pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 /* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }


 return(CMN_SUCCESS);
} /* end of function AZCS004BUSRemoveRelationship */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS004BUSCreateRelationship
**
**  DESCRIPTION      : This function controls the logic when the Apply PB is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**    01/28/94  C. Crampton           Added code for CheckDataTypes logic.
**
**    03/04/96   mconner              Added FndCommandSetDefaultButton(OKPB) so that
**                                        users could "OK" the window by pressing enter
**                                        after aan "Apply".
**
***************************************************************************/


/* 09/09/93 CSC: ADDED Logic for Multi page listbox */

static WCBPROC(AZCS004BUSCreateRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT           ServiceRow;
USHORT           ServiceElmnt;
USHORT           ClientRow;
USHORT           ClientElmnt;
SHORT                      CellData;
SHORT                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = AZCS4FndLstBxRowQuerySelect(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      CMN_ARCH_PARMS);

/*
** Calculate the index into the memory table
*/

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/**********************************************/
/*** If the client side uses the element    ***/
/**********************************************/

if (ClntTypeData == LT_ClntElementRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

    /* JLL: 06/30/93 CHANGED FROM "" to "NULL" */
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,"NULL");
    FndGenRC = AZCS4FndLstBxRowQuerySelect(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      CMN_ARCH_PARMS);


    /*
    ** Calculate the offset into the element table
    */

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


    /*
    ** Make sure the data types match
    */
    FndGenRC = CheckDataTypes( ClientElmnt, ServiceElmnt, ix, CMN_ARCH_PARMS);

    if (FndGenRC != CMN_SUCCESS)
    {
        return(CMN_FAIL);
    }

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);

    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = ClientElmnt;
    Rlb01ELBSelIndData[ClientRow] = FALSE;
    }

/**********************************************/
/*** If the client side uses the literal    ***/
/**********************************************/

else
 if (ClntTypeData == LT_ClntLiteralRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              ClntLiteralData);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntHvRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              CMN_HIGH_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntLVRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              CMN_LOW_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }

/**********************************************/
/*** See if the wildcard checkbox is marked ***/
/**********************************************/

if (WildcardData == TRUE)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue,
           SrvcWldCardData);
    }
else
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'N';

    /* JLL: 06/30/93 CHANGED "" TO "NULL" */
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue, "NULL");
    }

/**********************************************/
/*** Set the completed flag for this row    ***/
/**********************************************/

CellData = CMN_LBROW_STATUS_COMPLETED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);


 /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 /* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          CMN_ARCH_PARMS);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }

 return(CMN_SUCCESS);
} /* end of function AZCS004BUSCreateRelationship */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FindClientMatch
**
**  DESCRIPTION      : This function finds a matching service for a selected
**                        client row.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


/* 09/09/93 CSC: Added logic for multi-page support */

static SHORT FindClientMatch(CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
/*mdc 04/22/96 FCP call moved to function this no longer used
_FND_ERROR_BLOCK         FndGenErrorBlock;
*/
SHORT index;
SHORT ClientRow;
SHORT ClientElmnt;
SHORT ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    CMN_ARCH_PARMS);

if (FndGenRC != FND_SUCCESS)
   {
    return(CMN_FAIL);
   }
/*
** Calculate the element index based on the row and offset values
*/
ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[index].ClientLayoutIndex)
         return(index);
    }
return(-1);
} /*  end of function FindClientMatch */


