       {
        pWindContextData->WCD.ServiceLBOffset -= NUMRLB02ELBROWS;

        FndGenRC = FillServiceLB(pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );

        /* NEYDE - 03/25/99 - Re-select the row previously selected on this
		**                    page using megascrolling data and remove (pop)
		**					  the node from the megascrolling linked list.
        */

		if(pDataPointer->pServiceMegaScroll != NULL)
		{
		   pElb2MegaData = (_AZCS01_KEYS *) pDataPointer->pServiceMegaScroll->pKeys;
		}

        if (pElb2MegaData->KySelectedRow != ROW_NOT_SELECTED)
        {
            FndGenRC = FndLstBoxRowSelect( CBI_hwnd,
                                           MAPGEN_SERVICE_LB_NAME,
                                           pElb2MegaData->KySelectedRow,
                                           &FndGenErrorBlock);

        }


		AZCS01MegaScrollPop(&pDataPointer->pServiceMegaScroll,
						  CMN_ARCH_PARMS);
								  
        /* NEYDE - 03/25/99 - End of changes
        */

       }
    else
       {
        FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      &FndGenErrorBlock);
       }

  return(CMN_SUCCESS);
 }


SHORT CheckDataTypes( USHORT ClientIndex,
                      USHORT ServiceIndex,
                      USHORT ServiceNum,
                      CMN_ARCH_PARM_TYPES)
{
 SHORT FndGenRC=0;
 USHORT usSelectedButton;
  _FND_ERROR_BLOCK FndGenErrorBlock;

if ( (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable[ServiceIndex].Format ==
      pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable[ClientIndex].Format)
    &&
     (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable[ServiceIndex].ItemCLength ==
      pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable[ClientIndex].ItemCLength)
   )
{
      return(CMN_SUCCESS);
}

if ( (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable[ServiceIndex].Format == 'A')
    &&
     (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable[ServiceIndex].Format ==
      pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable[ClientIndex].Format)
    &&
     (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable[ServiceIndex].ItemCLength !=
      pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable[ClientIndex].ItemCLength)
   )
{


     FndGenRC = FndMsgBoxDisplayText( "These Two elements have different lengths !\n\n"
                                      "Should a relationship be applied ?",
                                      NULL,
                                      CBI_hwnd,
                                      FND_MSGBOX_YESNO,
                                      FND_MSGBOX_QUERY,
                                      FND_MSGBOX_IDNO,
                                      CMN_MAPGEN_NAME,
                                      &usSelectedButton,
                                      &FndGenErrorBlock);

     if (FND_MSGBOX_IDYES == usSelectedButton)
     {
         return(CMN_SUCCESS);
     }
     else
     {
         return(CMN_FAIL);
     }
}

/*
** Error condition
*/

FndGenRC = FndMsgBoxDisplayText( "You cannot map those two elements !\n\n"
                                 "They have different Data Types or Num. Bytes.",
                                      NULL,
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_ERROR,
                                      FND_MSGBOX_IDYES,
                                      CMN_MAPGEN_NAME,
                                      &usSelectedButton,
                                      &FndGenErrorBlock);
return(CMN_FAIL);

} /* End of function CheckDataTypes */


