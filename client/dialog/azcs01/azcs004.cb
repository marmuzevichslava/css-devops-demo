 /***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS4FndLstBxRowQuerySelect
**
**  DESCRIPTION      : Calls FCP function. This limits the space taken by 
**                     macro wrapping.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/22/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**	  04/22/96	mconner					created
***************************************************************************/
SHORT  AZCS4FndLstBxRowQuerySelect ( FND_HWND           WindowHandle,
                                          char               ListboxName[32],
                                          short              StartRowNumber,
                                          short             *pRowNumber,
                                          CMN_ARCH_PARM_TYPES)

{
	SHORT FndGenRC = 0;
	_FND_ERROR_BLOCK FndGenErrorBlock;


	FndGenRC = FndLstBoxRowQuerySelection (WindowHandle,
                                           ListboxName,
                                           StartRowNumber,
                                           pRowNumber,
                                          &FndGenErrorBlock);

    
	if (FndGenRC != CMN_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
	{
		return CMN_FAIL;
	}
	else if (FndGenRC == LBOX_NO_MORE_ROWS_SELECTED)
	{
		return LBOX_NO_MORE_ROWS_SELECTED;
	}
	else
	{
		return CMN_SUCCESS;
	}
}/*end of  AZCS4FndLstBxRowQuerySelect */

