***************************************************************************/

 SHORT  AZCS004FndFieldSetValue ( FND_HWND            WindowHandle,
                                char                *pszFldName,
                                unsigned short      DataLength,
                                void                *pNewValue,
                                CMN_ARCH_PARM_TYPES)


{
	SHORT FndGenRC = 0;
	_FND_ERROR_BLOCK FndGenErrorBlock;
	

	FndGenRC = 	FndFieldSetValue (WindowHandle,
                                  pszFldName,
                                  DataLength,
								  pNewValue,
                                  &FndGenErrorBlock);
                                 

	if(FndGenRC != CMN_SUCCESS)
	{
		return CMN_FAIL;
	}
	else
	{
		return CMN_SUCCESS;
	}
}/*end of AZCS004FndFieldSetValue*/										

