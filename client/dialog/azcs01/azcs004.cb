/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : CellDataComplete
**
**  DESCRIPTION      : This function controls the logic when a completed row
**                      is selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/04/96  mconner               If a "checked" row is selected, make "RemovePB"
**                                        the default, if a "non-checked" row is selected,
**                                        make "ApplyPB" the default.
**
***************************************************************************/


/* CSC: 09/13/93 Converted to multi-page support */

static WCBPROC(CellDataComplete)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;

SHORT                    ServiceRow=-1;
SHORT                    ix;
SHORT                    iy;
SHORT                    ClientRow=-1;

SHORT                    ClientElmnt;
SHORT                    ServiceElmnt;

    ix = pWindContextData->WCD.CurrentServiceIndex;

  /*
  ** Select was from Client Side
  */
    if (CBI_WidgetID == Rlb01ELB_FID)
        {
         ClientRow = CBI_ListRow;
         ClientElmnt = pWindContextData->WCD.ClientLBOffset + ClientRow;

         FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                                MAPGEN_SERVICE_LB_NAME,
                                                FND_LSTBOX_START,
                                                &ServiceRow,
                                                CMN_ARCH_PARMS);

       /*
       ** If there is no selected service
       **    find the match from the ClientLayoutIndex table
       */

         if (FndGenRC != FND_SUCCESS)
            {
             ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);

             FndGenRC =  LoadServiceElmnt(ServiceElmnt,
                                          CMN_ARCH_PARMS);

			/*mdc 04/17/96 Assign the selected row to "ServiceRow"*/
			FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                                MAPGEN_SERVICE_LB_NAME,
                                                FND_LSTBOX_START,
                                                &ServiceRow,
                                                CMN_ARCH_PARMS);

            }
         /*
         ** A service row is selected
         */
         else
            {
             ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
               /*
               ** If not a relationship between service and client
               **   find the first one
               */
             if (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex != ClientElmnt)
                {
                 ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);

                 FndGenRC = LoadServiceElmnt(ServiceElmnt,
                                             CMN_ARCH_PARMS);
                }
            }
       }
    /*
    ** Service Row was selected
    */
    else
        {

         ServiceRow = CBI_ListRow;
         ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

         if(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed == 'N')
            {
             ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex;
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);

             FndGenRC = LoadClientElmnt(ClientElmnt, CMN_ARCH_PARMS);

            }
        }


    if (ServiceRow >= 0 && ServiceRow < NUMRLB01ELBROWS)
       {
        /*                                                                                           */
        /* Move the Relationship data from the WCD table into the relationship section of the window */
        /*                                                                                           */

        /* Move the Client Element stuff down */
       if (toupper(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed) ==
                                        'N')
          {

           if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
              {
              strcpy(ClntElementData,
             (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
              }
           else
              {
                strcpy(ClntElementData,
                (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
              }
             /* set the radio button to element */

           FndGenRBValueShort = LT_ClntElementRB;
           FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           FndGenRBValueShort = LT_ClntHvRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           FndGenRBValueShort = LT_ClntLVRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           FndGenRBValueShort = LT_ClntLiteralRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           ClntTypeData = LT_ClntElementRB;


           strcpy(ClntLiteralData, "");
           FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "CLNTLITERAL",
                                      &FndGenErrorBlock);

           FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);

          }
       else
          {  /* Literal used not a data Element */
          /*
          ** Disable any selected client rows
          */

          for (iy=0; iy < NUMRLB01ELBROWS; iy++)
              {
               Rlb01ELBSelIndData[iy] = FALSE;
              }
          /*
          ** Disable client entry field and radio button
          */


           FndGenRBValueShort = LT_ClntElementRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

          strcpy(ClntElementData, "");

          FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);
          /*
          ** If the literal is High Values, enable the high values radio button
          **/
          if (strcmp(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
                     CMN_HIGH_VALUES_STR) == 0)
          {

           FndGenRBValueShort = LT_ClntHvRB;
           FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           ClntTypeData = LT_ClntHvRB;  /* Set the Radio Button */

           strcpy(ClntLiteralData, "");  /* Clear out the literal field */

           FndGenRBValueShort = LT_ClntLiteralRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           FndGenRBValueShort = LT_ClntLVRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
          }

          else
          if (strcmp(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
                     CMN_LOW_VALUES_STR) == 0)
          {
              FndGenRBValueShort = LT_ClntLVRB;
              FndGenRC = FndValueEnableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *) &FndGenRBValueShort,
                                             &FndGenErrorBlock);

              ClntTypeData = LT_ClntLVRB;

              strcpy(ClntLiteralData, "");  /* Clear out the literal field */

              FndGenRBValueShort = LT_ClntLiteralRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                              "CLNTTYPE",
                                              (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);

              FndGenRBValueShort = LT_ClntHvRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                              "CLNTTYPE",
                                              (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);
          }
          else
          {
              strcpy(ClntLiteralData,pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue);
              FndGenRBValueShort = LT_ClntLiteralRB;
              FndGenRC = FndValueEnableItem( CBI_hwnd,
                                            "CLNTTYPE",
                                            (VOID *) &FndGenRBValueShort,
                                            &FndGenErrorBlock);

              ClntTypeData = LT_ClntLiteralRB;

//              FndGenRC = FndFieldEnable( CBI_hwnd,
//                                        "SRVCELEMENT",
//                                         &FndGenErrorBlock);

              FndGenRC = FndFieldDisable( CBI_hwnd,
                                         "CLNTLITERAL",
                                         &FndGenErrorBlock);


              FndGenRBValueShort = LT_ClntHvRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);

              FndGenRBValueShort = LT_ClntLVRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *)&FndGenRBValueShort,
                                              &FndGenErrorBlock);
         }
        } /* End of literal selected */

      /* Copy the Service element down */
      if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
          {
            strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
          }
      else
          {
           strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
          }

       /* Copy the Wildcard field down if it is defined */
       if (toupper(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed) ==
                                        'Y')
         {
           strcpy(SrvcWldCardData, pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue);
           WildcardData = TRUE;

            FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "SRVCWLDCARD",
                                      &FndGenErrorBlock);



         }
       else
         {
          strcpy(SrvcWldCardData, "");
          WildcardData = FALSE;

         }
       } /* end of if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS) */



    if (Rlb02ELBCdStatusIconicData[ServiceRow] == CMN_LBROW_STATUS_COMPLETED)
       {
        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        /* *mdc - 03/04/96 - make the Remove pushbutton the default.*/
        FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "RemovePB",
                                          CMN_ARCH_PARMS);



        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);
       }
    else
       {

        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

         /* *mdc - 03/04/96 - make the apply pushbutton the default.*/
        FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          CMN_ARCH_PARMS);


       }

 return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : CellDataNotCompleteClient
**
**  DESCRIPTION      : This function controls the logic when a client row that
**                      does not have a relationship defined is selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/04/96  mconner               If a "non-checked" row is selected, make "ApplyPB"
**                                         the default.
**
**    04/18/96  mconner				Added logic to fill in service element
**                                  field and default apply pb.
**
***************************************************************************/


/* CSC: 09/13/93 Converted to multi-page support */

static WCBPROC(CellDataNotCompleteClient)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    RowNum = -1;
SHORT                      CellData;
SHORT                     *pCellData;
/*mdc 04/18/96 added ix and changed data type of ServiceIndex to USHORT*/
SHORT                      ix;
USHORT                      ServiceIndex;

     pCellData = &CellData;

    FndGenRC = InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    /* Find out if there is a selected Service row */
    FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                           MAPGEN_SERVICE_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           CMN_ARCH_PARMS);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
        return(CMN_FAIL);
       }
   /* A service row is selected */
    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_SERVICE_LB_NAME,
                                          RowNum,
                                          0,
                                          sizeof(CellData),
                                          (void *)pCellData,
                                          &FndGenErrorBlock);

      if (CellData == CMN_LBROW_STATUS_COMPLETED)
          {
           Rlb02ELBSelIndData[RowNum] = FALSE;
           InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                          pABHI );
          }
       else
           {
            FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

            /* *mdc - 03/04/96 - make the apply pushbutton the default.*/
            FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          CMN_ARCH_PARMS);



            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
           }


       }
    else
        {
         InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        ServiceIndex = LookForServiceName(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        if (ServiceIndex != CMN_FAIL)
           {
            FndGenRC = LoadServiceElmnt(ServiceIndex, CMN_ARCH_PARMS);

			/*mdc 04/18/96 aded to populate the service element field*/
			ix = pWindContextData->WCD.CurrentServiceIndex;

			FndGenRC = FndFieldEnable(CBI_hwnd,
			                             "SRVCELEMENT",
			                             &FndGenErrorBlock);


			if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
			    {
					AZCS004FndFieldSetValue(CBI_hwnd,
					                 "SRVCELEMENT",
									 (USHORT)strlen((pBFCD->pCSRMapBFCD->
									 	ServiceInfoTable[ix].
									 	pReposServiceLayoutTable + 
									 	ServiceIndex)->ItemCName),
									(pBFCD->pCSRMapBFCD->
										ServiceInfoTable[ix].
										pReposServiceLayoutTable + 
										ServiceIndex)->ItemCName,
										CMN_ARCH_PARMS);

			    }
			else
			    {
					AZCS004FndFieldSetValue(CBI_hwnd,
					                 "SRVCELEMENT",
									 (USHORT)strlen((pBFCD->pCSRMapBFCD->
									 	ServiceInfoTable[ix].
									 	pReposServiceLayoutTable + 
									 	ServiceIndex)->ItemCobolName),
									(pBFCD->pCSRMapBFCD->
										ServiceInfoTable[ix].
										pReposServiceLayoutTable + 
										ServiceIndex)->ItemCobolName,
										CMN_ARCH_PARMS);
					

			    }


 			/*mdc 04/17/96 Enable and default ApplyPB*/
			FndGenRC = FndCommandEnable(CBI_hwnd,
	                           		 	"ApplyPB",
										&FndGenErrorBlock);

			FndGenRC = AZCS4FndCommandSetDefaultButton(CBI_hwnd,
	                                      		"ApplyPB",
	                                      		CMN_ARCH_PARMS);

           }
        }


    FndGenRC = MoveClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);
}


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : CellDataNotCompleteService
**
**  DESCRIPTION      : This function controls the logic when a Service row that
**                      does not have a relationship defined is selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
**    03/04/96  mconner               Make 'ApplyPB" the default when a "non-checked"
**                                         row is selected.
**
**	  04/18/96	mconner				  Canged data type of ClientIndex to USHORT
**                                    CMN_FAIL is defined as (USHORT)
**
**	  04/18/96	mconner				  Added calls to select Element RB after
**                                    Element is selected for client
**
***************************************************************************/


/* CSC: 09/13/93 Converted to multi-page support */

static WCBPROC(CellDataNotCompleteService)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    RowNum = -1;
SHORT                      CellData;
SHORT                     *pCellData;
/*mdc 04/18/96 changed data type of ClientIndex and initialized it*/
USHORT                    ClientIndex = 0;
SHORT                  FndGenRBValueShort = 0;
/*USHORT                FndGenRBValueShort;*/

     pCellData = &CellData;

    /* Find out if there is a selected Client row */
    FndGenRC = AZCS4FndLstBxRowQuerySelect( CBI_hwnd,
                                           MAPGEN_CLIENT_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           CMN_ARCH_PARMS);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
        return(CMN_FAIL);
       }

   /*
   ** A client row is selected
   */

    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndCommandEnable(CBI_hwnd,
                                    "ApplyPB",
                                    &FndGenErrorBlock);

         /* *mdc - 03/04/96 - make the Apply pushbutton the default.*/
         FndGenRC = AZCS4FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          CMN_ARCH_PARMS);



        FndGenRC = FndCommandDisable(CBI_hwnd,
                                     "RemovePB",
                                     &FndGenErrorBlock);
       }
    else /*a client row is not selected*/
        {
       /*mdc 03/12/96 - removed so that literals can be inserted before service
                             choice.
         InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
        */
         /*
         ** Look for a matching name
         */
         ClientIndex = LookForClientName(pEventInfo,
                                         pEAIA,
                                         pBFCD,
                                         pWesMap,
                                         pWindContextData,
                                         pABHI );

        if (ClientIndex != CMN_FAIL)
           {
            FndGenRC = LoadClientElmnt(ClientIndex, CMN_ARCH_PARMS);


			/* mdc 04/18/96
			** Enable the client radio button and entry field
			*/

			FndGenRBValueShort = LT_ClntElementRB;
			FndGenRC = FndValueEnableItem( CBI_hwnd,
			                            "CLNTTYPE",
			                            (VOID *) &FndGenRBValueShort,
			                            &FndGenErrorBlock);

/*mdc 04/23/96 set other place this causes an error*/
			/*FndGenRC = FndFieldSetValue(CBI_hwnd,
                                                         "CLNTTYPE",
                                                         (USHORT)sizeof(FndGenRBValueShort),
                                                         (VOID *) &FndGenRBValueShort,
                                                         &FndGenErrorBlock); */

			FndGenRC = FndFieldEnable(CBI_hwnd,
			                             "CLNTELEMENT",
			                             &FndGenErrorBlock);



			/*mdc 04/17/96 populate client element field*/
			if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
              {
			  	FndGenRC = AZCS004FndFieldSetValue(CBI_hwnd,
                                                                         "CLNTELEMENT",
                                                                         (USHORT)strlen((pBFCD->pCSRMapBFCD->
                                                                           ClientInfo.pReposClientLayoutTable +
                                                                           ClientIndex)->ItemCName),
                                                                         (pBFCD->pCSRMapBFCD->
                                                                           ClientInfo.pReposClientLayoutTable +
                                                                           ClientIndex)->ItemCName,
                                                                         CMN_ARCH_PARMS);
              }
            else
              {
			  	FndGenRC = AZCS004FndFieldSetValue(CBI_hwnd,
				                            "CLNTELEMENT",
											(USHORT)strlen((pBFCD->pCSRMapBFCD->
												ClientInfo.pReposClientLayoutTable + 
												ClientIndex)->ItemCobolName),
											 (pBFCD->pCSRMapBFCD->
											 	ClientInfo.pReposClientLayoutTable + 
											 	ClientIndex)->ItemCobolName,
											 	CMN_ARCH_PARMS);

              }

			/*mdc 04/17/96 Enable and default ApplyPB*/
			FndGenRC = FndCommandEnable(CBI_hwnd,
	                           		 	"ApplyPB",
										&FndGenErrorBlock);

			FndGenRC = AZCS4FndCommandSetDefaultButton(CBI_hwnd,
	                                      		"ApplyPB",
	                                      		CMN_ARCH_PARMS);

           }

	/*mdc 03/11/96 - added to enable rest of radio button to allow user
                                   to select other than element if there is no match
        */
        else
	{
	    if(strcmp(ClntLiteralData,"") == 0 && ClntTypeData == LT_ClntLiteralRB)
	    {
                InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

		/*FndGenRBValueShort = LT_ClntLiteralRB;
		FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

                FndGenRBValueShort = LT_ClntHvRB;
                FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

			
		FndGenRBValueShort = LT_ClntLVRB;
		FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

		FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);


		FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

		FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);
             */
            }/*end of if ClntLiteralData*/

           /*mdc 05/02/96 removed to stop ApplyPB from being enabled if no
		   client type selected
            else 
            {
                 FndGenRC = FndCommandEnable(CBI_hwnd,
                                                    "ApplyPB",
                                                    &FndGenErrorBlock);

                 FndGenRC = AZCS4FndCommandSetDefaultButton(CBI_hwnd,
                                                              "ApplyPB",
                                                              CMN_ARCH_PARMS);
             } */
			 /*mdc 05/03/96 Added to enable ApplyPB if CLNTTYPE selected first*/
            else if (ClntTypeData == LT_ClntElementRB && strcmp(ClntElementData,"") == 0)
            {
                 FndGenRC = FndCommandDisable(CBI_hwnd,
                                                     "ApplyPB",
                                                     &FndGenErrorBlock);
            }
            else
            {
                 FndGenRC = FndCommandEnable(CBI_hwnd,
                                                    "ApplyPB",
                                                    &FndGenErrorBlock);

                 FndGenRC = FndCommandSetDefaultButton(CBI_hwnd,
                                                              "ApplyPB",
                                                              &FndGenErrorBlock);
             }
          
        }/*end of else - client name match not found*/
          
     }/*end of else - client row not selected*/


    FndGenRC = MoveService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);

}


