/***********************************************/
/* Find out what the attributes of the row are */
/***********************************************/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      &CellAttr,
                                      &FndGenErrorBlock);

/*******************************************************/
/* Move the selected row into the relationship section */
/*******************************************************/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevServiceRow = RowNum;
     FndGenRC = CellAttrNormS(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );
    }

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }



/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {

     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteService(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : NewService
**
**  DESCRIPTION      : This function controls the logic when a new service is
**                       is loaded into the combo box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (NewService)
{
  int index=0;
  int ServiceIndex=-1;
  unsigned int  nRC=0;
  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }

  if (ServiceIndex >= 0)
      {

      pWindContextData->WCD.ServiceLBOffset = 0;
      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);

     }

return(CMN_SUCCESS);

} /* end of NewService*/

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : RemoveRelationship
**
**  DESCRIPTION      : This function controls the logic when the remove pushbutton is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


/* 09/09/93 CSC: ADDED Logic for Multi page listbox */

static WCBPROC (RemoveRelationship)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    ServiceRow;
short                    ServiceElmnt;
short                    ClientRow;
short                    ClientElmnt;
int                      CellData;
short                    ix;
short                    iy;
BOOL                     MultipleService;

ix = pWindContextData->WCD.CurrentServiceIndex;


FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

CellData = CMN_LBROW_STATUS_UNCHANGED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/* Is there a matching client row or is there a literal ? */

if (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed == 'N')
   {
    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
    if (FndGenRC != FND_SUCCESS)
        return(CMN_FAIL);

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    MultipleService = FALSE;
    for (iy=0;
         iy < pWindContextData->WCD.ServiceInfoTable[ix].NumReposServiceRows;
         iy++)
        {
         if (pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[iy].ClientLayoutIndex == ClientElmnt &&
             iy != ServiceElmnt)
            {
             MultipleService = TRUE;
            }

        }
    if (!MultipleService)
       {
        FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);
        if (FndGenRC != FND_SUCCESS)
            return(CMN_FAIL);
       }

 /* De-Select the rows */
    Rlb01ELBSelIndData[ClientRow] = FALSE;
   }
else
   {
   pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,"NULL");

   /* JLL: 06/30/93 CHANGED FROM FALSE TO "N" */
   pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue,"NULL");

   }

Rlb02ELBSelIndData[ServiceRow] = FALSE;
pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex=-1;
pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 return(CMN_SUCCESS);
} /* end of function RemoveRelationship */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : CreateRelationship
**
**  DESCRIPTION      : This function controls the logic when the Apply PB is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**    01/28/94  C. Crampton           Added code for CheckDataTypes logic.
**
***************************************************************************/


/* 09/09/93 CSC: ADDED Logic for Multi page listbox */

static WCBPROC(CreateRelationship)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
unsigned short           ServiceRow;
unsigned short           ServiceElmnt;
unsigned short           ClientRow;
unsigned short           ClientElmnt;
int                      CellData;
short                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

/*
** Calculate the index into the memory table
*/

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/**********************************************/
/*** If the client side uses the element    ***/
/**********************************************/

if (ClntTypeData == LT_ClntElementRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'N';

    /* JLL: 06/30/93 CHANGED FROM "" to "NULL" */
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,"NULL");
    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);


    /*
    ** Calculate the offset into the element table
    */

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


    /*
    ** Make sure the data types match
    */
    FndGenRC = CheckDataTypes( ClientElmnt, ServiceElmnt, ix, CMN_ARCH_PARMS);

    if (FndGenRC != CMN_SUCCESS)
    {
        return(CMN_FAIL);
    }

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);

    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = ClientElmnt;
    Rlb01ELBSelIndData[ClientRow] = FALSE;
    }

/**********************************************/
/*** If the client side uses the literal    ***/
/**********************************************/

else
 if (ClntTypeData == LT_ClntLiteralRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              ClntLiteralData);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntHvRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              CMN_HIGH_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntLVRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].LiteralValue,
              CMN_LOW_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].ClientLayoutIndex = -1;
    }

/**********************************************/
/*** See if the wildcard checkbox is marked ***/
/**********************************************/

if (WildcardData == TRUE)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue,
           SrvcWldCardData);
    }
else
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardUsed = 'N';

    /* JLL: 06/30/93 CHANGED "" TO "NULL" */
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[ServiceElmnt].WildCardValue, "NULL");
    }

/**********************************************/
/*** Set the completed flag for this row    ***/
/**********************************************/

CellData = CMN_LBROW_STATUS_COMPLETED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);


 /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient1(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);


 return(CMN_SUCCESS);
} /* end of function CreateRelationship */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FindClientMatch
**
**  DESCRIPTION      : This function finds a matching service for a selected
**                        client row.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


/* 09/09/93 CSC: Added logic for multi-page support */

static short FindClientMatch(CMN_ARCH_PARM_TYPES)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short index;
short ClientRow;
short ClientElmnt;
short ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
   {
    return(CMN_FAIL);
   }
/*
** Calculate the element index based on the row and offset values
*/
ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pCompareKeys[index].ClientLayoutIndex)
         return(index);
    }
return(-1);
} /*  end of function FindClientMatch */


