                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}
/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*       AZCS011BUSNewService                                                  */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC (AZCS011BUSNewService)
{
  SHORT index=0;
  SHORT ServiceIndex=-1;
  USHORT  nRC=0;
  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }

  if (ServiceIndex >= 0)
      {

      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;
      pWindContextData->WCD.ServiceLBOffset = 0;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);
      }

return(CMN_SUCCESS);

} /* end of AZCS011BUSNewService*/


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*   AZCS011BUSRemoveRelationship                                              */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC (AZCS011BUSRemoveRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    ServiceRow;
SHORT                    ServiceElmnt;
SHORT                    ClientRow;
SHORT                    ClientElmnt;
SHORT                      CellData;
SHORT                    ix;
BOOL                     MultipleService;
SHORT                    iy;


ix = pWindContextData->WCD.CurrentServiceIndex;


FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

CellData = CMN_LBROW_STATUS_UNCHANGED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(CellData),
                                 &CellData,
                                 &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;


/* Is there a matching client row or is there a single occurence ? */

if (pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].SingleOccurence == 'N')
   {
    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    MultipleService = FALSE;
    for (iy=0;
         iy < pWindContextData->WCD.ServiceInfoTable[ix].NumReposServiceRows;
         iy++)
        {
         if (pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[iy].ClientLayoutIndex == ClientElmnt &&
             iy != ServiceElmnt)
            {
             MultipleService = TRUE;
            }

        }
    if (!MultipleService)
       {
        FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
       }

 /* De-Select the rows */
    Rlb01ELBSelIndData[ClientRow] = FALSE;




   }
else
   {
   pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].SingleOccurence = 'N';


   }

Rlb02ELBSelIndData[ServiceRow] = FALSE;
pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].ClientLayoutIndex=-1;

InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

ServiceDataComplete(pEventInfo,
                    pEAIA,
                    pBFCD,
                    pWesMap,
                    pWindContextData,
                    pABHI);

 return(CMN_SUCCESS);
} /* end of function AZCS011BUSRemoveRelationship */

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*       AZCS011BUSCreateRelationship                                          */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(AZCS011BUSCreateRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT           ServiceRow;
USHORT           ServiceElmnt;
USHORT           ClientRow;
USHORT           ClientElmnt;
SHORT                      CellData;
SHORT                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

/*
** Calculate the index into the memory table
*/

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;


/**********************************************/
/*** Set the completed flag for this row    ***/
/**********************************************/

CellData = CMN_LBROW_STATUS_COMPLETED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(CellData),
                                 &CellData,
                                 &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);
/**********************************************/
/*** If the client side uses the element    ***/
/**********************************************/

if (ClntTypeData == LT_ClntElementRB)
    {

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    if (FndGenRC != FND_SUCCESS)
        return(CMN_FAIL);


     FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
     if (FndGenRC != FND_SUCCESS)
         return(CMN_FAIL);

    pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].ClientLayoutIndex = ClientElmnt;
    Rlb01ELBSelIndData[ClientRow] = FALSE;
    pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].SingleOccurence = 'N';
    }

/**********************************************/
/*** If the client side uses the literal    ***/
/**********************************************/

else
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].ClientLayoutIndex = -1;
    pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].SingleOccurence = 'Y';
    }


 /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

    ServiceDataComplete(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 return(CMN_SUCCESS);
} /* end of function AZCS011BUSCreateRelationship */

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*      FindClientMatch                                              */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static SHORT FindClientMatch(CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT index;
SHORT ClientRow;
SHORT ClientElmnt;
SHORT ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
   {
    return(CMN_FAIL);
   }

/*
** Calculate the element index based on the row and offset values
*/
ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[index].ClientLayoutIndex)
         return(index);
    }
return(-1);
} /*  end of function FindClientMatch */


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*   CellAttrNormC                                                   */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(CellAttrNormC)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT   ClientElmnt;

     ClientElmnt = CBI_ListRow + pWindContextData->WCD.ClientLBOffset;

     if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
        {
         strcpy(ClntElementData,
    (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
        }
    else
        {
         strcpy(ClntElementData,
    (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);

        }

    Occurs1Data =
     (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemOccurs;

 return(CMN_SUCCESS);
}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*     CellAttrNormS                                                 */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(CellAttrNormS)
{
USHORT           FndGenRC = FND_SUCCESS;
SHORT                    ix;
USHORT   ServiceElmnt;

  ServiceElmnt = CBI_ListRow + pWindContextData->WCD.ServiceLBOffset;

  ix = pWindContextData->WCD.CurrentServiceIndex;

     if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
        {
         strcpy(SrvcElementData,
    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
        }
    else
        {
         strcpy(SrvcElementData,
    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);

        }

    OccursData =
     (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemOccurs;

 return(CMN_SUCCESS);
}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  AZCS011BusCellDataComplete                                                 */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(AZCS011BusCellDataComplete)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;

SHORT                    ServiceRow;
SHORT                    ServiceElmnt;
SHORT                    ix;
SHORT                    iy;
SHORT                    ClientRow;
SHORT                    ClientElmnt;


    ix = pWindContextData->WCD.CurrentServiceIndex;



  /* Select was from Client Side */

    if (CBI_WidgetID == Rlb01ELB_FID)
        {
         ClientRow = CBI_ListRow;
         ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

         FndGenRC = FndLstBoxRowSelect( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    ClientRow,
                                    &FndGenErrorBlock);


         FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                                MAPGEN_SERVICE_LB_NAME,
                                                FND_LSTBOX_START,
                                                &ServiceRow,
                                                &FndGenErrorBlock);

       /* If there is no selected service */
       /*    find the match from the ClientLayoutIndex table             */

         if (FndGenRC != FND_SUCCESS)
            {
             ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);
             ServiceRow = ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS);

             FndGenRC =LoadServiceElmnt(ServiceElmnt,
                                        CMN_ARCH_PARMS);

            }

         else
            {
              ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
              if (pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].ClientLayoutIndex != ClientElmnt)
                 {
                  ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);
                  ServiceRow = ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS);

                  FndGenRC = LoadServiceElmnt(ServiceElmnt,
                                              CMN_ARCH_PARMS);
                  }

            }
       }
    else
        {

         ServiceRow = CBI_ListRow;
         ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].ClientLayoutIndex;
         ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);

         FndGenRC = LoadClientElmnt(ClientElmnt, CMN_ARCH_PARMS);
        }


    if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS)
       {
        /*                                                                                           */
        /* Move the Relationship data from the WCD table into the relationship section of the window */
        /*                                                                                           */

        /* Move the Client Element stuff down */
       if (toupper(pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps[ServiceElmnt].SingleOccurence) ==
                                        'N')
          {


        /* Select the Service Row */
            FndGenRC = FndLstBoxRowSelect( CBI_hwnd,
                                    MAPGEN_SERVICE_LB_NAME,
                                    ServiceRow,
                                    &FndGenErrorBlock);

           if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
              {
              strcpy(ClntElementData,
             (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
              }
           else
              {
                strcpy(ClntElementData,
                (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
              }

             Occurs1Data =
                (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemOccurs;

             /* set the radio button to element */

             FndGenRBValueShort = LT_ClntElementRB;
             FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

             ClntTypeData = FndGenRBValueShort;

            /* Disable the Selection of the Single occurence RB */
             FndGenRBValueShort = LT_ClntLiteralRB;

             FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

            FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);

            FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "Occurs1",
                                      &FndGenErrorBlock);

             /*Make sure client row is normal */
             FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         MAPGEN_CLIENT_LB_NAME,
                                         ClientRow,
                                         AT_NORMAL,
                                         &FndGenErrorBlock);

             /* Select the Client Row */
            FndGenRC = FndLstBoxRowSelect (CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    ClientRow,
                                    &FndGenErrorBlock);
          }
       else
          {  /* Single occurence used not a data Element */
           FndGenRBValueShort = LT_ClntLiteralRB;

           FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           ClntTypeData = FndGenRBValueShort;
           FndGenRBValueShort = LT_ClntElementRB;

           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           strcpy(ClntElementData, "");
           FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);

           FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "Occurs1",
                                      &FndGenErrorBlock);

           FndGenRC = FndFieldEnable( CBI_hwnd,
                                     "SRVCELEMENT",
                                     &FndGenErrorBlock);

           FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "Occurs",
                                      &FndGenErrorBlock);



          for (iy=0; iy < NUMRLB01ELBROWS; iy++)
              {
               Rlb01ELBSelIndData[iy] = FALSE;
              }

          }

      /* Copy the Service element down */
      if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
          {
            strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
          }
      else
          {
           strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
          }

       OccursData =
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemOccurs;

       } /* end of if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS) */

    if (Rlb02ELBCdStatusIconicData[ServiceRow] == CMN_LBROW_STATUS_COMPLETED)
       {
        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        /* mdc - 03/04/96 - make the Remove pushbutton the default.*/
        FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "RemovePB",
                                          &FndGenErrorBlock);


        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);
       }
    else
       {

        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

        /* mdc - 03/04/96 - make the Apply pushbutton the default.*/
        FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);


       }



 return(CMN_SUCCESS);
}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* CellDataNotCompleteClient                                         */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(CellDataNotCompleteClient)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    RowNum = -1;
SHORT                      CellData;
SHORT                     *pCellData;


     pCellData = &CellData;

    FndGenRC = InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    /* Find out if there is a selected Service row */
    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                           MAPGEN_SERVICE_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           &FndGenErrorBlock);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
        return(CMN_FAIL);
       }
   /* A service row is selected */
    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_SERVICE_LB_NAME,
                                          RowNum,
                                          0,
                                          sizeof(CellData),
                                          (void *)pCellData,
                                          &FndGenErrorBlock);

      if (CellData == CMN_LBROW_STATUS_COMPLETED)
          {
           Rlb02ELBSelIndData[RowNum] = FALSE;
           InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                          pABHI );
          }
       else
           {
            FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

            /* mdc - 03/04/96 - make the Apply pushbutton the default.*/
            FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);


            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
           }


       }
    else
        {
         InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
        }


    FndGenRC = MoveClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);
}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* CellDataNotCompleteService                                        */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(CellDataNotCompleteService)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    RowNum = -1;
SHORT                      CellData;
SHORT                     *pCellData;
SHORT                      ServiceNum;
USHORT                    ClientIndex;
SHORT                    FndGenRBValueShort = 0;



     ServiceNum = pWindContextData->WCD.CurrentServiceIndex;

     pCellData = &CellData;

     /* Enable the Selection of the Single occurence RB */
      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);


    /* Find out if there is a selected Client row */
    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                           MAPGEN_CLIENT_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           &FndGenErrorBlock);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        return(CMN_FAIL);
       }

   /* A client row is selected */
    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_CLIENT_LB_NAME,
                                          RowNum,
                                          0,
                                          sizeof(CellData),
                                          (void *)pCellData,
                                          &FndGenErrorBlock);

      if (CellData == CMN_LBROW_STATUS_COMPLETED)
          {
/* 08/31/93 CSC : allow 1 to n client to servies
           Rlb01ELBSelIndData[RowNum] = FALSE;
           InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                          pABHI );
*/

/* CSC TEST Only         DisableClientRows(pEventInfo,
                            pEAIA,
                            pBFCD,
                            pWesMap,
                            pWindContextData,
                            pABHI );
*/

          FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);


           FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);



            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

          }
       else	 /*client selected but status not complete*/
           {
            FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

             /* mdc - 03/04/96 - make the Apply pushbutton the default.*/
             FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);



            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
           }


       }
    else /*client not selected*/
        {
         InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

/* CSC test only          DisableClientRows(pEventInfo,
                            pEAIA,
                            pBFCD,
                            pWesMap,
                            pWindContextData,
                            pABHI );
*/

        /* CSC: Added 08/31/93 */
        ClientIndex = LookForClientName(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        if (ClientIndex != CMN_FAIL)
           {
            FndGenRC = LoadClientElmnt(ClientIndex, CMN_ARCH_PARMS);


			/*mdc 04/17/96 Enable and default ApplyPB*/
			FndGenRC = FndCommandEnable(CBI_hwnd,
	                           		 	"ApplyPB",
										&FndGenErrorBlock);

			FndGenRC = FndCommandSetDefaultButton(CBI_hwnd,
	                                      		"ApplyPB",
										 		 &FndGenErrorBlock);




           }

        }


    FndGenRC = MoveService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);

}


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* AZCS011BUSSaveToBFCD                                                        */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(AZCS011BUSSaveToBFCD)
{
 SHORT ix;
 _RELATE_RPMH *pOldBFCD;
 _RELATE_RPMH *pTempBFCD;
 _RELATE_RPMH *pTempWCD;
 SHORT TempSize;


 for (ix=0; ix<pWindContextData->WCD.NumServices; ix++)
     {
      pOldBFCD = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps;

      pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps =
         (_RELATE_RPMH *) malloc(MAXSERVICEROWS * sizeof(_RELATE_RPMH) );

      memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps,
             0,
             MAXSERVICEROWS * sizeof(_RELATE_RPMH) );

      free(pOldBFCD);
      pTempBFCD = (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps);
      pTempWCD = (pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps);
      TempSize = (MAXSERVICEROWS * sizeof(_RELATE_RPMH));

      pOldBFCD =memcpy((pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pRepeatingMaps),
             (pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps),
             (MAXSERVICEROWS * sizeof(_RELATE_RPMH)) );

      free(pWindContextData->WCD.ServiceInfoTable[ix].pRepeatingMaps);
     }

return(CMN_SUCCESS);

} /* end of function AZCS011BUSSaveToBFCD  */

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* FillStatusRM                                                      */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(FillStatusRM)
{

SHORT ix;
SHORT ServNum;
SHORT ClientRow;
SHORT ClientElmnt;
SHORT ServiceRow;

ServNum = pWindContextData->WCD.CurrentServiceIndex;

/* Clear out the Client Listbox */
for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     if (Rlb01ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb01ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }

/* Clear out the Service Listbox */
for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     if (Rlb02ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb02ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }

/* Check the Service table for completed relationships */
for (ix=0; ix < pWindContextData->WCD.ServiceInfoTable[ServNum].NumReposServiceRows; ix++)
    {
     if (pWindContextData->WCD.ServiceInfoTable[ServNum].pRepeatingMaps[ix].ClientLayoutIndex > 0 )
        {
         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ServNum].pRepeatingMaps[ix].ClientLayoutIndex;
         /*
         ** If the row is in the Client or Service LB mark it completed
         */
         if (ClientElmnt >= pWindContextData->WCD.ClientLBOffset &&
             ClientElmnt <  pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS)
            {
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);
             Rlb01ELBCdStatusIconicData[ClientRow] = CMN_LBROW_STATUS_COMPLETED;
            }
         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
            ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }
        }
     else
      if (pWindContextData->WCD.ServiceInfoTable[ServNum].pRepeatingMaps[ix].SingleOccurence == 'Y')
          {
          if (ix >= pWindContextData->WCD.ServiceLBOffset &&
              ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
             {
              ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
              Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
             }
          }
    }  /* end of for loop thru all service RM rows */

return(CMN_SUCCESS);

} /* end of function FillStatusRM */

