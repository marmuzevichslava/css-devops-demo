/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  AZCS011BUSFillClientLB                                                     */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(AZCS011BUSFillClientLB)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT   usNumRows;
 _FND_ERROR_BLOCK         FndGenErrorBlock;

usNumRows = pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows -
            pWindContextData->WCD.ClientLBOffset;

if (usNumRows > NUMRLB01ELBROWS)
   {
    usNumRows = NUMRLB01ELBROWS;
   }

FndGenRC = FillGroupLB(MAPGEN_CLIENT_LB_NAME,
                        pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable +
                            pWindContextData->WCD.ClientLBOffset,
                        usNumRows,
                        pWindContextData->WCD.ClientLanguage,
                        CMN_ARCH_PARMS);

FndGenRC = FillStatusRM( pEventInfo,
                         pEAIA,
                         pBFCD,
                         pWesMap,
                         pWindContextData,
                         pABHI);
/*
** Reset the UP page button
*/

if (pWindContextData->WCD.ClientLBOffset > 0)
    {
     FndGenRC = FndLstBoxUpEnable(CBI_hwnd,
                                  MAPGEN_CLIENT_LB_NAME,
                                  &FndGenErrorBlock);
     }
else
     {
      FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                  MAPGEN_CLIENT_LB_NAME,
                                  &FndGenErrorBlock);
     }

/*
** Reset the DOWN page button
*/

if ((pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS) <
     pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
    {
     FndGenRC = FndLstBoxDownEnable(CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    &FndGenErrorBlock);
    }
else
    {
     FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                     MAPGEN_CLIENT_LB_NAME,
                                     &FndGenErrorBlock);
    }


return(CMN_SUCCESS);
} /* end of function AZCS011BUSFillClientLB */


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*    FillServiceLB                                                  */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(FillServiceLB)
{
USHORT           FndGenRC = FND_SUCCESS;
SHORT ix;
USHORT           usNumRows;
 _FND_ERROR_BLOCK         FndGenErrorBlock;

ix = pWindContextData->WCD.CurrentServiceIndex;

usNumRows = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows -
            pWindContextData->WCD.ServiceLBOffset;

if (usNumRows > NUMRLB02ELBROWS)
   {
    usNumRows = NUMRLB02ELBROWS;
   }


FndGenRC = FillGroupLB(MAPGEN_SERVICE_LB_NAME,
                        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable +
                          pWindContextData->WCD.ServiceLBOffset,
                        usNumRows,
                        pWindContextData->WCD.ServiceLanguage,
                        CMN_ARCH_PARMS);

FndGenRC = FillStatusRM( pEventInfo,
                         pEAIA,
                         pBFCD,
                         pWesMap,
                         pWindContextData,
                         pABHI);
/*
** Reset the UP page button
*/

if (pWindContextData->WCD.ServiceLBOffset > 0)
    {
     FndGenRC = FndLstBoxUpEnable(CBI_hwnd,
                                  MAPGEN_SERVICE_LB_NAME,
                                  &FndGenErrorBlock);
     }
else
     {
      FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                  MAPGEN_SERVICE_LB_NAME,
                                  &FndGenErrorBlock);
     }

/*
** Reset the DOWN page button
*/

if ((pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS) <
     pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows)
    {
     FndGenRC = FndLstBoxDownEnable(CBI_hwnd,
                                    MAPGEN_SERVICE_LB_NAME,
                                    &FndGenErrorBlock);
    }
else
    {
     FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                     MAPGEN_SERVICE_LB_NAME,
                                     &FndGenErrorBlock);
    }


return(CMN_SUCCESS);
} /* end of function FillServiceLB */





/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  FillGroupLB                                                     */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static SHORT FillGroupLB(char * LBName,
                           _LAYOUT_REC *pLayout,
                          SHORT NumRecords,
                          enum LANGUAGE_TYPE Language,
                          CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
_Rlb01ELBRow NewRow;
SHORT index=0;
char padding[]="   ";
SHORT index2=0;
 _LAYOUT_REC *pTemp;
 /*mdc 03/22/96 replaced by CONTROL_NAME_LEN in mapgen.h
char ControlName[34];
*/
SHORT SelectedRow;

/*
** Set the pointer to wait
*/

 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_WAIT,
                     &FndGenErrorBlock);


/* See if the list box has a selected row */

FndGenRC = FndLstBoxRowQuerySelection (CBI_hwnd,
                                       LBName,
                                       FND_LSTBOX_START,
                                       &SelectedRow,
                                       &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
   {
    SelectedRow = -1;
   }


/* Clear out the ListBox */

FndLstBoxRowDeleteAll( CBI_hwnd, LBName, &FndGenErrorBlock);


for (index=0; index < NumRecords; index++)
    {
     pTemp = (_LAYOUT_REC *)(pLayout+index);

     NewRow._Rlb01ELBCdStatusIconicData = CMN_LBROW_STATUS_AVAILABLE;

     /* CSC: 09/20/93 MODIFIED*/
     // NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemLength;
     NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemCLength;

     sprintf(NewRow._Rlb01ELBRecTypeData,"%c",toupper((pLayout+index)->ItemType));

     NewRow._Rlb01ELBOccursData = ((_LAYOUT_REC *)(pLayout+index))->ItemOccurs;

     strcpy(NewRow._Rlb01ELBControlNameData,"");
     for (index2=0; index2 < (pLayout+index)->IndentLevel &&
                    (index2 * strlen(padding)) <
                             CONTROL_NAME_LEN; index2++)
         {
          strcat(NewRow._Rlb01ELBControlNameData, padding);
         }

     if (Language == C_LANGUAGE)
         strncat(NewRow._Rlb01ELBControlNameData,
                 (pLayout+index)->ItemCName,
                 CONTROL_NAME_LEN - strlen(NewRow._Rlb01ELBControlNameData) - 1);
     else
        strncat(NewRow._Rlb01ELBControlNameData,(pLayout+index)->ItemCobolName,
                        CONTROL_NAME_LEN - strlen(NewRow._Rlb01ELBControlNameData) - 1);


     if (toupper((pLayout+index)->Format) == 'A')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Alpha");
         }

     else
      if (toupper((pLayout+index)->Format) == 'N')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Numeric");
         }
    else
          strcpy(NewRow._Rlb01ELBDataTypeData,"N/A");


     FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
                            LBName,
                            index,
                            sizeof(_Rlb01ELBRow),
                            &NewRow,
                            &FndGenErrorBlock);

     if ( (pLayout+index)->ItemType == 'G' && (pLayout+index)->ItemOccurs > 1)
        {
         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_NORMAL,
                                         &FndGenErrorBlock);
        }
     else
         {

         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_GREYED,

                                        &FndGenErrorBlock);
         }
    } /* end of for (index=0; index < NumRecords; index++) loop */

/****************************************************************/
/* If there was a selected row when you started select it again */
/****************************************************************/

   if (SelectedRow > 0)
      {
       FndGenRC = FndLstBoxRowSelect(CBI_hwnd,
                                     LBName,
                                     SelectedRow,
                                     &FndGenErrorBlock);

       if (FndGenRC != FND_SUCCESS)
          {
           return(CMN_FAIL);
          }

      }
/*
** Reset the pointer to arrow
*/

 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_ARROW,
                     &FndGenErrorBlock);


 return(CMN_SUCCESS);
}/* end of function FillGroupLB */

/********************************************************************/
/* DisableClientRows - This function disables the client rows based */
/*     on the selected service row. This forces the user to select  */
/*     only rows between established relationships.                 */
/********************************************************************/

static WCBPROC(DisableClientRows)
 {

USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    RowNum = -1;
SHORT                      CellData;
SHORT                      AboveRow, BelowRow;
SHORT                      ServiceNum;
SHORT                      ix;
SHORT                      NumServiceRows;
SHORT                      NumClientRows;
SHORT                    Elmnt;


    ServiceNum = pWindContextData->WCD.CurrentServiceIndex;
    NumServiceRows = pWindContextData->WCD.ServiceInfoTable[ServiceNum].NumReposServiceRows;
    NumClientRows =  pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows;

    /* find out if a row is completed above */
    /* if yes grey out the client list box from */
    /* the top to the matching client */

    AboveRow = -1;
    for (ix=CBI_ListRow-1; ix >= 0; ix--)
      {
       FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_SERVICE_LB_NAME,
                                          ix,
                                          0,
                                          sizeof(CellData),
                                          &CellData,
                                          &FndGenErrorBlock);

       Elmnt = ix + pWindContextData->WCD.ServiceLBOffset;

       if (CellData == CMN_LBROW_STATUS_COMPLETED &&
           pWindContextData->WCD.ServiceInfoTable[ServiceNum].pRepeatingMaps[Elmnt].SingleOccurence ==
                 'N')
          {
           Elmnt = pWindContextData->WCD.ServiceInfoTable[ServiceNum].pRepeatingMaps[Elmnt].ClientLayoutIndex;
           AboveRow = ClientElmntToRow(Elmnt, CMN_ARCH_PARMS);
           if (AboveRow < pWindContextData->WCD.ClientLBOffset || AboveRow == -1)
               {
                AboveRow = pWindContextData->WCD.ClientLBOffset;
               }
           break;
          }
      }
    for (ix=0; ix < AboveRow; ix++)
      {
       FndGenRC = FndLstBoxRowSetAttr(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      ix,
                                      AT_GREYED,
                                      &FndGenErrorBlock);
      }

    BelowRow = NumServiceRows;
    for (ix=CBI_ListRow; ix < NumServiceRows && ix >= 0; ix++)
      {
       FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_SERVICE_LB_NAME,
                                          ix,
                                          0,
                                          sizeof(CellData),
                                          &CellData,
                                          &FndGenErrorBlock);

       if (CellData == CMN_LBROW_STATUS_COMPLETED &&
           pWindContextData->WCD.ServiceInfoTable[ServiceNum].pRepeatingMaps[ix].SingleOccurence ==
                 'N')
          {
           BelowRow = pWindContextData->WCD.ServiceInfoTable[ServiceNum].pRepeatingMaps[ix].ClientLayoutIndex;
           break;
          }
      }
    for (ix=BelowRow+1; ix < NumClientRows && ix >= 0; ix++)
      {
       FndGenRC = FndLstBoxRowSetAttr(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      ix,
                                      AT_GREYED,
                                      &FndGenErrorBlock);
       if (FndGenRC != CMN_SUCCESS)
          {
           return(CMN_FAIL);
          }
      }

  return(CMN_SUCCESS);

 } /* end of function Disable ClientRows */



static WCBPROC(ServiceDataComplete)
{

 SHORT servx;
 SHORT elmntx;
 SHORT FndGenRC;
 _FND_ERROR_BLOCK FndGenErrorBlock;


 for(servx=0; servx < pBFCD->pCSRMapBFCD->NumServices; servx++)
    {
     for (elmntx=0; elmntx < pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].NumReposServiceRows; elmntx++)
          {
           /* if the element is a group with more than one occurence and
           **  it does not have a relationship defined yet set the status
           **  of serviceLayoutName to STS_INVALID. This will disable the OK
           **  pushbutton. The user cannot ok this window until all valid
           **  occuring groups have a relationsip defined.
           */

           /* CSC: 07/12/94 Delete Flag Checked also */
           if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].pReposServiceLayoutTable[elmntx].ItemType == 'G' &&
                pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].pReposServiceLayoutTable[elmntx].ItemOccurs > 1 &&
                pWindContextData->WCD.ServiceInfoTable[servx].pRepeatingMaps[elmntx].ClientLayoutIndex <= 0 &&
                pWindContextData->WCD.ServiceInfoTable[servx].pRepeatingMaps[elmntx].SingleOccurence != 'Y' &&
                pBFCD->pCSRMapBFCD->ServiceInfoTable[servx].DeleteFlag == FALSE)
              {
                /*mdc 03/04/96 changed call to this and added Fl Window Mod
                                    to azcs011 window to monitor window validation
                */
                FndGenRC = CmnWindowSetApplInvalid ( CMN_ARCH_PARMS );

                return(CMN_SUCCESS);
               }

          }
    }
/*mdc 03/04/96 Same as above on line 2270 */
FndGenRC = CmnWindowSetApplValid ( CMN_ARCH_PARMS );

/*mdc 04/26/96 set ApplyPB to disabled */
FndGenRC = FndCommandDisable( CBI_hwnd,
                              "ApplyPB",
							  &FndGenErrorBlock );

/* mdc - 03/04/96 - make the OK pushbutton the default.*/
 FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);



return(CMN_SUCCESS);

}



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : Azcs011busrlb01elbpagedown
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/99/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/99/93  C. Crampton           Original code.
**
***************************************************************************/




static WCBPROC(Azcs011busrlb01elbpagedown)
 {
  _FND_ERROR_BLOCK FndGenErrorBlock;
  USHORT FndGenRC;


  /*
  ** Range check incrementing the offset for the client list box
  */
    if (( pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS) <
          pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
       {
        pWindContextData->WCD.ClientLBOffset += NUMRLB01ELBROWS;

        FndGenRC = AZCS011BUSFillClientLB(pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );

       }
    else
       {
        FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                        MAPGEN_CLIENT_LB_NAME,
                                        &FndGenErrorBlock);
       }

  return(CMN_SUCCESS);
 }


