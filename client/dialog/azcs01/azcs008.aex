/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitHlpInit
**
**  DESCRIPTION      : This function initializes Help for this Window.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : CHRIS CRAMPTON
**
**  DATE CREATED     : APRIL 8, 1993
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  04/08/93  C. CRAMPTON           Original code.
**  04/15/93  C. CRAMPTON           Added CmnHlpMgrSetPanels logic.
**  10/06/94  J. LOONEY             Deleted all help logic.  Use a previous
**                                  revision to reimplement the help logic.
***************************************************************************/

AEXPROC (ExitHlpInit)
{

/****************  User Instructions  **********************************/
/***                                                                 ***/
/***  The User needs to make 3 changes to implement this             ***/
/***   functionality:                                                ***/
/***                                                                 ***/
/***    1. Change the macro field HELPWINDOWTITLE. Enter the string  ***/
/***       that you want as the title of the help window. It must be ***/
/***       enclosed in double quotes (C language string).            ***/
/***       (I.E. #define HELPWINDOWTITLE "Help for Window XXXX" )    ***/
/***                                                                 ***/
/***    2. Change the macro field HELPFILENAME. Enter the name of    ***/
/***       the help file including the filename extension. It must   ***/
/***       be enclosed in double quotes (C language string).         ***/
/***       (I.E. #define HELPFILENAME "HELP.HLP" )                   ***/
/***                                                                 ***/
/***    3. Add the Widget or Command Id and the corresponding        ***/
/***         Help Panels Panel Number to the PanelList array.        ***/
/***         When the user presses <F1> WES will look in this array  ***/
/***         for the Widget or Command ID. If the ID exists the      ***/
/***         corresponding Panel will be displayed.                  ***/
/***       (I.E. PanelList[] = { Widget Id1 , Panel Number 1,        ***/
/***                             Widget Id2 , Panel Number 2         ***/
/***                           };                                    ***/
/***                                                                 ***/
/***   NO OTHER CHANGES TO THIS FUNCTION SHOULD BE NECESSARY.        ***/
/***                                                                 ***/
/***********************************************************************/


/***********************************************************************/
/***  Change the 3 fields above. See User Instructions above.        ***/
/***                                                                 ***/
/***   NO OTHER CHANGES TO THIS FUNCTION SHOULD BE NECESSARY.        ***/
/***                                                                 ***/
/***********************************************************************/

/***********************************************************************/
/*** Initialize the help instance for this window by calling         ***/
/***    the CmnHlpMgrInitInst function.                              ***/
/***********************************************************************/


/***********************************************************************/
/*** Create the Widget and Command Id to Panel number relationship.  ***/
/***********************************************************************/

    return(CMN_SUCCESS);
}


