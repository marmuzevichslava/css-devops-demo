AEXPROC (ExitElb1BuildInitData)
{

 char Init[] = "GoodLuck";
 USHORT FndGenRC=0;
  _FND_ERROR_BLOCK FndGenErrorBlock;

  /* CSC: ADDED 06/18/93 */
  HEAP_CHECK

 FndGenRC = CmnElbAssignInitialData (
                          (void *) &Init,
                         strlen(Init) + 1,
                         CMN_ARCH_PARMS);


  /* CSC: ADDED 06/18/93 */
  HEAP_CHECK


  return CMN_SUCCESS;
}



