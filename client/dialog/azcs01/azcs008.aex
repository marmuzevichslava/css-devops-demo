/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElbRegister
**
**  DESCRIPTION      : This exit function allows for the coding of the
**                     enterable list box registration function:
**                     CmnElbRegisterRelations.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : CmnElbRegisterRelations (for each ELB in window)
**
**  AUTHOR           :
**
**  DATE CREATED     :
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
***************************************************************************/

AEXPROC (ExitElbRegister)
{
 unsigned short FndGenRC;
  _FND_ERROR_BLOCK FndGenErrorBlock;
 short rc=0;
 _CMNELBREGPARMS Parms;

    /*  Each enterable list box in a window MUST be registered with  */
    /*     the architecture.  Use the following function once for    */
    /*     enterable list box in the window.                         */


  strcpy(Parms.szElbWidgetName, "MapLB");
  Parms.nElbSeqNum = 1;
  Parms.nElbRowLen = sizeof(_MapLBRow);
  Parms.nElbMaxTxnCount = NUMMAPLBROWS;
  strcpy(Parms.szElbAddWinName,"AZCS010");
  strcpy(Parms.szElbChgWinName,"");
  strcpy(Parms.szElbAddPbName, "AddPB");
  strcpy(Parms.szElbAddUsingPbName,"");
  strcpy(Parms.szElbChangePbName,"");
  strcpy(Parms.szElbDeletePbName,"DeletePB");
  strcpy(Parms.szElbUndeletePbName,"UndeletePB");
  strcpy(Parms.szElbUpPbName,"");
  strcpy(Parms.szElbDownPbName,"");


  FndGenRC = CmnElbRegister(&Parms, CMN_ARCH_PARMS);


/* CSC: 08/04/93 Deleted to upgrade to new ELB code
    FndGenRC = CmnElbRegisterRelations("MapLB",
                                  1,
                                  sizeof(_MapLBRow),
                                  "AZCS010",
                                  "AddPB",
                                  "",
                                  "",
                                  "DeletePB",
                                  "UndeletePB",
                                  CMN_ARCH_PARMS);
*/
  return CMN_SUCCESS;
}



/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1CloseAfterSave
**
**  DESCRIPTION      : This exit function is for Close After Save processing
**                     for the enterable list box registered as sequence
**                     number 1.  Place any necessary statements in this
**                     exit to process the saved data from the enterable
**                     list box child window.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           :
**
**  DATE CREATED     :
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
***************************************************************************/

AEXPROC (ExitElb1CloseAfterSave)
{
 short FndGenRC = FND_SUCCESS;
  _FND_ERROR_BLOCK FndGenErrorBlock;
 _MapLBRow NewRow;
 short ix=0;

/******************************************************************/
/* Put the data that was added in window AZCS010 into the Listbox */
/******************************************************************/

    _SDMapName *pSDMapName;


    pSDMapName = CMN_ELB_CHILD_DATA;


    for (ix=0;ix < MAX_SD; ix++)
        {
         if (strcmp(pSDMapName[ix].SDMapName, "") == 0)
             break;

         NewRow._MapLBCdStatusIconicData = CMN_LBROW_STATUS_ADDED;
         strcpy(NewRow._MapLBRequestIDData, pSDMapName[ix].SDMapName);

         FndGenRC = CmnElbAssignRowData( CMN_ELB_WIDGET_NAME,
                                 CMN_ELB_ROW_PROCESSING,
                                 &NewRow,
                                 NULL,
                                 CMN_ARCH_PARMS);
        }
  return CMN_SUCCESS;
}



