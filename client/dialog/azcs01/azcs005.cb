			  	FndGenRC = FndFieldSetValue(CBI_hwnd,
				                            "CLNTELEMENT",
											(USHORT)strlen((pBFCD->pCSRMapBFCD->
												ClientInfo.pReposClientLayoutTable + 
												ClientIndex)->ItemCName),
											 (pBFCD->pCSRMapBFCD->
											 	ClientInfo.pReposClientLayoutTable + 
											 	ClientIndex)->ItemCName,
											&FndGenErrorBlock);
              }
            else
              {
			  	FndGenRC = FndFieldSetValue(CBI_hwnd,
				                            "CLNTELEMENT",
											(USHORT)strlen((pBFCD->pCSRMapBFCD->
												ClientInfo.pReposClientLayoutTable + 
												ClientIndex)->ItemCobolName),
											 (pBFCD->pCSRMapBFCD->
											 	ClientInfo.pReposClientLayoutTable + 
											 	ClientIndex)->ItemCobolName,
											&FndGenErrorBlock);

              }



			/*mdc 04/17/96 Enable and default ApplyPB*/
			FndGenRC = FndCommandEnable(CBI_hwnd,
	                            		"ApplyPB",
										&FndGenErrorBlock);

			FndGenRC = FndCommandSetDefaultButton(CBI_hwnd,
	                                     		 "ApplyPB",
										 		 &FndGenErrorBlock);

           }

        }


    FndGenRC = MoveService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);

}


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS005BUSSaveToBFCD
**
**  DESCRIPTION      : This function controls the logic when data needs to
**                      be moved from WCD to BFCD.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(AZCS005BUSSaveToBFCD)
{
 SHORT ix;
 _RELATE_RD *pOldBFCD;
 _RELATE_RD *pTempBFCD;
 _RELATE_RD *pTempWCD;
 SHORT TempSize;


 for (ix=0; ix<pWindContextData->WCD.NumServices; ix++)
     {
      pOldBFCD = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData;

      pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData =
         (_RELATE_RD *) malloc(MAXSERVICEROWS * sizeof(_RELATE_RD) );

      memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData,
             0,
             MAXSERVICEROWS * sizeof(_RELATE_RD));

      free(pOldBFCD);
      pTempBFCD = (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData);
      pTempWCD = (pWindContextData->WCD.ServiceInfoTable[ix].pReturnData);
      TempSize = (MAXSERVICEROWS * sizeof(_RELATE_RD));

      pOldBFCD =memcpy((pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReturnData),
             (pWindContextData->WCD.ServiceInfoTable[ix].pReturnData),
             (MAXSERVICEROWS * sizeof(_RELATE_RD)) );

      free(pWindContextData->WCD.ServiceInfoTable[ix].pReturnData);
     }

return(CMN_SUCCESS);

} /* end of function AZCS005BUSSaveToBFCD  */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FillStatusRD
**
**  DESCRIPTION      : This function controls the logic that fills the
**                      status icon column of the list boxes.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(FillStatusRD)
{

SHORT ix;
SHORT ServNum;
SHORT ServiceRow;
SHORT ClientRow;
SHORT ClientElmnt;

ServNum = pWindContextData->WCD.CurrentServiceIndex;

/* Clear out the Client Listbox */
for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     if (Rlb01ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb01ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }

    }
/*
** Clear out the service Listbox
*/
for (ix=0; ix < NUMRLB02ELBROWS; ix++)
    {
     if (Rlb02ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb02ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }


/* Check the Service table for completed relationships */
for (ix=0; ix < pWindContextData->WCD.ServiceInfoTable[ServNum].NumReposServiceRows; ix++)
    {
     if (pWindContextData->WCD.ServiceInfoTable[ServNum].pReturnData[ix].ClientLayoutIndex > 0 )
        {
         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ServNum].pReturnData[ix].ClientLayoutIndex;

         /*
         ** If the row is in the Client or Service LB mark it completed
         */
         if (ClientElmnt >= pWindContextData->WCD.ClientLBOffset &&
             ClientElmnt <  pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS)
            {
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);
             Rlb01ELBCdStatusIconicData[ClientRow] = CMN_LBROW_STATUS_COMPLETED;
            }
         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
             ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }
        }
    }  /* end of for loop thru all service CK rows */

return(CMN_SUCCESS);
} /* end of function FillStatusRD */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : InitClient
**
**  DESCRIPTION      : This function initializes the Client LB fields and
**                      sets the controls to thier default position.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
