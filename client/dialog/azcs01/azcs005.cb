/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : CellDataComplete
**
**  DESCRIPTION      : This function controls the logic when a completed row
**                      is selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(CellDataComplete)
{
USHORT	   FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT		    FndGenRBValueShort = 0;

SHORT		    ServiceRow = 0;
SHORT		    ServiceElmnt = 0;
SHORT		    ix = 0;
SHORT		    ClientRow= 0;
SHORT		    ClientElmnt = 0;

    ix = pWindContextData->WCD.CurrentServiceIndex;



    FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
    
    /* mdc - 03/04/96 - make the Remove pushbutton the default.*/
    FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "RemovePB",
                                          &FndGenErrorBlock);


    FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

  /*
  ** Select was from Client Side
  */
    if (CBI_WidgetID == Rlb01ELB_FID)
        {
         ClientRow = CBI_ListRow;
         ClientElmnt = pWindContextData->WCD.ClientLBOffset + ClientRow;

         FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                                MAPGEN_SERVICE_LB_NAME,
                                                FND_LSTBOX_START,
                                                &ServiceRow,
                                                &FndGenErrorBlock);

       /*
       ** If there is no selected service
       **    find the match from the ClientLayoutIndex table
       */

         if (FndGenRC != FND_SUCCESS)
            {
             ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);

/*mdc 03/13/96 Assign value to ServiceRow */
             ServiceRow = ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS);

             FndGenRC =  LoadServiceElmnt(ServiceElmnt,
                                          CMN_ARCH_PARMS);
            }
         /*
         ** A service row is selected
         */
         else
            {
             ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
               /*
               ** If not a relationship between service and client
               **   find the first one
               */
             if (pWindContextData->WCD.ServiceInfoTable[ix].pReturnData[ServiceElmnt].ClientLayoutIndex != ClientElmnt)
                {
                 ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);
                 ServiceRow = ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS);

                 FndGenRC = LoadServiceElmnt(ServiceElmnt,
                                             CMN_ARCH_PARMS);
                }
            }
       }
    /*
    ** Service Row was selected
    */
    else
        {

         ServiceRow = CBI_ListRow;
         ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ix].pReturnData[ServiceElmnt].ClientLayoutIndex;
         ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);

         FndGenRC = LoadClientElmnt(ClientElmnt, CMN_ARCH_PARMS);

        }




    if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS)
       {
        /*                                                                                           */
        /* Move the Relationship data from the WCD table into the relationship section of the window */
        /*                                                                                           */
	 fprintf(stderr,"ServiceRow = %d", ServiceRow);
        /* Select the Service Row */
            FndGenRC = FndLstBoxRowSelect( CBI_hwnd,
                                    MAPGEN_SERVICE_LB_NAME,
                                    ServiceRow,
                                    &FndGenErrorBlock);

           if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
              {
              strcpy(ClntElementData,
             (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
              }
           else
              {
                strcpy(ClntElementData,
                (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
              }

             /* Select the Client Row */
            FndGenRC = FndLstBoxRowSelect (CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    ClientRow,
                                    &FndGenErrorBlock);

      /* Copy the Service element down */
      if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
          {
            strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
          }
      else
          {
           strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
          }

       } /* end of if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS) */


 return(CMN_SUCCESS);
}


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellDataNotCompleteClient
**
**  DESCRIPTION      : This function controls the logic when a client row that
**                      does not have a relationship defined is selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/99/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/99/93  C. Crampton           Original code.
**
**
**    04/18/96  mconner				Added logic to fill in service element
**                                  field and default apply pb.
**
***************************************************************************/

static WCBPROC(CellDataNotCompleteClient)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
/*mdc 09/23/96 Changed initialize of rownumto 0 -1 doesn't work 
SHORT                    RowNum = -1;
*/
SHORT                    RowNum = 0;
SHORT                      CellData;
SHORT                     *pCellData;
/*mdc 04/18/96 added ix and changed data type of ServiceIndex to USHORT*/
SHORT                      ix;
USHORT                      ServiceIndex;

     pCellData = &CellData;

    FndGenRC = InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    /* Find out if there is a selected Service row */
    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                           MAPGEN_SERVICE_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           &FndGenErrorBlock);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
        return(CMN_FAIL);
       }
   /* A service row is selected */
    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                          MAPGEN_SERVICE_LB_NAME,
                                          RowNum,
                                          0,
                                          sizeof(CellData),
                                          (void *)pCellData,
                                          &FndGenErrorBlock);

      if (CellData == CMN_LBROW_STATUS_COMPLETED)
          {
           Rlb02ELBSelIndData[RowNum] = FALSE;
           InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                          pABHI );
          }
       else
           { 
            FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

            /* mdc - 03/04/96 - make the Apply pushbutton the default.*/
            FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);


            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

             }


       }
    else
        {
         InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        ServiceIndex = LookForServiceName(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        if (ServiceIndex != CMN_FAIL)
           {
            FndGenRC = LoadServiceElmnt(ServiceIndex, CMN_ARCH_PARMS);

   			/*mdc 04/18/96 aded to populate the service element field*/
			ix = pWindContextData->WCD.CurrentServiceIndex;

			FndGenRC = FndFieldEnable(CBI_hwnd,
			                             "SRVCELEMENT",
			                             &FndGenErrorBlock);


			if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
			    {
					FndFieldSetValue(CBI_hwnd,
					                 "SRVCELEMENT",
									 (USHORT)strlen((pBFCD->pCSRMapBFCD->
									 	ServiceInfoTable[ix].
									 	pReposServiceLayoutTable + 
									 	ServiceIndex)->ItemCName),
									(pBFCD->pCSRMapBFCD->
										ServiceInfoTable[ix].
										pReposServiceLayoutTable + 
										ServiceIndex)->ItemCName,
									&FndGenErrorBlock);

			    }
			else
			    {
					FndFieldSetValue(CBI_hwnd,
					                 "SRVCELEMENT",
									 (USHORT)strlen((pBFCD->pCSRMapBFCD->
									 	ServiceInfoTable[ix].
									 	pReposServiceLayoutTable + 
									 	ServiceIndex)->ItemCobolName),
									(pBFCD->pCSRMapBFCD->
										ServiceInfoTable[ix].
										pReposServiceLayoutTable + 
										ServiceIndex)->ItemCobolName,
									&FndGenErrorBlock);
					

			    }



			/*mdc 04/17/96 Enable and default ApplyPB*/
			FndGenRC = FndCommandEnable(CBI_hwnd,
	                            		"ApplyPB",
										&FndGenErrorBlock);

			FndGenRC = FndCommandSetDefaultButton(CBI_hwnd,
	                                      		"ApplyPB",
										 		 &FndGenErrorBlock);

           }
        else
          {
             FndGenRC = FndCommandSetDefaultButton(CBI_hwnd,
                                                          "OKPB",
                                                          &FndGenErrorBlock);
          }
        }


    FndGenRC = MoveClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);
}


