***************************************************************************/



static WCBPROC (AZCS005BUSMoveLB2)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           RowNum;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT             CellAttr;
USHORT           CellData;
USHORT          *pCellData;

/***********************************/
/* Find out which row was selected */
/***********************************/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                       MAPGEN_SERVICE_LB_NAME,
                            FND_LSTBOX_START,
                            &RowNum,
                            &FndGenErrorBlock);

/***********************************************/
/* Find out what the attributes of the row are */
/***********************************************/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      &CellAttr,
                                      &FndGenErrorBlock);

/*******************************************************/
/* Move the selected row into the relationship section */
/*******************************************************/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevServiceRow = RowNum;
     FndGenRC = MoveService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }

    }



/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {

     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteService(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS005BUSNewService
**
**  DESCRIPTION      : This function controls the logic when a new service is
**                       is loaded into the combo box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (AZCS005BUSNewService)
{
  SHORT index=0;
  SHORT ServiceIndex=-1;
  USHORT  nRC=0;
  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }

  if (ServiceIndex >= 0)
      {
      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;
      pWindContextData->WCD.ServiceLBOffset = 0;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);

     }

return(CMN_SUCCESS);

} /* end of AZCS005BUSNewService*/

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS005BUSRemoveRelationship
**
**  DESCRIPTION      : This function controls the logic when the remove pushbutton is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (AZCS005BUSRemoveRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    ServiceRow;
SHORT                    ServiceElmnt;
SHORT                    ClientRow;
SHORT                    ClientElmnt;

SHORT                      CellData;
SHORT                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which Service row is selected.
** Set its status to unchanged
*/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

CellData = CMN_LBROW_STATUS_UNCHANGED;

FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
    return(CMN_FAIL);

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/*
** Find out which Client row is selected
** Set its status to unchanged
*/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
if (FndGenRC != FND_SUCCESS)
        return(CMN_FAIL);

    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
    if (FndGenRC != FND_SUCCESS)
        return(CMN_FAIL);

/*
** De-Select the Client and Service rows
*/

Rlb01ELBSelIndData[ClientRow] = FALSE;
Rlb02ELBSelIndData[ServiceRow] = FALSE;

/*
** Calculate the memory offset
*/

ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;


pWindContextData->WCD.ServiceInfoTable[ix].pReturnData[ServiceElmnt].ClientLayoutIndex=-1;

InitService(pEventInfo,
            pEAIA,
            pBFCD,
            pWesMap,
            pWindContextData,
            pABHI);

InitClient(pEventInfo,
           pEAIA,
           pBFCD,
           pWesMap,
           pWindContextData,
           pABHI);

 /* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }



 return(CMN_SUCCESS);
} /* end of function AZCS005BUSRemoveRelationship */

/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS005BUSCreateRelationship
**
**  DESCRIPTION      : This function controls the logic when the Apply PB is clicked.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**    01/28/94  C. Crampton           Added Logic for data type check.
**
***************************************************************************/

static WCBPROC(AZCS005BUSCreateRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT           ServiceRow;
SHORT                    ServiceElmnt;
USHORT           ClientRow;
SHORT                    ClientElmnt;
SHORT                      CellData;
SHORT                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);

/*
** Find out what the selected Client row is.
** Update its icon column to completed.
*/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
/*
** Calculate the memory offset
*/
    ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Make sure the data types match
*/
FndGenRC = CheckDataTypes( ClientElmnt, ServiceElmnt, ix, CMN_ARCH_PARMS);

if (FndGenRC != CMN_SUCCESS)
 {
     return(CMN_FAIL);
 }

/**********************************************/
/*** Set the completed flag for this row    ***/
/**********************************************/

    CellData = CMN_LBROW_STATUS_COMPLETED;

    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);


    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);


    pWindContextData->WCD.ServiceInfoTable[ix].pReturnData[ServiceElmnt].ClientLayoutIndex = ClientElmnt;

    Rlb01ELBSelIndData[ClientRow] = FALSE;

 /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

/* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }



 return(CMN_SUCCESS);
} /* end of function AZCS005BUSRemoveRelationship */


/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : FindClientMatch
**
**  DESCRIPTION      : This function finds a matching service for a selected
**                        client row.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  C. Crampton           Original code.
**
***************************************************************************/



static SHORT FindClientMatch(CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT index;
SHORT ClientRow;
SHORT ClientElmnt;
SHORT ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which client row is selected
*/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS)
   {
    return(CMN_FAIL);
   }

ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pReturnData[index].ClientLayoutIndex)
         return(index);
    }
return(CMN_FAIL);
} /*  end of function FindClientMatch */


