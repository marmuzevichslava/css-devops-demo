            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
           }


       }
    else
        {
         InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

        ClientIndex = LookForClientName(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
