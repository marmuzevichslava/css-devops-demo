/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Nxydzzvj1987_Field_Change
 * 
 *   WidgetName:    ServiceMapType
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Nxydzzvj1987_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

if ( strcmp(ServiceMapTypeData, LT_Primary) == 0 )
   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "ALTMAP",
                            &FndGenErrorBlock);

   }
else
   {

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "ALTMAP",
                             &FndGenErrorBlock);

   } /* end if */

if ( strcmp(ServiceMapTypeData, LT_Alternate) == 0 )
   {

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "ALTMAP",
                             &FndGenErrorBlock);

   }
else
   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "ALTMAP",
                            &FndGenErrorBlock);

   } /* end if */

return 0;


}
