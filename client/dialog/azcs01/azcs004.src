/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Ejsugzjx1216_Field_Change
 * 
 *   WidgetName:    CLNTTYPE
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx1216_Field_Change)
{
   short                 FndCrRlb01ELB = 0;
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   short                 FndGenRBValueShort = 0;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   if (ClntTypeData == 1)
   {

      FndGenRC = FndFieldEnable( CBI_hwnd,
                                   "CLNTELEMENT",
                                   &FndGenErrorBlock);

      ClntTypeData = LT_ClntElementRB;

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTLITERAL",
                                    &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntHvRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLVRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                    "CLNTLITERAL",
                                    STS_VALID,
                                    &FndGenErrorBlock);

      FndGenRC = AZCS004BUSChangeClientType( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

   } /* end if */

   if (ClntTypeData == 2)
   {

      FndGenRC = FndFieldEnable( CBI_hwnd,
                                   "CLNTLITERAL",
                                   &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTELEMENT",
                                    &FndGenErrorBlock);

      FndGenRC = FndCommandDisable( CBI_hwnd,
                                    "ApplyPB",
                                    &FndGenErrorBlock);

      for ( FndCrRlb01ELB = 0;
            FndCrRlb01ELB < NUMRLB01ELBROWS;
            FndCrRlb01ELB++)
      {

         Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

      strncpy(ClntElementData,"",1);

      strncpy(ClntLiteralData,"",1);

      FndGenRBValueShort = LT_ClntElementRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntHvRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLVRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRC = AZCS004BUSSetCLNTLITERALStatus( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

      FndGenRC = AZCS004BUSChangeServiceType( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

      FndGenRC = FndFieldSetCursor( CBI_hwnd,
                                    "CLNTLITERAL",
                                    CUR_MAKECURRENT,
                                    &FndGenErrorBlock);

   } /* end if */

   if (ClntTypeData == 4)
   {

      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLVRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      strncpy(ClntElementData,"",1);

      strncpy(ClntLiteralData,"",1);

      for ( FndCrRlb01ELB = 0;
            FndCrRlb01ELB < NUMRLB01ELBROWS;
            FndCrRlb01ELB++)
      {

         Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

      FndGenRBValueShort = LT_ClntElementRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTELEMENT",
                                    &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTLITERAL",
                                    &FndGenErrorBlock);

      FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                    "CLNTLITERAL",
                                    STS_VALID,
                                    &FndGenErrorBlock);

      FndGenRC = AZCS004BUSChangeServiceType( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

      if (strncmp(SrvcElementData, "", 1) == 0)
      {

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "ApplyPB",
                                       &FndGenErrorBlock);

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "RemovePB",
                                       &FndGenErrorBlock);

      } /* end if */

   } /* end if */

   if (ClntTypeData == 3)
   {

      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntHvRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      strncpy(ClntElementData,"",1);

      strncpy(ClntLiteralData,"",1);

      for ( FndCrRlb01ELB = 0;
            FndCrRlb01ELB < NUMRLB01ELBROWS;
            FndCrRlb01ELB++)
      {

         Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

      FndGenRBValueShort = LT_ClntElementRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTELEMENT",
                                    &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "CLNTLITERAL",
                                    &FndGenErrorBlock);

      FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                    "CLNTLITERAL",
                                    STS_VALID,
                                    &FndGenErrorBlock);

      FndGenRC = AZCS004BUSChangeServiceType( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

      if (strncmp(SrvcElementData, "", 1) == 0)
      {

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "ApplyPB",
                                       &FndGenErrorBlock);

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "RemovePB",
                                       &FndGenErrorBlock);

      } /* end if */

   } /* end if */

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Ejsugzjx0869_Field_Change
 * 
 *   WidgetName:    WILDCARD
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx0869_Field_Change)
{
   short                 FndCrRlb02ELB = 0;
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   short                 FndGenRBValueShort = 0;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   if (WildcardData == 1)
   {

      FndGenRC = FndFieldEnable( CBI_hwnd,
                                   "CLNTELEMENT",
                                   &FndGenErrorBlock);

      ClntTypeData = LT_ClntElementRB;

      FndGenRC = FndFieldEnable( CBI_hwnd,
                                   "SRVCWLDCARD",
                                   &FndGenErrorBlock);

      for ( FndCrRlb02ELB = 0;
            FndCrRlb02ELB < NUMRLB02ELBROWS;
            FndCrRlb02ELB++)
      {

         Rlb02ELBSelIndData[FndCrRlb02ELB] = SIN_NOTSELECTED;

      } /* end for */

      FndGenRC = FndFieldEnable( CBI_hwnd,
                                   "SRVCELEMENT",
                                   &FndGenErrorBlock);

      strncpy(SrvcElementData,"",1);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "SRVCELEMENT",
                                    &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntHvRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLVRB;

      FndGenRC = FndValueDisableItem( CBI_hwnd,
                                      "CLNTTYPE",
                                      (void *) &FndGenRBValueShort,
                                      &FndGenErrorBlock);

      FndGenRC = AZCS004BUSSetSRVCWLDCARDStatus( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

      FndGenRC = FndFieldSetCursor( CBI_hwnd,
                                    "SRVCWLDCARD",
                                    CUR_MAKECURRENT,
                                    &FndGenErrorBlock);

   }
   else
   {

      strncpy(SrvcWldCardData,"",1);

      FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                    "SRVCWLDCARD",
                                    STS_VALID,
                                    &FndGenErrorBlock);

      FndGenRC = FndFieldDisable( CBI_hwnd,
                                    "SRVCWLDCARD",
                                    &FndGenErrorBlock);

      if (strncmp(SrvcElementData, "", 1) == 0)
      {

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "ApplyPB",
                                       &FndGenErrorBlock);

      } /* end if */

      FndGenRBValueShort = LT_ClntElementRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLiteralRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntHvRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

      FndGenRBValueShort = LT_ClntLVRB;

      FndGenRC = FndValueEnableItem( CBI_hwnd,
                                     "CLNTTYPE",
                                     (void *) &FndGenRBValueShort,
                                     &FndGenErrorBlock);

   } /* end if */

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Ejsugzjx0636_Field_Change
 * 
 *   WidgetName:    SRVCWLDCARD
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx0636_Field_Change)
{
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   if (strncmp(SrvcWldCardData, "", 1) == 0)
   {

      FndGenRC = AZCS004BUSSetSRVCWLDCARDStatus( pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);

   }
   else
   {

      if (strncmp(ClntElementData, "", 1) != 0)
      {

         FndGenRC = FndCommandEnable( CBI_hwnd,
                                      "ApplyPB",
                                      &FndGenErrorBlock);

         FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                                "ApplyPB",
                                                &FndGenErrorBlock);

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "RemovePB",
                                       &FndGenErrorBlock);

      }
      else
      {

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "ApplyPB",
                                       &FndGenErrorBlock);

         FndGenRC = FndCommandDisable( CBI_hwnd,
                                       "RemovePB",
                                       &FndGenErrorBlock);

      } /* end if */

   } /* end if */

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



