 *
 *   Callback Name: Ejsugzjx6990_List_Select
 * 
 *   WidgetName:    Rlb02ELB
 *
 *   Event Name:    LIST_SELECT
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx6990_List_Select)
{
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = FndFieldEnable( CBI_hwnd,
                                "SRVCELEMENT",
                                &FndGenErrorBlock);

   FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                 "CLNTLITERAL",
                                 STS_VALID,
                                 &FndGenErrorBlock);

   strncpy(SrvcWldCardData,"",1);

   FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                 "SRVCWLDCARD",
                                 STS_VALID,
                                 &FndGenErrorBlock);

   FndGenRC = FndFieldDisable( CBI_hwnd,
                                 "SRVCWLDCARD",
                                 &FndGenErrorBlock);

   FndGenRC = AZCS004BUSMoveLB2( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



