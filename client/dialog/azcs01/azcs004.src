/***************************************************************************
 *
 *   Window-Level Event
 *
 *   Callback Name: Ejsugzjx1534_Predisplay
 * 
 *
 *
 *   Event Name:    PREDISPLAY
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx1534_Predisplay)
{
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   short                 FndGenRBValueShort = 0;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = FndWindowSetText( CBI_hwnd,
                                "Define Compare Keys Relationship",
                                &FndGenErrorBlock);

   FndGenRC = FndCommandDisable( CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

   FndGenRC = FndCommandDisable( CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

   FndGenRC = FndCommandCheckMenu( CBI_hwnd,
                                   "AMNCLTC",
                                   &FndGenErrorBlock);

   FndGenRC = FndCommandCheckMenu( CBI_hwnd,
                                   "AMNSRVCB",
                                   &FndGenErrorBlock);

   WildcardData = FALSE;

   FndGenRC = FndFieldDisable( CBI_hwnd,
                                 "SRVCWLDCARD",
                                 &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntElementRB;

   FndGenRC = FndValueEnableItem( CBI_hwnd,
                                  "CLNTTYPE",
                                  (void *) &FndGenRBValueShort,
                                  &FndGenErrorBlock);

   ClntTypeData = LT_ClntElementRB;

   FndGenRC = FndFieldDisable( CBI_hwnd,
                                 "CLNTLITERAL",
                                 &FndGenErrorBlock);

   strncpy(ClntElementData,"",1);

   strncpy(ClntLiteralData,"",1);

   FndGenRC = UnLdAZCS4I( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = AZCS004BUSFillClientLB( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = AZCS004BUSNewService( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



