/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Ejsugzjx7008_List_Select
 * 
 *   WidgetName:    Rlb01ELB
 *
 *   Event Name:    LIST_SELECT
 *
 *
 ***************************************************************************/
static WCBPROC(Ejsugzjx7008_List_Select)
{
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = FndFieldEnable( CBI_hwnd,
                                "CLNTELEMENT",
                                &FndGenErrorBlock);

   FndGenRC = FndFieldDisable( CBI_hwnd,
                                 "CLNTLITERAL",
                                 &FndGenErrorBlock);

   FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                 "CLNTLITERAL",
                                 STS_VALID,
                                 &FndGenErrorBlock);

   FndGenRC = AZCS004BUSMoveLB1( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



