/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : CmnArchExitInitialize
**
**  DESCRIPTION      : This function is called during the windows Predisplay Event.
**                     It performs 2 functions:
**                       1. Allocates space for the Architecture Block portion
**                             of Widow Context Data.
**                       2. Assign a Window Context Data pointer to the
**                             ArchExitTable so the local function addresses
**                             can be located.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : CHRIS CRAMPTON
**
**  DATE CREATED     : MARCH 10, 1993
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Original Code
**
**
***************************************************************************/
AEXPROC( CmnArchExitInitialize )
{
  int ArchBlocksize = sizeof(_CMN_ARCH_BLOCK);

  HEAP_CHECK;

  /* Allocate space for Common Architecture Block, then Initialize */
  pCmnArchBlock = (_CMN_ARCH_BLOCK *) malloc( sizeof( _CMN_ARCH_BLOCK ));
  memset( pCmnArchBlock, 0, sizeof( _CMN_ARCH_BLOCK ));

  /* Set WCD pointer to Arch Exit Table equal to global table */
  ((_CMN_ARCH_BLOCK *) pWindContextData->ArchData.pArchBlock)->pArchExitTable = ArchExitTable;

  /* JSH: 03/16/93 MODIFIED */
  EAB_pArchExitTable = ArchExitTable;

  HEAP_CHECK;

  return CMN_SUCCESS;
} /* End of CmnArchExitInitialize */
