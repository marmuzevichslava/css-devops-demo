/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1BuildInstName
**
**  DESCRIPTION      : This exit function is used to specify any additional
**                     columns for building the window instance name for
**                     the child window of the enterable list box registered
**                     as sequence number 1.  This instance name is used
**                     by the architecture to build a complete window
**                     instance name for the child window during a 'change'
**                     operation.  It is important to note that the name
**                     built in this exit function is also used within
**                     window data tracking to identify the data.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : sprintf
**                     CmnElbAssignChgWinInstName
**
**  AUTHOR           : C. CRAMPTON
**
**  DATE CREATED     : 03/11/93
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
**  10/14/94  J. Looney             Clean Up.
***************************************************************************/
AEXPROC ( ExitElb1BuildInstName )
{
    SHORT  nRC      = 0;
    USHORT FndGenRC = CMN_SUCCESS;
    _Rlb01ELBRow Row;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    CHAR szKey[sizeof(Row._Rlb01ELBTranMapData) + 1]; /* Declare a variable
                                                       * that will
                                                       * contain your key
                                                       * columns string  */

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
                                      "Rlb01ELB",
                                      EAB_CurrElbRowNumber,
                                      sizeof(_Rlb01ELBRow),
                                      (void *)&Row,
                                      &FndGenErrorBlock );

    /* Populate the Key with the Translation Map Name */
    sprintf( szKey,
             "%s",
             Row._Rlb01ELBTranMapData );

    FndGenRC = CmnElbAssignChgWinInstName( szKey, CMN_ARCH_PARMS );

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of ExitElb1BuildInstName */

/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1BuildInitData
**
**  DESCRIPTION      : This exit function is used to build the initial data
**                     structure to be passed to the child window of the
**                     enterable list box registered as sequence number 1.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : CmnElbAssignInitialData
**
**  AUTHOR           : C. CRAMPTON
**
**  DATE CREATED     : 03/11/93
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
**  10/14/94  J. Looney             Clean up.
***************************************************************************/
AEXPROC (ExitElb1BuildInitData)
{
    _Rlb01ELBRow     SelectedRow;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _AZCS003I        Azcs003i;
    SHORT nRow     = 0;
    SHORT FndGenRC = CMN_SUCCESS;
    SHORT sIndex   = 0;

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    nRow = CMN_ELB_ROW_PROCESSING;

    /* Obtain the row data from the ELB */
    FndGenRC = FndLstBoxRowQueryData( CBI_hwnd,
                                      "Rlb01ELB",
                                      nRow,
                                      sizeof(SelectedRow),
                                      &SelectedRow,
                                      &FndGenErrorBlock );

    /* Copy row data to input layout */
    Azcs003i.Server     = SelectedRow._Rlb01ELBServerData;
    Azcs003i.ServiceID  = SelectedRow._Rlb01ELBServiceIDData;
    Azcs003i.ServiceAge = SelectedRow._Rlb01ELBServiceAgeData;
    strncpy( Azcs003i.TranMap,
             SelectedRow._Rlb01ELBTranMapData,
             sizeof( Azcs003i.TranMap ));
    strncpy( Azcs003i.AnticModule,
             SelectedRow._Rlb01ELBAnticModuleData,
             sizeof( Azcs003i.AnticModule ));
    strncpy( Azcs003i.AltMap,
             SelectedRow._Rlb01ELBAltMapData,
             sizeof( Azcs003i.AltMap ));
    strncpy( Azcs003i.Flush,
             SelectedRow._Rlb01ELBFlushData,
             sizeof( Azcs003i.Flush ));
    strncpy( Azcs003i.ForceCall,
             SelectedRow._Rlb01ELBForceCallData,
             sizeof( Azcs003i.ForceCall ));

    sIndex = GetServiceIndex( Azcs003i.Server,
                              Azcs003i.ServiceID,
                              Azcs003i.TranMap,
                              CMN_ARCH_PARMS );

    if ( sIndex > 0 )
    {
        strncpy( Azcs003i.ServiceMapType,
                 pBFCD->pCSRMapBFCD->ServiceInfoTable[sIndex].ServiceType,
                 sizeof( Azcs003i.ServiceMapType ));
    }
    else
    {
        strncpy( Azcs003i.ServiceMapType,
                 "1",
                 sizeof( Azcs003i.ServiceMapType ));
    }

    CmnElbAssignInitialData ((void *) &Azcs003i,
                             sizeof (Azcs003i),
                             CMN_ARCH_PARMS );

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of ExitElb1BuildInitData */

