/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElbRegister
**
**  DESCRIPTION      : This exit function allows for the coding of the
**                     enterable list box registration function:
**                     CmnElbRegisterRelations.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : CmnElbRegisterRelations (for each ELB in window)
**
**  AUTHOR           : C. CRAMPTON
**
**  DATE CREATED     : 03/11/93
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
**  08/04/93  C. Crampton           Upgrade to new ELB code.
**
**  10/14/94  J. Looney             Clean up.
***************************************************************************/
AEXPROC (ExitElbRegister)
{

    /*  Each enterable list box in a window MUST be registered with  */
    /*     the architecture.  Use the following function once for    */
    /*     enterable list box in the window.                         */

    SHORT FndGenRC = CMN_SUCCESS;
    SHORT rc = 0;
    _CMNELBREGPARMS Parms;

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    strncpy( Parms.szElbWidgetName,
             MAPGEN_ELB_NAME,
             sizeof( Parms.szElbWidgetName ));

    Parms.nElbSeqNum      = 1;
    Parms.nElbRowLen      = sizeof(_Rlb01ELBRow);
    Parms.nElbMaxTxnCount = NUMRLB01ELBROWS;
    strncpy( Parms.szElbAddWinName,
             "AZCS003",
             sizeof( Parms.szElbAddWinName ));
    strncpy( Parms.szElbChgWinName,
             "AZCS003",
             sizeof( Parms.szElbChgWinName ));
    strncpy( Parms.szElbAddPbName,
             "AddPB",
             sizeof( Parms.szElbAddPbName ));
    strncpy( Parms.szElbAddUsingPbName,
             "",
             sizeof( Parms.szElbAddUsingPbName ));
    strncpy( Parms.szElbChangePbName,
             "ChangePB",
             sizeof( Parms.szElbChangePbName ));
    strncpy( Parms.szElbDeletePbName,
             "DeletePB",
             sizeof( Parms.szElbDeletePbName ));
    strncpy( Parms.szElbUndeletePbName,
             "UndeletePB",
             sizeof( Parms.szElbUndeletePbName ));
    strncpy( Parms.szElbUpPbName,
             "",
             sizeof( Parms.szElbUpPbName ));
    strncpy( Parms.szElbDownPbName,
            "",
            sizeof( Parms.szElbDownPbName ));

    FndGenRC = CmnElbRegister( &Parms, CMN_ARCH_PARMS );

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    return CMN_SUCCESS;

} /* end of ExitElbRegister */

/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1CloseAfterSave
**
**  DESCRIPTION      : This exit function is for Close After Save processing
**                     for the enterable list box registered as sequence
**                     number 1.  Place any necessary statements in this
**                     exit to process the saved data from the enterable
**                     list box child window.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. CRAMPTON
**
**  DATE CREATED     : 03/11/93
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
**  08/04/93  C. CRAMPTON           Update for new ELB code
**
**  10/14/94  J. LOONEY             Clean up.
***************************************************************************/
AEXPROC (ExitElb1CloseAfterSave)
{
    SHORT nRC                = 0;
    SHORT sRC                = 0;
    SHORT ix                 = 0;
    SHORT nServiceTableIndex = 0;
    SHORT FndGenRC           = CMN_SUCCESS;
    _AZCS003O *pAzcs003O;
    _Rlb01ELBRow NewRow;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _CMN_WINDOW_INFO *pChildWinInfo;

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    pChildWinInfo = (_CMN_WINDOW_INFO *) CMN_PVOIDFROMMP(CBI_ApplParm1);

    /* Assign the output copybook pointer.             */
    pAzcs003O = CMN_ELB_CHILD_DATA;

    /* Move the return data into a local structure     */
    NewRow._Rlb01ELBServerData     = pAzcs003O->Server;
    NewRow._Rlb01ELBServiceIDData  = pAzcs003O->ServiceID;
    NewRow._Rlb01ELBServiceAgeData = pAzcs003O->ServiceAge;
    /* CSC 07/12/94 Modify Flush */
    strncpy( NewRow._Rlb01ELBFlushData,
             pAzcs003O->Flush,
             sizeof( NewRow._Rlb01ELBFlushData ));
    strncpy( NewRow._Rlb01ELBTranMapData,
             pAzcs003O->TranMap,
             sizeof( NewRow._Rlb01ELBTranMapData ));
    strncpy( NewRow._Rlb01ELBAnticModuleData,
             pAzcs003O->AnticModule,
             sizeof( NewRow._Rlb01ELBAnticModuleData ));
    strncpy( NewRow._Rlb01ELBAltMapData,
             pAzcs003O->AltMap,
             sizeof( NewRow._Rlb01ELBAltMapData ));
    strncpy( NewRow._Rlb01ELBForceCallData,
             pAzcs003O->ForceCall,
             sizeof( NewRow._Rlb01ELBForceCallData ));

    /* If it was an add, increment the number of services
     * Call the service to get the repos data.
     */
    if ( strncmp( pChildWinInfo->InstanceName, "Elb1AddRow", 10 ) == 0 )
    {
        ix = pBFCD->pCSRMapBFCD->NumServices - 1;
    }  /* end of if added */

    else /* Search for the Service Layout */
    {
        for( ix = 0; ix < pBFCD->pCSRMapBFCD->NumServices; ix++ )
        {
            if( strcmp( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                        ServiceLayoutName,
                        pAzcs003O->TranMap ) == 0 )

            {
                break;
            }

        }

        /* Could not find service layout during search */
        if ( ix >= pBFCD->pCSRMapBFCD->NumServices )
        {
             return CMN_FAIL;
        }

    } /* end of else:  Search for the Service Layout */

    /* Add the row to the List Box */
    FndGenRC = CmnElbAssignRowData( MAPGEN_ELB_NAME,
                                    CMN_ELB_ROW_PROCESSING,
                                    &NewRow,
                                    NULL,
                                    CMN_ARCH_PARMS );

    /* Put the data into the BFCD structure */
    strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceLayoutName,
             pAzcs003O->TranMap,
             sizeof( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].
                     ServiceLayoutName ));

    pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].Server    = pAzcs003O->Server;
    pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceId = pAzcs003O->ServiceID;
    pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceAgeLimit =
                                                        pAzcs003O->ServiceAge;

    strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ForceCall,
             pAzcs003O->ForceCall,
             sizeof( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ForceCall ));

    /* JLL: 07/01/93 ADDED/CHANGED THE IF/ELSE STMT */
    /* No anticipatory module */
    if (( pAzcs003O->AnticModule[0] == ' ' )  ||
        ( pAzcs003O->AnticModule[0] == '\0' ))
    {
        strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AnticCallModule,
                 "NULL",
                 _ANTIC_CALL_LEN );
    } /* end of if:  No anticipatory module */

    else /* Anticipatory module */
    {
        strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AnticCallModule,
                 pAzcs003O->AnticModule,
                 _ANTIC_CALL_LEN );
    } /* end of else:  Anticipatory module */

    /* JLL: 07/01/93 ADDED */
    strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].ServiceType,
             pAzcs003O->ServiceMapType,
             2 );

    /* JLL: 07/01/93 ADDED */
    /* No ASMH */
    if (( pAzcs003O->AltMap[0] == ' ' ) ||
        ( pAzcs003O->AltMap[0] == '\0' ))
    {
        strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AlternateService,
                 "NULL",
                 _ALT_SERV_LEN );
    } /* end of if:  No ASMH */

    else /* ASMH */
    {
        strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].AlternateService,
                 pAzcs003O->AltMap,
                 _ALT_SERV_LEN );
    } /* end of else:  ASMH */

    /* JLL: 07/01/93 ADDED */
    /* CSC: 07/12/94 Modify for flush being char[2] */
    /* Flush */
    if ( strcmp( pAzcs003O->Flush, "Y" ) == 0 )
    {
        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].FlushFlag = TRUE;
    } /* end of if: Flush */

    else /* No Flush */
    {
        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].FlushFlag = FALSE;
    } /* end of else:  No Flush */

    /* CSC: ADDED 06/18/93 */
    HEAP_CHECK

    /* To control the enabling of non-preemptive
     * controls we have added a hidden field to the
     * window. Usually the task list is used for
     * purpose. But in this application until the
     * user has identified the map and at least one
     * service we make the task list unavailable.
     * Once they have identified the map and service
     * we make this hidden field valid and let the
     * task list take over the status processing.
     * At predisplay: we make the hidden field
     * STS_INVALID.
     * At WktCloseAfterSave:  if they get a saved map
     * we make the field STS_VALID.
     * At ELB1CloseAfterSave: we make the field
     * STS_VALID.
     */
    if ( strcmp( pBFCD->pCSRMapBFCD->ClientInfo.ClientLayoutName,
                 "" ) != 0 )
    {
        FndGenRC = FndFieldSetStatus( CBI_hwnd,
                                      "GenerateStatus",
                                      STS_VALID,
                                      &FndGenErrorBlock );

        FndGenRC = RestoreTaskList( pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);

        FndGenRC = CmnTlCheckStatus( CMN_ARCH_PARMS );
    } /* end of valid clientlayoutname */

    HEAP_CHECK

    return CMN_SUCCESS;
} /* end of ExitElb1CloseAfterSave */



