/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {

     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteService(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : NewService
**
**  DESCRIPTION      : This function is invoked by a field_change event on the
**                      service combo-box. It handles any processing that is
**                      necessary when a new service needs to be loaded into
**                      the service combo-box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (NewService)
{
  int index=0;
  int ServiceIndex=-1;
  unsigned int  nRC=0;
  enum LANGUAGE_TYPE Language;
  /*
  ** Compare the BFCD Services versus the Service name in WES
  */

  ServiceIndex = -1;
  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }
  /*
  ** If a valid service match was found have the listbox upadate
  */
  if (ServiceIndex >= 0)
      {
      Language = COBOL_LANGUAGE;
      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;
      pWindContextData->WCD.ServiceLBOffset = 0;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);
     }

return(CMN_SUCCESS);

} /* end of NewService*/


