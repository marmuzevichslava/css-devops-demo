/*********************************************************************/
/*                                                                   */
/*   RemoveRelationship                                              */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : RemoveRelationship
**
**  DESCRIPTION      : This function remove a relationship between a client and
**                     service or a service and a literal.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (RemoveRelationship)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    ServiceRow;
short                    ServiceElmnt;
short                    ClientRow;
short                    ClientElmnt;
int                      CellData;
short                    ix;
short                    iy;
BOOL                     MultipleService;

/*
** Assign the Service Index to a local varaible
*/
ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which service row is selected and calculate its index
*/
FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);
ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/*
** Set the status icon cell to unchanged for the service row
*/
CellData = CMN_LBROW_STATUS_UNCHANGED;
FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);


/*
** Is there a matching client row or is there a literal ?
*/

if (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed == 'N')
   {
    /*
    ** There is a matching client row so get the row number and calculate the
    **  index.
    */
    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    /*
    ** See if this client has multiple service relationships. If it does you
    **  must leave the check mark in the status icon column. If it does not
    **  change the status icon column.
    */

    MultipleService = FALSE;
    /*
    ** Loop thru all of the service rows
    */
    for (iy=0; iy < pWindContextData->WCD.ServiceInfoTable[ix].NumReposServiceRows; iy++)
        {
         /*
         ** Check each service element to see it if matching client element is
         **  the current client. If they match and this service index is not the current
         **  service then the client has multiple service relationships.
         */
         if (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[iy].ClientLayoutIndex == ClientElmnt &&
             iy != ServiceRow)
            {
             MultipleService = TRUE;
            }

        }
    /*
    ** If this client does not have multiple service relationships set the status icon
    **  cell back to unchanged.
    */
    if (!MultipleService)
       {
        FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);

       }

 /* De-Select the rows */
    Rlb01ELBSelIndData[ClientRow] = FALSE;
   }
/*
** The service has a relationship with a literal not an element.
*/
else
   {
   pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,"NULL");

   }

/*
** Clean up the service side
*/
Rlb02ELBSelIndData[ServiceRow] = FALSE;
pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex=-1;
pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 return(CMN_SUCCESS);
} /* end of function RemoveRelationship */



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CreateRelationhsip
**
**  DESCRIPTION      : This function defines a relationship between a client and
**                      service element or between a service and a literal value.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**    01/28/94  C. Crampton           Added code for CheckDataTypes logic.
**
***************************************************************************/

static WCBPROC(CreateRelationship)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
unsigned short           ServiceRow;
unsigned short           ServiceElmnt;
unsigned short           ClientRow;
unsigned short           ClientElmnt;
int                      CellData;
short                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);
ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
/*
** If the client side uses the element
*/

if (ClntTypeData == LT_ClntElementRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

    /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
    strcpy( pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,"NULL" );

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


    /*
    ** Make sure the data types match
    */
    FndGenRC = CheckDataTypes( ClientElmnt, ServiceElmnt, ix, CMN_ARCH_PARMS);

    if (FndGenRC != CMN_SUCCESS)
    {
        return(CMN_FAIL);
    }

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = ClientElmnt;
    Rlb01ELBSelIndData[ClientRow] = FALSE;
    }

/*
** If the client side uses the literal
*/


else
 if (ClntTypeData == LT_ClntLiteralRB)
    {

    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              ClntLiteralData);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;

    }
else
 if (ClntTypeData == LT_ClntHvRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              CMN_HIGH_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntLVRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              CMN_LOW_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;
    }


    /*
    ** Set the completed flag for this row
    */

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(short),
                                 &CellData,
                                 &FndGenErrorBlock);


    /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

 return(CMN_SUCCESS);
} /* end of function CreateRelationship */


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : FindClientMatch
**
**  DESCRIPTION      : This function looks thru the service table to find a
**                      matching service relationship.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT - valid service index or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static short FindClientMatch(CMN_ARCH_PARM_TYPES)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short index;
short ClientRow;
short ClientElmnt;
short ix;

/*
** Assign the current service to a local variable
*/
ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which client row is selectd and calculate its index
*/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    &FndGenErrorBlock);
ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Loop thru all of the service rows and find the first service element with
**  the selected clients index
*/

for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[index].ClientLayoutIndex)
         return(index);
    }
/*
** If not match was found return CMN_FAIL
*/
return(CMN_FAIL);
} /*  end of function FindClientMatch */


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellAttrNormC
**
**  DESCRIPTION      : This function is called when a client row with the normal
**                      attributes has been selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(CellAttrNormC)
{
 unsigned short           FndGenRC = FND_SUCCESS;
 short ClientRow;
 short ClientElmnt;

/*
** Get the client row and calculate the client index
*/
 ClientRow = CBI_ListRow;
 ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Move the client name to WES depending on the selected language
*/
if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
    {
     strcpy(ClntElementData,
     (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
else
    {
     strcpy(ClntElementData,
     (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);

    }


 return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellAttrNormS
**
**  DESCRIPTION      : This function is copies the necessary data to WES for a
**                      service that has normal attributes.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(CellAttrNormS)
{
unsigned short           FndGenRC = FND_SUCCESS;
short                    ix;
short ServiceElmnt;

ServiceElmnt = CBI_ListRow + pWindContextData->WCD.ServiceLBOffset;

ix = pWindContextData->WCD.CurrentServiceIndex;

if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
   {
    strcpy(SrvcElementData,
    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
   }
else
   {
    strcpy(SrvcElementData,
    (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
    }


 return(CMN_SUCCESS);
}


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellDataComplete
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(CellDataComplete)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    FndGenRBValueShort = 0;

short                    ServiceRow;
short                    ServiceElmnt;
short                    ix;
short                    iy;
short                    ClientRow;
short                    ClientElmnt;

ix = pWindContextData->WCD.CurrentServiceIndex;


/*
** List Select was from Client Side
*/
    if (CBI_WidgetID == Rlb01ELB_FID)
        {
         /*
         ** Assign the row number and calculate the index
         */
         ClientRow = CBI_ListRow;
         ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

         /*
         ** Find out what the selected Service row is
         */
         FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                                MAPGEN_SERVICE_LB_NAME,
                                                FND_LSTBOX_START,
                                                &ServiceRow,
                                                &FndGenErrorBlock);
         /*
         ** If there isn't a selected service row find the first match for the client
         */

         if (FndGenRC == LBOX_NO_MORE_ROWS_SELECTED)
             {
              ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);
              FndGenRC = LoadServiceElmnt(ServiceElmnt,
                                          CMN_ARCH_PARMS);
             }
         /*
         ** A service row is selected
         */
         else
          if (FndGenRC == FND_SUCCESS)
             {
              ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
              /*
              ** If the service row does not have a relationship with the client defined
              **  find the first one that does
              */
              if (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex
                   != ClientElmnt)
                 {
                  ServiceElmnt = FindClientMatch(CMN_ARCH_PARMS);
                  FndGenRC = LoadServiceElmnt(ServiceElmnt,
                                              CMN_ARCH_PARMS);
                 }
             }
         /*
         **  Bad return code on the query of selected service row
         */
         else
             {
              return(CMN_FAIL);
             }
       }
    /*
    ** Sevice Row was selected
    */
    else
        {

         ServiceRow = CBI_ListRow;
         ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
         /*
         ** There is a relationship with a client element
         */
         if(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed == 'N')
            {
             ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex;
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);
             FndGenRC = LoadClientElmnt(ClientElmnt, CMN_ARCH_PARMS);
            }
        }
    /*
    ** If you have a valid service row
    */
    if (ServiceRow >= 0 && ServiceRow < NUMRLB02ELBROWS)
       {
        /*
        ** Move the Relationship data from the WCD table into the relationship section of the window
        */

        /* Move the Client Element stuff down */
       if (toupper(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed) ==
                                        'N')
          {

           if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
              {
              strcpy(ClntElementData,
             (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
              }
           else
              {
                strcpy(ClntElementData,
                (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
              }
             /* set the radio button to element */

             ClntTypeData = LT_ClntElementRB;

             FndGenRBValueShort = LT_ClntElementRB;
             FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

             FndGenRBValueShort = LT_ClntHvRB;
             FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);


             FndGenRBValueShort = LT_ClntLVRB;
             FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

             FndGenRBValueShort = LT_ClntLiteralRB;
             FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

            strcpy(ClntLiteralData, "");
            FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "CLNTLITERAL",
                                      &FndGenErrorBlock);

            FndGenRC = FndFieldEnable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);

          }
       else
          {  /* Literal used not a data Element */

          for (iy=0; iy < NUMRLB01ELBROWS; iy++)
              {
               Rlb01ELBSelIndData[iy] = FALSE;
              }
          /*
          ** Disable client entry field and radio button
          */


           FndGenRBValueShort = LT_ClntElementRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

          strcpy(ClntElementData, "");

          FndGenRC = FndFieldDisable( CBI_hwnd,
                                      "CLNTELEMENT",
                                      &FndGenErrorBlock);


          /*
          ** If the literal is High Values, enable the high values radio button
          **/
          if (strcmp(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
                     CMN_HIGH_VALUES_STR) == 0)
          {

           FndGenRBValueShort = LT_ClntHvRB;
           FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           ClntTypeData = LT_ClntHvRB;  /* Set the Radio Button */

           strcpy(ClntLiteralData, "");  /* Clear out the literal field */

           FndGenRBValueShort = LT_ClntLiteralRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

           FndGenRBValueShort = LT_ClntLVRB;
           FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
          }

          else
          if (strcmp(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
                     CMN_LOW_VALUES_STR) == 0)
          {
              FndGenRBValueShort = LT_ClntLVRB;
              FndGenRC = FndValueEnableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *) &FndGenRBValueShort,
                                             &FndGenErrorBlock);

              ClntTypeData = LT_ClntLVRB;

              strcpy(ClntLiteralData, "");  /* Clear out the literal field */

              FndGenRBValueShort = LT_ClntLiteralRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                              "CLNTTYPE",
                                              (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);

              FndGenRBValueShort = LT_ClntHvRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                              "CLNTTYPE",
                                              (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);
          }
          else
          {
              strcpy(ClntLiteralData,pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue);

              FndGenRBValueShort = LT_ClntLiteralRB;
              FndGenRC = FndValueEnableItem( CBI_hwnd,
                                            "CLNTTYPE",
                                            (VOID *) &FndGenRBValueShort,
                                            &FndGenErrorBlock);

              ClntTypeData = LT_ClntLiteralRB;


              FndGenRC = FndFieldDisable( CBI_hwnd,
                                         "CLNTLITERAL",
                                         &FndGenErrorBlock);


              FndGenRBValueShort = LT_ClntHvRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *) &FndGenRBValueShort,
                                              &FndGenErrorBlock);

              FndGenRBValueShort = LT_ClntLVRB;
              FndGenRC = FndValueDisableItem( CBI_hwnd,
                                             "CLNTTYPE",
                                             (VOID *)&FndGenRBValueShort,
                                              &FndGenErrorBlock);
          }




          }

      /* Copy the Service element down */
      if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
          {
            strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
          }
      else
          {
           strcpy(SrvcElementData,
           (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);
          }


       } /* end of if (ServiceRow >= 0 && ServiceRow < MAXSERVICEROWS) */



    if (Rlb02ELBCdStatusIconicData[ServiceRow] == CMN_LBROW_STATUS_COMPLETED)
       {
        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);
       }
    else
       {

        FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

        FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);
       }


 return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellDataNotCompleteClient
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC(CellDataNotCompleteClient)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    RowNum = -1;
int                      CellData;
int                     *pCellData;
short                    ServiceIndex;

pCellData = &CellData;

FndGenRC = InitClient(pEventInfo,
                      pEAIA,
                      pBFCD,
                      pWesMap,
                      pWindContextData,
                      pABHI );

/*
** Find out if there is a selected Service row
*/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                       MAPGEN_SERVICE_LB_NAME,
                                       FND_LSTBOX_START,
                                       &RowNum,
                                       &FndGenErrorBlock);

if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
    {
     return(CMN_FAIL);
    }
/*
** A service row is selected
*/
if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
    {
     FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                        MAPGEN_SERVICE_LB_NAME,
                                        RowNum,
                                        0,
                                        sizeof(CellData),
                                        (void *)pCellData,
                                        &FndGenErrorBlock);
      /*
      ** Does the seleced service row have a complete status
      */
      if (CellData == CMN_LBROW_STATUS_COMPLETED)
          {
           Rlb02ELBSelIndData[RowNum] = FALSE;
           InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                          pABHI );
          }
       /*
       ** the selected service row does not have a completed status
       */
       else
           {
            FndGenRC = FndCommandEnable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

            FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);
           }


    } /* end of if service row selected */
/*
** no client selected so look for a matching client
*/
else
    {
     InitService(pEventInfo,
                  pEAIA,
                  pBFCD,
                  pWesMap,
                  pWindContextData,
                  pABHI );

     ServiceIndex = LookForServiceName(pEventInfo,
                                       pEAIA,
                                       pBFCD,
                                       pWesMap,
                                       pWindContextData,
                                       pABHI );

     if (ServiceIndex != CMN_FAIL)
         {
          FndGenRC = LoadServiceElmnt(ServiceIndex, CMN_ARCH_PARMS);
         }
    }


FndGenRC = MoveClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);
}


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellDataNotCompleteService
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/
static WCBPROC(CellDataNotCompleteService)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    RowNum = -1;
int                      CellData;
int                     *pCellData;
short                    ClientIndex;

     pCellData = &CellData;

    /* Find out if there is a selected Client row */
    FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                           MAPGEN_CLIENT_LB_NAME,
                                           FND_LSTBOX_START,
                                           &RowNum,
                                           &FndGenErrorBlock);

    if (FndGenRC != FND_SUCCESS && FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
        {
        return(CMN_FAIL);
       }

   /*
   ** A client row is selected
   */

    if (FndGenRC != LBOX_NO_MORE_ROWS_SELECTED)
       {
        FndGenRC = FndCommandEnable(CBI_hwnd,
                                    "ApplyPB",
                                    &FndGenErrorBlock);

        FndGenRC = FndCommandDisable(CBI_hwnd,
                                     "RemovePB",
                                     &FndGenErrorBlock);
       }
    else
        {
         InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
         /*
         ** Look for a matching name
         */
         ClientIndex = LookForClientName(pEventInfo,
                                         pEAIA,
                                         pBFCD,
                                         pWesMap,
                                         pWindContextData,
                                         pABHI );

        if (ClientIndex != CMN_FAIL)
           {
            FndGenRC = LoadClientElmnt(ClientIndex, CMN_ARCH_PARMS);
           }
        }


    FndGenRC = MoveService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );
 return(CMN_SUCCESS);

}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* SaveToBFCD                                                        */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(SaveToBFCD)
{
 int ix;
 _RELATE_LD *pOldBFCD;
 _RELATE_LD *pTempBFCD;
 _RELATE_LD *pTempWCD;
 int TempSize;


 for (ix=0; ix<pWindContextData->WCD.NumServices; ix++)
     {
      pOldBFCD = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData;

      pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData =
         (_RELATE_LD *) malloc(MAXSERVICEROWS * sizeof(_RELATE_LD) );

      memset(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData,
             0,
             MAXSERVICEROWS * sizeof(_RELATE_LD));
      free(pOldBFCD);
      pTempBFCD = (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData);
      pTempWCD = (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData);
      TempSize = (MAXSERVICEROWS * sizeof(_RELATE_LD));

      pOldBFCD =memcpy((pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData),
             (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData),
             (MAXSERVICEROWS * sizeof(_RELATE_LD)) );

      free(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData);
     }

return(CMN_SUCCESS);

} /* end of function SaveToBFCD  */

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* FillStatusLD                                                      */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(FillStatusLD)
{

int ix;
short ServNum;
short ClientRow;
short ClientElmnt;
short ServiceRow;

ServNum = pWindContextData->WCD.CurrentServiceIndex;

/*
** Clear out the Client Listbox
*/
for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     if (Rlb01ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb01ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }
/*
** Clear out the Service Listbox
*/
for (ix=0; ix < NUMRLB02ELBROWS; ix++)
    {
     if (Rlb02ELBCdStatusIconicData[ix] != CMN_LBROW_STATUS_AVAILABLE)
        {
         Rlb02ELBCdStatusIconicData[ix] = CMN_LBROW_STATUS_AVAILABLE;
        }
    }


/* Check the Service table for completed relationships */
for (ix=0; ix < pWindContextData->WCD.ServiceInfoTable[ServNum].NumReposServiceRows; ix++)
    {
     if (pWindContextData->WCD.ServiceInfoTable[ServNum].pLoadData[ix].ClientLayoutIndex > 0 )
        {
         ClientElmnt = pWindContextData->WCD.ServiceInfoTable[ServNum].pLoadData[ix].ClientLayoutIndex;

         /*
         ** If the row is in the Client or Service LB mark it completed
         */
         if (ClientElmnt >= pWindContextData->WCD.ClientLBOffset &&
             ClientElmnt <  pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS)
            {
             ClientRow = ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS);
             Rlb01ELBCdStatusIconicData[ClientRow] = CMN_LBROW_STATUS_COMPLETED;
            }
         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
             ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }

        }
    /*
    ** If the service element has a literal relationship defined
    */
    else if (pWindContextData->WCD.ServiceInfoTable[ServNum].pLoadData[ix].LiteralUsed == 'Y')
        {

         if (ix >= pWindContextData->WCD.ServiceLBOffset &&
             ix < pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS)
            {
             ServiceRow = ServiceElmntToRow(ix, CMN_ARCH_PARMS);
             Rlb02ELBCdStatusIconicData[ServiceRow] = CMN_LBROW_STATUS_COMPLETED;
            }
        }
    }  /* end of for loop thru all service LD rows */

return(CMN_SUCCESS);

} /* end of function FillStatusLD */

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* InitService                                                       */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/



static WCBPROC(InitService)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;


strcpy(SrvcElementData, "");

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);


return(CMN_SUCCESS);


}


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* MoveService                                                       */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(MoveService)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    ix;
short                    ServiceElmnt;



ix = pWindContextData->WCD.CurrentServiceIndex;
ServiceElmnt = CBI_ListRow + pWindContextData->WCD.ServiceLBOffset;

FndGenRC = FndFieldEnable(CBI_hwnd,
                             "SRVCELEMENT",
                             &FndGenErrorBlock);

if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
    }
else
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);

    }


return(CMN_SUCCESS);


}

