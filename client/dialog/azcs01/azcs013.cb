/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : ChangeRPMH
**
**  DESCRIPTION      : This function changes the indexes for the Repeating Map
**                       relationship table.
**
**  INPUTS           : sServ - The current services index
**
**                     sIndex - Index to services saved relationship tables.
**
**                     sNewReposIx - Index to the services repository tables.
**
**                     pSTDParms - pointer to the standard parms data structure.
**                         This includes a pointer to BFCD and the calling programs window
**                         handle.
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : FindFullName
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/15/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
**
***************************************************************************/
SHORT ChangeRPMH( SHORT sServ,
                  SHORT sIndex,
                  SHORT sNewReposIx,
                  _STDParms *pSTDParms )

{
    USHORT MsgID=0;
    SHORT FndGenRC;
    SHORT sClientx;
    SHORT sNewClientIndex;
    SHORT sNumTimes;
    CHAR MsgData[255];
    CHAR ClientName[255];
    CHAR ServiceName[255];
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _BFCD * pBFCD;
    HWND hwnd;

    /* Assign the input parameters to local variables */
    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    /* Assign BFCD variables to local variables for easier reading */
    pSavedLayout = pBFCD->pCSRMapBFCD->ClientInfo.pClientLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable;

    /*
     * Copy the saved data using the old index to the new table
     * using the new index
     */
    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pRepeatingMaps[sNewReposIx] =
      pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].pSavedRepeatingMaps[sIndex];

    /* If a relationship exists see what the client indexes are */
    if ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
         pSavedRepeatingMaps[sIndex].ClientLayoutIndex > 0 )
    {
        /* Make sure the number of Occurs has not changed */
        /* If so and a relationship exists drop relationship and notify user */
        if( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pServiceLayoutTable[sIndex].ItemOccurs !=
            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pReposServiceLayoutTable[sNewReposIx].ItemOccurs )
        {
            sprintf( MsgData,                               /* 255 */
                     "The number of occurences for Group %s has changed !",
                     BuildFullName( sIndex,
                                    pBFCD->pCSRMapBFCD->
                                           ServiceInfoTable[sServ].
                                           pServiceLayoutTable) ); /* 70 */

            MsgID = CMN_MAPGEN_MSG_WARN;

            POSTMSG;

            sprintf( MsgData,                               /* 255 */
                     "Dropping relationships for Group %s.",
                     BuildFullName(sIndex,
                                   pBFCD->pCSRMapBFCD->
                                          ServiceInfoTable[sServ].
                                          pServiceLayoutTable) ); /* 70 */


            MsgID = CMN_MAPGEN_MSG_WARN;

            POSTMSG;

            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pRepeatingMaps[sNewReposIx].ClientLayoutIndex = -1;

            HEAP_CHECK_BEEP

            return(CMN_FAIL);

        }

        sClientx = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                   pSavedRepeatingMaps[sIndex].ClientLayoutIndex;

        /* Find the new Client index */
        sNumTimes = FindFullName(sClientx,
                                 pSavedLayout,
                                 pReposLayout,
                                 pBFCD->pCSRMapBFCD->ClientInfo.
                                        NumReposClientRows,
                                 &sNewClientIndex );

        switch(sNumTimes)
        {
            case 0:
            {
                sprintf( MsgData,                               /* 255 */
                         "Client Group %s no longer exists in the "
                         "repository layout. "
                         "Any previous relationships will be dropped",
                         BuildFullName(sClientx, pSavedLayout) );  /* 70 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                POSTMSG;

                DropClient(sClientx, sServ, 5, pSTDParms);

                HEAP_CHECK_BEEP

                return(CMN_FAIL);

            } /* end of case 0 */

            case 1:
            {
                pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                     pRepeatingMaps[sNewReposIx].ClientLayoutIndex =
                                                           sNewClientIndex;

                strncpy( ClientName,
                         BuildFullName(sClientx, pSavedLayout),
                         sizeof( ClientName ));

                strncpy( ServiceName,
                         BuildFullName( sIndex,
                                        pBFCD->pCSRMapBFCD->
                                               ServiceInfoTable[sServ].
                                               pServiceLayoutTable ),
                         sizeof( ServiceName ));

                sprintf(MsgData,                        /* 255 */
                        "Remapping RPMH Relationship between Client "
                        "Group %s and Service Group %s.",
                        ClientName ,                    /* 255 */
                        ServiceName );                  /* 255 */

                MsgID = CMN_MAPGEN_MSG_INFO;

                POSTMSG;

                break;

            } /* end of case 1 */

        } /* end of switch */

    } /* end of if a relationship is defined */

    HEAP_CHECK_BEEP

    return (CMN_SUCCESS);

} /* end of function ChangeRPMH */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : DropClientLK
**
**  DESCRIPTION      : This function does the actual details of dropping a relationship.
**                      It initializes all varaibles in the relationship data structure.
**                      Also it posts the message to the message box.
**
**  INPUTS           : sServ - Service index.
**                     sIndex - Saved layout index.
**                     sNewServIndex - Repository layout index.
**                     pSTDParms - Pointer to STDParms data structure.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 11/08/93
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  11/08/93  C. Crampton           Original code.
**
**  10/18/94  J. Looney             Clean up.
***************************************************************************/
SHORT DropClientLK( SHORT sServ,
                    SHORT sIndex,
                    SHORT sNewServIndex,
                    _STDParms *pSTDParms )
{
    CHAR MsgData[255];
    CHAR ClientName[255];
    CHAR ServiceName[255];
    USHORT MsgID=0;
    SHORT FndGenRC;
    _LAYOUT_REC *pSavedLayout;
    _LAYOUT_REC *pReposLayout;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _BFCD * pBFCD;
    HWND hwnd;

    HEAP_CHECK_BEEP

    pBFCD            = pSTDParms->pBFCD;
    hwnd             = pSTDParms->hwnd;

    pSavedLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                          pServiceLayoutTable;
    pReposLayout = pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                          pReposServiceLayoutTable;

    strncpy( ClientName,
             BuildFullName( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                                    pSavedLoadKeys[sIndex].ClientLayoutIndex,
                            pBFCD->pCSRMapBFCD->ClientInfo.
                                    pClientLayoutTable),
             sizeof( ClientName ));

    strncpy( ServiceName,
             BuildFullName( sIndex,
                            pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                                   pServiceLayoutTable ),
             sizeof( ServiceName ));

    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
           pLoadKeys[sNewServIndex].ClientLayoutIndex = -1;
    pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
           pLoadKeys[sNewServIndex].LiteralUsed = 'N';

    strncpy( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                    pLoadKeys[sNewServIndex].LiteralValue,
             "",
             sizeof ( pBFCD->pCSRMapBFCD->ServiceInfoTable[sServ].
                      pLoadKeys[sNewServIndex].LiteralValue));

    sprintf( MsgData,                               /* 255 */
             "Dropping LK Relationship between Client Element %s and "
             "Service Element %s",
             ClientName,                            /* 255 */
             ServiceName );                         /* 255 */

    MsgID = CMN_MAPGEN_MSG_WARN;

    POSTMSG;

    HEAP_CHECK_BEEP

    return CMN_SUCCESS;

} /* end of function DropClientLK */

