/***************************************************************************
 *
 *   Window-Level Event
 *
 *   Callback Name: Ejskkjkt2577_Predestroy
 * 
 *
 *
 *   Event Name:    PREDESTROY
 *
 *
 ***************************************************************************/
static WCBPROC(Ejskkjkt2577_Predestroy)
{
unsigned short           FndGenRC = FND_SUCCESS;
_CrtMemBlockHeader * pHead = pHdr(pCmnArchBlock);


CMN_ARCH_EXIT_INITIALIZE
HEAP_CHECK
FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
HEAP_CHECK
if( f )
free( pCmnArchBlock );



FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if( f )
free( pCmnArchBlock );


HEAP_CHECK
return 0;


}
