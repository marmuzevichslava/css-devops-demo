/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Fcwjwzdx4633_Field_Change
 * 
 *   WidgetName:    CLNTLITERAL
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Fcwjwzdx4633_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if (strcmp( ClntLiteralData, "" ) == 0)
   {

   FndGenRC = AZCS007BUSSetCLNTLITERALStatus( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   }
else
   {

   if (strcmp( SrvcElementData, "" ) != 0)
      {

      FndGenRC = FndCommandEnable(CBI_hwnd,
                            "ApplyPB",
                            &FndGenErrorBlock);

      FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                            "ApplyPB",
                            &FndGenErrorBlock);

      }
   else
      {

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "ApplyPB",
                             &FndGenErrorBlock);

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);

      } /* end if */

   } /* end if */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}

