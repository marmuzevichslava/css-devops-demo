/***************************************************************************
 *
 *   Widget-Level Event
 *
 *   Callback Name: Fcwjwzdx8326_Field_Change
 * 
 *   WidgetName:    CLNTTYPE
 *
 *   Event Name:    FIELD_CHANGE
 *
 *
 ***************************************************************************/
static WCBPROC(Fcwjwzdx8326_Field_Change)
{
unsigned short           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
short                    FndGenRBValueShort = 0;
short                    FndCrRlb01ELB = 0;

CMN_ARCH_EXIT_INITIALIZE

FndGenRC = CmnArchInit( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

if ( ClntTypeData == LT_ClntElementRB )

   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "CLNTELEMENT",
                            &FndGenErrorBlock);

   ClntTypeData = LT_ClntElementRB;

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);

   strncpy(ClntLiteralData,"",1);

   FndGenRBValueShort = LT_ClntLiteralRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntHvRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntLVRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRC = FndFieldSetStatus(CBI_hwnd,
                        "CLNTLITERAL",
                        STS_VALID,
                        &FndGenErrorBlock);

   FndGenRC = AZCS007BUSChangeClientType( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   } /* end if */

if ( ClntTypeData == LT_ClntLiteralRB )

   {

   FndGenRC = FndFieldEnable(CBI_hwnd,
                            "CLNTLITERAL",
                            &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTELEMENT",
                             &FndGenErrorBlock);

   FndGenRC = FndCommandDisable(CBI_hwnd,
                             "ApplyPB",
                             &FndGenErrorBlock);

   for ( FndCrRlb01ELB = 0;
      FndCrRlb01ELB < NUMRLB01ELBROWS;
      FndCrRlb01ELB++)
      {

      Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

   strncpy(ClntLiteralData,"",1);

   strncpy(ClntElementData,"",1);

   FndGenRBValueShort = LT_ClntElementRB;
   FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntHvRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntLVRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRC = AZCS007BUSSetCLNTLITERALStatus( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   FndGenRC = AZCS007BUSChangeServiceType( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   FndGenRC = FndFieldSetCursor( CBI_hwnd,
                             "CLNTLITERAL",
                             CUR_MAKECURRENT,
                             &FndGenErrorBlock);

   } /* end if */

if ( ClntTypeData == LT_ClntHvRB )

   {

   FndGenRBValueShort = LT_ClntLiteralRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntLVRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   strncpy(ClntElementData,"",1);

   strncpy(ClntLiteralData,"",1);

   for ( FndCrRlb01ELB = 0;
      FndCrRlb01ELB < NUMRLB01ELBROWS;
      FndCrRlb01ELB++)
      {

      Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

   FndGenRBValueShort = LT_ClntElementRB;
   FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTELEMENT",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldSetStatus(CBI_hwnd,
                        "CLNTLITERAL",
                        STS_VALID,
                        &FndGenErrorBlock);

   FndGenRC = AZCS007BUSChangeServiceType( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   if (strcmp( SrvcElementData, "" ) == 0)
      {

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "ApplyPB",
                             &FndGenErrorBlock);

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);

      } /* end if */

   } /* end if */

if ( ClntTypeData == LT_ClntLVRB )

   {

   FndGenRBValueShort = LT_ClntLiteralRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRBValueShort = LT_ClntHvRB;
   FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   strncpy(ClntLiteralData,"",1);

   strncpy(ClntElementData,"",1);

   for ( FndCrRlb01ELB = 0;
      FndCrRlb01ELB < NUMRLB01ELBROWS;
      FndCrRlb01ELB++)
      {

      Rlb01ELBSelIndData[FndCrRlb01ELB] = SIN_NOTSELECTED;

      } /* end for */

   FndGenRBValueShort = LT_ClntElementRB;
   FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTELEMENT",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);

   FndGenRC = FndFieldSetStatus(CBI_hwnd,
                        "CLNTLITERAL",
                        STS_VALID,
                        &FndGenErrorBlock);

   FndGenRC = AZCS007BUSChangeServiceType( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

   if (strcmp( SrvcElementData, "" ) == 0)
      {

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "ApplyPB",
                             &FndGenErrorBlock);

      FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);

      } /* end if */

   } /* end if */

FndGenRC = CmnArchTerm( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return 0;


}
