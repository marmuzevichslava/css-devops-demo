**  10/06/94  J. LOONEY             Deleted all help logic.  Use a previous
**                                  revision to reimplement the help logic.
***************************************************************************/

AEXPROC (ExitHlpInit)
{

/****************  User Instructions  **********************************/
/***                                                                 ***/
/***  The User needs to make 3 changes to implement this             ***/
/***   functionality:                                                ***/
/***                                                                 ***/
/***    1. Change the macro field HELPWINDOWTITLE. Enter the string  ***/
/***       that you want as the title of the help window. It must be ***/
/***       enclosed in double quotes (C language string).            ***/
/***       (I.E. #define HELPWINDOWTITLE "Help for Window XXXX" )    ***/
/***                                                                 ***/
/***    2. Change the macro field HELPFILENAME. Enter the name of    ***/
/***       the help file including the filename extension. It must   ***/
/***       be enclosed in double quotes (C language string).         ***/
/***       (I.E. #define HELPFILENAME "HELP.HLP" )                   ***/
/***                                                                 ***/
/***    3. Add the Widget or Command Id and the corresponding        ***/
/***         Help Panels Panel Number to the PanelList array.        ***/
/***         When the user presses <F1> WES will look in this array  ***/
/***         for the Widget or Command ID. If the ID exists the      ***/
/***         corresponding Panel will be displayed.                  ***/
/***       (I.E. PanelList[] = { Widget Id1 , Panel Number 1,        ***/
/***                             Widget Id2 , Panel Number 2         ***/
/***                           };                                    ***/
/***                                                                 ***/
/***   NO OTHER CHANGES TO THIS FUNCTION SHOULD BE NECESSARY.        ***/
/***                                                                 ***/
/***********************************************************************/


/***********************************************************************/
/***  Change the 3 fields above. See User Instructions above.        ***/
/***                                                                 ***/
/***   NO OTHER CHANGES TO THIS FUNCTION SHOULD BE NECESSARY.        ***/
/***                                                                 ***/
/***********************************************************************/



/***********************************************************************/
/*** Initialize the help instance for this window by calling         ***/
/***    the CmnHlpMgrInitInst function.                              ***/
/***********************************************************************/



/***********************************************************************/
/*** Create the Widget and Command Id to Panel number relationship.  ***/
/***********************************************************************/

    return(CMN_SUCCESS);
}



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Architecture Function
**
** FUNCTION     :   CmnExitTlChdIntDatSet
**
** DESCRIPTION      :   This function is called when a task list row has been
**                      double-clicked.  It provides the programmer with a
**                      means of specifying initial data for the window
**                      being created.  The programmer may specify different
**                      initial data structures for each child window of a
**                      task list.
**
** INPUTS           :   CMN_ARCH_PARM_TYPES CMN_ARCH_PARMS
**                                         (Standard FOUNDATION data needed
**                                          to access the WES map, BFCD,
**                                          WCD, etc...)
**
** OUTPUTS          :   return code (CMN_SUCCESS)
**
**
** CALLED FUNCTIONS :   NONE
**
**
** AUTHOR           :   Florida Power Corporation & Andersen Consulting
**
** DATE CREATED     :   3-08-93
**
**
** REVISION HISTORY
**
**   DATE      REVISED BY        SIR #      DESCRIPTION OF CHANGE
** --------  ----------------  ---------  ----------------------------------
** 03/08/93  FGANTER                      Original Code
**
***************************************************************************/
AEXPROC (CmnExitTlChdIntDatSet)
{

    /**
     ** Declare initial data structures for each child window of a TASK LIST.
     ** Declare an initial data structure for every window that has
     **   different initial data fields.
     ** If the child window does not require initial data, a structure
     **   should not be defined.  Also, this function will
     **   automatically set initial data to NULL.
     **
     ** In most cases the child window's input layout will already be
     **   declared in a copybook.  If not, declare the initial data structure
     **   similar to the following example.
     **
     ** NOTE:  This same structure should appear in the child window's
     **          CmnExitTlChdIntDatGet function.
     **/

    typedef struct __WIN1_INITIAL_DATA {
        short number;
        char string[10];
        } _WIN1_INITIAL_DATA;


    /**
     ** The programmer should define an instance of the structure as in the
     **   following example:
     **/
    _WIN1_INITIAL_DATA *pInitialData1;

    /* Assume there is no initial data. */
    pCmnArchBlock->TlbChildInfo.pInitialData = NULL;

    /* If there IS initial data, fill it in as in the following example. */

    if( !strncmp( pCmnArchBlock->TlbChildInfo.WindowName, "CUCP003", CMN_WINDOWNAME_LEN ) )
    {

        /**
         ** Allocate memory for the initial data.  (It will be deallocated by
         **   the child window.)
         **/
        pInitialData1 = malloc( sizeof(_WIN1_INITIAL_DATA) );

        /* Initialize Initial Data for window 1. */
        memset(pInitialData1, 0, sizeof(_WIN1_INITIAL_DATA));

        /* Fill in the initial data fields for structure 1. */

        pInitialData1->number = 10;
        strncpy (pInitialData1->string, "String 1", (sizeof(pInitialData1->string) - 1));

        /**
         ** Set the architecture's Initial Data pointer equal to the address
         **   of the InitialData1 values.  (The architecture will use this
         **   pointer when creating the child window.)
         **/
        pCmnArchBlock->TlbChildInfo.pInitialData = pInitialData1;

    } /* End if( !strncmp( pCmnArchBlock->TlbChildInfo.WindowName, "CUCP003", CMN_WINDOWNAME_LEN ) ) */

    else if( !strncmp( pCmnArchBlock->TlbChildInfo.WindowName, "CUCP004", CMN_WINDOWNAME_LEN ) )
    {

        /**
         ** Allocate memory for the initial data.  (It will be deallocated by
         **   the child window.)
         **/
        pInitialData1 = malloc( sizeof(_WIN1_INITIAL_DATA) );

        /* Initialize Initial Data for window 1. */
        memset(pInitialData1, 0, sizeof(_WIN1_INITIAL_DATA));

        /* Fill in the initial data fields for structure 1. */

        pInitialData1->number = 11;
        strncpy (pInitialData1->string, "String 2", (sizeof(pInitialData1->string) - 1));

        /**
         ** Set the architecture's Initial Data pointer equal to the address
         **   of the InitialData1 values.  (The architecture will use this
         **   pointer when creating the child window.)
         **/
        pCmnArchBlock->TlbChildInfo.pInitialData = pInitialData1;

    } /* End if( !strncmp( pCmnArchBlock->TlbChildInfo.WindowName, "CUCP004", CMN_WINDOWNAME_LEN ) ) */




  return (CMN_SUCCESS);
}

