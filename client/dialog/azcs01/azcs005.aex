/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1BuildInstName
**
**  DESCRIPTION      : This exit function is used to specify any additional
**                     columns for building the window instance name for
**                     the child window of the enterable list box registered
**                     as sequence number 1.  This instance name is used
**                     by the architecture to build a complete window
**                     instance name for the child window during a 'change'
**                     operation.  It is important to note that the name
**                     built in this exit function is also used within
**                     window data tracking to identify the data.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : sprintf
**                     CmnElbAssignChgWinInstName
**
**  AUTHOR           :
**
**  DATE CREATED     :
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
***************************************************************************/

AEXPROC (ExitElb1BuildInstName)
{


    /*  Declare a variable that will contain your key columns string  */

    /*  Example:
    |   char szKeyColumns[whatever size you may need];
    */

    /*  The enterable list box widget name and row number being processed
    |      can be accessed via the following:
    |      CMN_ELB_WIDGET_NAME
    |      CMN_ELB_ROW_PROCESSING
    */

    /*  Execute the C run-time routine 'sprintf' to concatenate the
    |      columns together into a null-terminated string...
    |   Example:
    |       sprintf (szKeyColumns,
    |                <Format Specification>,
    |                <Format Data Item1>,
    |                <Format Data Item2>,
    |                ...)
    */

    /*  Execute the architecture function CmnElbAssignChgWinInstName
    |      to tell the architecture what the window instance name is:
    |   Example:
    |       CmnElbAssignChgWinInstName (szKeyColumns, CMN_ARCH_PARMS);
    */


  return CMN_SUCCESS;
}



/***************************************************************************
**
**               Customer Service System Architecture Function
**
**  FUNCTION         : ExitElb1BuildInitData
**
**  DESCRIPTION      : This exit function is used to build the initial data
**                     structure to be passed to the child window of the
**                     enterable list box registered as sequence number 1.
**
**
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : short - CMN_SUCCESS or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : CmnElbAssignInitialData
**
**  AUTHOR           :
**
**  DATE CREATED     :
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/11/93  C. CRAMPTON           Created skeleton
**  03/12/93  L. Misfeldt           Modified to contain shell code
**
***************************************************************************/

AEXPROC (ExitElb1BuildInitData)
{

    /*  Declare an instance of the data structure to pass to the  */
    /*     child window of the enterable list box.                */

    /*  Example:
    |     YOUR_INITIAL_DATA_STRUCT  InitialData;
    */

    /*  The enterable list box widget name and row number being processed
    |      can be accessed via the following:
    |      CMN_ELB_WIDGET_NAME
    |      CMN_ELB_ROW_PROCESSING
    */

    /*  Fill your initial data structure with data   */

    /*  Execute the architecture function CmnElbAssignInitialData
    |      passing the address of your initial data structure and
    |      the length of your initial data structure.  Make sure to
    |      cast the address as a (void *).  This will allow the
    |      architecture to pass your data structure on to the child window
    |      of the enterable list box with the data you supplied.
    |
    |   Example:
    |       CmnElbAssignInitialData (
    |                                (void *) InitialData,
    |                                sizeof (InitialData),
    |                                CMN_ARCH_PARMS
    |                               );
    */

  return CMN_SUCCESS;
}



