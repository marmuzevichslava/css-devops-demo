#-------------------------
# Constants
#-------------------------
HEADER_AREA=1
SETUP_AREA=3
MENU_AREA=12

LK_FROM='$SW_SHARED'
LK_TO='$SW_USER'
CP_FROM='$SW_SHARED'
CP_TO='$SW_USER'
DL_FROM='$SW_USER'
export BK_FROM=$SW_USER
BK_TO='$SW_USER'
CL_FROM='$SW_USER'

#--------------------------------------------------------------------------
# termdefs defines terminal control code variables for terminals that
# can handle them. Terminals not listed before the default action are
# not supported fully for screen clearing and line clearing. The 
# baseTerm variable is a flag indicating an unsupported terminal.
#
# The terminal control strings are typeset as constants (read-only).
#--------------------------------------------------------------------------
termdefs ()
{
	case $TERM in
		vt100) ;;
		vt220) ;;
		*) print -u2 "TERM $TERM not supported."; baseTerm=1; return ;;
	esac

	CLS="\033[2J"		# Clear screen
	CLL="\033[2K"		# Clear entire line
	WRP="\033[?7h"		# Line wrap on 
	NOW="\033[?7l"		# Line wrap off
}

#--------------------------------------------------------------------------
# ClearLines blanks user input area lines on supported terminals.
#
#	Arguments	:	$1 - Number of lines to clear
#--------------------------------------------------------------------------
ClearLines ()
{
	if [[ -n $baseTerm ]]; then
		return
	fi

	numLines=$1
	loopCount=0

	while [[ loopCount -lt numLines ]]; do
		print $CLL
		let loopCount=loopCount+1
	done
}

#--------------------------------------------------------------------------
#	PrintString
#
# 	Arguments	:	$1 - Row
# 				$2 - Column
#				$3 - String
#--------------------------------------------------------------------------
PrintString ()
{
	if [[ -n $baseTerm ]]; then
		print
		return
	fi

	 print -u2 "\033[$1;$2H$3"

}

#--------------------------------------------------------------------------
# 	GetOption  
#--------------------------------------------------------------------------
function GetOption {

	print
	print "Select option: \c"
	read option
	return $option
}

#--------------------------------------------------------------------------
# 	PrintDBAreasSetting 
#--------------------------------------------------------------------------
PrintDBAreasSetting ()
{
	PrintString $SETUP_AREA 1 '+--------------------------------------------------------+'
	print '| Current setup for database areas                       |'
	print '|                                                        |'
	print '| SW_PRISTINE Area:                                      |'
	print '| SW_SHARED Area:                                        |' 
	print '| SW_DELTA Area:                                         |'
	print '| SW_USER Area:                                          |'
	print '+--------------------------------------------------------+'
	let ROW=$SETUP_AREA+3; PrintString $ROW 22 $SW_PRISTINE
	let ROW=$SETUP_AREA+4; PrintString $ROW 22 $SW_SHARED
	let ROW=$SETUP_AREA+5; PrintString $ROW 22 $SW_DELTA
	let ROW=$SETUP_AREA+6; PrintString $ROW 22 $SW_USER
}

#--------------------------------------------------------------------------
# 	PrintEditSetting 
#--------------------------------------------------------------------------
PrintEditSetting ()
{
	PrintString $SETUP_AREA 1 '+--------------------------------------------------------+'
	print '| Current setup for editing user areas                   |'
	print '|                                                        |'
	print '|                                                        |'
	print '|                                                        |' 
	print '|                                                        |'
	print '|                                                        |'
	print '+--------------------------------------------------------+'

	let ROW=$SETUP_AREA+3; 
	STR1="link $LK_FROM to $LK_TO"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+4; 
	STR1="copy $CP_FROM to $CP_TO"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+5; 
	STR1="delete from $DL_FROM"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+6; 
	STR1="create table from $CP_FROM"
	PrintString $ROW 3 "$STR1"    
}
#--------------------------------------------------------------------------
# 	PrintBackupSetting 
#--------------------------------------------------------------------------
PrintBackupSetting ()
{
	PrintString $SETUP_AREA 1 '+--------------------------------------------------------+'
	print '| Current setup for backing up area                      |'
	print '|                                                        |'
	print '|                                                        |'
	print '|                                                        |' 
	print '|                                                        |'
	print '|                                                        |'
	print '+--------------------------------------------------------+'

	let ROW=$SETUP_AREA+3; 
	STR1="back up from $BK_FROM"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+4; 
	STR1="restore to $BK_TO"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+5; 
	STR1="clear $CL_FROM"
	PrintString $ROW 3 "$STR1"    

	let ROW=$SETUP_AREA+6; 
	STR1="LOADSAVE: $LOADSAVE"
	PrintString $ROW 3 "$STR1"    
}

#--------------------------------------------------------------------------
# 	PrintMenu1 
#--------------------------------------------------------------------------
PrintMenu1 ()
{
	PrintString $MENU_AREA 1 'Main Options'
	echo '------------'
	print '1. Setup database areas'
	print '2. Edit user area'
	print '3. Backup user area'
	print '4. Admin'
	print '9. Exit'
}


#--------------------------------------------------------------------------
# 	SelectArea    
#--------------------------------------------------------------------------
SelectArea ()
{
	PrintString $MENU_AREA 1 $CLL
	ClearLines 11
	PrintString $MENU_AREA 1 'Database Areas'
	echo '--------------'
	cat /css/devtools/common/host/scripts/tdmareas.dat

	echo "\nEnter a database area ? [$SELECTED_AREA]: \c"
	read NEW_VALUE
	case "$NEW_VALUE" in
		"")	SELECTED_AREA="$SELECTED_AREA" ;;
		*)	SELECTED_AREA="$NEW_VALUE" ;;
	esac
	export SELECTED_AREA
	echo $SELECTED_AREA
}

#--------------------------------------------------------------------------
# 	SelectAreaVariable    
#--------------------------------------------------------------------------
SelectAreaVariable ()
{
	PrintString $MENU_AREA 1 $CLL
	ClearLines 11
	PrintString $MENU_AREA 1 'Database Areas'
	echo '--------------'
	print '1. SW_PRISTINE'
	print '2. SW_SHARED'
	print '3. SW_DELTA'
	print '4. SW_USER'

	echo "\nEnter a database area number ? [$SELECTED_AREA]: \c"
	read NEW_VALUE
	case "$NEW_VALUE" in
		1)	SELECTED_AREA='$SW_PRISTINE' ;;
		2)	SELECTED_AREA='$SW_SHARED' ;;
		3)	SELECTED_AREA='$SW_DELTA' ;;
		4)	SELECTED_AREA='$SW_USER' ;;
		*)	SELECTED_AREA="$SELECTED_AREA" ;;
	esac
	export SELECTED_AREA
}

#--------------------------------------------------------------------------
# 	SetupAreas    
#--------------------------------------------------------------------------
SetupAreas ()
{
	M2OPTION=1
	until [[ $M2OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Database areas'
		echo '---------------'
		print '1. Change SW_PRISTINE'
		print '2. Change SW_SHARED'
		print '3. Change SW_DELTA'
		print '4. Change SW_USER'
		print '9. Return'
		GetOption
		M2OPTION=$?
		case $M2OPTION in
			1)
			   export SELECTED_AREA=$SW_PRISTINE
			   SelectArea
			   export SW_PRISTINE=$SELECTED_AREA;;
			2) 
			   export SELECTED_AREA=$SW_SHARED
			   SelectArea
			   export SW_SHARED=$SELECTED_AREA;;
			3) 
			   export SELECTED_AREA=$SW_DELTA
			   SelectArea
			   export SW_DELTA=$SELECTED_AREA;;
			4) 
			   export SELECTED_AREA=$SW_USER
			   SelectArea
			   export SW_USER=$SELECTED_AREA;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M2OPTION -ne 9 ]]; then
			PrintDBAreasSetting
		fi
	done
}

#--------------------------------------------------------------------------
# 	SetupEdit    
#--------------------------------------------------------------------------
SetupEdit ()
{
	M4OPTION=1
	until [[ $M4OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'From/To Options'
		echo '---------------'
		print '1. link from'
		print '2. link to'
		print '3. copy from'
		print '4. copy to'
		print '5. delete from'
		print '9. Return'
		GetOption
		M4OPTION=$?
		case $M4OPTION in
			1)
			   export SELECTED_AREA=$LK_FROM
			   SelectAreaVariable
			   export LK_FROM=$SELECTED_AREA;;
			2) 
			   export SELECTED_AREA=$LK_TO
			   SelectAreaVariable
			   export LK_TO=$SELECTED_AREA;;
			3) 
			   export SELECTED_AREA=$CP_FROM
			   SelectAreaVariable
			   export CP_FROM=$SELECTED_AREA;;
			4) 
			   export SELECTED_AREA=$CP_TO
			   SelectAreaVariable
			   export CP_TO=$SELECTED_AREA;;
			5) 
			   export SELECTED_AREA=$DL_FROM
			   SelectAreaVariable
			   export DL_FROM=$SELECTED_AREA;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M4OPTION -ne 9 ]]; then
			PrintEditSetting
		fi
	done
}

#--------------------------------------------------------------------------
# 	SetupBackup    
#--------------------------------------------------------------------------
SetupBackup ()
{
	M7OPTION=1
	until [[ $M7OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'From/To Options'
		echo '---------------'
		print '1. backup from'
		print '2. retore to'
		print '3. clear'
		print '4. LOADSAVE'
		print '9. Return'
		GetOption
		M7OPTION=$?
		case $M7OPTION in
			1)
			   export SELECTED_AREA=$BK_FROM
			   SelectAreaVariable
			   export BK_FROM=$SELECTED_AREA;;
			2) 
			   export SELECTED_AREA=$BK_TO
			   SelectAreaVariable
			   export BK_TO=$SELECTED_AREA;;
			3) 
			   export SELECTED_AREA=$CL_FROM
			   SelectAreaVariable
			   export CL_FROM=$SELECTED_AREA;;
			4) 
			   echo "\nEnter LOADSAVE path ? [$LOADSAVE]:"
			   read NEW_VALUE
			   case "$NEW_VALUE" in
				"") LOADSAVE='$LOADSAVE' ;;
				 *) LOADSAVE="$NEW_VALUE" ;;
			   esac
			   export LOADSAVE;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M7OPTION -ne 9 ]]; then
			PrintBackupSetting
		fi
	done
}


#--------------------------------------------------------------------------
#	LinkTable
#--------------------------------------------------------------------------
LinkTable ()
{
	M5OPTION=1
	until [[ $M5OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Link options'
		echo '------------'
		print '1. Link all tables overwriting exisiting objects'
		print '2. Link all tables without overwriting existing objects'
		print '3. Enter table name'
		print '4. Check Links'
# added a new function by Suresh Pellakur on 13/08/2000

		print '5. Leave Local tables and overwrite other existing objects'
		print '9. Return'
		GetOption
		M5OPTION=$?
		case $M5OPTION in
			1) 
			   eval synontb all $LK_FROM $LK_TO;;
                        2)
			   eval synontbnd all $LK_FROM $LK_TO;;
			3) 
			   print
			   print 'Enter table name:'
			   read TABLE
			   eval synontb $TABLE $LK_FROM $LK_TO;;
		        4)
			  eval chkarea ;;
	                5)
			   eval synontb2 all $LK_FROM $LK_TO;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M5OPTION -ne 9 ]]; then
			echo "\n--- Enter any key to continue ---"
			read dummy
			PrintHeader
			PrintEditSetting
		fi
	done
}


