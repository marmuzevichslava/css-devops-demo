#--------------------------------------------------------------------------
#	CopyTable
#--------------------------------------------------------------------------
CopyTable ()
{
	print
	print 'Enter table name:'
	read TABLE
	eval copytb $TABLE $CP_FROM $CP_TO

	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}


#--------------------------------------------------------------------------
#	CreateTable
#--------------------------------------------------------------------------
CreateTable ()
{
	print
	print 'Enter table name:'
	read TABLE
	eval creattb $TABLE $CP_FROM $CP_TO

	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}

#--------------------------------------------------------------------------
#	DeleteTable
#--------------------------------------------------------------------------
DeleteTable ()
{
	print
	print 'Enter table name:'
	read TABLE
	eval deletetb $TABLE $DL_FROM

	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}



#--------------------------------------------------------------------------
#	BackupScript
#		$1	pathname
#--------------------------------------------------------------------------
BackupScript ()
{
	if [[ ! $1 = "" ]]; then
	     print
	     print 'Enter a filename:'
	     read FILE
	     FILE="$1/$FILE"
        fi
	if [[ $1 = "" ]]; then
	     GetBackupPath 
	     GetBkupTblList
	fi
	eval backupdb $FILE $BK_FROM $TblList

	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}


#--------------------------------------------------------------------------
#	GetBkupTblList
#		
#--------------------------------------------------------------------------
GetBkupTblList ()
{
        PrintString $MENU_AREA 1 $CLL
        ClearLines 11
        PrintString $MENU_AREA 1 'Backup options'
	echo '------------'
	print 'What type of backup would you like perform:' 
	print '    1. A Full User Area Backup.' 
	print '    2. One (or several) table(s) only.' 
	GetOption
	BkupType=$?
	case $BkupType in
		1) TblList="";;
		2) print
                   Quit=" "
                   comma=" " 
		   TblList=""
		   BkTbl=""
                   print '[Tip: Always check table spelling]'
                   until [[ $Quit = "" ]];
                   do
                     print 'Enter a backup table name (or * to quit):'
                     read BkTbl
                     if [[ $BkTbl = "*" ]]; then
                            break 
                     else
                        TblList=`echo $TblList$comma$BK_FROM.$BkTbl `
                        echo "\n----------------------------"
                     fi
                     comma=","  
                   done
		   ;;
		*) echo "\n***Error: Invalid option"
		   echo "--- Enter any key to continue ---"
		   read dummy;;
	esac

}



#--------------------------------------------------------------------------
#	GetBackupPath
#		
#--------------------------------------------------------------------------
GetBackupPath ()
{
	M12OPTION=0
	UserPath=""
	OPT_PATH=""
	until [[ $M12OPTION -eq 1 || $M12OPTION -eq 2 || $M12OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Backup path options'
		echo '------------'
                print 'Since you did not choose the LOADSAVE option, ' 
		print 'pick one of the following as a backup destination:' 
		print '    1. Your home root directory.' 
		print '    2. Other file system directory.' 
		print '    9. Return.' 
		GetOption
		M12OPTION=$?
		case $M12OPTION in
			1) UserPath=' ~' ;;
			2) 
	            print
		    print '[WARNING: Backups fail if path invalid/inaccessable]'
	            print 'Enter a directory path for which you have access:'
			   read OPT_PATH ;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac
	done
        print 'Now, enter a file name w/o extension.'
        print 'The extension default will be [.dmp]:'
	read DFILE
        FILE=""
        if [[ -n $UserPath  ]]; then
              FILE="$UserPath/$DFILE"
        elif [[ -n $OPT_PATH  ]]; then
              FILE="$OPT_PATH/$DFILE"
        fi

} 


 
#--------------------------------------------------------------------------
#	RestoreScript
#		$1	pathname
#--------------------------------------------------------------------------
RestoreScript ()
{
        RS_FROM=""
	if [[ ! $1 = "" ]]; then
	   print
	   print 'Enter file name:'
	   read FILE
		FILE="$1/$FILE"
	fi
	if [[ $1 = "" ]]; then
	     GetRestorePath 
	fi
	eval restoredb $FILE $BK_FROM $RS_FROM
	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}


#--------------------------------------------------------------------------
#	GetRestorePath
#		
#--------------------------------------------------------------------------
GetRestorePath ()
{
	M13OPTION=0
	until [[ $M13OPTION -eq 1 || $M13OPTION -eq 2 || $M13OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Restore path options'
		echo '------------'
                print 'Since you did not choose the LOADSAVE option, ' 
		print 'pick one of the following as the retore location:' 
		print '    1. Your home root directory.' 
		print '    2. Other file system directory.' 
		print '    9. Return.' 
		GetOption
		M13OPTION=$?
		case $M13OPTION in
			1) UserPath=' ~' ;;
			2) print
			   print '[WARNING: Restores fail if path invalid/inaccessable]'
			   print 'Enter a directory path for which you have access:'
			   read OPT_PATH ;;
			9) return ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac
	done
	print
        print 'Now, enter a file name w/o extension.'
        print 'The extension default will be [.dmp]:'
	read DFILE
        FILE=""
        if [[ -n $UserPath ]]; then
              FILE="$UserPath/$DFILE"
        elif [[ -n $OPT_PATH  ]]; then
              FILE="$OPT_PATH/$DFILE"
        fi
	print
        print 'Now, enter the Oracle userid of the person who had '
        print 'created the *.dmp file from which you are restoring:'
	read RS_FROM

} 


#--------------------------------------------------------------------------
#	ClearScript
#		$1	pathname
#--------------------------------------------------------------------------
ClearScript ()
{
	eval cleardb $BK_FROM

	echo "\n--- Enter any key to continue ---"
	read dummy
	PrintHeader
}

#--------------------------------------------------------------------------
# 	EditArea      
#--------------------------------------------------------------------------
EditArea ()
{
	PrintEditSetting
	M3OPTION=1
	until [[ $M3OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Edit user area options'
		echo '----------------------'
		print '1. Setup editing user area'
		print '2. Link Table (synontb)'
		print '3. Copy Table (copytb)'
		print '4. Delete Table (deletetb)'
		print '9. Return'
		GetOption
		M3OPTION=$?
		case $M3OPTION in
			1) SetupEdit;;
			2) LinkTable;;
			3) CopyTable;;
			4) DeleteTable;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M3OPTION -ne 9 ]]; then
			PrintEditSetting
		fi
	done
}

#--------------------------------------------------------------------------
# 	BackupArea      
#--------------------------------------------------------------------------
BackupArea ()
{
	PrintBackupSetting
	M6OPTION=1
	until [[ $M6OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Backup options'
		echo '--------------'
		print '1. Setup backup area'
		print '2. backup to LOADSAVE'
		print '3. backup to filepath'
		print '4. restore from LOADSAVE'
		print '5. restore from filepath'
		print '6. clear area'
		print '9. Return'
		GetOption
                M6OPTION=$?
		case $M6OPTION in
			1) SetupBackup;;
			2) BackupScript $LOADSAVE;;
			3) BackupScript "";;
			4) RestoreScript $LOADSAVE;;
			5) RestoreScript "";;
			6) ClearScript;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

		if [[ $M6OPTION -ne 9 ]]; then
			PrintBackupSetting
		fi
	done
}

#--------------------------------------------------------------------------
# 	PrintHeader 
#--------------------------------------------------------------------------
PrintHeader ()
{
	print $CLS
	PrintString $HEADER_AREA 1 'TDM V.2 System'
}

#--------------------------------------------------------------------------
# 	PrintDisplay1 
#--------------------------------------------------------------------------
PrintDisplay1 ()
{
	PrintHeader
	PrintDBAreasSetting
	PrintMenu1
}


#--------------------------------------------------------------------------
# Admin Task Options    
#--------------------------------------------------------------------------
AdminOptions ()
{      
        OWNER="fcp"
        USERID=`id -un`

        if [[ ! "$USERID" = "$OWNER" && ! "$USERID" = "oracle" ]]; then
             echo "You are not authorized."
	     exit
	fi
		
	M10OPTION=1
	until [[ $M10OPTION -eq 9 ]]
	do
		PrintString $MENU_AREA 1 $CLL
		ClearLines 11
		PrintString $MENU_AREA 1 'Admin Options'
		echo '---------------'
		print '1. Backup Tablespace'
		print '2. Recover Tablespace'
		print '3. Recover User'
		print '9. Return'
		GetOption
		M10OPTION=$?
		case $M10OPTION in
			1)
                           MakeTblspExport ;;
			2) 
                           MakeTblsImport ;;
			3) 
                           MakeUserImport ;;
			9) ;;
			*) echo "\n***Error: Invalid option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac

        done
}



#**************************************************************************
#
# MAIN SHELL BODY
#
#**************************************************************************
Main ()
{
	termdefs

	M1OPTION=1
	until [[ $M1OPTION -eq 9 ]]
	do
		PrintDisplay1
		GetOption
		M1OPTION=$?
		case $M1OPTION in
			1) SetupAreas;;
			2) EditArea;;
			3) BackupArea;;
			4) AdminOptions;;
			9) ;;
			*) echo "\n***Error: Invalid or not available option"
			   echo "--- Enter any key to continue ---"
			   read dummy;;
		esac
	done
}

Main



#------------------------------------
#	display default options 
#------------------------------------
DisplayDefaultOptions ()
{
tput clear


#-------------
# SW_PASSWORD
#-------------
echo "SW_PASSWORD ? [$SW_PASSWORD]: \c"
read NEW_VALUE
case "$NEW_VALUE" in
	"")	SW_PASSWORD="$SW_PASSWORD" ;;
	*)	SW_PASSWORD="$NEW_VALUE" ;;
esac
export SW_PASSWORD

#-------------
# SW_PRISTINE
#-------------
echo "SW_PRISTINE ? [$SW_PRISTINE]: \c"
read NEW_VALUE
case "$NEW_VALUE" in
	"")	SW_PRISTINE="$SW_PRISTINE" ;;
	*)	SW_PRISTINE="$NEW_VALUE" ;;
esac
export SW_PRISTINE

#-------------
# SW_SHARED
#-------------
echo "SW_SHARED ? [$SW_SHARED]: \c"
read NEW_VALUE
case "$NEW_VALUE" in
	"")	SW_SHARED="$SW_SHARED" ;;
	*)	SW_SHARED="$NEW_VALUE" ;;
esac
export SW_SHARED

#-------------
# SW_DELTA
#-------------
echo "SW_DELTA ? [$SW_DELTA]: \c"
read NEW_VALUE
case "$NEW_VALUE" in
	"")	SW_DELTA="$SW_DELTA" ;;
	*)	SW_DELTA="$NEW_VALUE" ;;
esac
export SW_DELTA
}

#------------------------------------
#	display source areas    
#------------------------------------
DisplaySourceAreas ()
{
tput clear
echo "Source Areas"
echo "------------"
echo "c1_base_unit"
echo "c1_base_unit_shr1"
echo "c1_base_unt_d0_s1200_prstn"
echo "c1_base_unt_d0_s1200_shr1"
echo "g1_base_unit"
echo "w1_base_unit"
echo "<User Area>"
echo " "
echo "Enter source area [$1]: \c"
read NEW_SA
case "$NEW_SA" in
	"")	SOURCE_AREA="$1" ;;
	*)	SOURCE_AREA="$NEW_SA" ;;
esac

export SOURCE_AREA
}

#------------------------------------
#	delete table function 
#------------------------------------
DeleteTableFunction ()
{
tput clear
echo "\nEnter table name:"
read TABLE
deletetb $TABLE $SOURCE_AREA
}


#------------------------------------
#	verify table function 
#------------------------------------
VerifyTableFunction ()
{
tput clear
verifydb
}

#------------------------------------
#	reformat table function 
#------------------------------------
ReformatTableFunction ()
{
tput clear
reformatdb
}

#------------------------------------
#	backup function
#------------------------------------
BackupFunction ()
{
tput clear
echo "\nEnter output file where the environment is going to be dumped to."
read FILE 
exportdb $FILE
}

#------------------------------------
#	restore function
#------------------------------------
RestoreFunction ()
{
tput clear
echo "\nEnter input file where the environment was dumped to."
read FILE 
importdb $FILE
}

#------------------------------------
#	clear function
#------------------------------------
ClearFunction ()
{
tput clear
cleardb
}

#------------------------------------
#	grant function
#------------------------------------
GrantFunction ()
{
tput clear
grantdb
}

#------------------------------------
#	 Password function
#------------------------------------
PasswordFunction ()
{
tput clear
orapasswd
}

#------------------------------------
#	 Password function
#------------------------------------
PublicSynonymFunction ()
{
tput clear
publicdb
}


