#-------------------------------------------------------------------------
# Function: removes files used in the batch scripts of customer/1          
#-------------------------------------------------------------------------
# Revisions:
# Date       Who                      comments                            
#-------------------------------------------------------------------------
# 01/17/95 mconner                  created
#-------------------------------------------------------------------------
#-------------------------------------------------------------------------
# Return codes: 0 = success                    
#-------------------------------------------------------------------------
#-------------------------------------------------------------------------
# Parameters: $1 file to delete or remove including full path
#-------------------------------------------------------------------------
#-------------------------------------------------------------------------
#STEP 1: Definitions:                                                     
#-------------------------------------------------------------------------
EXEPATH=/bin
#-------------------------------------------------------------------------
#STEP 2: removes file 1                 
#-------------------------------------------------------------------------
$EXEPATH/rm -f $1
exit 0
