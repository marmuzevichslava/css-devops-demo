/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BusFindpbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**                                    Original code.
**
***************************************************************************/
WCBPROC( AZRP001BusFindpbClk )
{
  #define DEST_APPL_ID   1
  #define DEST_SRVC_ID   1
  #define DEST_SRVC_VER  "00"

  _FND_ERROR_BLOCK  FndGenErrorBlock;
  USHORT FndGenRC = 0;
//  _FND_STANDARD_PB  FndStandardPB;
//  _MSG_PARM_BLOCK   ParmBlock;

//  _REQUEST_HDR      RequestHdr;
//  _REPLY_HDR        *pReplyHdr;
//  _SERVICE_REPLY *pServiceReply;

  /*
  _MESSAGEINPUT  *pMessageInput;
  _MESSAGEOUTPUT *pMessageOutput;

  pMessageInput  = malloc( sizeof( _MESSAGEINPUT ));
  pMessageOutput = malloc( sizeof( _MESSAGEOUTPUT ));

  memcpy( FndStandardPB.ver, FND_MSG_VER, _VER_LEN );
  */
 /*mdc 04/12/96 unreferenced local variables replaced by #defines in header
  CHAR EntityId[ 9 ];
  CHAR EntityType[ 9 ];
  */

//  _ENTITYDATA *pEntityDataTable;
//  USHORT NumRows;

  /* Set up Request Header */
  FndGenRC = FndFieldQueryValue( CBI_hwnd, "EntityId",
                                 ENTITY_ID_LEN,
                                 WCD_RequestHdr.EntityId,
                                 &FndGenErrorBlock );

  FndGenRC = FndFieldQueryValue( CBI_hwnd, "EntityType",
                                 ENTITY_TYPE_LEN,
                                 WCD_RequestHdr.EntityType,
                                 &FndGenErrorBlock );

  switch( WCD_RequestHdr.EntityType[0] )
  {
    case 'T':
      strcpy( WCD_RequestHdr.EntityType, "DEDTABLE" );
      break;

    case 'F':
      strcpy( WCD_RequestHdr.EntityType, "DEFILE" );
      break;

    case 'C':
      strcpy( WCD_RequestHdr.EntityType, "DECOPYBK" );
      break;

    case 'R':
      strcpy( WCD_RequestHdr.EntityType, "DERECORD" );
      break;

    case 'G':
      strcpy( WCD_RequestHdr.EntityType, "DEGROUP" );
      break;

    default:
      break;
  }

  /*
  pMessageInput->RequestHdr.MaxRows = _MESSAGEINPUT__ENTITYDATA_SIZE;

  MSGInitPB( &FndStandardPB, &ParmBlock, pEAIA, DEST_APPL_ID,
             DEST_SRVC_ID, DEST_SRVC_VER, pABHI );

  memcpy( ParmBlock.commarea.ver, FND_MSG_VER, _VER_LEN );
  ParmBlock.commarea.function_code = MSGIO_CONVERSE;
  ParmBlock.buffer_size = sizeof( _MESSAGEINPUT );
//  ParmBlock.buffer_size = MAX_MSG_LEN;
  ParmBlock.actual_length_send = sizeof( _REQUESTHDR );

//  strcpy( ParmBlock.secur.user_id, "USERID" );
//  strcpy( ParmBlock.secur.user_pw, "PASSWO" );
  ParmBlock.timeout_interval = 10;

  FndGenRC = MSGConvUI( &ParmBlock, (_MSG_SEND_AREA) pMessageInput,
                        (_MSG_RECV_AREA) pMessageOutput, pABHI );
  */

  /* Clear MLE */
  FndGenRC = FndFieldSetValue( CBI_hwnd, "LongDesc",
                               LONG_DESC_LEN,
                               "",
                               &FndGenErrorBlock );

  /* Clear listbox */
  FndGenRC = FndLstBoxRowDeleteAll( CBI_hwnd, "ReposDataLB",
                                    &FndGenErrorBlock );

  /* Set maximum number of rows to return */
  WCD_RequestHdr.MaxRows = NUMREPOSDATALBROWS;

  /* Retrieve Layout */
  FndGenRC = SegRptRetrieveLayout( &WCD_RequestHdr, &WCD_ReplyHdr,
                                   WCD_EntityData, CMN_ARCH_PARMS );

  if( FndGenRC == MSGIO_SUCCESS  /*&& WCD_ReplyHdr.RowsReturned <= NUMREPOSDATALBROWS */)
  {
    FndGenRC = AZRP001PopulateWindow( WCD_EntityData,
                                      &(WCD_ReplyHdr),
                                      CMN_ARCH_PARMS );
  }/*
  else if (	WCD_ReplyHdr.RowsReturned > NUMREPOSDATALBROWS )
  {
	FndGenRC = FndMsgBoxDisplayMdlssText( "\n\nThe number of rows retrieved exceeds the number of displayable rows.",
                                   NULL,
                                   CBI_hwnd,
                                   FND_MSGBOX_OK,
                                   FND_MSGBOX_WARNING,
                                   FND_MSGBOX_IDOK,
                                   CMN_CSS_APPL_NAME,
                                   &FndGenErrorBlock);
   } */

  return CMN_SUCCESS;
}/*end of AZRP001BusFindpbClk */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001PopulateWindow
**
**  DESCRIPTION      : This function populates the main seament reporter 
**                     window.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**                                    Original code.
**
**    04/12/96  mconner               Removed insertion of carraige returns and 
**                                    in long description. Concateneated
**                                    8 incoming strings into a single
**                                    string for SetValue of multiline field
**
**   04/26/96  mconner                Removed trim of trailing blanks. If a 
**                                    line ends in a blank words will bleed
**                                    together.  Added test for blank lines
**                                    making them NULL.
**
**   05/09/96  mconner                Added logic to cope with more rows being
**                                    returned than can be displayed in the list box.
***************************************************************************/
SHORT AZRP001PopulateWindow( _ENTITYDATA *pEntityDataTable,
                             _REPLYHDR *pReplyHdr,
                             CMN_ARCH_PARM_TYPES )
{
  _ReposDataLBRow ReposDataLBRow;
  CHAR Indent[ 20 ];
  USHORT i,j;
  _FND_ERROR_BLOCK  FndGenErrorBlock;
  USHORT FndGenRC = 0;
  USHORT usLBRows;
  SHORT TextLen;
  SHORT sCtr = 0;
  USHORT usAllSpaces = 0;
  char *psLongDesc;
  char *pszStr;
  char *pszTmp;

//  for( i=0; i<_REPLYHDR__ENTITYTEXT_SIZE; i++ )
  for( i=0; i<pReplyHdr->NumTextRows; i++ )
  {
    /*mdc 04/26/96 do not trim blanks */
    /*CmnStrTrimTrailBlanks( pReplyHdr->EntityText[i],
                           sizeof( pReplyHdr->EntityText[i] ),
                           CMN_ARCH_PARMS );
	 */

	/*mdc 04/26/96 set any blank line to NULL
	sCtr = 0;
	pszStr = pReplyHdr->EntityText[i];
	while(isspace(*pszStr) )
	{
		++sCtr;
		++pszStr;
	}
	if (sCtr > NUM_BLANKS_IN_BLANK_STRING )
	{
		*pReplyHdr->EntityText[i] = '\0';
	}*/
    /* Trim CR/LF from text */
	/*mdc 05/07/96 This function also trims the trialing spaces so we can't 
	use it.
   CmnDdeTrimCRLF( pReplyHdr->EntityText[i],
                    sizeof( pReplyHdr->EntityText[i] ));
	*/
	/*mdc 05/07/96 Change CRLF to spaces */
	pszStr = pReplyHdr->EntityText[i];

	while (*pszStr)
	{
		if(*pszStr == '\r' || *pszStr == '\n')
			*pszStr = ' ';
		++pszStr;
	}

    TextLen = strlen(pReplyHdr->EntityText[i]);

	/*mdc 04/11/96 Can't insert characters in array of text*/
    /*pReplyHdr->EntityText[i][TextLen] = '\n';
    pReplyHdr->EntityText[i][TextLen+1] = '\0';
	*/ 
   }

  /*mdc Allocate memory for long description string*/
  psLongDesc = (char *)calloc(LONG_DESC_LEN, sizeof(char));
  if(!psLongDesc) return CMN_FAIL;

  /* Copy long description to string */
 CmnStrCat( CMN_ARCH_PARMS, psLongDesc, LONG_DESC_LEN,
             8,
             pReplyHdr->EntityText[0], pReplyHdr->EntityText[1],
             pReplyHdr->EntityText[2], pReplyHdr->EntityText[3],
             pReplyHdr->EntityText[4], pReplyHdr->EntityText[5],
             pReplyHdr->EntityText[6], pReplyHdr->EntityText[7] );

/*mdc remove extra spaces */
pszStr = psLongDesc;
++pszStr;

while (*pszStr)
{
	while (*(pszStr - 1) == ' ' && *pszStr == ' ')
		strcpy(pszStr, pszStr + 1);
	++pszStr;
}



  /*mdc populate window with long description*/
  FndGenRC = FndFieldSetValue(CBI_hwnd,
                              "LongDesc",
							  LONG_DESC_LEN,
							  psLongDesc,
							  &FndGenErrorBlock);

  /*mdc 05/20/96 free lon desc*/
  free(psLongDesc);

  /*mdc 05/09/96 Added this logic to prevent the error caused by the 
  number of rows returned exceeding the number of rows that the list
  box can hold */

  usLBRows = min(pReplyHdr->RowsReturned, NUMREPOSDATALBROWS );

  for( i=0; i<usLBRows; i++ )
  {
    memset( Indent, 0, sizeof(Indent ));

    for( j=0; j<pEntityDataTable[i].EntityLevel; j++ )
    {
      strcat( Indent, "  " );
    }

    memset( &ReposDataLBRow, 0, sizeof( ReposDataLBRow ));

    /* JSH: 07/29/93 REMOVED */
    /*
    /* JSH: 09/21/93 MODIFIED from CmnStrTrimBlanks
    CmnStrTrimTrailBlanks( pEntityDataTable[i].EntityId,
                           sizeof( pEntityDataTable[i].EntityId ),
                           CMM_ARCH_PARMS );
    */
    /* JSH: 07/29/93 ADDED */
    /* Null terminate at first space in EntityId */
    j = 0;
    while( pEntityDataTable[i].EntityId[j] != ' ' )
    {
      j++;
    }
    pEntityDataTable[i].EntityId[j] = '\0';

    CmnStrCat( CMN_ARCH_PARMS, ReposDataLBRow._ReposDataLBEntityIdData,
               sizeof( ReposDataLBRow._ReposDataLBEntityIdData ),
               2, Indent, pEntityDataTable[i].EntityId );

    /* JSH: 09/21/93 MODIFIED from CmnStrTrimBlanks */
    CmnStrTrimTrailBlanks( pEntityDataTable[i].EntityType,
                           sizeof( pEntityDataTable[i].EntityType),
                           CMN_ARCH_PARMS );

	FndGenRC = GetEntityType(pEntityDataTable[i].EntityType);

    /*mdc 06/11/96 Alocate memory for the temp entity type */
    pszStr = (char *)calloc((strlen(Indent) + strlen(pEntityDataTable[i].EntityType) + 2),
                                sizeof(char));
    if (pszStr )
    {
        strcpy(pszStr, Indent);
        strcat(pszStr, pEntityDataTable[i].EntityType);
    }
    else
    {
         return CMN_FAIL;
    }


    if ( strlen(pszStr) > sizeof( ReposDataLBRow._ReposDataLBEntityTypeData ) - 1)
    {
        FndGenRC = FndMsgBoxDisplayMdlssText( "\n\nIndentation from nesting will cause some data to be truncated.",
                                   NULL,
                                   CBI_hwnd,
                                   FND_MSGBOX_OK,
                                   FND_MSGBOX_WARNING,
                                   FND_MSGBOX_IDOK,
                                   CMN_CSS_APPL_NAME,
                                   &FndGenErrorBlock);

        *(pszStr + sizeof(ReposDataLBRow._ReposDataLBEntityTypeData) - 2) = '\0';
        /*check if all spaces */
        pszTmp = pszStr;
        while( *pszTmp )
        {
            if (isspace(*pszTmp))
            {
                usAllSpaces = 1;
            }
            else
            {
                usAllSpaces = 0;
                break;
            }
            ++pszTmp;
        }
        if ( usAllSpaces )
        {
            FndGenRC = FndMsgBoxDisplayMdlssText( "\n\nIndentation from nesting will cause some data to not be shown!",
                                   NULL,
                                   CBI_hwnd,
                                   FND_MSGBOX_OK,
                                   FND_MSGBOX_WARNING,
                                   FND_MSGBOX_IDOK,
                                   CMN_CSS_APPL_NAME,
                                   &FndGenErrorBlock);
        }

 
     } /*End of if ( strlen(pszStr) > sizeof( ReposDataLBRow */

   /*mdc 05/10/96 removed to funtion  above
    if( strcmp( pEntityDataTable[i].EntityType, "DEDTABLE" ) == 0)
    {
      strcpy( pEntityDataTable[i].EntityType, ENTITY_TYPE_1);
    }
    else if( strcmp( pEntityDataTable[i].EntityType, "DECOPYBK") == 0)
    {
      strcpy( pEntityDataTable[i].EntityType, ENTITY_TYPE_2);
    }
    else if( strcmp( pEntityDataTable[i].EntityType, "DERECORD") == 0)
    {
      strcpy( pEntityDataTable[i].EntityType, ENTITY_TYPE_3);
    }
    else if( strcmp( pEntityDataTable[i].EntityType, "DEGROUP") == 0)
    {
      strcpy( pEntityDataTable[i].EntityType, ENTITY_TYPE_4);
    }
    else if( strcmp( pEntityDataTable[i].EntityType, "DEDTELEM") == 0)
    {
      strcpy( pEntityDataTable[i].EntityType, ENTITY_TYPE_5);
    } */

    CmnStrCat( CMN_ARCH_PARMS, ReposDataLBRow._ReposDataLBEntityTypeData,
               sizeof( ReposDataLBRow._ReposDataLBEntityTypeData ),
               1, pszStr );

    /*mdc 06/11/96 pszStr no longer needed so free it*/
    free(pszStr);

    /* JSH: 09/21/93 MODIFIED from CmnStrTrimBlanks */
    CmnStrTrimTrailBlanks( pEntityDataTable[i].EntityCobolName,
                           sizeof( pEntityDataTable[i].EntityCobolName),
                           CMN_ARCH_PARMS );
    CmnStrCat( CMN_ARCH_PARMS,
               ReposDataLBRow._ReposDataLBEntityNameData,
               sizeof( ReposDataLBRow._ReposDataLBEntityNameData ),
               2, Indent, pEntityDataTable[i].EntityCobolName );

    /* Display length if it's non-zero */
    if( pEntityDataTable[i].DteIntLength > 0 )
    {
      CmnStrFromInt( ReposDataLBRow._ReposDataLBLengthData,
                     sizeof( ReposDataLBRow._ReposDataLBLengthData ),
                     pEntityDataTable[i].DteIntLength,
                     CMN_LEADING_ZEROES_NO,
                     CMN_ARCH_PARMS );
    }
    else
    {
      strcpy( ReposDataLBRow._ReposDataLBLengthData, "" );
    }

    ReposDataLBRow._ReposDataLBFormatData[0] =
        pEntityDataTable[i].DteIntFormat;

    /* Display precision if format is numeric */
    if( pEntityDataTable[i].DteIntFormat == 'N' )
    {
      CmnStrFromInt( ReposDataLBRow._ReposDataLBPrecisionData,
                     sizeof( ReposDataLBRow._ReposDataLBPrecisionData ),
                     pEntityDataTable[i].DteIntPrecision,
                     CMN_LEADING_ZEROES_NO,
                     CMN_ARCH_PARMS );
    }
    else
    {
      strcpy( ReposDataLBRow._ReposDataLBPrecisionData, "" );
    }

    CmnStrCopy( ReposDataLBRow._ReposDataLBUsageData,
                pEntityDataTable[i].DteIntUsage,
                sizeof( ReposDataLBRow._ReposDataLBUsageData ),
                CMN_ARCH_PARMS );

    /* Display occurs only if occurs > 1 */
    if( pEntityDataTable[i].RelatOccFact > 1 )
    {
      CmnStrFromInt( ReposDataLBRow._ReposDataLBOccursData,
                     sizeof( ReposDataLBRow._ReposDataLBOccursData ),
                     pEntityDataTable[i].RelatOccFact,
                     CMN_LEADING_ZEROES_NO,
                     CMN_ARCH_PARMS );
    }
    /*
    else
    {
      strcpy( ReposDataLBRow._ReposDataLBOccursData, "" );
    }
    */


    /* Display Other and Other2 */
    /* Display only if first row represents a TABLE */
    if(( strcmp( pEntityDataTable[0].EntityType, "TABLE" ) == 0 ) &&
/*       ( pEntityDataTable[i].RelatNulFl == 'N' )) */
       ( strcmp( pEntityDataTable[i].EntityType, "ELEMENT" ) == 0 ) &&
       ( pEntityDataTable[i].RelatNulFl != 'Y' ))
    {
      if( pEntityDataTable[i].RelatDefaultFl == 'Y' )
      {
        strcpy( ReposDataLBRow._ReposDataLBOther2Data,
                "NOT NULL WITH DEFAULT" );
      }
      else
      {
        strcpy( ReposDataLBRow._ReposDataLBOther2Data,
                "NOT NULL" );
      }
    }

    /* Add the new row */
    FndGenRC = FndLstBoxRowAdd( CBI_hwnd, "ReposDataLB", i,
                                sizeof( _ReposDataLBRow ),
                                (VOID *) &ReposDataLBRow,
                                &FndGenErrorBlock );
  }

  /*mdc 05/09/96 Let the user know if all the rows are not displayed in the LB */
  if (pReplyHdr->RowsReturned > NUMREPOSDATALBROWS)
  {
	FndGenRC = FndMsgBoxDisplayMdlssText( "\n\nThe number of rows retrieved exceeds the number of displayable rows.",
                                   NULL,
                                   CBI_hwnd,
                                   FND_MSGBOX_OK,
                                   FND_MSGBOX_WARNING,
                                   FND_MSGBOX_IDOK,
                                   CMN_CSS_APPL_NAME,
                                   &FndGenErrorBlock);
    }  	

  return CMN_SUCCESS;
}  /*end of AZRP001PopulateWindow*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : GetEntityType
**
**  DESCRIPTION      : This function decodes the entity type 
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    05/10/96  mconner              Original code.
**
***************************************************************************/
/*mdc 05/09/96 Added == 0 logic this was not working*/

USHORT GetEntityType(char *pszStr)
{
    if( strcmp( pszStr, "DEDTABLE" ) == 0)
    {
      strcpy(pszStr, ENTITY_TYPE_1);
    }
    else if( strcmp( pszStr, "DECOPYBK") == 0)
    {
      strcpy( pszStr, ENTITY_TYPE_2);
    }
    else if( strcmp( pszStr, "DERECORD") == 0)
    {
      strcpy( pszStr, ENTITY_TYPE_3);
    }
    else if( strcmp( pszStr, "DEGROUP") == 0)
    {
      strcpy( pszStr, ENTITY_TYPE_4);
    }
    else if( strcmp( pszStr, "DEDTELEM") == 0)
    {
      strcpy( pszStr, ENTITY_TYPE_5);
    }

	return CMN_SUCCESS;
 
}/*end of GetEntityType */


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BusPrintReport
**
**  DESCRIPTION      : This function prints the Segment Report 
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : MEVANS
**
**  DATE CREATED     : 10/31/97
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  10/31/97  MEVANS       T4       Original code.
**
**  01/27/98  B Lucas               rewrote function to incorporate new
**                                  print driver
**
**  04/13/98  JRICE                 Modified code to include occurences 
**                                  for elements
**
**  04/17/98  JRICE                 Added logic to concatenate item name 
**                                  when the value is too long
**
**  04/24/98  JRICE                 Modified code to include usage for 
**                                  non-numeric elements
**
***************************************************************************/
SHORT AZRP001BusPrintReport( _REQUESTHDR  *pRequestHdr, 
                             _REPLYHDR    *pReplyHdr,
                             _ENTITYDATA  *pEntityDataTable, 
                             CHAR         Duplex, 
                             CMN_ARCH_PARM_TYPES )
{
    USHORT CurrRow   = 0;
    USHORT CurrPage  = 1;
    USHORT CurrLine  = 0;
    SHORT  rc        = 0;
	LONG   PrintSize = 0;
    _CMN_PD_PRINT_DATA_PARMS_EXT PrintParms;
	LONG   ItemNameLength = 0;

    /* set print parms for desired format */
	memset( &PrintParms, 0, sizeof( _CMN_PD_PRINT_DATA_PARMS_EXT ));
    PrintParms.Font           = atoi( CDCONTROLCHAR_FONT_COURIER8 );
    PrintParms.Orientation    = atoi( CDCONTROLCHAR_ORIENT_PORTRAIT );
	PrintParms.Margins.Top    = DEFAULT_MARGIN_TOP;
    PrintParms.Margins.Bottom = DEFAULT_MARGIN_BOTTOM;
    PrintParms.Margins.Left   = DEFAULT_MARGIN_LEFT;
    PrintParms.Margins.Right  = DEFAULT_MARGIN_RIGHT;

    if( Duplex == CMN_YES )
    {
        PrintParms.Duplex = atoi( CDCONTROLCHAR_DOUBLE_SIDED );
    }
    else
    {
        PrintParms.Duplex = atoi( CDCONTROLCHAR_SINGLE_SIDED );
    }

    /* Allocate memory to store the segment report data */
    PrintParms.DataToPrint = malloc ( 2 * NUMREPOSDATALBROWS * LINE_LEN );
	memset( PrintParms.DataToPrint, 0, 2 * NUMREPOSDATALBROWS * LINE_LEN );

    /* print data. do not exceed NUMREPOSDATALBROWS rows */
    while (( CurrRow < NUMREPOSDATALBROWS )       && 
           ( CurrRow < pReplyHdr->RowsReturned ))
    {

		/* print header information */  
		AZRP001BusFormatHeader( PrintParms.DataToPrint,
								&PrintSize, 
								pRequestHdr, 
								pReplyHdr, 
								pEntityDataTable,
								CurrPage, 
								&CurrLine, 
								CMN_ARCH_PARMS );

		/* print entities for remainder of page */
		while( CurrLine < MAX_LINES_PER_PAGE        &&
               CurrRow  < NUMREPOSDATALBROWS        &&
               CurrRow  < pReplyHdr->RowsReturned )
		{

			/* bold all entities except 'element' type */
			if( WCD_EntityData[CurrRow].EntityType[0] != \
				ENTITY_TYPE_ELEMENT )
			{

				PrintSize += sprintf( &PrintParms.DataToPrint[PrintSize], 
								      "%c%s",

									  /* bold on */
									  CMN_PD_PRINT_PCL_TOKEN,
									  CDCONTROLCHAR_BOLD_ON );
			}

			/* JRICE 04/17/98
			** Calculate item name length otuside of the sprintf statement
			** as this value will now be used twice: once for minimum length
			** as before, but now also for maximum length
			*/
			/* 
	        ** item name 
			** both 'document id' and 'item type' have
			** fixed lengths to print.  however, to
		    ** keep 'item name' from overwriting the
			** detail columns, it does not have a set
			** width to print.  instead, it will print
			** from the end of 'item type' to the 
			** beginning of 'fmt'
			*/

			ItemNameLength = 	( FMT_START_COL - OFFSET_FMT ) -         \
								(( WCD_EntityData[CurrRow].EntityLevel * \
								INDENT_FACTOR ) + COL_WIDTH_DOC_ID +     \
								COL_WIDTH_ITEM_TYPE );
			
			/* all entities print doc id, item type, and item name */
			PrintSize += sprintf( &PrintParms.DataToPrint[PrintSize], 
								  "%*s%-*s%-*s%-*.*s",
								  
								  /* indent */
								  WCD_EntityData[CurrRow].EntityLevel * \
								  INDENT_FACTOR,
								  "",

								  /* doc id */
								  COL_WIDTH_DOC_ID,
								  &WCD_EntityData[CurrRow].EntityId,

								  /* item type */
								  COL_WIDTH_ITEM_TYPE,
								  &WCD_EntityData[CurrRow].EntityType,

								  /* JRICE 04/17/98
								  ** Added value for max item length
								  ** along with minimum
								  */
								  ItemNameLength, ItemNameLength,
								  &WCD_EntityData[CurrRow].EntityCobolName );

			/*
			** print different columns depending on entity type:
			**                fmt len prec us occur bytes other_char
			**     copybook -
			**     table    -
			**     group    - 					x
			**     element  -  x   x	x	x	x	  x			x
			**
			** when an item like 'group' and 'element' skip columns, 'spaces'
			** are printed to hold the allignment 
			*/
			switch( WCD_EntityData[CurrRow].EntityType[0] )
			{
				case ENTITY_TYPE_COPYBOOK:
					{						
						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize], 
											  "%c%s",

											  /* bold off */
											  CMN_PD_PRINT_PCL_TOKEN,
											  CDCONTROLCHAR_BOLD_OFF );

						break;
					}

				case ENTITY_TYPE_TABLE:
					{
						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize], 
											  "%c%s",

											  /* bold off */
											  CMN_PD_PRINT_PCL_TOKEN,
											  CDCONTROLCHAR_BOLD_OFF );

						break;
					}

				case ENTITY_TYPE_RECORD:
					{
						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize ],
											  "%c%s",

											  /* bold off */
											  CMN_PD_PRINT_PCL_TOKEN,
											  CDCONTROLCHAR_BOLD_OFF );

						break;
					}

				case ENTITY_TYPE_GROUP:
					{

						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize], 
											  "%*s%*s%*s%*s%*s%*s%*s%*s" \
											  "%*s%*s%c%s",

											  /* fmt indent */
											  OFFSET_FMT,
											  "",

											  /* dummy fmt */
											  COL_WIDTH_FMT,
											  "",

											  /* len indent */
											  OFFSET_LEN,
											  "",

											  /* dummy len */
											  COL_WIDTH_LEN,
											  "",

											  /* prec indent */
											  OFFSET_PREC,
											  "",

											  /* dummy prec */
											  COL_WIDTH_PREC,
											  "",

											  /* us indent */
											  OFFSET_US,
											  "",

											  /* dummy us */
											  COL_WIDTH_US,
											  "",										  

											  /* occur indent */
											  OFFSET_OCCUR,
											  "",

											  /* occur */
											  COL_WIDTH_OCCUR,
											  ReposDataLBOccursData\
											  [CurrRow], 
											  
											  /* bold off */
											  CMN_PD_PRINT_PCL_TOKEN,
											  CDCONTROLCHAR_BOLD_OFF );

						break;
					}

				case ENTITY_TYPE_ELEMENT:
					{
						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize], 
											  "%*s%*c%*s%*d",

											  /* fmt indent */
											  OFFSET_FMT,
											  "",

											  /* fmt */
											  COL_WIDTH_FMT,
											  WCD_EntityData[CurrRow].\
											  DteIntFormat,

											  /* len indent */
											  OFFSET_LEN,
											  "",

											  /* len */
											  COL_WIDTH_LEN,
											  WCD_EntityData[CurrRow].\
											  DteIntLength );

						/* 
						** if this entity is numeric, print prec and us 
						** attributes 
						*/
						if( WCD_EntityData[CurrRow].DteIntFormat == \
							    ENTITY_TYPE_NUMERIC )
						{
						
							PrintSize += sprintf( &PrintParms.DataToPrint\
								                  [PrintSize],
												  "%*s%*d%*s%*s",

												  /* prec indent */
												  OFFSET_PREC,
												  "",

												  /* prec */
												  COL_WIDTH_PREC,
												  WCD_EntityData[CurrRow].\
												  DteIntPrecision,

												  /* us indent */
												  OFFSET_US,
												  "",

												  /* us */
												  COL_WIDTH_US,
												  &WCD_EntityData[CurrRow].\
												  DteIntUsage );
						}
						/* JRICE 04/24/98
						** Modified code to include usage for non numeric elements
						*/
						/* if not, print 'spaces' */
						else
						{

							PrintSize += sprintf( &PrintParms.DataToPrint
								                  [PrintSize], 
												  "%*s%*s%*s%*s",

												  /* prec indent */
												  OFFSET_PREC,
												  "",

												  /* dummy prec */
												  COL_WIDTH_PREC,
												  "",

												  /* us indent */
												  OFFSET_US,
												  "",

												  /* dummy us */
												  COL_WIDTH_US,
												  &WCD_EntityData[CurrRow].\
												  DteIntUsage );
						}
						/* JRICE 04/13/98
						** Modified code to include occurences for elements
						*/
						PrintSize += sprintf( &PrintParms.DataToPrint\
							                  [PrintSize], 
											  "%*s%*s%*s%*s%*s%-*s",

											  /* occur indent */
											  OFFSET_OCCUR,
											  "",

											  /* dummy occur */
											  COL_WIDTH_OCCUR,
											  ReposDataLBOccursData\
											  [CurrRow],

											  /* bytes indent */
											  OFFSET_BYTES,
											  "",

											  /* bytes */
											  COL_WIDTH_BYTES,
											  ReposDataLBBytesData[CurrRow],

											  /* other char indent */
											  OFFSET_OTHER_CHAR,
											  "",

											  /* other char */
											  COL_WIDTH_OTHER_CHAR,
											  ReposDataLBOther2Data\
											  [CurrRow] );

						break;
					}
			}

			/* line feed */
			PrintSize += sprintf( &PrintParms.DataToPrint[PrintSize], 
								  "%c%s",
								  CMN_PD_PRINT_PCL_TOKEN,
								  CDCONTROLCHAR_LINE_FEED );

			/* Increment counters */
			CurrRow++;
			CurrLine++;
		}

		/* check why loop ended */
		if( CurrLine >= MAX_LINES_PER_PAGE      &&
	        CurrRow < NUMREPOSDATALBROWS        &&
			CurrRow < pReplyHdr->RowsReturned )
		{
			/* lines per page exceeded, but still data. start new page */
			PrintSize += sprintf( &PrintParms.DataToPrint[PrintSize], 
								  "%c%s",
								  CMN_PD_PRINT_PCL_TOKEN,
								  CDCONTROLCHAR_FORM_FEED );

			CurrPage++;
		}	
    }    
	
	/* if there are more lines print a message */
    if( CurrRow >= NUMREPOSDATALBROWS )
    {
		PrintSize += sprintf( &PrintParms.DataToPrint[PrintSize], 
							  MSG_TOO_MANY_ROWS,

							  /* double line feed */
							  CMN_PD_PRINT_PCL_TOKEN,
							  CDCONTROLCHAR_DBL_LINE_FEED, 

							  /* bold on */
							  CMN_PD_PRINT_PCL_TOKEN,
							  CDCONTROLCHAR_BOLD_ON,

							  /* max rows */
							  NUMREPOSDATALBROWS,

							  /* line feed */
							  CMN_PD_PRINT_PCL_TOKEN,
							  CDCONTROLCHAR_LINE_FEED,

							  /* bold off */
							  CMN_PD_PRINT_PCL_TOKEN,
							  CDCONTROLCHAR_BOLD_OFF );
    }

	/* send data to print driver */
	PrintParms.DataToPrintSize = PrintSize;
	rc = CmnPdPrintDriver( PrintParms, CMN_ARCH_PARMS );

	/* release print buffer */
    free( PrintParms.DataToPrint );

	return CMN_SUCCESS;		  
} 


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BusFormatHeader
**
**  DESCRIPTION      : This function formats the segment report header.
**
**  INPUTS           : pDatatoPrint
**                         pointer to print buffer
**
**                     DataToPrintSize
**                         pointer to print buffer size counter
**
**                     pRequestHdr
**                         pointer to request header
**
**                     pReplyHdr
**                         pointer to service's reply header
**
**                     CurrPage
**                         current page
**
**                     pCurrLine
**                         pointer to current line counter
**
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  10/31/97  MEVANS       T4       Original code.
**
**  01/27/98  B Lucas               rewrote function to incorporate new
**                                  print driver
**
***************************************************************************/
SHORT AZRP001BusFormatHeader( CHAR         *pDatatoPrint,
						      LONG         *pDatatoPrintSize,
                              _REQUESTHDR  *pRequestHdr,
                              _REPLYHDR    *pReplyHdr, 
                              _ENTITYDATA  *pEntityDataTable,
                              SHORT        CurrPage, 
                              SHORT        *pCurrLine, 
                              CMN_ARCH_PARM_TYPES )
{

    CHAR    *psLongDesc            = NULL;
    CHAR    *pszStr                = NULL;
    CHAR    CurrDate[DATE_STR_LEN] = "";
    USHORT  usNumLongDescRows      = 0;
    SHORT   i                      = 0;
	SHORT   j                      = 0;
	CHAR    *pWrappedWord          = NULL;

	/* format the title section */
    _strdate( CurrDate );
	*pDatatoPrintSize  += sprintf( &pDatatoPrint[*pDatatoPrintSize], 
		                           "%*s%c%s%-*s%*s%s%4.4d%c%s%*s%-*s%*s" \
								   "%-s%c%s%*s%-s ( %s )%c%s%c%s",

	                               /* fnd/css indent */
						           OFFSET_FND_CSS,
							       "",

							       /* bold on */
				                   CMN_PD_PRINT_PCL_TOKEN,
							       CDCONTROLCHAR_BOLD_ON, 

                                   /* foundation/css */
							       COL_WIDTH_TITLE,
							       LABEL_FND_CSS,

	                               /* page offset */
						           OFFSET_PAGE,
							       "",

	                               /* page number */
							       LABEL_PAGE,
							       CurrPage,

                                   /* line feed */
                                   CMN_PD_PRINT_PCL_TOKEN,
                                   CDCONTROLCHAR_LINE_FEED,

							       /* seg rpt indent */
						           OFFSET_SEG_RPT,
							       "",

	                               /* segment reporting */
							       COL_WIDTH_TITLE,
							       LABEL_SEG_RPT,

							       /* date indent */
						           OFFSET_DATE,
						           "",

	                               /* date */
							       CurrDate,

                                   /* line feed */
                                   CMN_PD_PRINT_PCL_TOKEN,
                                   CDCONTROLCHAR_LINE_FEED,

							       /* title indent */
						           OFFSET_ENTITY,
							       "",

	                               /* entity name */
							       pRequestHdr->EntityId,
							       pEntityDataTable[0].EntityType,

							       /* bold off */
	                               CMN_PD_PRINT_PCL_TOKEN,
							       CDCONTROLCHAR_BOLD_OFF, 

                                   /* line feed */
                                   CMN_PD_PRINT_PCL_TOKEN,
                                   CDCONTROLCHAR_LINE_FEED );

    /* update current line counter to reflect the 3 title lines */
    *pCurrLine = 3;

    /* if this is the first page, print description header */
    if( CurrPage == 1 )
    {
		*pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize],
			                          "%s %s%c%s%s%c%s",

								      /* 'entity' characteristics */
                                      pEntityDataTable[0].EntityType,
								      LABEL_CHARACTERISTICS,

								      /* line feed */
								      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_LINE_FEED,

								      /* ---- */
                                      AZRP001_SEG_RPT_COLHDR1,

								      /* line feed */
  								      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_DBL_LINE_FEED );

		/* if table report, print the table name */
		if( pEntityDataTable[0].EntityType[0] == ENTITY_TYPE_TABLE )
		{
			*pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize], 
				                          "%*s%c%s%*s%c%s%*s%s%c%s",

									      /* tbl name label indent */
									      OFFSET_TBL_NAME_LABEL,
									      "",

									      /* bold on */
				                          CMN_PD_PRINT_PCL_TOKEN,
									      CDCONTROLCHAR_BOLD_ON, 

									      /* tbl name label*/
									      COL_WIDTH_DESC,
									      LABEL_TABLE_NAME,

									      /* bold off */
	                                      CMN_PD_PRINT_PCL_TOKEN,
								          CDCONTROLCHAR_BOLD_OFF, 

								          /* tbl name offset */
								          OFFSET_TBL_NAME,
									      "",

									      /* tbl name */
									      pReplyHdr->TabName,

									      /* line feed */
	   								      CMN_PD_PRINT_PCL_TOKEN,
						                  CDCONTROLCHAR_LINE_FEED );

			/* add to line count */
			*pCurrLine += 1;
		}

		/* print short desc label, short desc, and long desc label */
        *pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize],
			                          "%*s%c%s%*s%c%s%*s%s%c%s%*s%c%s" \
									  "%*s%c%s%*s",

								      /* short desc label indent */
								      OFFSET_SHORT_DESC_LABEL,
								      "",

								      /* bold on */
				                      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_BOLD_ON, 

								      /* short desc label */
                                      COL_WIDTH_DESC,
								      LABEL_SHORT_DESC,

								      /* bold off */
				                      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_BOLD_OFF, 

								      /* short desc offset */
								      OFFSET_SHORT_DESC,
								      "",

								      /* short desc */
								      pEntityDataTable[0].EntityId,

								      /* line feed */
  								      CMN_PD_PRINT_PCL_TOKEN,
					                  CDCONTROLCHAR_LINE_FEED,

		                              /* long desc label indent */
								      OFFSET_LONG_DESC_LABEL,
								      "",

								      /* bold on */
				                      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_BOLD_ON, 						  

		                              /* long desc label */
                                      COL_WIDTH_DESC,
								      LABEL_LONG_DESC,

								      /* bold off */
				                      CMN_PD_PRINT_PCL_TOKEN,
								      CDCONTROLCHAR_BOLD_OFF, 

		                              /* long desc offset */
								      OFFSET_LONG_DESC,
								      "" );

        /* update line counter */
        *pCurrLine += 4;

		/* if long desc was returned */
		if( pReplyHdr->NumTextRows )
		{

			/* format and print the long desc */
			for( i = 0; i < pReplyHdr->NumTextRows; i++ )
			{

				/* init variables */
				j = ENTITYTEXT_LEN - 2;

				/* the last element is not a space */
				if( pReplyHdr->EntityText[i][j] != ' ' )
				{
					
					/* the last element is not a period */
					if( pReplyHdr->EntityText[i][j] != '.' )
					{

						/* find last complete word */
						for( ; pReplyHdr->EntityText[i][j] != ' '; j-- );

						/* set pointer to beginning or wrapped word */
						pWrappedWord = &pReplyHdr->EntityText[i][j+1];
					}
					else
					{

						/* last char was a period.  no word wrapped */
						pWrappedWord = NULL;						  
					}
				}

				/* last element is a space */
				else
				{

					/* find end of string */
					for( ; pReplyHdr->EntityText[i][j-1] == ' '; j-- );

					/* 
					** set pointer to null character.  cannot use NULL 
					** because '(null)' will print
					*/
					pWrappedWord = &pReplyHdr->EntityText[i]\
						                       [ENTITYTEXT_LEN - 1];

				}

				/* print line i of entity test */
				*pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize],
											  "%-.*s%c%s",
											  j,
											  &pReplyHdr->EntityText[i],
											  CMN_PD_PRINT_PCL_TOKEN,
											  CDCONTROLCHAR_LINE_FEED );

				/* increment row count */
				*pCurrLine += 1;

				if( i < ( pReplyHdr->NumTextRows - 1 ))
				{

					/* not the last. add offset and wrapped word */
					*pDatatoPrintSize += sprintf( &pDatatoPrint\
												  [*pDatatoPrintSize],
												  "%*s%*s%*s%s",

												  /* long desc label indent */
												  OFFSET_LONG_DESC_LABEL,
												  "",
							 
												  /* dummy long desc label */
												  COL_WIDTH_DESC,
												  "",

												  /* long desc offset */
												  OFFSET_LONG_DESC,
												  "",

												  /* wrapped word */
												  pWrappedWord );

				}
			}
		}

		/* no long desc */
		else
		{

			/* line feed */
			*pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize],
										  "%c%s",
										  CMN_PD_PRINT_PCL_TOKEN,
										  CDCONTROLCHAR_LINE_FEED );
		}
    } 

    /* Format the Column headers */
    *pDatatoPrintSize += sprintf( &pDatatoPrint[*pDatatoPrintSize], 
                                  "%c%s%s%c%s%c%s%s%c%s%c%s%s%c%s",
 							      CMN_PD_PRINT_PCL_TOKEN,
							      CDCONTROLCHAR_LINE_FEED,
                                  AZRP001_SEG_RPT_COLHDR1,
							      CMN_PD_PRINT_PCL_TOKEN,
				                  CDCONTROLCHAR_LINE_FEED,
                                  CMN_PD_PRINT_PCL_TOKEN,
							      CDCONTROLCHAR_BOLD_ON,
                                  AZRP001_SEG_RPT_COLHDR2,
                                  CMN_PD_PRINT_PCL_TOKEN,
							      CDCONTROLCHAR_BOLD_OFF,
							      CMN_PD_PRINT_PCL_TOKEN,
				                  CDCONTROLCHAR_LINE_FEED,
                                  AZRP001_SEG_RPT_COLHDR3,
							      CMN_PD_PRINT_PCL_TOKEN,
				                  CDCONTROLCHAR_LINE_FEED );

    /* Reset CurrLine */
    *pCurrLine += 4;

    return CMN_SUCCESS;

}
 

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BusWriteReport
**
**  DESCRIPTION      : This function writes the segment report to a file.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**                                  Original code.
**
***************************************************************************/
SHORT AZRP001BusWriteReport( _REQUESTHDR *pRequestHdr, 
                             _REPLYHDR   *pReplyHdr,
                             _ENTITYDATA *pEntityDataTable, 
                             CHAR        *PrintFile,
                             CHAR         Duplex, 
                             CMN_ARCH_PARM_TYPES )
{
#define PRINTER_RESET         "\033E"
#define FONT_LINE_PRINTER     "\033(0N\033(s0p16.67h8.5v0s0b0T"
#define VMI                   "\033&l5.6C"
#define DUPLEX                "\033&l1S"

  FILE *pfPrinter;
  USHORT CurrRow = 0;
  USHORT CurrPage = 1;
  USHORT CurrLine;

  /* Open PrintFile */
  pfPrinter = fopen( PrintFile, "w" );
  if(!pfPrinter) 
  {
  	return CMN_FAIL;
  }

  /* Initialize PrintFile */
  fprintf( pfPrinter, PRINTER_RESET );
  fprintf( pfPrinter, FONT_LINE_PRINTER );
  fprintf( pfPrinter, VMI );

  if( Duplex == 'Y' )
  {
    fprintf( pfPrinter, DUPLEX );
  }

  if( pfPrinter )
  {
  /*mdc 07/08/96 Changed to keep rows beyond 200 from printing garbage*/
  /*mdc 07/08/96 NUMREPOSDATALBROWS repalces pReplyHdr->RowsReturned throughout this function*/
    /*while( CurrRow < pReplyHdr->RowsReturned ) */
    while ( CurrRow < NUMREPOSDATALBROWS && 
            CurrRow < pReplyHdr->RowsReturned )
    {
      /* Print Header Information */
      AZRP001BusWriteHeader( pfPrinter, 
                             pRequestHdr, 
                             pReplyHdr, 
                             pEntityDataTable,
                             CurrPage, 
                             &CurrLine, 
                             CMN_ARCH_PARMS );

      while( CurrLine < MAX_LINES_PER_PAGE &&
             CurrRow < NUMREPOSDATALBROWS &&
             CurrRow < pReplyHdr->RowsReturned )
      {
        /* Print Current Row */
        /*
        fprintf( pfPrinter, "Page %4d Line %4d Row %4d\n",
                 CurrPage, CurrLine, CurrRow );
        */
        CHAR  FormatString[ 80 ];
        SHORT Indent;
        CHAR  EntityIdTypeName[ 80 ];

        /* Calculate number of spaces to indent */
        Indent = WCD_EntityData[CurrRow].EntityLevel * 2;


        sprintf( EntityIdTypeName, "%-25s%-15s%-30s",
                 WCD_EntityData[CurrRow].EntityId,
                 WCD_EntityData[CurrRow].EntityType,
                 WCD_EntityData[CurrRow].EntityCobolName );
                 /*
                 ReposDataLBEntityIdData[ CurrRow ],
                 ReposDataLBEntityTypeData[ CurrRow ],
                 ReposDataLBEntityNameData[ CurrRow ] );
                 */

        /* Build format string: "%-<Indent>s%-<70-Indent>s" */
        if( Indent == 0 )
        {
          fprintf( pfPrinter, "      %70.70s", EntityIdTypeName );
        }
        else
        {
          sprintf( FormatString, "      %%-%d.%ds%%-%d.%ds",
                   Indent, Indent,
                   70-Indent, 70-Indent );
          fprintf( pfPrinter, FormatString, "", EntityIdTypeName );
        }

        fprintf( pfPrinter, SEG_RPT_DTL_FMT,
                 ReposDataLBFormatData[ CurrRow ],
                 ReposDataLBLengthData[ CurrRow ],
                 ReposDataLBPrecisionData[ CurrRow ],
                 ReposDataLBUsageData[ CurrRow ],
                 ReposDataLBOccursData[ CurrRow ],
                 ReposDataLBBytesData[ CurrRow ],
                 ReposDataLBOtherData[ CurrRow ] );

        if( strlen( ReposDataLBOther2Data[ CurrRow ] ))
        {
          fprintf( pfPrinter, "      %70.70s", "" );
          fprintf( pfPrinter, SEG_RPT_DTL_FMT,
                   "",
                   "",
                   "",
                   "",
                   "",
                   "",
                   ReposDataLBOther2Data[ CurrRow ] );

          CurrLine++;
        }

        /* Increment counters */
        CurrRow++;
        CurrLine++;

      }

      /* Check why loop terminated */
      if( CurrLine >= MAX_LINES_PER_PAGE &&
          CurrRow < NUMREPOSDATALBROWS &&
          CurrRow < pReplyHdr->RowsReturned )
      {
        /* Lines per page exceeded, but still more data */
        fprintf( pfPrinter, "\f" );
        CurrPage++;
      }
    }/*end of while CurrRow <= MAX_RPT_LINES */
    /*mdc 07/08/96 if there are more lines print a message*/
    if ( CurrRow >= NUMREPOSDATALBROWS )
    {
        if (CurrLine >= MAX_LINES_PER_PAGE - 3 )
        {
            fprintf(pfPrinter, "\f" );
            ++CurrPage;
            /* Print Header Information */
            AZRP001BusWriteHeader( pfPrinter, 
                                   pRequestHdr, 
                                   pReplyHdr, 
                                   pEntityDataTable,
                                   CurrPage, 
                                   &CurrLine, 
                                   CMN_ARCH_PARMS );

        }
        fprintf(pfPrinter, "\n\n\tThe maximum number of printable lines is %d.", NUMREPOSDATALBROWS);
        fprintf(pfPrinter, "\n\tThere are additional lines of data that will not be printed.");
    }

    /* Reset printer and close */
    fprintf( pfPrinter, PRINTER_RESET );
    fclose( pfPrinter );
  }
  else
  {
    /* ERROR OPENING PRINT FILE */
  }

  return CMN_SUCCESS;
}/*end of AZRP001BusWriteReport*/


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BusWriteHeader
**
**  DESCRIPTION      : This function writes the segment report header. 
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**                                    Original code.
**
***************************************************************************/
SHORT AZRP001BusWriteHeader( FILE        *pfPrinter, 
                             _REQUESTHDR *pRequestHdr,
                             _REPLYHDR   *pReplyHdr, 
                             _ENTITYDATA *pEntityDataTable,
                             SHORT        CurrPage, 
                             SHORT       *pCurrLine, 
                             CMN_ARCH_PARM_TYPES )
{
#define SEG_RPT_HDR1 \
"                                                          FOUNDATION 3.2/CSS                                              Page %4.4d\n"
#define SEG_RPT_HDR2 \
"                                                          SEGMENT REPORTING                                                %8.8s\n"
#define SEG_RPT_HDR3 \
"                                                          %8.8s (%s)\n"

  CHAR CurrDate[ 9 ];
  USHORT usNumLongDescRows = 0;
  char *psLongDesc;
  char *pszStr;
  fprintf( pfPrinter, "\n" );
  fprintf( pfPrinter, SEG_RPT_HDR1, CurrPage );
  _strdate( CurrDate );

  fprintf( pfPrinter, SEG_RPT_HDR2, CurrDate );
  fprintf( pfPrinter, SEG_RPT_HDR3, pRequestHdr->EntityId,
           pEntityDataTable[0].EntityType );
  fprintf( pfPrinter, "\n\n" );
  *pCurrLine = 6;

  if( CurrPage == 1 )
  {

    /* Print Page 1 header */
    fprintf( pfPrinter, "          %s CHARACTERISTICS\n",
             pEntityDataTable[0].EntityType );
    fprintf( pfPrinter, "%s\n", SEG_RPT_COLHDR1 );
    fprintf( pfPrinter, "            SHORT DESCRIPTION:  %s\n",
             pEntityDataTable[0].EntityId );
    *pCurrLine += 3;

    /* Print long description */
    fprintf( pfPrinter, "             LONG DESCRIPTION:  " );
    *pCurrLine += 1;

    if( pReplyHdr->NumTextRows > 0 )
    {
	  
	    /*mdc Allocate memory for long description string*/
		  psLongDesc = (char *)calloc(LONG_DESC_LEN + 256, sizeof(char));
		  if(!psLongDesc) return CMN_FAIL;

		  /* Copy long description to string */
		  CmnStrCat( CMN_ARCH_PARMS, psLongDesc, LONG_DESC_LEN,
		             8,
		             pReplyHdr->EntityText[0], pReplyHdr->EntityText[1],
		             pReplyHdr->EntityText[2], pReplyHdr->EntityText[3],
		             pReplyHdr->EntityText[4], pReplyHdr->EntityText[5],
		             pReplyHdr->EntityText[6], pReplyHdr->EntityText[7] );
		 
		/*mdc remove extra spaces*/
		pszStr = psLongDesc;
		++pszStr;
		while (*pszStr)
		{
			while (*(pszStr - 1) == ' ' && *pszStr == ' ')
				strcpy(pszStr, pszStr + 1);
			++pszStr;
		}


		 /*mdc format the long description*/
		 FormatLongDesc(psLongDesc, &usNumLongDescRows);

		 /*mdc print the long desc and increment the line counter*/
		 fprintf(pfPrinter, "%s\n", psLongDesc);
		 *pCurrLine += usNumLongDescRows;

      /* Print first line of text */
	  /*mdc 
      fprintf( pfPrinter, pReplyHdr->EntityText[0] );

      for( i=1; i<pReplyHdr->NumTextRows; i++ )
      {
        if( strlen( pReplyHdr->EntityText[i] ) > 0 )
        {
          fprintf( pfPrinter, "                                %s",
                   pReplyHdr->EntityText[i] );
          *pCurrLine += 1;
        }
	   
      }*/
	  /*mdc free memory*/
	  free (psLongDesc);
    }
    else
    {
      fprintf( pfPrinter, "\n" );
    }

    if( strcmp( pEntityDataTable[0].EntityType, "TABLE" ) == 0 )
    {
      /* Print TABLE-specific fields */
      fprintf( pfPrinter, "\n                   TABLE NAME:  %s\n",
               pReplyHdr->TabName );

      *pCurrLine += 2;
    }


    fprintf( pfPrinter, "\n\n" );
    *pCurrLine += 2;
  }

  fprintf( pfPrinter, "%s\n%s\n%s\n",
           SEG_RPT_COLHDR1,
           SEG_RPT_COLHDR2,
           SEG_RPT_COLHDR3 );

  /* Reset CurrLine */
  *pCurrLine += 3;   /* Adjust this based on size of header */

  return 0;
}/*end of AZRP001BusWriteHeader*/	

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : FormatLongDesc
**
**  DESCRIPTION      : This function formats the long description for printing
**                     a hard copy of the segment report.
**
**  INPUTS           : psStr - pointer to the long desc.
**                     n     - pointer to the line counter.
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : StrInsertCRLF
**                     StrAllocateSubs
**                     StrParse
**                     StrPad
**                     StrAssemble
**                     FreeMemArray
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/

USHORT FormatLongDesc(char *psStr, 
                     USHORT *n)
{

    USHORT i = 0;
	USHORT j = 0;
    char *ppStr[NUM_SUBS];
    USHORT usNumRows = *n; /*set to passed in value*/
    USHORT rc = 0;
    char cParseChar = PARSE_CHAR;
    char cPadChar = PAD_CHAR;
    USHORT usNumChar = PAD_LEN;

	/*insert all the newlines*/
    rc = StrInsertCRLF(psStr, &usNumRows);


	/*allocate memory for the string array*/
    rc = StrAllocateSubs(ppStr,
			 NUM_SUBS,
			 SUB_STR_LEN);
    if(rc)
    {
		fprintf(stderr, "\nThe memory allocation failed with %d\n",rc);
		return(rc);
    }
	

	/*parse the long desc on the newlines*/
    rc = StrParse(psStr,ppStr,cParseChar, usNumRows);

	/*pad the strings in the array for indentation alignment*/
    for(i = 0; i < usNumRows - 1; ++i)
    {
		rc = StrPad(ppStr[i], cPadChar, usNumChar);
    }

	/*reassemble the long desc*/
    rc = StrAssemble(psStr,ppStr);

	/*free the allocated memory*/
    FreeMemArray((void **)ppStr);

	/*set the number of lines added to the page*/
	*n = usNumRows + 1;

    return(CMN_SUCCESS);

}/*end of FormatLongDesc*/


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : StrAssemble
**
**  DESCRIPTION      : This function assembles an array of strings into a single string
**
**  INPUTS           : s - pointer to the string.
**                     ppStr     - pointer to the array of strings.
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/

USHORT StrAssemble(char * s,
		   char *ppStr[])
{
	USHORT i = 0;

    /*initailize the passed in string */
    *s = '\0';

    /*assemble the string*/
	for(i = 0; i < NUM_SUBS; ++i)
	{
		strcat(s, ppStr[i]);
	}
    return CMN_SUCCESS;

}/*end of StrAssemble*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : StrPad
**
**  DESCRIPTION      : This function pads a string with the designated number 
**                     of characters of the passed in type.
**
**  INPUTS           : s - pointer to the string.
**                     cPadChar - character to use for padding
**                     usNum - number of characters to pad.
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/


USHORT StrPad(char *s,
	      char cPadChar,
	      USHORT usNum)

{
    USHORT i = 0;
    char *psStart = s;

    /*move to the end of the string*/
    while(*s) ++s;
    for(i = 0; i < usNum && s < psStart + SUB_STR_LEN; ++i)
    {
		*(s + 1) = '\0'; /* move the NULL up */
		*s = cPadChar;
		++s;
    }
    return CMN_SUCCESS;
}/*end of StrPad*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : StrParse
**
**  DESCRIPTION      : This function parses a string on the designated character
**                     into the passed in string array.
**
**  INPUTS           : psStr - pointer to the string.
**                     ppStr - Target array of strings
**                     cParseChar - character to parse on.
**                     usNumStrs - number of strings.
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/

USHORT StrParse(char *psStr,
				char *ppStr[],
				char cParseChar,
				USHORT usNumStrs)

{
/*mdc 06/11/96 change i to short */
    SHORT i = 0;
    char *s;

    s = psStr;

    /*move to the end of the string*/
    while (*s) ++s;

	i = usNumStrs - 1;
    /*back up to each parse character and copy off the substring created*/
    while(s > psStr && (i >= 0))
    {
		while(*s != cParseChar && s >= psStr) --s;
		strcpy(ppStr[i], s + 1);
		--i;
		if(s > psStr)  /*account for last substring*/
		{
		   *(s + 1) = '\0'; /*chaop off the copied string*/
		   --s; /*move off the parse character*/
		}
    }
    return CMN_SUCCESS;
}/*end of StrParse */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**
**  FUNCTION         : StrInsertCRLF
**
**  DESCRIPTION      : This function inserts a newline at approximately every 
**                     LINE_LEN chars from the begining of the string. It 
**                     replces the closest space with \n
**
**  INPUTS           : psStr - pointer to the string.
**                     usNumRows - number of rows created
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/

USHORT StrInsertCRLF(char *psStr,
		    USHORT *usNumRows)
{
    USHORT i;

    /*initialize the line count just in case */
    *usNumRows = 0;

    while(*psStr) /*test for end of string*/
    {
		for(i = 0; i < LINE_LEN && *psStr; ++i) ++psStr;/*move up LINE_LEN*/
		if(*psStr)
		{
		    while(*psStr != ' ') --psStr;/*back up to space */
		    *psStr = '\n'; /*set space to newline*/
		    ++*usNumRows; /*increment the number of lines created */
		    ++psStr; /*move pointer ahead one and loop*/
		}
    }
	++*usNumRows;/*add the last row*/
    return CMN_SUCCESS;

}/*end of StrInsertCRLF */

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**
**  FUNCTION         : StrAllocateSubs
**
**  DESCRIPTION      : This function allocates memory for anumber of substrings in an array
**                     of substrings. If it fails on any allocation it frees all and returns
**                     a CMN_ERR_MEM_ALLOC_FAILED error.
**
**  INPUTS           : psStr - pointer to the string array.
**                     usNumSubs - number of strings to allocate
**                     usStrSize - size of each string
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
***************************************************************************/

USHORT StrAllocateSubs(char *ppStr[],
		       USHORT usNumSubs,
		       USHORT usStrSize)
{
    USHORT i = 0;


	/*allocate memeory for the pointers*/
    for(i = 0; i < usNumSubs; ++i)
    {
		ppStr[i] = (char *)calloc(usStrSize, sizeof(char));
		if(!ppStr[i])
		{
		    FreeMemArray((void **)ppStr);
		    return CMN_ERR_MEM_ALLOC_FAILED;
		}

    }
    return CMN_SUCCESS;
}/*end of StrAllocateSubs*/

/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**
**  FUNCTION         : FreeMemArray
**
**  DESCRIPTION      : This function frees an array of pointers
**
**  INPUTS           : pp - pointer to the string array.
**                     usNumSubs - number of strings to free
**
**  OUTPUTS          : Return Code - USHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : mconner
**
**  DATE CREATED     : 04/15/96
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    04/15/96  mconner              Original code.
**
**    04/25/96  mconner              Increased free to accomodate max num
**                                   of substrings.
***************************************************************************/
USHORT FreeMemArray(void *pp[])
{
    USHORT i = 0;

	for (i = 0; i < NUM_SUBS; ++i)
	{
		free(pp[i]);
	}
    return CMN_SUCCESS;
}/*end of FreeMemArray */


/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**
**  FUNCTION         : SegRptRetrieveLayout
**
**  DESCRIPTION      : 
**
**  INPUTS           : 
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : none
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**                                    Original code.
**
***************************************************************************/
SHORT SegRptRetrieveLayout( _REQUESTHDR *pRequestHdr,
                            _REPLYHDR *pReplyHdr,
                            _ENTITYDATA *pEntityDataTable,
                            CMN_ARCH_PARM_TYPES )
{
  #define DEST_APPL_ID   1
  #define DEST_SRVC_ID   1
  #define DEST_SRVC_VER  "00"

  USHORT FndGenRC = 0;
  _FND_STANDARD_PB  FndStandardPB;
  _FND_ERROR_BLOCK  FndGenErrorBlock;
  _MSG_PARM_BLOCK   ParmBlock;

//  _LAYOUT_REC *pLayoutRecTable;
//  _ENTITYDATA *pEntityDataTable;
//  USHORT OffsetTable[ 20 ];
//  USHORT GroupCLength;

//  USHORT i;

  /* JSH: 07/24/93 MODIFIED */
  _MESSAGEOUTPUT  *pMessageInput;
  _MESSAGEOUTPUT *pMessageOutput;

  SHORT ReturnCode = 0;
  CHAR Message[ 255 ];
  USHORT SelectedButton;


  FndGenRC = FndWindowSetPointer(CBI_hwnd,
                                 FNDSYSPTR_WAIT,
                                 &FndGenErrorBlock);

  FndGenRC = FndMsgBoxDisplayMdlssText( "\n\nRetrieving Data From The Repository ...\n\n Please be patient.",
                                   "ReposWait",
                                   CBI_hwnd,
                                   FND_MSGBOX_NOBUTTONS,
                                   FND_MSGBOX_INFORMATION,
                                   FND_MSGBOX_IDNOBUTTON,
                                   CMN_CSS_APPL_NAME,
                                   &FndGenErrorBlock);

  /* JSH: 07/24/93 MODIFIED */
  pMessageInput  = malloc( sizeof( _MESSAGEOUTPUT ));
  pMessageOutput = malloc( sizeof( _MESSAGEOUTPUT ));

  memcpy( FndStandardPB.ver, FND_MSG_VER, _VER_LEN );

  /* Set up Request Header */
  strcpy( pMessageInput->RequestHdr.EntityType, pRequestHdr->EntityType );

  strcpy( pMessageInput->RequestHdr.EntityId, pRequestHdr->EntityId );
  pMessageInput->RequestHdr.MaxRows = pRequestHdr->MaxRows;

  /* Initialize Foundation Parm Block */
  MSGInitPB( &FndStandardPB, &ParmBlock, pEAIA, DEST_APPL_ID,
             DEST_SRVC_ID, DEST_SRVC_VER, pABHI );

  memcpy( ParmBlock.commarea.ver, FND_MSG_VER, _VER_LEN );
  ParmBlock.commarea.function_code = MSGIO_CONVERSE;
  /* JSH: 07/24/93 MODIFIED */
  ParmBlock.buffer_size = sizeof( _MESSAGEOUTPUT );
  ParmBlock.actual_length_send = sizeof( _REQUESTHDR );
  ParmBlock.timeout_interval = 30;

  memcpy( ParmBlock.translation.map_name, "AZCR001O", _FND_MAP_NAME_LEN );
  memcpy( ParmBlock.translation.map_version, "01", _VER_LEN );
  
  #ifdef FND_WIN32
  FndGenRC = MSGConvUI( &ParmBlock, (_MSG_SEND_AREA) pMessageInput,
                      (_MSG_RECV_AREA) pMessageOutput, pABHI );
  #endif

  #ifdef FND_OS2
  FndGenRC = MSGConv( &ParmBlock, (_MSG_SEND_AREA) pMessageInput,
                      (_MSG_RECV_AREA) pMessageOutput, pABHI );
  #endif

  if( FndGenRC == MSGIO_SUCCESS &&
      ParmBlock.appl_status.explan_code == FND_SUCCESS )
  {
    /* Allocate space for Layout Record Table */
    //pReplyHdr->RowsReturned = pMessageOutput->ReplyHdr.RowsReturned;
    memcpy( pReplyHdr, &(pMessageOutput->ReplyHdr), sizeof( _REPLYHDR ));

    /* Check if any rows were returned */
    if( pReplyHdr->RowsReturned )
    {
      //pEntityDataTable = (_ENTITYDATA *)
      //                       malloc( *pNumRows * sizeof( _ENTITYDATA ));

      /* Initialize memory */
      memcpy( pEntityDataTable, &(pMessageOutput->EntityData),
              pReplyHdr->RowsReturned * sizeof( _ENTITYDATA ));

      /*
      for( i=0; i<*pNumRows; i++ )
      {
        CsrMapInitItem( &(pMessageOutput->EntityData[i]),
                        &(pLayoutRecTable[i]), CMN_ARCH_PARMS );
      }
      */

      //*ppEntityDataTable = pEntityDataTable;

      /* Initialize OffsetTable */
      /*
      memset( OffsetTable, 0, sizeof( OffsetTable ));
      */
      /*

      CsrMapProcessDataLayout( pMessageOutput->EntityData,
                               OffsetTable,
                               pLayoutRecTable,
                               0,
                               0,
                               0,
                               &GroupCLength );
      */

      /* Check SQLCODE */
      if( pReplyHdr->SqlCode )
      {
        sprintf( Message, "Rows were returned by the Repository "
                          "Extract Service.  However, a non-zero "
                          "SQL Code was returned.  The SQL Code was "
                          "%ld.",
                 pReplyHdr->SqlCode );

        FndMsgBoxDisplayText( Message, NULL, CBI_hwnd, FND_MSGBOX_OK,
                              FND_MSGBOX_WARNING, FND_MSGBOX_OK,
                              NULL, &SelectedButton, &FndGenErrorBlock );
      }


    }
    else
    {
      /* No rows were returned */
      /* Check SQL Code */
      switch( pMessageOutput->ReplyHdr.SqlCode )
      {
        case 0:
            sprintf( Message, "No rows were returned by the Repository "
                              "Extract Service.  The SQL Code was %ld.",
                     pMessageOutput->ReplyHdr.SqlCode );
            break;

        default:
            sprintf( Message, "No rows were returned by the Repository "
                              "Extract Service.  The SQL Code was %ld.",
                     pMessageOutput->ReplyHdr.SqlCode );
            break;
      }

      FndMsgBoxDisplayText( Message, NULL, CBI_hwnd, FND_MSGBOX_OK,
                            FND_MSGBOX_CRITICAL, FND_MSGBOX_OK,
                            NULL, &SelectedButton, &FndGenErrorBlock );

      /* Set ReturnCode to indicate error */
      ReturnCode = 1;
    }
  }
  else
  {
    sprintf( Message, "Distribution Services returned an error.  "
                      "The return code from MSGConv is %d.  "
                      "The explanation code is %d.",
             FndGenRC, ParmBlock.appl_status.explan_code );


    FndMsgBoxDisplayText( Message, NULL, CBI_hwnd, FND_MSGBOX_OK,
                          FND_MSGBOX_CRITICAL, FND_MSGBOX_OK,
                          NULL, &SelectedButton, &FndGenErrorBlock );

    /* DS Error occurred */
    ReturnCode = 1;
  }

  /* Free the memory allocated for Message Input and Output */
  free( pMessageInput );
  free( pMessageOutput );

  FndGenRC = FndWindowSetPointer( CBI_hwnd,
                                  FNDSYSPTR_ARROW,
                                  &FndGenErrorBlock );

  FndGenRC = FndMsgBoxDestroy("ReposWait",
                               &FndGenErrorBlock);

  return ReturnCode;
}
