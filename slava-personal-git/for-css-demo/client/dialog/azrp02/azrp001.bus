/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION         : AZRP001BUSPredisplay
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : 
**
**  DATE CREATED     : 
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**                                   Original code.
**
***************************************************************************/
WCBPROC ( AZRP001BUSPredisplay )
{
    _FND_ERROR_BLOCK  FndGenErrorBlock;
    USHORT FndGenRC = 0;

	FndGenRC = FndValueInit( CBI_hwnd,
	                         "EntityType",  
	                         1,
	                         8,
	                         20,
	                         &FndGenErrorBlock);

	FndGenRC = FndValueAddItem( CBI_hwnd,
	                            "EntityType",
	                            1,
	                            FND_VALUE_END,
	                            "T",
	                            "TABLE",
	                            &FndGenErrorBlock);


	FndGenRC = FndValueAddItem( CBI_hwnd,
	                            "EntityType",
	                            1,
	                            FND_VALUE_END,
	                            "F",
	                            "FILE",
	                            &FndGenErrorBlock);


	FndGenRC = FndValueAddItem( CBI_hwnd,
	                            "EntityType",
	                            1,
	                            FND_VALUE_END,
	                            "C",
	                            "COPYBOOK",
	                            &FndGenErrorBlock);


	FndGenRC = FndValueAddItem( CBI_hwnd,
	                            "EntityType",
	                            1,
	                            FND_VALUE_END,
	                            "R",
	                            "RECORD",
	                            &FndGenErrorBlock);


	FndGenRC = FndValueAddItem( CBI_hwnd,
	                            "EntityType",
	                            1,
	                            FND_VALUE_END,
	                            "G",
	                            "GROUP",
	                            &FndGenErrorBlock);

	FndGenRC = FndFieldHide(CBI_hwnd,
	                        "CLength",
							&FndGenErrorBlock);

	FndGenRC = FndFieldHide(CBI_hwnd,
	                        "CobolLength",
							&FndGenErrorBlock);

	FndGenRC = FndFieldHide(CBI_hwnd,
	                        "Db2Length",
							&FndGenErrorBlock);


	return CMN_SUCCESS;

}/*end of  AZRP001BUSPredisplay */

