AEXPROC( ExitTlPopulateData )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following block of code will add one row to
  //  the Task List.  The code should be copied for
  //  each row that will appear in the Task List, then
  //  customized with the corresponding WindowTitle,
  //  WindowName, and Attributes.
  //
  //  Note: This exit is invoked during PREDISPLAY, and
  //        in some cases, there may not be enough
  //        information available to determine what the
  //        attributes of one or more rows should be.
  //        If this is the case, defer the call to
  //        FndLstBoxRowSetAttr until ExitCsrNotification.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //  USHORT            FndGenRC = FND_SUCCESS;
  //  _FND_ERROR_BLOCK  FndGenErrorBlock;
  //  _TaskListRow      TaskListData;
  //  USHORT            RowNumber = 0;
  //
  //-- --------------------------------------------------
  //
  //  /* Set Task List Row status to UNCHANGED */
  //  TaskListData._TaskListCdStatusIconicData = CMN_LBROW_STATUS_UNCHANGED;
  //
  //  /* Set Window Title of Task List child window */
  //  FndGenRC = CmnStrCopy( TaskListData._TaskListWnWindowTitleData,
  //                         "<WindowTitle>",
  //                         sizeof(TaskListData._TaskListWnWindowTitleData),
  //                         CMN_ARCH_PARMS );
  //
  //  /* Set Window Name of Task List child window */
  //  FndGenRC = CmnStrCopy( TaskListData._TaskListWktWindowNameData,
  //                         "<WindowName>",
  //                         sizeof(TaskListData._TaskListWktWindowNameData),
  //                         CMN_ARCH_PARMS );
  //
  //  /* Add Task List row to Task List */
  //  FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
  //                              CMN_LB_TLB_CONTROL_NAME,
  //                              RowNumber,
  //                              sizeof(_TaskListRow),
  //                              (VOID *) &TaskListData,
  //                              &FndGenErrorBlock );
  //
  //  /* Set attributes of new Task List row, and increment RowNumber */
  //  FndGenRC = FndLstBoxRowSetAttr( CBI_hwnd,
  //                                  CMN_LB_TLB_CONTROL_NAME,
  //                                  RowNumber++,
  //                                  < AT_REQUIRED or AT_OPTIONAL or
  //                                  AT_UNAVAILABLE >,
  //                                  &FndGenErrorBlock );
  //
  //---------------------------------------------------

    return CMN_SUCCESS;

} /* End ExitTlPopulateData function */



