**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/


AEXPROC( ExitCsrRequestFailed )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If the structure chart specifies that the window
  //  should be destroyed when the CSR Request fails,
  //  then include the following Overrides,
  //  otherwise remove it.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //  /* Set Logging Flag to Yes. */
  //  FndGenRC = CmnMsgBoxOverrides( CMN_LOGGGING_YES,
  //                                 CMN_ARCH_PARMS );
  //
  //  /* Display the problem to the user. */
  //  FndGenRC = CmnMsgBoxDisplay( EAB_CsrReturnCode,
  //                               NULL,
  //                               NULL,
  //                               CMN_ARCH_PARMS );
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If the structure chart specifies that the window
  //  should be destroyed when the CSR Request fails,
  //  then include the following WindowDestroy,
  //  otherwise remove it.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //  FndGenRC = FndWindowDestroy( CBI_hwnd,
  //                               &FndGenErrorBlock );
  //

    return CMN_SUCCESS;
}

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrProcessReply
**
**  DESCRIPTION      : This exit is called for a successful Top Window reply.
**                     The reply request id is checked to see if it is the
**                     LUW Process reply.  If so, a flag must be set and a
**                     message box must be destroyed.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitCsrProcessReply )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Modify the strcmp instruction to contain the name
  //  of the LUW request for the window.  If the window
  //  does not have an LUW, this exit should contain
  //  only the return statement.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  if( strcmp( EAB_CsrRequestId, "<CUffnnL>" ) == 0 )
  //  {
  //      CMN_PROCESS_REPLY_RECEIVED
  //  }
  //

  return CMN_SUCCESS;
}


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWdtSetDataLength
**
**  DESCRIPTION      : This exit is invoked when the OK button on this
**                     window is clicked.  The application must provide the
**                     length of the OUT layout for Window Data Tracking
**                     purposes.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitWdtSetDataLength )
{
    /* Set EAB_OutDataLength to the sizeof the OUT layout for this window */
    EAB_OutDataLength = sizeof( _AZRP003OUTPUT );

    return CMN_SUCCESS;
}


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWdtBuildLUW
**
**  DESCRIPTION      : This exit will be invoked ONCE FOR EACH descendent
**                     window in the dialog that added, changed, or deleted
**                     data during the life of the dialog.  The exit is
**                     invoked just after the user clicks on the Process
**                     Menu Item, and before the Process Menu Item callback
**                     is invoked.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitWdtBuildLUW )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  This shell code contains two types of examples:
  //  first, for single instance child windows, and
  //  second, for multiple instance child windows.
  //  Note that in the second case, the instance name
  //  should be referenced to determine which instance
  //  of the child window's data is being handled.  The
  //  specific processing in this case depends on the
  //  application.
  //
  //  As in previous examples, be sure to replace the
  //  template variable names (those enclosed with <...>
  //  with actual application-specific names.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //  /* Handle window CUffnnnX */
  //  if( strcmp( EAB_WdtWindowName, "<CUffnnnX>" ) == 0 )
  //  {
  //---------------------------------------------------
  //   Single Instance Window Example
  //
  //   REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //      /* Set up a pointer to the child window OUT layout <_CUffnnnO> */
  //      <_CUffnnnO> *p<CUffnnnO>;
  //
  //      /* Set the pointer to EAB_pWdtOutData */
  //      p<CUffnnnO> = EAB_pWdtOutData;
  //
  //      /* Format the global data area as necessary */
  //
  //      /* Format the LUW layout as necessary */
  //
  //  }
  //  else if( ... )
  //  {
  //---------------------------------------------------
  //   Multiple Instance Window Example
  //
  //   REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //      /* Set up a pointer to the child window OUT layout <_CUffnnnO> */
  //      <_CUffnnnO> *p<CUffnnnO>;
  //
  //       /* Set the pointer to EAB_pWdtOutData */
