/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         :
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(LookForServiceName)

{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
char ReposName[ITEM_NAME_LEN];
SHORT ix;
SHORT ServiceNum = 0;
BOOL ClientInC;
char TempName[ITEM_NAME_LEN];
SHORT ClientRow;
SHORT ClientElmnt;

 ServiceNum = pWindContextData->WCD.CurrentServiceIndex;

/***************************************************************/
/* Find out what language the client is using.                 */
/***************************************************************/

 FndGenRC = FndCommandQueryChecked( CBI_hwnd,
                                    "AMNCLTC",
                                    &FndGenErrorBlock);

 FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);

 ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


/***************************************************************/
/* Get the client name from the repository based on language. */
/***************************************************************/

 if (FndGenRC == FND_SUCCESS)
    {
     ClientInC = TRUE ;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
 else
    {
     ClientInC = FALSE;
     strcpy(ReposName,
           (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);
    }

/***************************************************************/
/* Loop thru the client repository rows and try to find a match*/
/***************************************************************/

 for (ix=0; ix < pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].NumReposServiceRows; ix++)
     {
      if (ClientInC)  /* Client name is in C */
         {
          strcpy(TempName,
             (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCName);

          if(strcmp(ReposName,
                    TempName) == 0)
            {
             return(ix);
            }
         }
      else
         {
          strcpy(TempName,
              (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCobolName);

          if(strcmp(ReposName,
              (pBFCD->pCSRMapBFCD->ServiceInfoTable[ServiceNum].pReposServiceLayoutTable + ix)->ItemCobolName) == 0)
            {
             return(ix);
            }
         }
     } /* end of for loop thru client repository rows */

return(CMN_FAIL);   /* Did not find a match so return fail */

}/* end of function  LookForServiceName */


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         :
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/


static SHORT LoadClientElmnt(SHORT ClientElmnt, CMN_ARCH_PARM_TYPES)
{
 SHORT ix;
 USHORT           FndGenRC = FND_SUCCESS;
 _FND_ERROR_BLOCK         FndGenErrorBlock;

 ix = 0;

 /*
 ** Make sure the ClientElmnt parameter is valid
 */

 if (ClientElmnt < 0 ||
     ClientElmnt > pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
    {
     return(CMN_FAIL);
    }

 /*
 ** Calculate what the offset should be
 */

 while ((ix + NUMRLB01ELBROWS - 1) < ClientElmnt)
     {
      ix += NUMRLB01ELBROWS;
     }

 /*
 ** If the client element is not in the current offset reload the listbox
 */
 if (pWindContextData->WCD.ClientLBOffset != ix)
    {

      /*
      ** Set the BFCD offset
      */

      pWindContextData->WCD.ClientLBOffset = ix;

      /*
      ** Fill the listbox
      */
      FndGenRC =  AZCS007BUSFillClientLB (pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );
    }

 /*
 ** Select the row
 */
 FndGenRC = FndLstBoxRowSelect(CBI_hwnd,
                               MAPGEN_CLIENT_LB_NAME,
                               ClientElmntToRow(ClientElmnt, CMN_ARCH_PARMS),
                               &FndGenErrorBlock);


 return(CMN_SUCCESS);

} /* end of function LoadClientElmnt */



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         :
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static SHORT LoadServiceElmnt(SHORT ServiceElmnt, CMN_ARCH_PARM_TYPES)
{

 SHORT ix;
 USHORT           FndGenRC = FND_SUCCESS;
 _FND_ERROR_BLOCK         FndGenErrorBlock;
 USHORT usIndex;
 ix = 0;


 usIndex = pWindContextData->WCD.CurrentServiceIndex;


 /*
 ** Make sure the ServiceElmnt parameter is valid
 */

 if (ServiceElmnt < 0 ||
     ServiceElmnt > pBFCD->pCSRMapBFCD->ServiceInfoTable[usIndex].NumReposServiceRows)
    {
     return(CMN_FAIL);
    }

 /*
 ** Calculate what the offset should be
 */

 while ((ix + NUMRLB02ELBROWS - 1) < ServiceElmnt)
     {
      ix += NUMRLB02ELBROWS;
     }


 /*
 ** If the row is not in the current listbox reload the listbox
 */

 if (pWindContextData->WCD.ServiceLBOffset != ix)
    {
     /*
     ** Set the BFCD offset
     */

     pWindContextData->WCD.ServiceLBOffset = ix;

     /*
     ** Fill the listbox
     */

     FndGenRC =  FillServiceLB (pEventInfo,
                                pEAIA,
                                pBFCD,
                                pWesMap,
                                pWindContextData,
                                pABHI );
    }

 /*
 ** Select the row
 */

 FndGenRC = FndLstBoxRowSelect(CBI_hwnd,
                               MAPGEN_SERVICE_LB_NAME,
                               ServiceElmntToRow(ServiceElmnt, CMN_ARCH_PARMS),
                               &FndGenErrorBlock);


 return(CMN_SUCCESS);

} /* end of function LoadServiceElmnt */



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         :
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static SHORT ClientElmntToRow(SHORT ClientElmnt, CMN_ARCH_PARM_TYPES)
{
 SHORT ix;

 ix = ClientElmnt % NUMRLB01ELBROWS;

 return(ix);

} /* end of function ClientElmntToRow */

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         :
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
