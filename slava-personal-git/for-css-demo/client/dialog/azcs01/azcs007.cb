strcpy(SrvcElementData, "");

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);


return(CMN_SUCCESS);


}


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* MoveService                                                       */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(MoveService)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    ix;
SHORT                    ServiceElmnt;



ix = pWindContextData->WCD.CurrentServiceIndex;
ServiceElmnt = CBI_ListRow + pWindContextData->WCD.ServiceLBOffset;

FndGenRC = FndFieldEnable(CBI_hwnd,
                             "SRVCELEMENT",
                             &FndGenErrorBlock);

if (pWindContextData->WCD.ServiceLanguage == C_LANGUAGE)
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCName);
    }
else
    {
     strcpy(SrvcElementData,
      (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable + ServiceElmnt)->ItemCobolName);

    }


return(CMN_SUCCESS);


}

/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* initclient                                                       */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(InitClient)
{

USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;


ClntTypeData = LT_ClntElementRB;

FndGenRBValueShort = LT_ClntElementRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

strcpy(ClntElementData, "");
FndGenRC = FndFieldEnable(CBI_hwnd,
                          "CLNTELEMENT",
                          &FndGenErrorBlock);


strcpy(ClntLiteralData, "");

FndGenRBValueShort = LT_ClntLiteralRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);


FndGenRBValueShort = LT_ClntHvRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRBValueShort = LT_ClntLVRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);


FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "RemovePB",
                                 &FndGenErrorBlock);

FndGenRC = FndCommandDisable(CBI_hwnd,
                                 "ApplyPB",
                                 &FndGenErrorBlock);

return(CMN_SUCCESS);

} /* initclient */


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* MoveClient                                                       */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(MoveClient)
{

USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;
SHORT                    ClientElmnt;


ClientElmnt = CBI_ListRow + pWindContextData->WCD.ClientLBOffset;

FndGenRBValueShort = LT_ClntElementRB;
FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

FndGenRC = FndFieldEnable(CBI_hwnd,
                             "CLNTELEMENT",
                             &FndGenErrorBlock);



if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
    {
     strcpy(ClntElementData,
      (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
else
    {
     strcpy(ClntElementData,
      (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);

    }


FndGenRC = FndFieldDisable(CBI_hwnd,
                             "CLNTLITERAL",
                             &FndGenErrorBlock);
strcpy(ClntLiteralData, "");

if (Rlb01ELBCdStatusIconicData[CBI_ListRow] == CMN_LBROW_STATUS_COMPLETED)
{
    FndGenRBValueShort = LT_ClntLiteralRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntHvRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntLVRB;
    FndGenRC = FndValueDisableItem( CBI_hwnd,
                                "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
}
else
{

    FndGenRBValueShort = LT_ClntLiteralRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntHvRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                            "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);

    FndGenRBValueShort = LT_ClntLVRB;
    FndGenRC = FndValueEnableItem( CBI_hwnd,
                                "CLNTTYPE",
                            (VOID *) &FndGenRBValueShort,
                            &FndGenErrorBlock);
}


return(CMN_SUCCESS);

}


