/***************************************************************************
**
**               CUSTOMER SERVICE SYSTEM Business Logic Function
**
**  FUNCTION         : AZCS007BUSAboutMNClick}
**
**  DESCRIPTION      : This function creates the About window for the applicaition.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : Michael D. Conner
**
**  DATE CREATED     : 03/11/96
**
**  REVISION HISTORY :
**
**  DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  -------------------------------------
**  03/15/96  mconner                   Copied from AZCS001BUSAboutMNClick
**
***************************************************************************/
static WCBPROC(AZCS007BUSAboutMNClick)
{
    SHORT FndGenRC = CMN_SUCCESS;
    SHORT nRC      = CMN_SUCCESS;
    CHAR WindowName[]   = "AZCS014";
    CHAR InstanceName[] = "";

    HEAP_CHECK

    FndGenRC = CmnWindowCreate( WindowName,
                                InstanceName,
                                NULL,
                                NULL,
                                CMN_ARCH_PARMS );

    HEAP_CHECK

    return CMN_SUCCESS;

} /* End of AZCS007BUSAboutMNClick */



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : UnLdAZCS7I
**
**  DESCRIPTION      : This function is called at predisplay of window 7. It
**                      sets all the defaults for the window.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
**    03/06/96 mconner                Replaced strcpy to WES fields with
**                                        FndFieldSetVlaue.
**
***************************************************************************/

static WCBPROC (UnLdAZCS7I)
{
     USHORT           FndGenRC = FND_SUCCESS;
     _FND_ERROR_BLOCK         FndGenErrorBlock;
     SHORT ix=0;
     SHORT iy=0;

  _AZCS004I *pAzcs004i;

  pAzcs004i = (_AZCS004I *)CBI_pInitData;

/*mdc - 03/06/96 - Changed for standards compliance
  strcpy(ClientLayoutData, pAzcs004i->ClientLayout);
*/
FndGenRC = FndFieldSetValue( CBI_hwnd,
                                 "CLIENTLAYOUT",
                                 (USHORT)strlen(pAzcs004i->ClientLayout),
                                 (void *)pAzcs004i->ClientLayout,
                                 &FndGenErrorBlock);


/*mdc - 03/06/96 - Changed for standards compliance
  strcpy(ServiceLayoutNameData,pAzcs004i->Services[0].ServerLayout);
*/
FndGenRC = FndFieldSetValue( CBI_hwnd,
                                 "ServiceLayoutName",
                                 (USHORT)strlen(pAzcs004i->Services[0].ServerLayout),
                                 (void *)pAzcs004i->Services[0].ServerLayout,
                                 &FndGenErrorBlock);



  pWindContextData->WCD.CurrentServiceIndex = 0;

  FndGenRC = FndValueInit( CBI_hwnd,
                         "ServiceLayoutName",
                         1,
                         31,
                         32,
                         &FndGenErrorBlock);

  if (FndGenRC != FND_SUCCESS)
      {
       return (CMN_FAIL);
      }

    for (ix = 0; ix < pAzcs004i->NumServices; ix++)
       {

        FndGenRC = FndValueAddItem (CBI_hwnd,
                                    "ServiceLayoutName",
                                     1,
                                     FND_VALUE_END,
                                     pAzcs004i->Services[ix].ServerLayout,
                                     pAzcs004i->Services[ix].ServerLayout,
                                     &FndGenErrorBlock);

        if (FndGenRC != FND_SUCCESS)
            {
             return (CMN_FAIL);
            }

       } /* end of while loop for filling Services combo box */

      /* SET THE DEFAULTS */
      /*   1. WINDOW LANGUAGES IN WCD */
      /*   2. Number of services      */
      /*   3. Previous Good List_Select row */

      pWindContextData->WCD.ClientLanguage = C_LANGUAGE;
      pWindContextData->WCD.ServiceLanguage = COBOL_LANGUAGE;

      pWindContextData->WCD.NumServices = pBFCD->pCSRMapBFCD->NumServices;
      pWindContextData->WCD.PrevClientRow = 0;
      pWindContextData->WCD.PrevServiceRow = 0;

  /*********************************************************************/
  /* Loop thru and copy all the service stuff down from BFCD into WCD  */
  /*********************************************************************/
      for (ix=0; ix < pWindContextData->WCD.NumServices; ix++)
          {
            memcpy(&(pWindContextData->WCD.ServiceInfoTable[ix]),
                   &(pBFCD->pCSRMapBFCD->ServiceInfoTable[ix]),
                   sizeof(_SERVICE_INFO) );
            pWindContextData->WCD.ServiceInfoTable[ix].pLoadData =
               (_RELATE_LD *) malloc(MAXSERVICEROWS * sizeof(_RELATE_LD) );

            memset(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData,
                   0,
                   MAXSERVICEROWS * sizeof(_RELATE_LD) );

          /* JLL:  07/06/93 CHANGED FROM MAXSERVICEROWS TO NumReposServiceRows */
           if (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData)
           {
             memcpy((pWindContextData->WCD.ServiceInfoTable[ix].pLoadData),
                  (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pLoadData),
                  (pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows
                   * sizeof(_RELATE_LD)) );
           }
           else
             {
              for(iy=0; iy < MAXSERVICEROWS; iy++)
                {
                 pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[iy].ClientLayoutIndex = -1;
                 pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[iy].LiteralUsed = 'N';

                 /* JLL: 06/30/93 ADDED */
                 strcpy( pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[iy].LiteralValue, "NULL" );
                }
             }
          } /* end of for loop */

  /*********************************************************************/
  /* Setup the Relationship stuff                                      */
  /*********************************************************************/

   /*mdc 03/12/96 - Do not want ApplyPB default here */
   /* Make the apply pushbutton the default */
   /*FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);
    */
  /*
  ** Make the List Box Offsets 0
  */
     pWindContextData->WCD.ClientLBOffset = 0;
     pWindContextData->WCD.ServiceLBOffset = 0;


/***************************************************************************************
   * Set the window to valid by calling CmnWindowSetDataModified
   * mdc - 03/04/96 - Added this because Architecture Validation field was added to
   *                  window.
   ***************************************************************************************/
   FndGenRC = CmnWindowSetDataModified ( CMN_ARCH_PARMS );

   if (FndGenRC != CMN_SUCCESS )
   {
	return(CMN_FAIL);
   }

/* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }




  return(CMN_SUCCESS);
}


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : AZCS007BUSMoveLB1
**
**  DESCRIPTION      : The function is invoked by the List_Select event for the
**                     Client List Box. It controls the flow of control depending
**                     on the status of the selected row.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (AZCS007BUSMoveLB1)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           RowNum;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT             CellAttr;
USHORT           CellData;
USHORT          *pCellData;

/*
** Find out which row was selected
*/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                       MAPGEN_CLIENT_LB_NAME,
                                       FND_LSTBOX_START,
                                       &RowNum,
                                       &FndGenErrorBlock);

/*
** Find out what the attributes of the selected row are
*/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                   MAPGEN_CLIENT_LB_NAME,
                                   RowNum,
                                   0,
                                   &CellAttr,
                                   &FndGenErrorBlock);

/*
** Move the selected rows data into the relationship section
**   if the attribute is normal otherwise return.
*/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevClientRow = RowNum;
     FndGenRC = CellAttrNormC(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }


    }

/*
** Find out what the value of the icon field is
*/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {
     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteClient(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);

   }

return(CMN_SUCCESS);



} /* end of AZCS007BUSMoveLB1() */

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : AZCS007BUSMoveLB2
**
**  DESCRIPTION      : This function is invoked by a List_Select event on the
**                     service listbox. It controls the logic flow depending
**                     on the status of the selected row.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (AZCS007BUSMoveLB2)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           RowNum;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT             CellAttr;
USHORT           CellData;
USHORT          *pCellData;

/***********************************/
/* Find out which row was selected */
/***********************************/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                       MAPGEN_SERVICE_LB_NAME,
                            FND_LSTBOX_START,
                            &RowNum,
                            &FndGenErrorBlock);

/***********************************************/
/* Find out what the attributes of the row are */
/***********************************************/

FndGenRC = FndLstBoxCellQueryAttr( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      &CellAttr,
                                      &FndGenErrorBlock);

/*******************************************************/
/* Move the selected row into the relationship section */
/*******************************************************/

if (CellAttr == AT_NORMAL)
    {
     pWindContextData->WCD.PrevServiceRow = RowNum;
     FndGenRC = CellAttrNormS(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI );

    }
else
    {
    FndGenRC = CellAttrNotNorm(pEventInfo,
                               pEAIA,
                               pBFCD,
                               pWesMap,
                               pWindContextData,
                               pABHI );

    if (FndGenRC != FND_SUCCESS)
       {
        return(CMN_FAIL);
       }


    }/*end of if cell attributes normal*/



/************************************************/
/* Find out what the value of the icon field is */
/************************************************/
pCellData = &CellData;
FndGenRC = FndLstBoxCellQueryData( CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      RowNum,
                                      0,
                                      sizeof(CellData),
                                      (void *)pCellData,
                                      &FndGenErrorBlock);

if (CellData == CMN_LBROW_STATUS_COMPLETED)  /* Checked */
   {

     FndGenRC = CellDataComplete(pEventInfo,
                                 pEAIA,
                                 pBFCD,
                                 pWesMap,
                                 pWindContextData,
                                 pABHI);
   }
else
   {
     FndGenRC = CellDataNotCompleteService(pEventInfo,
                                    pEAIA,
                                    pBFCD,
                                    pWesMap,
                                    pWindContextData,
                                    pABHI);
   }
return(CMN_SUCCESS);

}

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : AZCS007BUSNewService
**
**  DESCRIPTION      : This function is invoked by a field_change event on the
**                      service combo-box. It handles any processing that is
**                      necessary when a new service needs to be loaded into
**                      the service combo-box.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC (AZCS007BUSNewService)
{
  SHORT index=0;
  SHORT ServiceIndex=-1;
  USHORT  nRC=0;
  enum LANGUAGE_TYPE Language;
  /*
  ** Compare the BFCD Services versus the Service name in WES
  */

  ServiceIndex = -1;
  for(index=0; index < pBFCD->pCSRMapBFCD->NumServices; index++)
      {
       if
          (strcmp(pBFCD->pCSRMapBFCD->ServiceInfoTable[index].ServiceLayoutName,
                  ServiceLayoutNameData) == 0)
          {
           ServiceIndex = index;
           break;
          }

      }
  /*
  ** If a valid service match was found have the listbox upadate
  */
  if (ServiceIndex >= 0)
      {
      Language = COBOL_LANGUAGE;
      pWindContextData->WCD.CurrentServiceIndex = ServiceIndex;
      pWindContextData->WCD.ServiceLBOffset = 0;

      nRC = FillServiceLB(pEventInfo,
                          pEAIA,
                          pBFCD,
                          pWesMap,
                          pWindContextData,
                          pABHI);
     }

return(CMN_SUCCESS);

} /* end of AZCS007BUSNewService*/


