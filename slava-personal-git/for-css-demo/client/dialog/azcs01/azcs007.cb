/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/* AZCS007BUSChangeServiceType                                                 */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC(AZCS007BUSChangeServiceType)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    FndGenRBValueShort = 0;

SHORT ix=0;

for (ix=0; ix < NUMRLB01ELBROWS; ix++)
    {
     Rlb01ELBSelIndData[ix] = FALSE;
    }

/*mdc - 03/07/96 - Added to disable Apply if literal rb selected */
 

if ( ClntTypeData == LT_ClntLiteralRB )
{
	FndGenRC = FndCommandDisable( CBI_hwnd,
                                             "ApplyPB",
                                             &FndGenErrorBlock);

	FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);

  FndGenRC = FndFieldSetCursor( CBI_hwnd,
                             "CLNTLITERAL",
                             CUR_MAKECURRENT,
                             &FndGenErrorBlock);


}
else
{

	FndGenRC = FndCommandEnable(CBI_hwnd,
                            "ApplyPB",
                            &FndGenErrorBlock);

	 /* mdc - 03/04/96 - make the Apply pushbutton the default.*/
	FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "ApplyPB",
                                          &FndGenErrorBlock);


	FndGenRC = FndCommandDisable(CBI_hwnd,
                             "RemovePB",
                             &FndGenErrorBlock);

}
return(CMN_SUCCESS);
} /* END OF FUNCTION AZCS007BUSChangeServiceType */



/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  AZCS007BUSClntLng                                                          */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static WCBPROC (AZCS007BUSClntLng)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

FndGenRC = FndCommandQueryChecked (CBI_hwnd,
                                   "AMNCLTC",
                                   &FndGenErrorBlock);

if (FndGenRC == FND_SUCCESS)
    {
     pWindContextData->WCD.ClientLanguage = C_LANGUAGE;
    }
else if (FndGenRC == CMD_COMMAND_NOT_CHECKED)
    {
     pWindContextData->WCD.ClientLanguage = COBOL_LANGUAGE;
    }
else
    {
     return(CMN_FAIL);
    }

FndGenRC = AZCS007BUSFillClientLB(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
return(CMN_SUCCESS);
} /* end of function AZCS007BUSClntLng */


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  AZCS007BUSSrvLng                                                           */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/



static WCBPROC (AZCS007BUSSrvLng)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;

FndGenRC = FndCommandQueryChecked (CBI_hwnd,
                                   "AMNSRVC",
                                   &FndGenErrorBlock);

if (FndGenRC == FND_SUCCESS)
    {
     pWindContextData->WCD.ServiceLanguage = C_LANGUAGE;
    }
else if (FndGenRC == CMD_COMMAND_NOT_CHECKED)
    {
     pWindContextData->WCD.ServiceLanguage = COBOL_LANGUAGE;
    }
else
    {
     return(CMN_FAIL);
    }


FndGenRC = FillServiceLB(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

return(CMN_SUCCESS);

}/* end of function AZCS007BUSSrvLng */



/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  FillLayoutLB                                                     */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/


static SHORT FillLayoutLB(char * LBName,
                           _LAYOUT_REC *pLayout,
                          USHORT NumRecords,
                          enum LANGUAGE_TYPE Language,
                          CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
_Rlb01ELBRow NewRow;
USHORT index=0;
char padding[]="   ";
SHORT index2=0;
 _LAYOUT_REC *pTemp;
 /*mdc 03/22/96 Replaced by CONTROL_NAME_LEN defined in mapgen.h
char ControlName[34];
*/

/*
** Set the pointer to wait
*/

 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_WAIT,
                     &FndGenErrorBlock);

/* Clear out the ListBox */

FndLstBoxRowDeleteAll( CBI_hwnd, LBName, &FndGenErrorBlock);


for (index=0; index < NumRecords; index++)
    {
     pTemp = (_LAYOUT_REC *)(pLayout+index);

     NewRow._Rlb01ELBCdStatusIconicData = CMN_LBROW_STATUS_AVAILABLE;

     /* CSC: 09/20/93 MODIFIED*/
     // NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemLength;
     NewRow._Rlb01ELBNumBytesData = ((_LAYOUT_REC *)(pLayout+index))->ItemCLength;

     sprintf(NewRow._Rlb01ELBRecTypeData,"%c",toupper((pLayout+index)->ItemType));

     strcpy(NewRow._Rlb01ELBControlNameData,"");
     for (index2=0; index2 < (pLayout+index)->IndentLevel &&
                    (index2 * strlen(padding)) <
                             CONTROL_NAME_LEN; index2++)
         {
          strcat(NewRow._Rlb01ELBControlNameData, padding);
         }

     if (Language == C_LANGUAGE)
         strncat(NewRow._Rlb01ELBControlNameData,
                 (pLayout+index)->ItemCName,
                  CONTROL_NAME_LEN - strlen(NewRow._Rlb01ELBControlNameData) - 1);
     else
        strncat(NewRow._Rlb01ELBControlNameData,(pLayout+index)->ItemCobolName,
                        CONTROL_NAME_LEN - strlen(NewRow._Rlb01ELBControlNameData) - 1);


     if (toupper((pLayout+index)->Format) == 'A')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Alpha");
         }
     else
      if (toupper((pLayout+index)->Format) == 'N')
         {
          strcpy(NewRow._Rlb01ELBDataTypeData,"Numeric");
         }
    else
          strcpy(NewRow._Rlb01ELBDataTypeData,"");


     FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
                            LBName,
                            index,
                            sizeof(_Rlb01ELBRow),
                            &NewRow,
                            &FndGenErrorBlock);

     if ((pLayout+index)->ItemType != 'E')
        {
         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_GREYED,
                                         &FndGenErrorBlock);
        }
     else
         {

         FndGenRC = FndLstBoxRowSetAttr (CBI_hwnd,
                                         LBName,
                                         index,
                                         AT_NORMAL,
                                         &FndGenErrorBlock);
         }
    } /* end of for (index=0; index < NumRecords; index++) loop */

/*
** Reset the pointer to arrow
*/

 FndWindowSetPointer(CBI_hwnd,
                     FNDSYSPTR_ARROW,
                     &FndGenErrorBlock);


 return(CMN_SUCCESS);

}


/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*  AZCS007BUSFillClientLB                                                     */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/

static WCBPROC(AZCS007BUSFillClientLB)
{
USHORT           FndGenRC = FND_SUCCESS;
USHORT           usNumRows;
_FND_ERROR_BLOCK         FndGenErrorBlock;

usNumRows = pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows -
            pWindContextData->WCD.ClientLBOffset;

if (usNumRows > NUMRLB01ELBROWS)
   {
    usNumRows = NUMRLB01ELBROWS;
   }


FndGenRC = FillLayoutLB(MAPGEN_CLIENT_LB_NAME,
                        pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable +
                        pWindContextData->WCD.ClientLBOffset,
                        usNumRows,
                        pWindContextData->WCD.ClientLanguage,
                        CMN_ARCH_PARMS);

FndGenRC = FillStatusLD( pEventInfo,
                         pEAIA,
                         pBFCD,
                         pWesMap,
                         pWindContextData,
                         pABHI);

/*
** Reset the UP page button
*/

if (pWindContextData->WCD.ClientLBOffset > 0)
    {
     FndGenRC = FndLstBoxUpEnable(CBI_hwnd,
                                  MAPGEN_CLIENT_LB_NAME,
                                  &FndGenErrorBlock);
     }
else
     {
      FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                  MAPGEN_CLIENT_LB_NAME,
                                  &FndGenErrorBlock);
     }

/*
** Reset the DOWN page button
*/

if ((pWindContextData->WCD.ClientLBOffset + NUMRLB01ELBROWS) <
     pBFCD->pCSRMapBFCD->ClientInfo.NumReposClientRows)
    {
     FndGenRC = FndLstBoxDownEnable(CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    &FndGenErrorBlock);
    }
else
    {
     FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                     MAPGEN_CLIENT_LB_NAME,
                                     &FndGenErrorBlock);
    }

return(CMN_SUCCESS);
} /* end of function AZCS007BUSFillClientLB */




/*********************************************************************/
/*********************************************************************/
/*                                                                   */
/*    FillServiceLB                                                  */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/

static WCBPROC(FillServiceLB)
{
USHORT           FndGenRC = FND_SUCCESS;
SHORT ix;
USHORT           usNumRows;
_FND_ERROR_BLOCK         FndGenErrorBlock;

ix = pWindContextData->WCD.CurrentServiceIndex;

usNumRows = pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows -
            pWindContextData->WCD.ServiceLBOffset;

if (usNumRows > NUMRLB02ELBROWS)
   {
    usNumRows = NUMRLB02ELBROWS;
   }

FndGenRC = FillLayoutLB(MAPGEN_SERVICE_LB_NAME,
                        pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].pReposServiceLayoutTable +
                         pWindContextData->WCD.ServiceLBOffset,
                        usNumRows,
                        pWindContextData->WCD.ServiceLanguage,
                        CMN_ARCH_PARMS);

FndGenRC = FillStatusLD( pEventInfo,
                         pEAIA,
                         pBFCD,
                         pWesMap,
                         pWindContextData,
                         pABHI);
/*
** Reset the UP page button
*/

if (pWindContextData->WCD.ServiceLBOffset > 0)
    {
     FndGenRC = FndLstBoxUpEnable(CBI_hwnd,
                                  MAPGEN_SERVICE_LB_NAME,
                                  &FndGenErrorBlock);
     }
else
     {
      FndGenRC = FndLstBoxUpDisable(CBI_hwnd,
                                  MAPGEN_SERVICE_LB_NAME,
                                  &FndGenErrorBlock);
     }

/*
** Reset the DOWN page button
*/

if ((pWindContextData->WCD.ServiceLBOffset + NUMRLB02ELBROWS) <
     pBFCD->pCSRMapBFCD->ServiceInfoTable[ix].NumReposServiceRows)
    {
     FndGenRC = FndLstBoxDownEnable(CBI_hwnd,
                                    MAPGEN_SERVICE_LB_NAME,
                                    &FndGenErrorBlock);
    }
else
    {
     FndGenRC = FndLstBoxDownDisable(CBI_hwnd,
                                     MAPGEN_SERVICE_LB_NAME,
                                     &FndGenErrorBlock);
    }

return(CMN_SUCCESS);
} /* end of function FillServiceLB */




