/*   AZCS007BUSRemoveRelationship                                              */
/*                                                                   */
/*********************************************************************/
/*********************************************************************/

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : AZCS007BUSRemoveRelationship
**
**  DESCRIPTION      : This function remove a relationship between a client and
**                     service or a service and a literal.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/


static WCBPROC (AZCS007BUSRemoveRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT                    ServiceRow;
SHORT                    ServiceElmnt;
SHORT                    ClientRow;
SHORT                    ClientElmnt;
SHORT                      CellData;
SHORT                    ix;
SHORT                    iy;
BOOL                     MultipleService;

/*
** Assign the Service Index to a local varaible
*/
ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which service row is selected and calculate its index
*/
FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);
ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;

/*
** Set the status icon cell to unchanged for the service row
*/
CellData = CMN_LBROW_STATUS_UNCHANGED;
FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);


/*
** Is there a matching client row or is there a literal ?
*/

if (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed == 'N')
   {
    /*
    ** There is a matching client row so get the row number and calculate the
    **  index.
    */
    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

    /*
    ** See if this client has multiple service relationships. If it does you
    **  must leave the check mark in the status icon column. If it does not
    **  change the status icon column.
    */

    MultipleService = FALSE;
    /*
    ** Loop thru all of the service rows
    */
    for (iy=0; iy < pWindContextData->WCD.ServiceInfoTable[ix].NumReposServiceRows; iy++)
        {
         /*
         ** Check each service element to see it if matching client element is
         **  the current client. If they match and this service index is not the current
         **  service then the client has multiple service relationships.
         */
         if (pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[iy].ClientLayoutIndex == ClientElmnt &&
             iy != ServiceRow)
            {
             MultipleService = TRUE;
            }

        }
    /*
    ** If this client does not have multiple service relationships set the status icon
    **  cell back to unchanged.
    */
    if (!MultipleService)
       {
        FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);

       }

 /* De-Select the rows */
    Rlb01ELBSelIndData[ClientRow] = FALSE;
   }
/*
** The service has a relationship with a literal not an element.
*/
else
   {
   pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

   /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
   strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,"NULL");

   }

/*
** Clean up the service side
*/
Rlb02ELBSelIndData[ServiceRow] = FALSE;
pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex=-1;
pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);


/* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);



 return(CMN_SUCCESS);
} /* end of function AZCS007BUSRemoveRelationship */



/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : AZCS007BUSCreateRelationship
**
**  DESCRIPTION      : This function defines a relationship between a client and
**                      service element or between a service and a literal value.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**    01/28/94  C. Crampton           Added code for CheckDataTypes logic.
**
***************************************************************************/

static WCBPROC(AZCS007BUSCreateRelationship)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
USHORT           ServiceRow;
USHORT           ServiceElmnt;
USHORT           ClientRow;
USHORT           ClientElmnt;
SHORT                      CellData;
SHORT                    ix;

ix = pWindContextData->WCD.CurrentServiceIndex;

/**********************************************/
/*** Find out which service row is selected ***/
/**********************************************/

FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_SERVICE_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ServiceRow,
                                      &FndGenErrorBlock);
ServiceElmnt = ServiceRow + pWindContextData->WCD.ServiceLBOffset;
/*
** If the client side uses the element
*/

if (ClntTypeData == LT_ClntElementRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'N';

    /* JLL: 06/30/93 CHANGED FROM "" TO "NULL" */
    strcpy( pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,"NULL" );

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
                                      MAPGEN_CLIENT_LB_NAME,
                                      FND_LSTBOX_START,
                                      &ClientRow,
                                      &FndGenErrorBlock);
    ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;


    /*
    ** Make sure the data types match
    */
    FndGenRC = CheckDataTypes( ClientElmnt, ServiceElmnt, ix, CMN_ARCH_PARMS);

    if (FndGenRC != CMN_SUCCESS)
    {
        return(CMN_FAIL);
    }

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_CLIENT_LB_NAME,
                                 ClientRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = ClientElmnt;
    Rlb01ELBSelIndData[ClientRow] = FALSE;
    }

/*
** If the client side uses the literal
*/


else
 if (ClntTypeData == LT_ClntLiteralRB)
    {

    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              ClntLiteralData);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;

    }
else
 if (ClntTypeData == LT_ClntHvRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              CMN_HIGH_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;
    }
else
 if (ClntTypeData == LT_ClntLVRB)
    {
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralUsed = 'Y';
    strcpy(pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].LiteralValue,
              CMN_LOW_VALUES_STR);
    pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[ServiceElmnt].ClientLayoutIndex = -1;
    }


    /*
    ** Set the completed flag for this row
    */

    CellData = CMN_LBROW_STATUS_COMPLETED;
    FndGenRC = FndLstBoxCellSetData( CBI_hwnd,
                                 MAPGEN_SERVICE_LB_NAME,
                                 ServiceRow,
                                 0,
                                 sizeof(SHORT),
                                 &CellData,
                                 &FndGenErrorBlock);


    /* De-Select the service row */
    Rlb02ELBSelIndData[ServiceRow] = FALSE;

    InitService(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);
    InitClient(pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);

/* mdc - 03/04/96 - make the OK pushbutton the default.*/
  FndGenRC = FndCommandSetDefaultButton( CBI_hwnd,
                                          "OKPB",
                                          &FndGenErrorBlock);

  if ( FndGenRC != CMN_SUCCESS )
  {
       return ( CMN_FAIL );
  }



 return(CMN_SUCCESS);
} /* end of function AZCS007BUSCreateRelationship */


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : FindClientMatch
**
**  DESCRIPTION      : This function looks thru the service table to find a
**                      matching service relationship.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT - valid service index or CMN_FAIL.
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static SHORT FindClientMatch(CMN_ARCH_PARM_TYPES)
{
USHORT           FndGenRC = FND_SUCCESS;
_FND_ERROR_BLOCK         FndGenErrorBlock;
SHORT index;
SHORT ClientRow;
SHORT ClientElmnt;
SHORT ix;

/*
** Assign the current service to a local variable
*/
ix = pWindContextData->WCD.CurrentServiceIndex;

/*
** Find out which client row is selectd and calculate its index
*/

FndGenRC = FndLstBoxRowQuerySelection( CBI_hwnd,
                                    MAPGEN_CLIENT_LB_NAME,
                                    FND_LSTBOX_START,
                                    &ClientRow,
                                    &FndGenErrorBlock);
ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Loop thru all of the service rows and find the first service element with
**  the selected clients index
*/

for (index=0; index < MAXSERVICEROWS; index++)
    {
     if (ClientElmnt == pWindContextData->WCD.ServiceInfoTable[ix].pLoadData[index].ClientLayoutIndex)
         return(index);
    }
/*
** If not match was found return CMN_FAIL
*/
return(CMN_FAIL);
} /*  end of function FindClientMatch */


/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellAttrNormC
**
**  DESCRIPTION      : This function is called when a client row with the normal
**                      attributes has been selected.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : C. Crampton
**
**  DATE CREATED     : 09/26/93
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    09/26/93  C. Crampton           Original code.
**
***************************************************************************/

static WCBPROC(CellAttrNormC)
{
 USHORT           FndGenRC = FND_SUCCESS;
 SHORT ClientRow;
 SHORT ClientElmnt;

/*
** Get the client row and calculate the client index
*/
 ClientRow = CBI_ListRow;
 ClientElmnt = ClientRow + pWindContextData->WCD.ClientLBOffset;

/*
** Move the client name to WES depending on the selected language
*/
if (pWindContextData->WCD.ClientLanguage == C_LANGUAGE)
    {
     strcpy(ClntElementData,
     (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCName);
    }
else
    {
     strcpy(ClntElementData,
     (pBFCD->pCSRMapBFCD->ClientInfo.pReposClientLayoutTable + ClientElmnt)->ItemCobolName);

    }


 return(CMN_SUCCESS);
}

/***************************************************************************
**
**               CUSTOMER/1-Cooperative Business Logic Function
**
**  FUNCTION         : CellAttrNormS
**
**  DESCRIPTION      : This function is copies the necessary data to WES for a
**                      service that has normal attributes.
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
