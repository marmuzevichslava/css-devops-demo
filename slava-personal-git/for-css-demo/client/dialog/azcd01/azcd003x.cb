#define DLG_BOX
#define INCL_AGRWN01
#define INCL_C1CBASE
#define INCL_C1CCALLBACK

#include <C1C.H>     /*  CUSTOMER/1-Cooperative standard header file  */

#define _STANDARDHEADER void

typedef struct __ERR_MSG_TABLE
{
   _ERR_CODE_KEY CodeKey;
   _CMN_ERROR_DECODE ErrorDecode;
} _ERR_MSG_TABLE;

typedef struct __ERR_MSG_INIT_DATA
{
	_AWHINITIALDATA WinHndlTrkInfo;
			  short ErrMsgPassed;
			   char ErrMsgAction;
} _ERR_MSG_INIT_DATA;

void CmnRemNull(char *string, int strlngth);


/*  Begin Source Code Section ***********************************************
						 Window Level Event Callbacks                       *
*****************************************************************************/

static WCBPROC (WINPRDIS)
/****************************************************************************

		Control/Events which call this callback:

					 WINDOW - PREDISPLAY


	 Description: Enter description for WINPRDIS

*****************************************************************************/
{
	/*
		Local Variable Declarations
    */
    CMN_WDT_VARS

	_ERR_MSG_INIT_DATA *pErrMsgInitData;
	_ERR_CODE_KEY       StrtKey;
	_ERR_MSG_TABLE      ErrMsgTbl;
	_CODE_PARM_BLOCK    CodeParmBlock;
	short               rc=0, i=0;
	char                Msg[100], Value[3];
	BYTE                ByteValue;

	/*
		Initialize Window Context Data Architecture variables.
	*/
	memset(&(WCD_ArchData), 0, sizeof(_ARCHDATA));

	/*
		Initialize CmnErrBlock
	*/
	CMN_INIT_ERR_BLK

	CMN_FORMAT_ERR_BLK("WINPRDIS", "AZCD003X")

	/*
		Initialize the Architecture Window Handle Tracking Array.
	*/
    CMN_INIT_WIN_HWND_TRACK(CMN_NO)
    CMN_INIT_WIN_DATA_TRACK(CMN_NO)
	WCD_ArchData.WnMsgType = CMN_MSG_WIN_CLOSE_AFTER_CANCEL;

	/*
		Callback Logic
	*/

	pErrMsgInitData = (_ERR_MSG_INIT_DATA *) CBI_pInitData;

	if (pErrMsgInitData->ErrMsgAction == 'A')
	{
		sprintf(WindowTitle,
				"Add Error Message Number: %u",
				pErrMsgInitData->ErrMsgPassed);
	}
	else
	{
	   if (pErrMsgInitData->ErrMsgAction == 'U')
	   {
		  sprintf(WindowTitle,
				  "Update Error Message Number: %u",
				  pErrMsgInitData->ErrMsgPassed);
	   }
	   else
	   {
		  sprintf(WindowTitle,
				  "Delete Error Message Number: %u",
				  pErrMsgInitData->ErrMsgPassed);
	   }
	}

	/*
		  initialize window fields
	*/
	memset(TxErrorMsgTitleData,0,30);
	memset(TxErrorMsgData,0,123);
	memset(CdErrorSeverityData,0,3);
	strcpy(CdErrorSeverityData,"0 ");
	CdPushbuttonTypeData=(BYTE) 0;
	CdIconTypeData=(BYTE) 2;
	CdDefaultPushbuttonData =(BYTE) 0;

	/*
		  Retrieve error message data from the Error Codes Table
	*/

	StrtKey.ErrMsgNum = pErrMsgInitData->ErrMsgPassed;
	StrtKey.Lang='E';
	strncpy(StrtKey.SeqNum,"001",_SEQ_NUM_LEN);

	memset(&CodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));
	memset(&ErrMsgTbl,0,sizeof(_ERR_MSG_TABLE));

	memcpy(&CodeParmBlock.Code_Parm_Block_Version,
		   FND_CTS_VER,
		   _VER_LEN);

	memcpy(&CodeParmBlock.Code_Function_Code,
		   _CTIO_GET_UNIQUE,
		   _CTS_FUNCTION_LEN);

	memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_Id,
		   ERROR_CODE_TABLE,
		   _CTB_TABLE_LEN);

	memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_User_Key,
		   &StrtKey,
		   sizeof(_ERR_CODE_KEY));

	CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Requested=1;

/*
	  Retrieve the error message from the codes table
*/

	WFNDCODE(&CodeParmBlock, pABHI, &ErrMsgTbl);

/*
	  Check explanation code for a successful retrieval
*/
	 if (CodeParmBlock.Code_Explanation_Code == FND_SUCCESS)
	 {
		/*
			  if in add mode and error message found, display message
			  box indicating this and allow to update message.
		*/
		if (pErrMsgInitData->ErrMsgAction == 'A')
		{
		   pErrMsgInitData->ErrMsgAction = 'U';
		   sprintf(WindowTitle,
				  "Update Error Message Number: %u",
				  pErrMsgInitData->ErrMsgPassed);
		   rc=FpsDisplayChoiceBoxText(CBI_hwnd,
									  "The requested error message already"
									  " exists, you will be allowed to "
									  " update the existing error...",
									  "WARNING!",
									  FPS_OK|FPS_WARNING,
									  FPS_DEFBUTTON1);
		}
		/*
			  move data to the window fields
		*/
		memcpy (TxErrorMsgTitleData,ErrMsgTbl.ErrorDecode.TxErrorMsgTitle,29);
		memcpy (TxErrorMsgData,ErrMsgTbl.ErrorDecode.TxErrorMsg,122);
		memcpy (CdErrorSeverityData, ErrMsgTbl.ErrorDecode.CdErrorSeverity,2);
		CdPushbuttonTypeData = ErrMsgTbl.ErrorDecode.CdPushbuttonType;
		CdIconTypeData = ErrMsgTbl.ErrorDecode.CdIconType;
		CdDefaultPushbuttonData = ErrMsgTbl.ErrorDecode.CdDefaultPushbutton;
		/*
			  if in delete mode protect all fields
		*/
		if (pErrMsgInitData->ErrMsgAction == 'D')
		{
		   TxErrorMsgTitleRights= RGT_PROTECTED;
		   TxErrorMsgRights = RGT_PROTECTED;
		   strcpy(Value,LT_RBG_SEVERITY_OK);
		   rc=WesInvalidValue(CBI_hwnd,
							  CdErrorSeverity_FID,
							  Value);
		   strcpy(Value,LT_RBG_SEVERITY_WA);
		   rc=WesInvalidValue(CBI_hwnd,
							  CdErrorSeverity_FID,
							  Value);
		   strcpy(Value,LT_RBG_SEVERITY_CR);
		   rc=WesInvalidValue(CBI_hwnd,
							  CdErrorSeverity_FID,
							  Value);
		   strcpy(Value,LT_RBG_SEVERITY_FA);
		   rc=WesInvalidValue(CBI_hwnd,
							  CdErrorSeverity_FID,
							  Value);
		   rc=WesValidValue(CBI_hwnd,
							CdErrorSeverity_FID,
							CdErrorSeverityData);
		   for(i=0;i<9;i++)
		   {
			  ByteValue = (BYTE) i;
			  rc=WesInvalidValue(CBI_hwnd,
								 CdPushbuttonType_FID,
								 &ByteValue);
		   }
		   for(i=0;i<5;i++)
		   {
			  ByteValue = (BYTE) i;
			  rc=WesInvalidValue(CBI_hwnd,
								 CdIconType_FID,
								 &ByteValue);
		   }
		   for(i=0;i<3;i++)
		   {
			  ByteValue = (BYTE) i;
			  rc=WesInvalidValue(CBI_hwnd,
								 CdDefaultPushbutton_FID,
								 &ByteValue);
		   }
		   rc=WesValidValue(CBI_hwnd,
							CdPushbuttonType_FID,
							&CdPushbuttonTypeData);
		   rc=WesValidValue(CBI_hwnd,
							CdIconType_FID,
							&CdIconTypeData);
		   rc=WesValidValue(CBI_hwnd,
							CdDefaultPushbutton_FID,
							&CdDefaultPushbuttonData);
		}
	 }
	 else
	 {
		if ((CodeParmBlock.Code_Explanation_Code==CTS_KEY_NOT_FOUND)
			&&
		   (pErrMsgInitData->ErrMsgAction != 'A'))
		{
		   rc=FpsDisplayChoiceBoxText(CBI_hwnd,
			   "Requested message was not found, please refresh message list",
			   "SORRY!",
			   FPS_OK|FPS_WARNING,
			   FPS_DEFBUTTON1);
		   rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
		}
		else
		{
		   if (CodeParmBlock.Code_Explanation_Code !=CTS_KEY_NOT_FOUND)
		   {
			  sprintf(Msg,
				  "Unknown error from retrieval: %u",
				  CodeParmBlock.Code_Explanation_Code);
			  rc=FpsDisplayChoiceBoxText(CBI_hwnd,
									 Msg,
									 "ERROR!",
									 FPS_OK|FPS_WARNING,
									 FPS_DEFBUTTON1);
			  rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
		   }
		}
	 }

	for (i=0;i<3;i++)
	{
	   rc=WesValidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
	}

	switch(CdPushbuttonTypeData)
	{
		case LT_OK_PBTYPE:
		case LT_CANCEL_PBTYPE:
		case LT_ENTER_PBTYPE:
		   i = LT_DEF_PB2;
		   rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
		   i = LT_DEF_PB3;
		   rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
		   CdDefaultPushbuttonData = LT_DEF_PB1;
		   break;

		case LT_OKCANCEL_PBTYPE:
		case LT_RETRYCANCEL_PBTYPE:
		case LT_YESNO_PBTYPE:
		case LT_ENTERCANCEL_PBTYPE:
			i=LT_DEF_PB3;
			rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
			if (CdDefaultPushbuttonData > LT_DEF_PB2)
			{
			   CdDefaultPushbuttonData = LT_DEF_PB1;
			}
			break;
	}
	WCD_KyErrorMessage = pErrMsgInitData->ErrMsgPassed;
	WCD_CdProcMode = pErrMsgInitData->ErrMsgAction;


return (CMN_CALLBACK_RC);

}   /*  End WINPRDIS */


