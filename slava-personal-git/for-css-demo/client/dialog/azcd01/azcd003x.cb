static WCBPROC (WINPRDES)
/****************************************************************************
   
		Control/Events which call this callback:
   
					 WINDOW - PREDESTROY
   
   
	 Description: Enter description for WINPRDES
   
*****************************************************************************/
{
	/*
		Local Variable Declarations
	*/

	/*
		Initialize CmnErrBlock with WINPRDES
	*/ 
	CMN_UPDATE_CB_IN_ERR_BLK("WINPRDES")

	/*
		Cleanup the Window Handle Tracking List
	*/  
	CMN_FREE_WIN_HWND_TRACK(CMN_NO)


	/*
		Callback Logic
	*/ 


	/*
		Free memory allocated for this window's error block.
	*/
	free(pCmnErrBlock);
	return (CMN_CALLBACK_RC);

} /* End WINPRDES */



/*  Begin Source Code Section ***********************************************
					 Pushbutton and Menu Event Callbacks                    *
*****************************************************************************/

static WCBPROC (SPBPROCE)
/****************************************************************************
   
		Control/Events which call this callback:
   
					 PROCESS_CMD - CLICK
   
   
	 Description: Enter description for SPBPROCE
   
*****************************************************************************/
{
	/*
		Local Variable Declarations
	*/ 
	_CMN_ERROR_DECODE ErrDecode;
	_CODE_PARM_BLOCK  CodeParmBlock;
	_ERR_CODE_KEY     StrtKey;
	short rc=0;
	char Msg[100], MsgTitle[30];

	/* 
		Initialize CmnErrBlock with SPBPROCE
	*/ 
	CMN_UPDATE_CB_IN_ERR_BLK("SPBPROCE")


	/* 
		Callback Logic
	*/ 

	WCD_ArchData.WnMsgType =  CMN_MSG_WIN_CLOSE_AFTER_SAVE;

	StrtKey.ErrMsgNum = WCD_KyErrorMessage;
	StrtKey.Lang='E';
	strncpy(StrtKey.SeqNum,"001",_SEQ_NUM_LEN);

	memset(&CodeParmBlock,0,sizeof(_CODE_PARM_BLOCK));
	memset(&ErrDecode,0,sizeof(_CMN_ERROR_DECODE));

	memcpy(&CodeParmBlock.Code_Parm_Block_Version,
		   FND_CTS_VER,
		   _VER_LEN);

	if (WCD_CdProcMode == 'A')
	{
	   memcpy(&CodeParmBlock.Code_Function_Code,
			  _CTIO_WRITE,
			  _CTS_FUNCTION_LEN);
	}
	else
	{
	   if (WCD_CdProcMode == 'U')
	   {
		  memcpy(&CodeParmBlock.Code_Function_Code,
				 _CTIO_REWRITE,
				 _CTS_FUNCTION_LEN);
	   }
	   else
	   {
		  if (WCD_CdProcMode == 'D')
		  {
			 memcpy(&CodeParmBlock.Code_Function_Code,
				   _CTIO_DELETE,
				   _CTS_FUNCTION_LEN);
		  }
	   }
	}

	memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_Id,
		   ERROR_CODE_TABLE,
		   _CTB_TABLE_LEN);

	memcpy(&CodeParmBlock.Code_Detail_Parms.Code_Ctb_User_Key,
		   &StrtKey,
		   sizeof(_ERR_CODE_KEY));

	CodeParmBlock.Code_Detail_Parms.Code_Num_Rec_Requested=1;

	if (WCD_CdProcMode != 'D')
	{
	   memcpy(&ErrDecode.CdErrorSeverity,&CdErrorSeverityData,2);
	   CmnRemNull(ErrDecode.CdErrorSeverity,3);
	   memcpy(&ErrDecode.TxErrorMsg,&TxErrorMsgData,122);
	   CmnRemNull(ErrDecode.TxErrorMsg,123);
	   memcpy(&ErrDecode.TxErrorMsgTitle,&TxErrorMsgTitleData,29);
	   CmnRemNull(ErrDecode.TxErrorMsgTitle,30);
	   ErrDecode.CdPushbuttonType = CdPushbuttonTypeData;
	   ErrDecode.CdIconType = CdIconTypeData;
	   ErrDecode.CdDefaultPushbutton = CdDefaultPushbuttonData;
	   WFNDCODE(&CodeParmBlock, pABHI, &ErrDecode);
	   if (CodeParmBlock.Code_Explanation_Code == FND_SUCCESS)
	   {
		   if (WCD_CdProcMode == 'A')
		   {
			  sprintf(Msg,
				 "Error Message %u was successfully added "
				 "to the Error Codes Table",
				 WCD_KyErrorMessage);
			  strcpy(MsgTitle,"ADD SUCCESSFUL");
		   }
		   else
		   {
			  sprintf(Msg,
				 "Error Message %u was successfully updated "
				 "in the Error Codes Table",
				 WCD_KyErrorMessage);
			  strcpy(MsgTitle,"UPDATE SUCCESSFUL");
		   }
		   rc=FpsDisplayChoiceBoxText(CBI_hwnd,
									  Msg,
									  MsgTitle,
									  FPS_OK|FPS_INFORMATION,
									  FPS_DEFBUTTON1);
		   rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
	   }
	   else
	   {
		   if (WCD_CdProcMode == 'A')
		   {
			  sprintf(Msg,
				 "An error occurred while adding error message %u."
				 "  The return code error message was: %u."
				 "  Please refer to the FCP TRG for details.",
				 WCD_KyErrorMessage,
				 CodeParmBlock.Code_Explanation_Code);
			  strcpy(MsgTitle,"ADD UNSUCCESSFUL!!!");
		   }
		   else
		   {
			  sprintf(Msg,
				 "An error occurred while updating error message %u."
				 "  The return code error message was: %u."
				 "  Please refer to the FCP TRG for details.",
				 WCD_KyErrorMessage,
				 CodeParmBlock.Code_Explanation_Code);
			  strcpy(MsgTitle,"UPDATE UNSUCCESSFUL!!!");
		   }
		   rc=FpsDisplayChoiceBoxText(CBI_hwnd,
									  Msg,
									  MsgTitle,
									  FPS_OK|FPS_WARNING,
									  FPS_DEFBUTTON1);
	   }
	}
	else
	{
	   sprintf(Msg,
		  "Are you sure you want to DELETE error message %u?",
		  WCD_KyErrorMessage);
	   rc=FpsDisplayChoiceBoxText(CBI_hwnd,
			  Msg,
			  "DELETE?",
			  FPS_YESNOCANCEL|FPS_QUERY,
			  FPS_DEFBUTTON2);
	   if (rc==FPSID_YES)
	   {
		  WFNDCODE(&CodeParmBlock, pABHI, NULL);
		  if (CodeParmBlock.Code_Explanation_Code == FND_SUCCESS)
		  {
			  sprintf(Msg,
				 "Error Message %u was successfully deleted "
				 "from the Error Codes Table",
				 WCD_KyErrorMessage);
			  strcpy(MsgTitle,"DELETE SUCCESSFUL");
			  rc=FpsDisplayChoiceBoxText(CBI_hwnd,
										 Msg,
										 MsgTitle,
										 FPS_OK|FPS_INFORMATION,
										 FPS_DEFBUTTON1);
			  rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);
		  }
		  else
		  {
			  sprintf(Msg,
				 "An error occurred while deleting error message %u."
				 "  The return code error message was: %u."
				 "   Please refer to the FCP TRG for details.",
				 WCD_KyErrorMessage,
				 CodeParmBlock.Code_Explanation_Code);
			  strcpy(MsgTitle,"DELETE UNSUCCESSFUL!!!");
			  rc=FpsDisplayChoiceBoxText(CBI_hwnd,
										 Msg,
										 MsgTitle,
										 FPS_OK|FPS_WARNING,
										 FPS_DEFBUTTON1);
		  }
	   }
	}


	return (CMN_CALLBACK_RC);

} /* End SPBPROCE */


static WCBPROC (APBCANCL)
/****************************************************************************
   
		Control/Events which call this callback:
   
					 CancelPB_CMD - CLICK
   
   
	 Description: Enter description for APBCANCL
   
*****************************************************************************/
{
	/*
		Local Variable Declarations
	*/ 
	short rc=0;
	char Msg[100],MsgTitle[30];

	/* 
		Initialize CmnErrBlock with APBCANCL
	*/ 
	CMN_UPDATE_CB_IN_ERR_BLK("APBCANCL")


	/*
		Callback Logic
	*/ 
	WCD_ArchData.WnMsgType = CMN_MSG_WIN_CLOSE_AFTER_CANCEL;
	if (WCD_CdProcMode == 'A')
	{
	   sprintf(Msg,
			"Are you sure you wish to CANCEL adding error message %u?",
			WCD_KyErrorMessage);
	   strcpy(MsgTitle,"CANCEL ADD?");
	}
	else
	{
		if (WCD_CdProcMode == 'U')
		{
			sprintf(Msg,
				"Are you sure you wish to CANCEL updating error message %u?",
				WCD_KyErrorMessage);
			strcpy(MsgTitle,"CANCEL UPDATE?");
		}
		else
		{
			sprintf(Msg,
				"Are you sure you wish to CANCEL deleting error message %u?",
				WCD_KyErrorMessage);
			strcpy(MsgTitle,"CANCEL DELETE?");
		}
	}
	rc=FpsDisplayChoiceBoxText(CBI_hwnd,
							   Msg,
							   MsgTitle,
							   FPS_YESNO|FPS_QUERY,
							   FPS_DEFBUTTON2);
	if (rc==FPSID_YES)
	   rc=CmnCloseWindow(CMN_WIN_KEY_SELF,pCmnErrBlock);

	return (CMN_CALLBACK_RC);

} /* End APBCANCL */


static WCBPROC (SPBVIEW)
/****************************************************************************
   
		Control/Events which call this callback:
   
					 VIEW_CMD - CLICK
   
   
	 Description: Enter description for SPBVIEW
   
*****************************************************************************/
{
	/*
		Local Variable Declarations
	*/ 
	short rc=0, PBtype=0, IconType=0, ChoiceTypes=0, DefPB=0;


	/* 
		Initialize CmnErrBlock with SPBVIEW
	*/ 
	CMN_UPDATE_CB_IN_ERR_BLK("SPBVIEW")


	/* 
		Callback Logic
	*/
	switch (CdPushbuttonTypeData)
	{
		case LT_OK_PBTYPE:
		   PBtype = FPS_OK;
		   break;

		case LT_OKCANCEL_PBTYPE:
		   PBtype = FPS_OKCANCEL;
		   break;

		case LT_RETRYCANCEL_PBTYPE:
		   PBtype = FPS_RETRYCANCEL;
		   break;

		case LT_ABORTRETRYIGNORE_PBTYPE:
		   PBtype = FPS_ABORTRETRYIGNORE;
		   break;

		case LT_YESNO_PBTYPE:
		   PBtype = FPS_YESNO;
		   break;

		case LT_YESNOCANCEL_PBTYPE:
		   PBtype = FPS_YESNOCANCEL;
		   break;

		case LT_CANCEL_PBTYPE:
		   PBtype = FPS_CANCEL;
		   break;

		case LT_ENTER_PBTYPE:
		   PBtype = FPS_ENTER;
		   break;

		case LT_ENTERCANCEL_PBTYPE:
		   PBtype = FPS_ENTERCANCEL;
		   break;

	}

	switch (CdIconTypeData)
	{
		case LT_QUERY_ICTYPE:
		   IconType = FPS_QUERY;
		   break;

		case LT_WARNING_ICTYPE:
		   IconType = FPS_WARNING;
		   break;

		case LT_INFO_ICTYPE:
		   IconType = FPS_INFORMATION;
		   break;

		case LT_CRITICAL_ICTYPE:
		   IconType = FPS_CRITICAL;
		   break;

		case LT_ERROR_ICTYPE:
		   IconType = FPS_ERROR;
		   break;
	}

	switch (CdDefaultPushbuttonData)
	{
		case LT_DEF_PB1:
		   DefPB = FPS_DEFBUTTON1;
		   break;

		case LT_DEF_PB2:
		   DefPB = FPS_DEFBUTTON2;
		   break;

		case LT_DEF_PB3:
		   DefPB = FPS_DEFBUTTON3;
		   break;
	}

	ChoiceTypes = PBtype | IconType;
	rc=FpsDisplayChoiceBoxText(CBI_hwnd,
							   TxErrorMsgData,
							   TxErrorMsgTitleData,
							   ChoiceTypes,
							   DefPB);


	return (CMN_CALLBACK_RC);

} /* End SPBVIEW */



/*  Begin Source Code Section ***********************************************
						  List Box Event Callbacks                          *
*****************************************************************************/


/*  Begin Source Code Section ***********************************************
		Field Event Callbacks - includes Radio Buttons and Check Boxes      *
*****************************************************************************/

static WCBPROC (E00003FC)
/****************************************************************************
   
		Control/Events which call this callback:
   
					 CdPushbuttonType_FID - FIELD_CHANGE
   
   
	 Description: Enter description for E00003FC
   
*****************************************************************************/
{
	/*
		Local Variable Declarations
	*/ 
	short rc=0, i=0;

	/*
		Initialize CmnErrBlock with E00003FC
	*/ 
	CMN_UPDATE_CB_IN_ERR_BLK("E00003FC")


	/* 
		Callback Logic
	*/ 
	for (i=0;i<3;i++)
	{
	   rc=WesValidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
	}

	switch(CdPushbuttonTypeData)
	{
		case LT_OK_PBTYPE:
		case LT_CANCEL_PBTYPE:
		case LT_ENTER_PBTYPE:
		   i = LT_DEF_PB2;
		   rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
		   i = LT_DEF_PB3;
		   rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
		   CdDefaultPushbuttonData = LT_DEF_PB1;
		   break;

		case LT_OKCANCEL_PBTYPE:
		case LT_RETRYCANCEL_PBTYPE:
		case LT_YESNO_PBTYPE:
		case LT_ENTERCANCEL_PBTYPE:
			i=LT_DEF_PB3;
			rc=WesInvalidValue(CBI_hwnd, CdDefaultPushbutton_FID, (BYTE *) &i);
			if (CdDefaultPushbuttonData > LT_DEF_PB2)
			{
			   CdDefaultPushbuttonData = LT_DEF_PB1;
			}
			break;
	}

	return (CMN_CALLBACK_RC);

} /* End E00003FC */



/*  Begin Source Code Section ***********************************************
						  Module Common Functions                           *
*****************************************************************************/

void CmnRemNull(char *string, int strlngth)
{
   int i;

   for (i=0; ((i<strlngth) && (string[i]!='\0')); i++);

   for (;i<strlngth; i++)
	string[i]=' ';
   return;
}





