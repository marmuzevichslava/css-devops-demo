**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO013xSecLbSelect )
{

    USHORT FndGenRC = 0;
    USHORT LRowNumber = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
					  REPOSDAT,
					  FND_LSTBOX_START,
					  &LRowNumber,
					  &FndGenErrorBlock);

    FndGenRC = FndLstBoxRowDeselect(CBI_hwnd,
					                REPOSDAT,
					                LRowNumber,
					                &FndGenErrorBlock);

    FndGenRC = FndCommandDisable(CBI_hwnd,
	                            "AddPB",
								&FndGenErrorBlock);

    FndGenRC = FndCommandEnable(CBI_hwnd,
	                            "DeletePB",
								&FndGenErrorBlock);



    return FndGenRC;
}






/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO013xAddPbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO013xAddPbClk )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT RRowNumber = 0;
    USHORT LRowNumber = 0;
    char OrdFlg[4] = NULL_STR;
    USHORT j = 0;
    USHORT test_var = 0;

    _Dz00751Row RowData;
    _ReposDataLBRow EntrData;

    FndGenRC = FndCommandEnable(CBI_hwnd,
	                            "OKPB",
								&FndGenErrorBlock);


    memset(RowData._Dz00751Dz00799Data,' ',
			      sizeof(RowData._Dz00751Dz00799Data) );

    memset(RowData._Dz00751KeyTypData,' ',
			      sizeof(RowData._Dz00751KeyTypData) );




    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
					  REPOSDAT,
					  FND_LSTBOX_START,
					  &LRowNumber,
					  &FndGenErrorBlock);

    // Query of the row to be added from the right list box

    FndGenRC = FndLstBoxRowQueryData (CBI_hwnd,
				      REPOSDAT,
				      LRowNumber,
				      sizeof(_ReposDataLBRow),
				      (void *) &(EntrData),
				      &FndGenErrorBlock);




    RowData._Dz00751NmRowIndxData++;

//  Make certain that the key in question has not been added already

    test_var = 0;

    for (j = 0; j < SelectElementsCount; j++)
    {
	 FndGenRC = FndLstBoxRowQueryData (CBI_hwnd,
				      DZ00751,
				      j,
				      sizeof(_Dz00751Row),
				      (void *) &(RowData),
				      &FndGenErrorBlock);

	 if (strcmp(RowData._Dz00751Dz00799Data ,
		    EntrData._ReposDataLBDz00707Data ) == 0)
	 {
	     test_var++;
	 }

    }

    if (test_var == 0)
    {

	strncpy(RowData._Dz00751Dz00799Data, EntrData._ReposDataLBDz00707Data ,
			  sizeof(RowData._Dz00751Dz00799Data) );

	strncpy(RowData._Dz00751KeyTypData, OrdFlg,
			  sizeof(RowData._Dz00751KeyTypData) );

	FndGenRC = FndLstBoxRowAdd(CBI_hwnd,
				DZ00751,
				RRowNumber,
				sizeof(RowData),
				&RowData,
				&FndGenErrorBlock);

    SelectElementsCount = SelectElementsCount + 1;

    }
    else
    {
	FndGenRC = FndMsgBoxDisplayMdlssText(TITLE1,
					     BOX_TITLE,
					     CBI_hwnd,
					     FND_MSGBOX_OK,
					     FND_MSGBOX_WARNING,
					     FND_MSGBOX_IDOK,
					     BOX_TITLE,
					     &FndGenErrorBlock);


    }

    return FndGenRC;
}






/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO013xDelPbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO013xDelPbClk )
{

    _FND_ERROR_BLOCK FndGenErrorBlock;
    USHORT FndGenRC = 0;
    USHORT LRowNumber = 0;
    char OrdFlg[4] = NULL_STR;

    FndGenRC = FndCommandEnable(CBI_hwnd,
	                            "OKPB",
								&FndGenErrorBlock);

  //  Place Application Business Logic here

    FndGenRC = FndLstBoxRowQuerySelection(CBI_hwnd,
					  DZ00751,
					  FND_LSTBOX_START,
					  &LRowNumber,
					  &FndGenErrorBlock);

    FndGenRC = FndLstBoxRowDelete(CBI_hwnd,
				  DZ00751,
				  LRowNumber,
				  &FndGenErrorBlock);

    SelectElementsCount = SelectElementsCount - 1;


    if (SelectElementsCount == 0)
    {
        FndGenRC = FndCommandDisable(CBI_hwnd,
	                            "DeletePB",
								&FndGenErrorBlock);

    }


    return CMN_SUCCESS;
}






/***************************************************************************
**
**               Customer Service System Business Logic Function
**
**  FUNCTION	     : DZIO013xOkPbClk
**
**  DESCRIPTION      :
**
**  INPUTS           : WCBPROC - Six standard FOUNDATION callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting - Solutionworks
**
**  DATE CREATED     :
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 07/13/95    IPEREZAR		  Creation
**
***************************************************************************/

WCBPROC(DZIO013xOkPbClk )
{

    USHORT FndGenRC = 0;
    USHORT RowNumber = 0;

    _Dz00751Row RowData;
    _FND_ERROR_BLOCK FndGenErrorBlock;

   if (strcmp(pBFCD->DZIO01Hdr.SrcTyp,SECTABB) == 0)
   {
        memset(&(pBFCD->DZIO013Luw.DZIO013ASelect), 0, 
		                       sizeof(pBFCD->DZIO013Luw.DZIO013ASelect) );

		for (RowNumber = 0; RowNumber < SelectElementsCount; RowNumber++)
		{
		     memset(&(RowData), 0, sizeof(RowData) );

			 FndGenRC = FndLstBoxRowQueryData (CBI_hwnd,
				      DZ00751,
				      RowNumber,
				      sizeof(_Dz00751Row),
				      (void *) &(RowData),
				      &FndGenErrorBlock);

			 memcpy ( pBFCD->DZIO013Luw.DZIO013ASelect[RowNumber].ElmId,
						  RowData._Dz00751Dz00799Data,
						  sizeof(pBFCD->DZIO013Luw.DZIO013ASelect[RowNumber].ElmId) );

			 CmnStrCopy ( pBFCD->DZIO013Luw.DZIO013ASelect[RowNumber].ElmTblNm,
						  pBFCD->DZIO012Luw.SecTabBNm,
						  sizeof(pBFCD->DZIO013Luw.DZIO013ASelect[RowNumber].ElmTblNm),
						  CMN_ARCH_PARMS);

		}
   }
   else if (strcmp(pBFCD->DZIO01Hdr.SrcTyp,SECTABC) == 0)
   {
        memset(&(pBFCD->DZIO013Luw.DZIO013BSelect), 0, 
		                       sizeof(pBFCD->DZIO013Luw.DZIO013BSelect) );

		for (RowNumber = 0; RowNumber < SelectElementsCount; RowNumber++)
		{
		     memset(&(RowData), 0, sizeof(RowData) );

			 FndGenRC = FndLstBoxRowQueryData (CBI_hwnd,
				      DZ00751,
				      RowNumber,
				      sizeof(_Dz00751Row),
				      (void *) &(RowData),
				      &FndGenErrorBlock);

			 memcpy ( pBFCD->DZIO013Luw.DZIO013BSelect[RowNumber].ElmId,
						  RowData._Dz00751Dz00799Data,
						  sizeof(pBFCD->DZIO013Luw.DZIO013BSelect[RowNumber].ElmId) );

			 CmnStrCopy ( pBFCD->DZIO013Luw.DZIO013BSelect[RowNumber].ElmTblNm,
						  pBFCD->DZIO012Luw.SecTabCNm,
						  sizeof(pBFCD->DZIO013Luw.DZIO013BSelect[RowNumber].ElmTblNm),
						  CMN_ARCH_PARMS);

		}
   }


    return FndGenRC;
}
