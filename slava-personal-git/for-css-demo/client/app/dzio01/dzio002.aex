AEXPROC( ExitElb1BuildDelData )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit function to build and assign the data to use for
  //    window data tracking for unchanged rows being flagged for deletion.
  //
  //  The following macro names are valid during this exit:
  //    EAB_CurrElbWidgetName
  //    EAB_CurrElbRowNumber
  //
  //  Perform the following steps to build and assign the delete data.
  //
  //    1.  Declare an instance of the child's output data layout.
  //
  //    2.  Move the data to the instance of the output data layout.
  //
  //    3.  Call the function CmnElbAssignDeleteData passing a void
  //        pointer to the data and the length of the data layout.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //  Declare an instance of the child's output data layout.
  //
  //    <CUFFnnnOUTPUT>  CUFFnnnOutput;
  //
  //    .
  //    .  Move the needed data to the instance of the output layout
  //    .
  //
  //  Call the function CmnElbAssignDeleteData.
  //
  //    CmnElbAssignDeleteData (&CUFFnnnOutput,
  //                            sizeof (<_CUFFnnnOUTPUT>),
  //                            CMN_ARCH_PARMS);
  //


    return CMN_SUCCESS;

} /* End of ExitElb1BuildDelData */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1PbOverride
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit allows the application to override the
**                     architecture's normal enablement of ELB pushbuttons.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1PbOverride )
{

  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  This exit is associated with the enterable list box registered as
  //      sequence number 1.
  //
  //  The following macro names are valid during this exit:
  //
  //    EAB_CurrElbWidgetName
  //        This is the widget name of the enterable list box that was
  //        registered as sequence number 1.
  //
  //    EAB_CurrElbRowNumber
  //        This is the row number of the selected row (relative to 0) in
  //        the enterable list box registered as sequence number 1.
  //        PLEASE NOTE:
  //            If a row is not currently selected in the enterable list
  //            box, the value of this macro will be CMN_ELB_ROW_NOT_FOUND.
  //
  //    EAB_ElbChildWinFunction
  //        This indicates the pushbutton clicked.  All enterable list box
  //        pushbutton clicks cause this exit to occur. The possible values
  //        of this macro are:
  //            CMN_ELB_PBTYPE_NONE (some other event caused exit)
  //            CMN_ELB_PBTYPE_ADD
  //            CMN_ELB_PBTYPE_ADD_USING
  //            CMN_ELB_PBTYPE_CHANGE (for row double-click as well)
  //            CMN_ELB_PBTYPE_DELETE
  //            CMN_ELB_PBTYPE_UNDELETE
  //            CMN_ELB_PBTYPE_UP
  //            CMN_ELB_PBTYPE_DOWN
  //
  //
  //  IMPORTANT NOTES:
  //
  //    This exit is called several times during the course of selecting
  //        rows and clicking pushbuttons associated with an enterable
  //        list box.  Therefore, it is best to only override pushbuttons
  //        based upon the data or status of a selected row.
  //
  //    To override a pushbutton based upon the data or status of a
  //        selected row, perform the following:
  //
  //        1)  Declare an instance of a row data structure.
  //
  //        2)  If a row is selected (EAB_CurrElbRowNumber is not
  //            equal to CMN_ELB_ROW_NOT_FOUND), query the row data,
  //            placing the retrieved data into the declared row data
  //            structure.
  //
  //        3)  Based upon the data or status of the row, override the
  //            enabled pushbuttons as needed by calling the function:
  //            CmnElbOverrideEnabledPb passing the pushbuttons to be
  //            overriden to a disabled status.
  //
  //            The first parameter of CmnElbOverrideEnabledPb can be
  //            any combination of the following constants 'OR'd together:
  //
  //            CMN_ELB_ADD_PB
  //            CMN_ELB_ADD_USING_PB
  //            CMN_ELB_CHANGE_PB
  //            CMN_ELB_DELETE_PB
  //            CMN_ELB_UNDELETE_PB
  //            CMN_ELB_ROW_UP_PB
  //            CMN_ELB_ROW_DOWN_PB
  //
  //            For example, to disable the Add and Add Using pushbuttons,
  //            the function call would be:
  //                CmnElbOverrideEnabledPb
  //                        (CMN_ELB_ADD_PB | CMN_ELB_ADD_USING_PB,
  //                         CMN_ARCH_PARMS);
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //
  //  Declare an instance of the ELB row typedef
  //
  //    <WESmap ELB ROW TYPEDEF>     ElbRowData;
  //
  //  Declare variables for FOUNDATION API calls
  //
  //    USHORT              FndGenRC=0;
  //    _FND_ERROR_BLOCK    FndErrorBlock;
  //
  //    .
  //    .  Declare additional variables as needed.
  //    .
  //
  //
  //  If a row is selected in the enterable list box
  //
  //    if (EAB_CurrElbRowNumber != CMN_ELB_ROW_NOT_FOUND)
  //    {
  //
  //        Query the data in the selected enterable list box row
  //
  //        FndGenRC = FndLstBoxRowQueryData
  //                                (CBI_hwnd,
  //                                 EAB_CurrElbWidgetName,
  //                                 EAB_CurrElbRowNumber,
  //                                 sizeof (<WESmap ELB ROW TYPEDEF>),
  //                                 (void *) &ElbRowData,
  //                                 &FndErrorBlock);
  //
  //        Test the data in the row to determine what pushbuttons
  //            to disable.
  //
  //        if (ElbRowData._<ELB NAME>CdStatusIconicData == .....)
  //        {
  //            Override the necessary pushbuttons
  //
  //            CmnElbOverrideEnabledPb ( <ELB pb 1> | <ELB pb 2> | ...,
  //                                      CMN_ARCH_PARMS);
  //        }
  //
  //        if (ElbRowData._<ELB NAME><Data Element name> .....)
  //        {
  //            Override the necessary pushbuttons
  //
  //            CmnElbOverrideEnabledPb ( <ELB pb 1> | <ELB pb 2> | ...,
  //                                      CMN_ARCH_PARMS);
  //        }
  //    }

    return CMN_SUCCESS;

} /* End of ExitElb1PbOverride */


AEXPROC( ExitElb2CloseAfterSave )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  This exit is associated with the enterable list box registered
  //    as sequence number 2.
  //
  //  Instructions for this exit are identical to the sequence number 1
  //    exit function.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
