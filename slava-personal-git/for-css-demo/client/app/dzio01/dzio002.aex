/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrNotification
**
**  DESCRIPTION      : This exit is invoked when the CSR request and reply
**                     exchange is completed successfully.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting
**
**  DATE CREATED     : 08/29/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 08/29/95    IPEREZAR 	   Creation
**
***************************************************************************/

AEXPROC( ExitCsrNotification )
{
    USHORT	     FndGenRC = 0;
    SHORT	     RowNumber = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _ImpObjNmLBRow   RowData;
    _RQST	     *pClientData;

    FndGenRC = DZIO01MsgBoxDestroy(BOX_TITLE,
				   CMN_ARCH_PARMS);


    if ( strcmp( EAB_CsrRequestId, CSRRQST ) == 0 )
    {

	 pClientData = &( pWindContextData->Rqst );

	 if (EAB_CdMsgioStatus == 0)
	 {
	     if (pClientData->Dzsr002xKeys.QyALRAclCnt == 0)
	     {


    		DZIO01MsgBoxDisplay(TITLE4,
									BOX_TITLE,
									CBI_hwnd,
									FND_MSGBOX_OK,
									FND_MSGBOX_INFORMATION,
									FND_MSGBOX_IDOK,
									BOX_TITLE,
									CMN_ARCH_PARMS);




            FndWindowDestroy( CBI_hwnd,
                        &FndGenErrorBlock );


	     }
	     else
	     {
         
         FndWindowShow( CBI_hwnd,
                        &FndGenErrorBlock );

	     while (RowNumber < (pClientData -> Dzsr002xKeys.QyALRAclCnt) )
	     {
		   CmnStrCopy( RowData._ImpObjNmLBTxObjectDescData ,
			       pClientData->Dzsr002xLbData[RowNumber].TxObjectDesc,
			       sizeof(RowData._ImpObjNmLBTxObjectDescData ),
			       CMN_ARCH_PARMS );

		   FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
					       IMPOBJ,
					       RowNumber,
					       sizeof(_ImpObjNmLBRow),
					       (VOID *) &(RowData),
					       &FndGenErrorBlock );

		   RowNumber++;

	     } /* End While */
	     }

	 } /* EAB_CdMsgioStatus = 0 */
	 else
	 {
	     CmnMsgBoxOverrides ( CMN_LOGGING_YES,
				  CMN_ARCH_PARMS);

	     CmnMsgBoxDisplay (EAB_CdServErrMsg,
			       CMN_NULL_RETURN_BUTTON,
			       CMN_NULL_MSGBOX_NAME,
			       CMN_ARCH_PARMS );


	 }  /* end else */

    } /* Request = DZIO002R  */


    return CMN_SUCCESS;

} /* End of ExitCsrNotification */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrRequestFailed
**
**  DESCRIPTION      : This exit is invoked when the CSR request and reply
**                     exchange is NOT completed successfully.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting
**
**  DATE CREATED     : 08/29/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 08/29/95    IPEREZAR 	   Creation
**
***************************************************************************/


AEXPROC( ExitCsrRequestFailed )
{
    USHORT	     FndGenRC = 0;

    FndGenRC = DZIO01MsgBoxDestroy(BOX_TITLE,
				   CMN_ARCH_PARMS);

    /* Set Logging Flag to Yes. */
    CmnMsgBoxOverrides( CMN_LOGGING_YES,
			 CMN_ARCH_PARMS );

    /* Display the problem to the user. */
    CmnMsgBoxDisplay( EAB_CsrReturnCode,
		       CMN_NULL_RETURN_BUTTON,
		       CMN_NULL_MSGBOX_NAME,
		       CMN_ARCH_PARMS );




    return CMN_SUCCESS;

} /* End of ExitCsrRequestFailed */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrProcessReply
**
**  DESCRIPTION      : This exit is called for a successful Main Window
**                     reply.  The reply request id is checked to see if it
**                     is the LUW Process reply.  If so, an architecture
**                     macro is called.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR	     : Andersen Consulting
**
**  DATE CREATED     : 08/29/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
** 08/29/95    IPEREZAR 	   Creation
**
***************************************************************************/

AEXPROC( ExitCsrProcessReply )
{
    USHORT	     FndGenRC = 0;
    SHORT	     RowNumber = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;
    _ImpObjNmLBRow   RowData;
    _RQST	     *pClientData;

    FndGenRC = DZIO01MsgBoxDestroy(BOX_TITLE,
				   CMN_ARCH_PARMS);


    if ( strcmp( EAB_CsrRequestId, CSRRQST ) == 0 )
    {

	 pClientData = &( pWindContextData->Rqst );

	 if (EAB_CdMsgioStatus == 0)
	 {
	     if (pClientData->Dzsr002xKeys.QyALRAclCnt == 0)
	     {


		    FndGenRC = FndMsgBoxDisplayMdlssText(
					    TITLE4,
					    BOX_TITLE,
					    CBI_hwnd,
					    FND_MSGBOX_OK,
					    FND_MSGBOX_WARNING,
					    FND_MSGBOX_IDOK,
					    BOX_TITLE,
					    &FndGenErrorBlock);



	     }
	     else
	     {

	     while (RowNumber < (pClientData -> Dzsr002xKeys.QyALRAclCnt) )
	     {
		   CmnStrCopy( RowData._ImpObjNmLBTxObjectDescData ,
			       pClientData->Dzsr002xLbData[RowNumber].TxObjectDesc,
			       sizeof(RowData._ImpObjNmLBTxObjectDescData ),
			       CMN_ARCH_PARMS );

		   FndGenRC = FndLstBoxRowAdd( CBI_hwnd,
					       IMPOBJ,
					       RowNumber,
					       sizeof(_ImpObjNmLBRow),
					       (VOID *) &(RowData),
					       &FndGenErrorBlock );

		   RowNumber++;

	     } /* End While */
	     }



	 } /* EAB_CdMsgioStatus = 0 */
	 else
	 {
	     CmnMsgBoxOverrides ( CMN_LOGGING_YES,
				  CMN_ARCH_PARMS);

	     CmnMsgBoxDisplay (EAB_CdServErrMsg,
			       CMN_NULL_RETURN_BUTTON,
			       CMN_NULL_MSGBOX_NAME,
			       CMN_ARCH_PARMS );

	     FndWindowDestroy (CBI_hwnd,
			       &FndGenErrorBlock);

	 }  /* end else */

    } /* Request = DZIO002R  */



  return CMN_SUCCESS;
} /* End of ExitCsrProcessReply */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWdtSetDataLength
**
**  DESCRIPTION      : This exit is invoked when the OK button on this
**                     window is clicked.  The application must provide the
**                     length of the OUT layout for Window Data Tracking
**                     purposes.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitWdtSetDataLength )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If this window has an Output layout, replace the
  //  0 in the following line of code with:
  //
  //    sizeof(<_CUFFnnnOUTPUT>)
  //
  //  where <CUFFnnnOUTPUT> is the name of the window's
  //  output layout.  If the window has no output
  //  layout, do not modify the shell.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

    /* Set EAB_OutDataLength to the sizeof the OUT layout for this window */

    EAB_OutDataLength = 0;

    return CMN_SUCCESS;

} /* End of ExitWdtSetDataLength */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWdtBuildLUW
**
**  DESCRIPTION      : This exit will be invoked ONCE FOR EACH descendent
**                     window in the dialog that added, changed, or deleted
**                     data during the life of the dialog.  The exit is
**                     invoked just after the user clicks on the Process
**                     Menu Item, and before the Process Menu Item callback
**                     is invoked.  (This exit is only called in the Main
**                     window of a Process dialog.)
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitWdtBuildLUW )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  This shell code contains three types of examples:
  //  first, for single instance child windows,
  //  second, for multiple instance child windows, and
  //  third, for enterable list box child windows.
  //
  //  Note that in the second case, the instance name
  //  should be referenced to determine which instance
  //  of the child window's data is being handled.  The
  //  specific processing in this case depends on the
  //  application.
  //
  //  As in previous examples, be sure to replace the
  //  template variable names (those enclosed with <...>
  //  with actual application-specific names.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //---------------------------------------------------
  //   Single Instance Window Example
  //
  //   REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //  /* Handle window CUFFnnnX */
  //  if( strcmp( EAB_WdtWindowName, "<CUFFnnnX>" ) == 0 )
  //  {
  //
  //      /* Set up pointer to child window OUT layout <_CUFFnnnOUTPUT> */
  //      <_CUFFnnnOUTPUT> *p<CUFFnnnOutput>;
  //
  //      /* Set the pointer to EAB_pWdtProcessData */
  //      p<CUFFnnnOutput> = EAB_pWdtProcessData;
  //
  //      /* Format the global data area as necessary */
  //
  //      /* Format the LUW layout as necessary */
  //
  //  }
  //
  //---------------------------------------------------
  //   Multiple Instance Window Example
  //
  //   REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //  else if( ... )
  //  {
  //      /* Set up pointer to child window OUT layout <_CUFFnnnOUTPUT> */
  //      <_CUFFnnnOUTPUT> *p<CUFFnnnOutput>;
  //
  //       /* Set the pointer to EAB_pWdtProcessData */
  //      p<CUFFnnnOutput> = EAB_pWdtProcessData;
  //
  //      /* Reference EAB_WdtInstanceName to determine which instance */
  //
  //      /* Format the global data area as necessary */
  //
  //      /* Format the LUW layout as necessary */
  //
  //  }
  //  else if( ... )
  //  {
  //      ...
  //  }
  //
  //--------------------------------------------------------------
  //   Enterable list box Window Example
  //
  //  The following shell code applies to processing output from child
  //    windows of an enterable list box.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------------------
  //  /* Handle window CUFFnnnX */
  //  if( strcmp( EAB_WdtWindowName, "<CUFFnnnX>" ) == 0 )
  //  {
  //
  //      /* Set up pointer to child window OUT layout <_CUFFnnnOUTPUT> */
  //      <_CUFFnnnOUTPUT> *p<CUFFnnnOutput>;
  //
  //      /* Set the pointer to EAB_pWdtProcessData */
  //      p<CUFFnnnOutput> = EAB_pWdtProcessData;
  //
  //
  //      /*
  //      ** Determine what ELB action was performed on this instance of
  //      **  of output data: "ADD", "CHANGE", "DELETE".
  //      */
  //
  //      /*
  //      ** Case where this row was added and possibly modified...
  //      */
  //      if( ( EAB_WdtDataStatus == CMN_LBROW_STATUS_ADDED )
  //          ||
  //          ( EAB_WdtDataStatus == CMN_LBROW_STATUS_ADD_CHANGED ))
  //      {
  //
  //          /* Format the global data area as necessary */
  //
  //          /* Format the LUW layout as necessary */
  //
  //      }
  //
  //      /*
  //      ** Case where this row was added and ultimately deleted...
  //      **  It is very rare that this situation should need special logic,
  //      **  but for thoroughness this logic is included.
  //      */
  //      else if( ( EAB_WdtDataStatus == CMN_LBROW_STATUS_ADD_DELETED )
  //               ||
  //               ( EAB_WdtDataStatus == CMN_LBROW_STATUS_ADD_CHG_DEL ))
  //      {
  //
  //          /* Application-specific logic, if required */
  //
  //      }
  //
  //      /*
  //      ** Case where this row was not deleted (but not modified)...
  //      */
  //      else if( EAB_WdtDataStatus == CMN_LBROW_STATUS_UNCHG_DELETED )
  //      {
  //
  //          /* Format the global data area as necessary */
  //
  //          /* Format the LUW layout as necessary */
  //
  //      }
  //
  //      /*
  //      ** Case where this row was modified then deleted...
  //      */
  //      else if( EAB_WdtDataStatus == CMN_LBROW_STATUS_CHG_DELETED )
  //      {
  //
  //          /* Format the global data area as necessary */
  //
  //          /* Format the LUW layout as necessary */
  //
  //      } /* End of else if row is changed then deleted */
  //
  //      /*
  //      ** Case where this row was modified...
  //      */
  //      else if( EAB_WdtDataStatus == CMN_LBROW_STATUS_CHANGED )
  //      {
  //
  //          /* Format the global data area as necessary */
  //
  //          /* Format the LUW layout as necessary */
  //
  //      }
  //  }
  //
    return CMN_SUCCESS;

} /* End of ExitWdtBuildLUW */



/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitTlPopulateData
**
**  DESCRIPTION      : This exit is invoked during PREDISPLAY in order to
**                     populate the tasks in the Task List.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitTlPopulateData )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  The following block of code will add one row to
  //  the Task List.  The code should be copied for
  //  each row that will appear in the Task List, then
  //  customized with the corresponding WindowTitle,
  //  WindowName, and Attributes.
