/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitDomDragPrepare
**
**  DESCRIPTION      : This exit is used by the application to build the
**                     necessary data objects to drag and inform the
**                     architecture of those data objects and their types.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/
AEXPROC( ExitDomDragPrepare )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If this application IS NOT a DOM source, remove ALL
  //  source code from this exit.
  //
  //  This exit is invoked when the user requests a DOM
  //  using the mouse (as defined by the operating system).
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Exit Steps:
  //
  //  1.  Initialize and load the data structures corresponding
  //      to the objects being dragged from this window.
  //
  //  2.  Initialize and build an architecture _CMNDOMOBJ structure
  //      for each object being dragged from this window.
  //
  //  3.  Call the function CmnDomPrepare passing CMN_ARCH_PARMS, the
  //      number of objects being dragged and pointers to each _CMNDOMOBJ
  //      structure built.
  //
  //  SAMPLE CODE:
  //
  //  Declare structure variables...
  //
  //  <appl data object structure 1>  DataObj1;
  //  <appl data object structure 2>  DataObj2;
  //
  //  _CMNDOMOBJ    DomObject1;
  //  _CMNDOMOBJ    DomObject2;
  //
  //  Declare other variables as needed...
  //
  //  USHORT        FndGenRC = 0;
  //
  //
  //  Initialize and build the application data object structures...
  //
  //  memset (&DataObj1, 0, sizeof (<appl data object structure 1>));
  //  memset (&DataObj2, 0, sizeof (<appl data object structure 2>));
  //
  //
  //  ... Perform the code to load the data object structures with data
  //
  //
  //  Initialize and build the architecture _CMNDOMOBJ structures...
  //
  //  memset (&DomObject1, 0, sizeof (_CMNDOMOBJ));
  //  memset (&DomObject2, 0, sizeof (_CMNDOMOBJ));
  //
  //
  //  Set the object type number...
  //
  //  DomObject1.ObjectTypeNumber = <object type number of data object 1>;
  //  DomObject2.ObjectTypeNumber = <object type number of data object 2>;
  //
  //
  //  Set the pointer to the object data structures...
  //
  //  DomObject1.pObjectData = &DataObj1;
  //  DomObject2.pObjectData = &DataObj2;
  //
  //
  //  Set the length of the object data structures...
  //
  //  DomObject1.ObjectDataLen = sizeof (<appl data object structure 1>);
  //  DomObject2.ObjectDataLen = sizeof (<appl data object structure 2>);
  //
  //
  //  Call CmnDomPrepare to tell the architecture what objects to drag...
  //
  //  FndGenRC = CmnDomPrepare
  //      (CMN_ARCH_PARMS,   /* THIS MUST BE THE FIRST PARM AT ALL TIMES  */
  //       2,                /* THE NUMBER OF OBJECTS BEING DRAGGED       */
  //       &DomObject1,      /* ADDRESS OF EACH ARCH DOM OBJECT STRUCTURE */
  //       &DomObject2);
  //
  //  if (FndGenRC != CMN_SUCCESS)
  //  {
  //      Initiation of DOM has not occurred
  //      return (CMN_FAIL);
  //  }
  //


    return CMN_SUCCESS;

} /* End of ExitDomDragPrepare */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitDomDragOver
**
**  DESCRIPTION      : This exit is used by the application to tell the
**                     architecture which object types the application will
**                     accept for a drop operation.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/
AEXPROC( ExitDomDragOver )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If this application DOES NOT accept DOM objects, remove ALL
  //  source code from this exit.
  //
  //  This exit is invoked an object is dragged over this window
  //  using the mouse (as defined by the operating system).
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

/*!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!
!!
!!  D O   N O T   R E M O V E   T H I S   C O M M E N T   B L O C K !!!!!
!!
!!
!!  UNDER ANY CIRCUMSTANCES...
!!
!!  DO NOT SET A CODEVIEW BREAKPOINT IN THIS EXIT UNDER OS/2...
!!
!!  DOING SO WILL CAUSE THE OPERATING SYSTEM TO LOCK UP!!!
!!
!!
!!  D O   N O T   R E M O V E   T H I S   C O M M E N T   B L O C K !!!!!
!!
!!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!*/

  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Exit Steps:
  //
  //  1.  Call CmnDomAcceptObjects to tell the architecture what
  //      objects the window will accept.
  //
  //
  //  SAMPLE CODE...
  //
  //  CmnDomAcceptObjects
  //     (CMN_ARCH_PARMS,     /* THIS MUST BE THE FIRST PARM AT ALL TIMES  */
  //      <number of object types being specified>,
  //      <object type number1>,
  //      <object type number2>,
  //      <object type number3>,  ...);
  //
  //----------------------------------------------------

    return CMN_SUCCESS;

} /* End of ExitDomDragOver */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitDomDrop
**
**  DESCRIPTION      : This exit is used by the application to access data
**                     that was dropped upon the window using DOM.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/
AEXPROC( ExitDomDrop )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  If this application DOES NOT accept DOM objects, remove ALL
  //  source code from this exit.
  //
  //  This exit is invoked when the mouse cursor is dragged
  //  over this window and the right mouse button is released.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Exit Steps:
  //
  //  1.  Declare pointers to the object data structures being obtained.
  //
  //  2.  Call CmnDomGetObject to obtain an address to the dragged object
  //      data for a specific object type.
  //
  //  3.  If the pointer value returned is NULL then data for that
  //      specific object type was not dragged.
  //
  //  4.  If the pointer value returned is NOT NULL then data for that
  //      specific object type was dragged and can be accessed for
  //      processing.
  //
  //  5.  Repeat steps 2 thru 4 to access other object data structures.
  //
  //
  //  NOTE:
  //     The address returned by CmnDomGetObject is valid ONLY for the
  //        duration of this exit function.  Use of the address after
  //        this exit returns WILL result in an addressing violation.
  //
  //
  //  SAMPLE CODE...
  //
  //  Declare data object structure pointers...
  //
  //  <appl data object structure1> *pDataObj1;
  //  <appl data object structure2> *pDataObj2;
  //
  //
  //  Call CmnDomGetObject to access a dragged object data.
  //
  //  CmnDomGetObject
  //         (<object type number to access>,
  //          &pDataObj1,       /* address of data object pointer */
  //          CMN_ARCH_PARMS);
  //
  //
  //  Check to see if data for the specified object type was dragged...
  //
  //  if (!pDataObj1)
  //  {
  //      No data for that object type was dragged
  //  }
  //  else
  //  {
  //      Process object data pointed at...
  //         pDataObj1->member1....
  //  }
  //
  //  Access other data objects...
  //
  //  CmnDomGetObject
  //         (<object type number to access>,
  //          &pDataObj2,       /* address of data object pointer */
  //          CMN_ARCH_PARMS);
  //
  //
  //  Check to see if data for the specified object type was dragged...
  //
  //  if (!pDataObj2)
  //  {
  //     No data for that object type was dragged
  //  }
  //  else
  //  {
  //      Process object data pointed at...
  //         pDataObj2->member1...
  //  }
  //
  //
  //----------------------------------------------------


    return CMN_SUCCESS;

} /* End of ExitDomDrop */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitSecSetBrowse
**
**  DESCRIPTION      : This exit is invoked when the application has called
**                     CmnSecWindowSecure in this window, or during
**                     Predisplay when this window is a descendent (child,
**                     grandchild, etc.) of a window in which the application
**                     called CmnSecWindowSecure.  The only action in this
**                     exit is to call CmnSecControlsSecure.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitSecSetBrowse )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Secure all non-navigational preemptive commands
  //  and all non-navigational fields using the
  //  appropriate combination of parameters in
  //  CmnSecControlsSecure.
  //
  //  Do NOT call any native FOUNDATION control
  //  manipulation functions, such as FndCommand... or
  //  FndField....
  //
  //  This function call must be uncommented and coded for
  //  all windows that may be secured per the DESCRIPTION
  //  in the comment block above.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  _FND_ERROR_BLOCK FndGenErrorBlock;
  //  USHORT           FndGenRC = 0;
  //
  //  /* This example secures all fields except
  //  ** list boxes, plus one other field or command.
  //  ** Adjust the parameters as required for this
  //  ** window.
  //  **/
  //  CmnSecControlsSecure( CMN_ARCH_PARMS,
  //                        2, /* number of arguments */
  //                        CMN_SEC_ALL_NONLB_FIELDS,
  //                        "<field-or-command-name>");
  //

    return CMN_SUCCESS;

} /* End of ExitSecSetBrowse */


AEXPROC( ExitHlpInit )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  For the Main window only, declare an array
  //  of help window library list, with one entry
  //  for each window in the dialog, pointing to the
  //  Help file containing help for each window.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  _FND_HLPMGR_WINLIB WinLibList[] = {"<CUFFnnnX>", ' ', "<FILE>.HLP",
  //                                     "<CUFFnnnX>", ' ', "<FILE>.HLP",
  //                                     "<CUFFnnnX>", ' ', "<FILE>.HLP"
  //                                     };
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  For all windows, declare an array of help manager
  //  panel id.  The first entry is for business process
  //  help for the dialog, followed by an entry for
  //  window help for the window, followed by entries
  //  for each widget id, and each command id associated
  //  with a pushbutton.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  _FND_HLPMGR_PANEL_ID PanelList[] = {
  //                          BusProcessHelpMN_CMD,   <CUFFnn>,
  //                          WindowHelpMN_CMD,       <CUFFnnnX>_Window,
  //                          <Widget1>_WID,          <id-from-hh-file>,
  //                          <Widget2>_WID,          <id-from-hh-file>,
  //                          <Widget3>_WID,          <id-from-hh-file>,
  //                          <Button1>_CMD,          <id-from-hh-file>,
  //                          <Button2>_CMD,          <id-from-hh-file>,
  //                          <Button3>_CMD,          <id-from-hh-file>
  //                                     };
  //
  //  USHORT FndGenRC = 0;
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  For the Main window only, initialize the help
  //  window library list.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  FndGenRC = CmnHlpMgrInitInst(CMN_HELP_TITLE,
  //                               WinLibList,
  //                               sizeof(WinLibList) /
  //                                   sizeof(_FND_HLPMGR_WINLIB),
  //                               CMN_ARCH_PARMS);
  //
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  For all windows, call the functions to establish
  //  help.
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------
  //
  //  FndGenRC = CmnHlpMgrSetPanels(PanelList,
  //                                (sizeof(PanelList) /
  //                                    sizeof (_FND_HLPMGR_PANEL_ID)),
  //                                0,
  //                                TRUE,
  //                                CMN_ARCH_PARMS);
  //
  //  FndGenRC = CmnHlpMgrSetCommands(HelpforHelpMN_CMD,
  //                                  0,
  //                                  KeysHelpMN_CMD,
  //                                  ContentsHelpMN_CMD,
  //                                  CMN_ARCH_PARMS );
  //
  //  FndGenRC = CmnHlpMgrSetWinPanels(<CUFFnn>,
  //                                   <CUFFnnnX>_Window,
  //                                   CMN_ARCH_PARMS);
  //
  //
  //
    return CMN_SUCCESS;

} /* End of ExitHlpInit */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElbRegister
**
**  DESCRIPTION      : This exit occurs during the PREDISPLAY callback (via
**                     CmnArchInit) to allow the application to register
**                     each enterable list box (and its associations) with
**                     the architecture.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElbRegister )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit to register EACH enterable list box
  //    contained in this window.
  //
  //  To register the ELB perform the following steps:
  //
  //        1. Declare an instance of the ELB registration
  //           parameters structure, _CMNELBREGPARMS
  //
  //        2. Initialize the members of the structures as
  //           required for the application's use of the ELB
  //           control.
  //
  //        3. Call the function CmnELbRegister passing the
  //           the address of the ELB registration parameter
  //           structure.
  //
  //        4. The function will return CMN_SUCCESS if the ELB
  //           was successfully registered with the architecture,
  //           otherwise, the function returns CMN_FAIL.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------


  //
  //  Declare an instance of the ELB registration parameter
  //    structure, _CMNELBREGPARMS, as follows:
  //
  //    _CMNELBREGPARMS     ElbRegParms;
  //
  //  Initialize the structure, this eliminates the need to
  //  copy null strings for non-applicable pushbuttons.
  //    memset(&ElbRegParms, 0, sizeof(_CMNELBREGPARMS));
  //
  //  Initialize the members of the structure as follows:
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbWidgetName,
  //         "<field name of ELB list box>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    ElbRegParms.nElbSeqNum = <a value from 1 to 5, inclusive>;
  //
  //    ElbRegParms.nElbRowLen = sizeof (<ELB row typedef in the WESmap>)
  //
  //    /* Set maximum transactions at size of array in LUW structure
  //       in BFCD. */
  //    ElbRegParms.nElbMaxTxnCount = <>_SIZE;
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddWinName,
  //         "<add child window name or omit this function call>",
  //          CMN_WINDOWNAME_LEN,
  //          CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbChgWinName,
  //         "<default change child window name or omit this function call>",
  //         CMN_WINDOWNAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddPbName,
  //         "<add pushutton widget name or omit this function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbAddUsingPbName,
  //         "<add using pushbutton widget name or omit this function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbChangePbName,
  //         "<change pushbutton widget name or omit this function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbDeletePbName,
  //         "<delete pushbutton widget name or omit this function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbUndeletePbName,
  //         "<undelete pushbutton widget name or omit this function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbUpPbName,
  //         "<move row up pushbutton widget name or omit function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnStrCopy
  //        (ElbRegParms.szElbDownPbName,
  //         "<move row down pushbutton widget name or omit function call>",
  //         CMN_WIDGET_NAME_LEN,
  //         CMN_ARCH_PARMS);
  //
  //    CmnElbRegister (&ElbRegParms, CMN_ARCH_PARMS);
  //

    return CMN_SUCCESS;

} /* End of ExitElbRegister */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1CloseAfterSave
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit is called to allow the application to load
**                     saved data to an enterable list box row.  This exit
**                     is called during one of the following events:
**                       1.  The OK pushbutton on an ELB child window was
**                           clicked.
**                       2.  A row is to be added or updated while loading
**                           previously saved data from window data tracking
**                           via the function CmnElbLoadWdtData.
**                       3.  A row is being added to an enterable list box
**                           from its child window using the function
**                           CmnElbAddFromChild.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1CloseAfterSave )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit routine to place the data saved in a child window
  //    of an ELB into a row of the ELB.
  //
  //  There are several macro names that are available that identify the
  //    the name of the ELB, the row being processed, the operation
  //    that is occuring and the child data itself.  They are as follows:
  //
  //    EAB_CurrElbWidgetName:  Identifies the name of the current ELB
  //                            being processed.
  //
  //    EAB_CurrElbRowNumber:   Identifies the current ELB row being
  //                            processed.
  //
  //    EAB_pElbChildData:      A pointer to the child's window data
  //                            tracking output data.
  //
  //    EAB_ElbChildDataStatus: The status of the child's window data
  //                                tracking output data.
  //
  //    To update data in a row in the enterable list box, perform the
  //        following steps:
  //
  //        1.  Declare a pointer to the child's window data tracking
  //            output structure.
  //
  //        2.  Declare an instance of the ELB row typedef structure found
  //            in the WESmap.
  //
  //        3.  Establish addressability to the child's output data.
  //
  //        4.  Move the child data to the row structure.
  //
  //        5.  Perform any additional processing as needed for derived
  //            columns in the row.
  //
  //        6.  Determine if an override change window is required for
  //            the row.
  //
  //        7.  Call the function CmnElbAssignRowData passing a void pointer
  //            to the row structure and the override change window name.
  //            If no override change window name is required and you wish
  //            the architecture to assign the default change window name,
  //            pass a NULL parameter as the override change window name.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------


  //  Declare a pointer to the child's window data tracking output layout.
  //
  //    <CUFFnnnOUTPUT>  *pCUFFnnnOutput;
  //
  //  Declare an instance of the ELB row typedef
  //
  //    <WESmap ELB ROW TYPEDEF>     ElbRowData;
  //    .
  //    .  Declare additional variables as needed.
  //    .
  //
  //  Establish addressability to the child data.
  //
  //    pCUFFnnnOutput = EAB_pElbChildData;
  //
  //  Move the child data to the row structure.
  //
  //    ElbRowData.<member> = pCUFFnnnOutput-><member>;
  //    CmnStrCopy (ElbRowData.<member>,
  //                pCUFFnnnOutput-><member>,
  //                <length of pCUFFnnnOutput-><member>,
  //                CMN_ARCH_PARMS);
  //    .
  //    .  Any additional processing as required for the ELB row data
  //    .
  //
  //  If an override change window is required, call CmnElbAssignRowData
  //    passing the name of the override change window and a pointer
  //    to the row structure.  Otherwise, call CmnElbAssignRowData setting
  //    the override change window parameter to a NULL.  A NULL override
  //    change window name will tell the architecture to use the default
  //    change window name specified when the ELB was registered.
  //
  //    if (<expression determining if an override change window is needed>)
  //    {
  //        CmnElbAssignRowData
  //                    (EAB_CurrElbWidgetName,
  //                     EAB_CurrElbRowNumber,
  //                     &ElbRowData,
  //                     "<override change window name>",
  //                     CMN_ARCH_PARMS);
  //    }
  //    else
  //    {
  //        CmnElbAssignRowData
  //                    (EAB_CurrElbWidgetName,
  //                     EAB_CurrElbRowNumber,
  //                     &ElbRowData,
  //                     NULL,          /* SPECIFIES NO OVERRIDE WINDOW */
  //                     CMN_ARCH_PARMS);
  //    }
  //



    return CMN_SUCCESS;

} /* End of ExitElb1CloseAfterSave */


