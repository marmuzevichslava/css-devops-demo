/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1BuildInstName
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit allows the application to build an
**                     instance name and assign that instance name to the
**                     enterable list box row.  This exit is called when
**                     a row has either been added to an ELB or a row has
**                     been updated in an ELB.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1BuildInstName )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit function to build the instance name for
  //    an enterable list box row.
  //
  //  All instance names generated MUST be unique and consistent.
  //    Non-unique and/or inconsistent names WILL CAUSE ERRORS.
  //
  //  The following macro names are valid during this exit:
  //    EAB_CurrElbWidgetName
  //    EAB_CurrElbRowNumber
  //
  //  Perform the following steps to build and assign the
  //    instance name for the enterable list box row:
  //
  //    1.  Declare a character array variable long enough to
  //        contain the longest instance name that could be built.
  //
  //    2.  Build the instance name string by concatenating columns of
  //        of data in the specified row along with any other data as
  //        needed to provide a consistent unique name.  The recommended
  //        function for building the name is CmnStrBuildStr.
  //
  //    3.  Assign the instance name to the row by calling the function,
  //        CmnElbAssignChgWinInstName passing the built instance name
  //        string to the function.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //    Declare a character array to contain the instance name to build.
  //
  //    CHAR InstName[<as long as necessary>];
  //
  //    .  Build the instance name (using CmnStrBuildStr), using columns
  //    .    in the ELB row along with any other data as needed to build
  //    .    a unique and consistent instance name.
  //    .
  //
  //    Call CmnElbAssignChgWinInstName passing the instance name built.
  //
  //    CmnElbAssignChgWinInstName (InstName, CMN_ARCH_PARMS);
  //

    return CMN_SUCCESS;

} /* End of ExitElb1BuildInstName */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1BuildInitData
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit allows the application to build and assign
**                     initial data for a child window being opened for a
**                     change or an add using operation.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1BuildInitData )
{
  //---------------------------------------------------
  //  S H E L L   I N S T R U C T I O N S
  //
  //  Use this exit function to build and assign initial data for
  //    a child window being opened for a change or add using operation.
  //
  //  The following macro names are valid during this exit:
  //    EAB_CurrElbWidgetName
  //    EAB_CurrElbRowNumber
  //
  //  Perform the following steps to build and assign the initial
  //    data for a child window:
  //
  //    1.  Declare an instance of the child's input data layout.
  //
  //    2.  Move the data to the input layout.
  //
  //    3.  Call the function CmnElbAssignInitialData passing a void
  //        pointer to the data and the length of the data layout.
  //
  //
  //  REMOVE THIS COMMENT BLOCK WHEN DONE.
  //
  //---------------------------------------------------

  //
  //  Declare an instance of the child's input data layout.
  //
  //    <_CUFFnnnINPUT>  CUFFnnnInput;
  //
  //    .
  //    .  Move the needed data to the instance of the input layout
  //    .
  //
  //  Call the function CmnElbAssignInitialData.
  //
  //    CmnElbAssignInitialData (&CUFFnnnInput,
  //                             sizeof (<_CUFFnnnINPUT>),
  //                             CMN_ARCH_PARMS);
  //


    return CMN_SUCCESS;

} /* End of ExitElb1BuildInitData */


/***************************************************************************
**
