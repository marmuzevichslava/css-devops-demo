              FND_STATICTEXT,
              WS_VISIBLE | SS_LEFT 
              ,2,42,40,12

   CONTROL "",101,
              FND_ENTRYFIELD,
              WS_VISIBLE | WS_TABSTOP
              ,52,42,50,0

