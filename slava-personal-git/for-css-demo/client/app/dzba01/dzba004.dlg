              FND_STATICTEXT,
              WS_VISIBLE | SS_LEFT 
              ,2,10,60,12

   CONTROL "",102,
              FND_ENTRYFIELD,
              WS_VISIBLE | WS_TABSTOP
              ,63,10,38,0

   CONTROL "Cancel",1000,
              FND_PUSH_BUTTON,
              WS_VISIBLE  | WS_GROUP | WS_TABSTOP
              | BS_PUSHBUTTON
              ,55,57,36,12

   CONTROL "",5200,
              FND_ENTRYFIELD,
              WS_VISIBLE
              ,4,70,101,12

   CONTROL "OK",1001,
              FND_PUSH_BUTTON,
              WS_VISIBLE  | WS_GROUP | WS_TABSTOP
              | BS_PUSHBUTTON
              ,14,57,36,12

End /* controls */


