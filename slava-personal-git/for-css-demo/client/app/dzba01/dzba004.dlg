   CONTROL "Export File :",500,
              FND_STATICTEXT,
              WS_VISIBLE | SS_LEFT 
              ,2,26,40,12

   CONTROL "",100,
              FND_ENTRYFIELD,
              WS_VISIBLE | WS_TABSTOP
              ,52,26,50,0

