};


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWktCloseAfterSave
**
**  DESCRIPTION      : This exit occurs when a child of this window closes
**                     after pressing OK.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/02/94
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

AEXPROC( ExitWktCloseAfterSave )
{
    /* 
     * If the child window is Window 4, then format the WCD with the file names
     * to be used in import and export.
     */

    if( strcmp( EAB_ChildWindowName, "DZBA004X" ) == 0 )
    {
        /* Set up pointer to child window OUT layout <_CUFFnnnOUTPUT> */

        _DZBA004OUTPUTREC *pDZBA004OUTPUTREC;

        /* Set the pointer to EAB_pChildData */
        pDZBA004OUTPUTREC = EAB_pChildData;

        /* Format the WCD with the file names used for import and export */
        CmnStrCopy( WCD_Dzba004c.ExportFile,
                    pDZBA004OUTPUTREC->DZBA004Input.ExportFile,
                    sizeof(WCD_Dzba004c.ExportFile),
                    CMN_ARCH_PARMS );

        CmnStrCopy( WCD_Dzba004c.ImportFile,
                    pDZBA004OUTPUTREC->DZBA004Input.ImportFile,
                    sizeof(WCD_Dzba004c.ExportFile),
                    CMN_ARCH_PARMS );

     }

    return CMN_SUCCESS;

} /* End of ExitWktCloseAfterSave */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitWktCloseAfterCancel
**
**  DESCRIPTION      : This exit is invoked when a child of this window has
**                     been closed by clicking on the CANCEL button.  No
**                     data has been saved by the child window.  This exit
**                     is REQUIRED for ALL parent windows.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

AEXPROC( ExitWktCloseAfterCancel )
{

    return CMN_SUCCESS;

} /* End of ExitWktCloseAfterCancel */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrNotification
**
**  DESCRIPTION      : This exit is invoked when the CSR request and reply
**                     exchange is completed successfully.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/28/95  KCHASE                Original code.
**  10/05/98  JMEISSNE      5543    Code changed to detect incorrect file name.
**  01/14/99  TMCEWEN    IR 31531	Removed hard-coding of REPORT_FILE path
**                                  Path name now read from registry key
**
***************************************************************************/

AEXPROC( ExitCsrNotification )
{

    USHORT            nTableCounter = 0,
	                  nTableDone = 0,
	                  FndGenRC = 0;
    USHORT            SelectButton = 0;  /* For Prebill Errors MsgBox */
    USHORT            SelectedButton = 0;  /* For Prebill Errors MsgBox */
	long              nTotalReturnCounter = 0;

    char              ErrorMessage[] = "";
		
    _ExtractInsertLBRow RowData;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    /* Declare a pointer of the Working Storage type */
    _WindowData      *pWCDStorage;

    /* Set a pointer to the working storage area */
    pWCDStorage = SWAT01A_WorkStorage;

    /* Handle LUW Process reply */
    if( strcmp( EAB_CsrRequestId, "DZBA01L" ) == 0 )
    {
        /* Handle a successful update. */
        if( EAB_CdMsgioStatus == 0 )
        {


        /* 
        | If the inputted password was correct, the transaction continues, else
        | a message box informing the user of his error is popped into the 
        | screen.
        */
           
            if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NOCONN) == 0)
            {
                FndMsgBoxDisplayText( BAD_EXT_PW,
                                      "DZBA001X",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );
            }
          
           

            else if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NODATA) == 0)
            {
                FndMsgBoxDisplayText( NO_DATA_FOUND,
                                      "DZBA001X",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );


            }
		   
		   

		    else if (	strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NOFILE) == 0)
			{
		        FndMsgBoxDisplayText(  NO_FILE_FOUND,
			                          "DZBA001X",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );

                


			}
		   
		   
        /*
		| Populate the log file with the results of the table accesses of the
		| previous CSR service call.
		*/
		  

			else if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract,LT_Second_Pass) == 0)
			{					

	        /** format error message **/
			    
				sprintf (ErrorMessage, "%s%s", 
				                       BAD_EXTRACT, 
									   ReportFile);
											
			/** Bad table access make the user aware of it by printing 			**/

				FndMsgBoxDisplayText( ErrorMessage,
                                      "DZBA001X",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );

				
			  		
				nTableCounter = 0;

				while (nTableCounter < TableCountLimit)
				{
					if(strcmp(BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed,
			          NullString) == 0)
					{
					   nTableCounter = TableCountLimit;
					}
					else
					{

			            if ( ( BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode != 0) ||
						     ( BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode != 100) )
					    {
							for (nTableDone = 0; nTableDone < nTableCounter; nTableDone++)
							{
								if ( BFCD_SWAT01Luw.AccessResults[nTableDone].TableAccessed ==
									 BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed)
								{
							      break;
								}
							}
							if ( nTableDone == nTableCounter)
							{
								fprintf(LogFile, "%d  \t%0.0lf \t%s \tEXTRACT \t\t%d\n",
				                  nTableCounter,
				                  BFCD_SWAT01Luw.SWAT01BData[0].KyExtractNo,
								  BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed,
								  BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode);
						
						
								fflush(LogFile);
							}
						}
					}

					nTableCounter++;

				} /* end while */
			

				CMN_WN_CL_AFTER_SUCCESS_PROCESS

				return CMN_SUCCESS;

				

		    } /* end else if  bad account was found */
		/*
		| If the function type is Extract/Insert, another CSR service call should be 
		| made to the Insert service. Otherwise, the processing is done and a "done"
		| message box should be flashed to the user.
		*/
			else
			{
				if ( (strcmp(WCD_SWAT01ARqst.SWAT01AData.CdExtractInsertAct, LT_Ext_Ins_Mode) == 0)
					&&  (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NODATA) != 0) )
				{

					CmnStrCopy( BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract ,
						        LT_First_Pass,
							    sizeof(BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract),
								CMN_ARCH_PARMS );

					CmnStrCopy( BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct ,
						        LT_Insert_Mode,
							    sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct),
								CMN_ARCH_PARMS );

					CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
								 LT_First_Pass,
								sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
								CMN_ARCH_PARMS);

					memset(&BFCD_SWAT01Luw.AccessResults, 0, 
						                 sizeof(_ACCESSRESULTS) );

					CmnCsrCall((BYTE *)&(BFCD_SWAT01Luw),
                           (ULONG)sizeof(_SWAT01LUW),
                            CMN_FORCECALL_YES,
                            "DZBA01M",
                            CMN_ARCH_PARMS);
				}
				else
				{
					RowQueryNumber++;

					if ( RowQueryNumber  < NumberOfRows )
					{

                   
						memset( &RowData, 0, sizeof(_ExtractInsertLBRow ) );

						memset( &BFCD_SWAT01Luw.SWAT01BData, 0, sizeof(_SWAT01BDATA) );

						FndGenRC = FndLstBoxRowSelect ( CBI_hwnd,
                                            "ExtractInsertLB",
                                            RowQueryNumber,
                                            &FndGenErrorBlock);

						FndGenRC = FndLstBoxRowQueryData ( CBI_hwnd,
                                               "ExtractInsertLB",
                                               RowQueryNumber,
                                               sizeof(RowData),
                                               &RowData,
                                               &FndGenErrorBlock);

					/* 
					 * if a row is flagged for deletion, do not process it for 
					 * extraction/insertion. Instead loop through the listbox searching
					 * for a row not flagged for deletion.
					 */
						while ( (RowData._ExtractInsertLBCdStatusIconicData 
					              == CMN_LBROW_STATUS_ADD_DELETED) ||
								(RowData._ExtractInsertLBCdStatusIconicData 
						          == CMN_LBROW_STATUS_ADD_CHG_DEL) )
            			{
							memset( &RowData, 0, sizeof(_ExtractInsertLBRow ) );

							RowQueryNumber++;

							if ( RowQueryNumber  == NumberOfRows )
							{
								CmnMsgBoxDisplay( CSS_MX_TRANS_SUCCESS,
                                              CMN_NULL_RETURN_BUTTON,
                                              CMN_NULL_MSGBOX_NAME,
                                              CMN_ARCH_PARMS );

								CMN_WN_CL_AFTER_SUCCESS_PROCESS

								return CMN_SUCCESS;
							}
							else
							{
                              FndGenRC = FndLstBoxRowSelect ( CBI_hwnd,
                                                              "ExtractInsertLB",
                                                              RowQueryNumber,
                                                              &FndGenErrorBlock);

                              FndGenRC = FndLstBoxRowQueryData ( CBI_hwnd,
                                                                 "ExtractInsertLB",
                                                                 RowQueryNumber,
                                                                 sizeof(RowData),
                                                                 &RowData,
                                                                 &FndGenErrorBlock);
							}
						} /* end while deleted rows */
                    


						FndFieldQueryValue( CBI_hwnd,
                                        "CdExtractInsertAct",
                                        CDEXTRACTINSERTACT_LEN,
                                        BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct,
                                        &FndGenErrorBlock);

						if (strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, 
                                 LT_Ext_Ins_Mode,
							sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
						{

                            CmnStrCopy( WCD_SWAT01ARqst.SWAT01AData.CdExtractInsertAct ,
                                        BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct,
                                        sizeof(WCD_SWAT01ARqst.SWAT01AData.CdExtractInsertAct),
                                        CMN_ARCH_PARMS );

                            CmnStrCopy( BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct ,
                                        LT_Extract_Mode,
                                        sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct),
                                        CMN_ARCH_PARMS );

						}

						memset(&BFCD_SWAT01Luw.SWAT01BData, 0, 
                                             sizeof(BFCD_SWAT01Luw.SWAT01BData));

						BFCD_SWAT01Luw.SWAT01BData[0].KyExtractNo = 
                                         RowData._ExtractInsertLBKyExtractNoData;

						CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].CdAccessType, 
							 RowData._ExtractInsertLBCdAccessTypeData,
							sizeof(BFCD_SWAT01Luw.SWAT01BData[0].CdAccessType),
							CMN_ARCH_PARMS);

						CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, 
                         RowData._ExtractInsertLBTsKyExtractData,
                         sizeof(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract),
                         CMN_ARCH_PARMS);

						CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].TxExtractRemarks2, 
                         RowData._ExtractInsertLBTxExtractRemarksData,
                         sizeof(BFCD_SWAT01Luw.SWAT01BData[0].TxExtractRemarks2),
                         CMN_ARCH_PARMS);


						if ( strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, LT_Extract_Mode, 
	                            sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
						{

                                CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
                                         LT_First_Pass,
                                         sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
                                         CMN_ARCH_PARMS);


								memset(&BFCD_SWAT01Luw.AccessResults, 0, 
								                         sizeof(_ACCESSRESULTS) );


			                    /* call the CSR with the LUW layout SWAT01L */
			                    CmnCsrCall(	(BYTE *)&(BFCD_SWAT01Luw),
						                    (ULONG)sizeof(_SWAT01LUW),
						                    CMN_FORCECALL_YES,
						                    "DZBA01L",
						                    CMN_ARCH_PARMS);

						}
						else if ( strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, LT_Insert_Mode,
	                        sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
						{


                                CmnStrCopy( BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract ,
                                            LT_First_Pass,
                                            sizeof(BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract),
                                            CMN_ARCH_PARMS );

                                CmnStrCopy( BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct ,
                                        LT_Insert_Mode,
                                        sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct),
                                        CMN_ARCH_PARMS );

                                CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
                                             LT_First_Pass,
                                             sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
                                             CMN_ARCH_PARMS);

								memset(&BFCD_SWAT01Luw.AccessResults, 0, 
								                         sizeof(_ACCESSRESULTS) );


			                    /* call the CSR with the LUW layout SWAT01M */
                                CmnCsrCall( (BYTE *)&(BFCD_SWAT01Luw),
                                            (ULONG)sizeof(_SWAT01LUW),
                                            CMN_FORCECALL_YES,
                                            "DZBA01M",
                                            CMN_ARCH_PARMS);


						}  /* end if */

					} 
					else
					{             
                 		CmnMsgBoxDisplay( CSS_MX_TRANS_SUCCESS,
                      	              CMN_NULL_RETURN_BUTTON,
                        	          CMN_NULL_MSGBOX_NAME,
                            	      CMN_ARCH_PARMS );

						CMN_WN_CL_AFTER_SUCCESS_PROCESS
					}                 
				}
			}
        }


        else
        {
            /* Turn Message Box Logging on */
            FndGenRC = CmnMsgBoxOverrides( CMN_LOGGING_YES,
                                           CMN_ARCH_PARMS );

            /* Display Error Message */
            FndGenRC = CmnMsgBoxDisplay( EAB_CdServErrMsg,
                                         CMN_NULL_RETURN_BUTTON,
                                         CMN_NULL_MSGBOX_NAME,
                                         CMN_ARCH_PARMS);


        } /* END: ELSE PROCESSING ERROR */


    } /* END: Handle LUW Process reply for if "DZBA01L"*/


    else if( strcmp( EAB_CsrRequestId, "DZBA01M" ) == 0 )
    {
        /* Declare a pointer to the Client Data area(CUSO18L) */
        _SWAT01LUW   *pSWAT01Luw;

        /* Change the pointer to point to BFCD_CUSO18Luw Record Group. */
        pSWAT01Luw = &(BFCD_SWAT01Luw);

        /* Handle a successful update. */
        if( EAB_CdMsgioStatus == 0 )
        {

           if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NOCONN) == 0)
           {
                FndMsgBoxDisplayText( BAD_INS_PW, 
                                      "DZBA001X",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );
           }

           else if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NODATA) == 0 )
		   {
				     
					FndMsgBoxDisplayText( NO_DATA_FOUND,
					                       "DZBA001X",
                                          CBI_hwnd,
                                          FND_MSGBOX_OK,
                                          FND_MSGBOX_WARNING,
                                          FND_MSGBOX_OK,
                                          "Bill Account Extract",
                                          &SelectedButton,
				                          &FndGenErrorBlock );
           }

           else if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, NOFILE) == 0 )
		   {
				     
					FndMsgBoxDisplayText( NO_FILE_FOUND,
					                       "DZBA001X",
                                          CBI_hwnd,
                                          FND_MSGBOX_OK,
                                          FND_MSGBOX_WARNING,
                                          FND_MSGBOX_OK,
                                          "Bill Account Extract",
                                          &SelectedButton,
				                          &FndGenErrorBlock );
           }



        /*
		| Populate the log file with the results of the table accesses of the
		| previous CSR service call.
		*/

			else if (strcmp(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, LT_Second_Pass) == 0)
			{										
			/** format error message **/
			    
				sprintf (ErrorMessage, "%s%s", 
				                       BAD_INSERT, 
									   ReportFile);
			
			/*
			** If a bad table access is made on a first pass, make the user aware of it
			**/

                FndMsgBoxDisplayText( ErrorMessage,
                                      "DZBA001Y",
                                      CBI_hwnd,
                                      FND_MSGBOX_OK,
                                      FND_MSGBOX_WARNING,
                                      FND_MSGBOX_OK,
                                      "Bill Account Extract",
                                      &SelectedButton,
				                      &FndGenErrorBlock );

			
			
				nTableCounter = 1;

				while (nTableCounter < TableCountLimit)
				{
					if(strcmp(BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed,
			          NullString) == 0)
					{
					nTableCounter = TableCountLimit;
					}
					else
					{


						if ((BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode != 0) ||
							(BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode != 100))
						{
							for (nTableDone = 0; nTableDone < nTableCounter; nTableDone++)
							{
							   if ( BFCD_SWAT01Luw.AccessResults[nTableDone].TableAccessed ==
							        BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed )
								{					  
								   break;
								}
							 }
							if (nTableDone == nTableCounter)
							{
								fprintf(LogFile, "%d  \t%0.0lf \t%s \tINSERT \t\t%d\n",
				                  nTableCounter,
				                  BFCD_SWAT01Luw.SWAT01BData[0].KyExtractNo,
								  BFCD_SWAT01Luw.AccessResults[nTableCounter].TableAccessed,
								  BFCD_SWAT01Luw.AccessResults[nTableCounter].ReturnSqlcode);
							}
						}
					
						fflush(LogFile);

				
					}

					nTableCounter++;

				} /* end while */

				CMN_WN_CL_AFTER_SUCCESS_PROCESS

				return CMN_SUCCESS;

			} /* end else ifs*/

			else
			{
				


                RowQueryNumber++;

                if ( RowQueryNumber < NumberOfRows  )
                {

                    memset( &RowData, 0, sizeof(_ExtractInsertLBRow ) );

                    memset( &BFCD_SWAT01Luw.SWAT01BData, 0, sizeof(_SWAT01BDATA) );

                    FndGenRC = FndLstBoxRowSelect ( CBI_hwnd,
                                            "ExtractInsertLB",
                                            RowQueryNumber,
                                            &FndGenErrorBlock);

                    FndGenRC = FndLstBoxRowQueryData ( CBI_hwnd,
                                               "ExtractInsertLB",
                                               RowQueryNumber,
                                               sizeof(RowData),
                                               &RowData,
                                               &FndGenErrorBlock);

					/* 
					 * if a row is flagged for deletion, do not process it. 
					 * Instead loop through the listbox searching for a row not
					 * not flagged for deletion.
					 */

                    while ( (RowData._ExtractInsertLBCdStatusIconicData 
					              == CMN_LBROW_STATUS_ADD_DELETED) ||
                            (RowData._ExtractInsertLBCdStatusIconicData 
						          == CMN_LBROW_STATUS_ADD_CHG_DEL) )
            		{
                              memset( &RowData, 0, sizeof(_ExtractInsertLBRow ) );

							  RowQueryNumber++;

						if ( RowQueryNumber == NumberOfRows  )
						{
                            CmnMsgBoxDisplay( CSS_MX_TRANS_SUCCESS,
                                              CMN_NULL_RETURN_BUTTON,
                                              CMN_NULL_MSGBOX_NAME,
                                              CMN_ARCH_PARMS );

				            CMN_WN_CL_AFTER_SUCCESS_PROCESS

							return CMN_SUCCESS;
						}
						else
						{
                              FndGenRC = FndLstBoxRowSelect ( CBI_hwnd,
                                                              "ExtractInsertLB",
                                                              RowQueryNumber,
                                                              &FndGenErrorBlock);

                              FndGenRC = FndLstBoxRowQueryData ( CBI_hwnd,
                                                                 "ExtractInsertLB",
                                                                 RowQueryNumber,
                                                                 sizeof(RowData),
                                                                 &RowData,
                                                                 &FndGenErrorBlock);
						 }
					} /* end while deleted rows */
                    

                    FndFieldQueryValue( CBI_hwnd,
                                        "CdExtractInsertAct",
                                        CDEXTRACTINSERTACT_LEN,
                                        BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct,
                                        &FndGenErrorBlock);

                    if (strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, 
                                 LT_Ext_Ins_Mode,
	                    sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
                    {

                            CmnStrCopy( WCD_SWAT01ARqst.SWAT01AData.CdExtractInsertAct ,
                                        BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct,
                                        sizeof(WCD_SWAT01ARqst.SWAT01AData.CdExtractInsertAct),
                                        CMN_ARCH_PARMS );

                            CmnStrCopy( BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct ,
                                        LT_Extract_Mode,
                                        sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct),
                                        CMN_ARCH_PARMS );

	                }


                    memset(&BFCD_SWAT01Luw.SWAT01BData, 0, 
                                             sizeof(BFCD_SWAT01Luw.SWAT01BData));

                    BFCD_SWAT01Luw.SWAT01BData[0].KyExtractNo = 
                                          RowData._ExtractInsertLBKyExtractNoData;

                    CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].CdAccessType, 
                         RowData._ExtractInsertLBCdAccessTypeData,
                         sizeof(BFCD_SWAT01Luw.SWAT01BData[0].CdAccessType),
                         CMN_ARCH_PARMS);

                    CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract, 
                         RowData._ExtractInsertLBTsKyExtractData,
                         sizeof(BFCD_SWAT01Luw.SWAT01BData[0].TsKyExtract),
                         CMN_ARCH_PARMS);

                    CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[0].TxExtractRemarks2, 
                         RowData._ExtractInsertLBTxExtractRemarksData,
                         sizeof(BFCD_SWAT01Luw.SWAT01BData[0].TxExtractRemarks2),
                         CMN_ARCH_PARMS);


                    if ( strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, 
                                     LT_Extract_Mode, 
	                    sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
                    {

                                CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
                                         LT_First_Pass,
                                         sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
                                         CMN_ARCH_PARMS);

								memset(&BFCD_SWAT01Luw.AccessResults, 0, 
								                         sizeof(_ACCESSRESULTS) );

			                    /* call the CSR with the LUW layout SWAT01L */
			                    CmnCsrCall(	(BYTE *)&(BFCD_SWAT01Luw),
						                    (ULONG)sizeof(_SWAT01LUW),
						                    CMN_FORCECALL_YES,
						                    "DZBA01L",
						                    CMN_ARCH_PARMS);

                    }
                    else if ( strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, LT_Export_Mode,
	                            sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
                    {

                            CmnStrCopy( BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract ,
                                        LT_First_Pass,
                                        sizeof(BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract),
                                        CMN_ARCH_PARMS );

                            CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
                                         LT_First_Pass,
                                         sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
                                         CMN_ARCH_PARMS);

							memset(&BFCD_SWAT01Luw.AccessResults, 0, 
								                         sizeof(_ACCESSRESULTS) );

			                /* call the CSR with the LUW layout SWAT01M */
                            CmnCsrCall((BYTE *)&(BFCD_SWAT01Luw),
                                        (ULONG)sizeof(_SWAT01LUW),
                                        CMN_FORCECALL_YES,
                                        "DZBA01M",
                                        CMN_ARCH_PARMS);


                    }  /* end if */   
                    else if ( strncmp(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct, LT_Insert_Mode,
	                            sizeof(BFCD_SWAT01Luw.SWAT01AData.CdExtractInsertAct) ) == 0)
                    {

                            CmnStrCopy( BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract ,
                                        LT_First_Pass,
                                        sizeof(BFCD_SWAT01Luw.SWAT01BData[1].TsKyExtract),
                                        CMN_ARCH_PARMS );


                            CmnStrCopy ( BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType, 
                                         LT_First_Pass,
                                         sizeof(BFCD_SWAT01Luw.SWAT01BData[1].CdAccessType),
                                         CMN_ARCH_PARMS);

	
							memset(&BFCD_SWAT01Luw.AccessResults, 0, 
								                         sizeof(_ACCESSRESULTS) );


			                /* call the CSR with the LUW layout SWAT01M */
                            CmnCsrCall((BYTE *)&(BFCD_SWAT01Luw),
                                        (ULONG)sizeof(_SWAT01LUW),
                                        CMN_FORCECALL_YES,
                                        "DZBA01M",
                                        CMN_ARCH_PARMS);


                    }  /* end if */
                } 
                else
                {             
                    CmnMsgBoxDisplay( CSS_MX_TRANS_SUCCESS,
                                      CMN_NULL_RETURN_BUTTON,
                                      CMN_NULL_MSGBOX_NAME,
                                      CMN_ARCH_PARMS );

				    CMN_WN_CL_AFTER_SUCCESS_PROCESS
                }

                
			}
               

			

        }


        else
        {
            /* Turn Message Box Logging on */
            FndGenRC = CmnMsgBoxOverrides( CMN_LOGGING_YES,
                                           CMN_ARCH_PARMS );

            /* Display Error Message */
            FndGenRC = CmnMsgBoxDisplay( EAB_CdServErrMsg,
                                         CMN_NULL_RETURN_BUTTON,
                                         CMN_NULL_MSGBOX_NAME,
                                         CMN_ARCH_PARMS);


        } /* END: ELSE PROCESSING ERROR */


        memset(&BFCD_SWAT01Luw, 0, sizeof(BFCD_SWAT01Luw));


    } /* END: Handle LUW Process reply */


    /* Handle CSR reply for request SWAT01AR */
    else if( strcmp( EAB_CsrRequestId, "SWAT01AR" ) == 0 )
    {
        /* Handle a successful reply. */
        if( EAB_CdMsgioStatus == 0 )
        {


		  /* No logic here yet because not making a Retrieval Service Call */


        } /* if( EAB_CdMsgioStatus == 0 ) */

        else /* CdMsgioStatus is non-zero */

        {
            /* Set Logging Flag to Yes. */
            CmnMsgBoxOverrides( CMN_LOGGING_YES,
                                CMN_ARCH_PARMS );
  
            /* Display the problem to the user. */
            CmnMsgBoxDisplay( EAB_CdServErrMsg,
                              CMN_NULL_RETURN_BUTTON,
                              CMN_NULL_MSGBOX_NAME,
                              CMN_ARCH_PARMS );

            FndWindowDestroy(CBI_hwnd,
                             &FndGenErrorBlock );

         } /* END:  CdMsgioStatus is non-zero */


    } /* if( strcmp( EAB_CsrRequestId, "SWAT01BR" ) == 0 ) */


    return CMN_SUCCESS;

} /* End of ExitCsrNotification */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrRequestFailed
**
**  DESCRIPTION      : This exit is invoked when the CSR request and reply
**                     exchange is NOT completed successfully.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/28/95  KCHASE                 Original code.
**
***************************************************************************/


AEXPROC( ExitCsrRequestFailed )
{
    USHORT FndGenRC = 0;
    _FND_ERROR_BLOCK FndGenErrorBlock;

    /* Set Logging Flag to Yes. */
    CmnMsgBoxOverrides( CMN_LOGGING_YES,
                        CMN_ARCH_PARMS );

    /* Display the problem to the user. */
    CmnMsgBoxDisplay( EAB_CsrReturnCode,
                      CMN_NULL_RETURN_BUTTON,
                      CMN_NULL_MSGBOX_NAME,
                      CMN_ARCH_PARMS );

    /* Destroy the window, unless this occurred on an LUW request */
    if( strcmp( EAB_CsrRequestId, "SWAT01L" ) != 0 ) 
    {
        FndWindowDestroy( CBI_hwnd,
                          &FndGenErrorBlock );
    }  /* if CsrRequestId is SWAT01L */	

    return CMN_SUCCESS;

} /* End of ExitCsrRequestFailed */

/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitCsrProcessReply
**
**  DESCRIPTION      : This exit is called for a successful Top Window reply.
**                     The reply request id is checked to see if it is the
**                     LUW Process reply.  If so, a flag must be set and a
**                     message box must be destroyed.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**
**  REVISION HISTORY
**
**  DATE      REVISED  BY   SIR #    DESCRIPTION OF CHANGE
**  --------  -----------  -------  ---------------------------------------
**  03/28/95  KCHASE                Original code.
**
***************************************************************************/

AEXPROC( ExitCsrProcessReply )
{
    USHORT            FndGenRC = 0;


    if( strcmp( EAB_CsrRequestId, "DZBA01L" ) == 0 ) 
    {
        CMN_PROCESS_REPLY_RECEIVED

    }
    else if( strcmp( EAB_CsrRequestId, "DZBA01M" ) == 0 ) 
    {
        CMN_PROCESS_REPLY_RECEIVED

    }

  return CMN_SUCCESS;

} /* End of ExitCsrProcessReply */


