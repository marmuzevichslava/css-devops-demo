/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitSibStartDialog
**
**  DESCRIPTION      : This exit is invoked when this window receives a
**                     request from a child window to start a sibling dialog.
**                     If this window can start the dialog, it does.
**                     Otherwise, it sends the request to its parent.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : XXXXXXXX
**
**  DATE CREATED     : 99/99/99
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    99/99/99  XXXXXXXX              Original code.
**
***************************************************************************/
AEXPROC( ExitSibStartDialog )
{

    USHORT FndGenRC = 0;;

    /* Pass the message to the parent window */
    CmnWndMsgSend( CMN_WIN_KEY_PARENT,
                   CMN_WIN_KEY_PARENT,
                   CMN_MSG_START_SIBLING_DLG,
                   EAB_pSibDialogHdr,
                   CMN_ARCH_PARMS );


    return CMN_SUCCESS;

} /* End of ExitSibStartDialog */


