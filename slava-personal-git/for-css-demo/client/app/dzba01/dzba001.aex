/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElbRegister
**
**  DESCRIPTION      : This exit occurs during the PREDISPLAY callback (via
**                     CmnArchInit) to allow the application to register
**                     each enterable list box (and its associations) with
**                     the architecture.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE              Original code.
**
***************************************************************************/

AEXPROC( ExitElbRegister )
{


      /* Declare an instance of the ELB registration parameter structure */
      _CMNELBREGPARMS     ElbRegParms;

      /* Initialize the ELB structure */
      memset(&ElbRegParms, 0, sizeof(_CMNELBREGPARMS));


    CmnStrCopy
        (ElbRegParms.szElbWidgetName,
         "ExtractInsertLB",
         CMN_WIDGET_NAME_LEN,
         CMN_ARCH_PARMS);

    ElbRegParms.nElbSeqNum = 1;

    ElbRegParms.nElbRowLen = sizeof (_ExtractInsertLBRow);

    ElbRegParms.nElbMaxTxnCount = _SWAT01LUW__SWAT01BDATA_SIZE;

    CmnStrCopy
        (ElbRegParms.szElbChgWinName,
         "DZBA002X",
         CMN_WINDOWNAME_LEN,
         CMN_ARCH_PARMS);

    CmnStrCopy
        (ElbRegParms.szElbAddWinName,
         "DZBA002X",
         CMN_WINDOWNAME_LEN,
         CMN_ARCH_PARMS);

 
 //  One CmnStrCopy for each applicable pushbutton only.

    CmnStrCopy (ElbRegParms.szElbAddPbName,
                "AddPB",
                CMN_WIDGET_NAME_LEN,
                CMN_ARCH_PARMS);

    CmnStrCopy (ElbRegParms.szElbChangePbName,
                "ChangePB",
                CMN_WIDGET_NAME_LEN,
                CMN_ARCH_PARMS);

    CmnStrCopy (ElbRegParms.szElbDeletePbName,
                "DeletePB",
                CMN_WIDGET_NAME_LEN,
                CMN_ARCH_PARMS);

    CmnStrCopy (ElbRegParms.szElbUndeletePbName,
                "UndeletePB",
                CMN_WIDGET_NAME_LEN,
                CMN_ARCH_PARMS);



    CmnElbRegister (&ElbRegParms, CMN_ARCH_PARMS);



    return CMN_SUCCESS;

} /* End of ExitElbRegister */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1CloseAfterSave
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit is called to allow the application to load
**                     saved data to an enterable list box row.  This exit
**                     is called during one of the following events:
**                       1.  The OK pushbutton on an ELB child window was
**                           clicked.
**                       2.  A row is to be added or updated while loading
**                           previously saved data from window data tracking
**                           via the function CmnElbLoadWdtData.
**                       3.  A row is being added to an enterable list box
**                           from its child window using the function
**                           CmnElbAddFromChild.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

AEXPROC( ExitElb1CloseAfterSave )
{
    USHORT              FndGenRC = 0;
    _ExtractInsertLBRow ExtractInsertLBRow; /* Instance of LB Row */
    USHORT              i = 0;
	CHAR                KyBaStrMask[12]; /* Masked String Format */
    _FND_ERROR_BLOCK  FndGenErrorBlock;

    /* Set up pointer to child window OUT layout _SWAT01BOUTPUT */
    _SWAT01BOUTPUT *pSWAT01BOutput;

    /* Declare a pointer of the Working Storage type */
    _WindowData      *pWCDStorage;

	/* Memset the Ky BA Mask to Null characters */
    memset(KyBaStrMask, 0 , sizeof(KyBaStrMask));

    /* Set the pointer to CMN_ELB_CHILD_DATA */
    pSWAT01BOutput = CMN_ELB_CHILD_DATA;


    /* Set a pointer to the working storage area */
    pWCDStorage = SWAT01A_WorkStorage;


    /* Initialize the row structure */
    memset( &ExtractInsertLBRow, 0, sizeof( _ExtractInsertLBRow ));

    
	/*Format CdAccessType */
    CmnStrCopy (ExtractInsertLBRow._ExtractInsertLBCdAccessTypeData,
                pSWAT01BOutput->SWAT01BData.CdAccessType,
                sizeof(ExtractInsertLBRow._ExtractInsertLBCdAccessTypeData),
                CMN_ARCH_PARMS);

	/*Format TsKyExtract */
    CmnStrCopy (ExtractInsertLBRow._ExtractInsertLBTsKyExtractData,
                pSWAT01BOutput->SWAT01BData.TsKyExtract,
                TSKYEXTRACT_LEN,
                CMN_ARCH_PARMS);

	/*Format TxExtractRemarks */
    CmnStrCopy (ExtractInsertLBRow._ExtractInsertLBTxExtractRemarksData,
                pSWAT01BOutput->SWAT01BData.TxExtractRemarks2,
                TXEXTRACTREMARKS_LEN,
                CMN_ARCH_PARMS);

	/*Format KyExtractNo */
    ExtractInsertLBRow._ExtractInsertLBKyExtractNoData =
						   pSWAT01BOutput->SWAT01BData.KyExtractNo;


   /* If AccessType is Account */
   if (strcmp ( pSWAT01BOutput->SWAT01BData.CdAccessType, LT_Acct_A) == 0) 
   {

	    /*Format KyBaStrMask */
        CmnStrCopy (KyBaStrMask,
                    pSWAT01BOutput->SWAT01BData.KyExtractNoA,
                    KYEXTRACTNOA_LEN,
                    CMN_ARCH_PARMS);
 

        
	    /*Format KyExtractNoA */
        CmnStrCopy (ExtractInsertLBRow._ExtractInsertLBKyExtractNoAData,
                    KyBaStrMask,
                    KYEXTRACTNOA_LEN,
                    CMN_ARCH_PARMS);

   } /* END: If AccessType is Account */

   else	 /* AccessType = Premise or Building */
   {
    	/*Format KyExtractNoA */
        CmnStrCopy (ExtractInsertLBRow._ExtractInsertLBKyExtractNoAData,
                    pSWAT01BOutput->SWAT01BData.KyExtractNoA,
                    KYEXTRACTNOA_LEN,
                    CMN_ARCH_PARMS);
 

   }  /* END: AccessType = Premise or Building */

    /* Add the row to the ELB */

	if (ChangeFlag == FALSE)
	{
       NumberOfRows++;
	}

    CmnElbAssignRowData( "ExtractInsertLB",
                          EAB_CurrElbRowNumber,
                          &ExtractInsertLBRow,
                          NULL,
                          CMN_ARCH_PARMS);

    FndCommandEnable( CBI_hwnd,
                       "DeletePB",
    		           &FndGenErrorBlock);

	FndGenRC = DZBA001BusProcessMNEnable( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);



    return CMN_SUCCESS;

} /* End of ExitElb1CloseAfterSave */


