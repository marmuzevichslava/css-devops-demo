/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1BuildInitData
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit allows the application to build and assign
**                     initial data for a child window being opened for a
**                     change or an add using operation.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE                Original code.
**
***************************************************************************/

AEXPROC( ExitElb1BuildInitData )
{
    USHORT            FndGenRC = 0;
   _FND_ERROR_BLOCK  FndGenErrorBlock;

    _SWAT01BINPUT   SWAT01BInput; /* Declare instance on ELB Child Window */
                                 /* Input Layout  SWAT01BI */

    _ExtractInsertLBRow  ExtractInsertLBRow;   /* Instance of LB Row */


    /* Initialize Input structure */
    memset(&SWAT01BInput, 0, sizeof(_SWAT01BINPUT));

    /* Initialize ELB structure */
    memset(&ExtractInsertLBRow, 0, sizeof(_ExtractInsertLBRow));


    if (EAB_ElbChildWinFunction == CMN_ELB_PBTYPE_CHANGE)
    {

        CmnElbRowQueryData(    EAB_CurrElbWidgetName,
                               EAB_CurrElbRowNumber,
                               sizeof(_ExtractInsertLBRow),
                               &ExtractInsertLBRow,
                               CMN_ARCH_PARMS );


        /* Populate each of the required fields */

    	/*Format CdAccessType */
        CmnStrCopy (SWAT01BInput.SWAT01BData.CdAccessType,
                ExtractInsertLBRow._ExtractInsertLBCdAccessTypeData,
                sizeof(SWAT01BInput.SWAT01BData.CdAccessType),
                CMN_ARCH_PARMS);

     	/*Format KyExtractNoA (Alphanumeric Number Value)*/
        CmnStrCopy (SWAT01BInput.SWAT01BData.KyExtractNoA,
                ExtractInsertLBRow._ExtractInsertLBKyExtractNoAData,
                KYEXTRACTNOA_LEN,
                CMN_ARCH_PARMS);

		/* Format KyExtractNo */ 
		SWAT01BInput.SWAT01BData.KyExtractNo = 
		           ExtractInsertLBRow._ExtractInsertLBKyExtractNoData;


	    /*Format TsKyExtract */
        CmnStrCopy (SWAT01BInput.SWAT01BData.TsKyExtract,
                ExtractInsertLBRow._ExtractInsertLBTsKyExtractData,
                TSKYEXTRACT_LEN,
                CMN_ARCH_PARMS);

	    /*Format TxExtractRemarks */
        CmnStrCopy (SWAT01BInput.SWAT01BData.TxExtractRemarks2,
                ExtractInsertLBRow._ExtractInsertLBTxExtractRemarksData,
                TXEXTRACTREMARKS_LEN,
                CMN_ARCH_PARMS);

	    /*Format CdExtInsAct */
        FndFieldQueryValue( CBI_hwnd,
                            "CdExtractInsertAct",
                            CDEXTRACTINSERTACT_LEN,
                            SWAT01BInput.SWAT01BData.CdExtractInsertAct,
                            &FndGenErrorBlock);


    } /* END: EAB_ElbChildWinFunction == CMN_ELB_PBTYPE_CHANGE */ 

    else if (EAB_ElbChildWinFunction == CMN_ELB_PBTYPE_ADD)
    {
	    /*Format Default Description for Add Mode */
        FndFieldQueryValue( CBI_hwnd,
                            "TxExtractRemarks2",
                            TXEXTRACTREMARKS2_LEN,
                            SWAT01BInput.SWAT01BData.TxExtractRemarks2,
                            &FndGenErrorBlock);


	    /*Format CdExtractInsertAct */
        FndFieldQueryValue( CBI_hwnd,
                            "CdExtractInsertAct",
                            CDEXTRACTINSERTACT_LEN,
                            SWAT01BInput.SWAT01BData.CdExtractInsertAct,
                            &FndGenErrorBlock);


	} /* END:EAB_ElbChildWinFunction == CMN_ELB_PBTYPE_ADD */ 

    /* Call CmnElbAssignInitialData */
    CmnElbAssignInitialData(&SWAT01BInput,
                            sizeof(_SWAT01BINPUT),
                            CMN_ARCH_PARMS);

    return CMN_SUCCESS;

} /* End of ExitElb1BuildInitData */


/***************************************************************************
**
**            Customer Service System Architecture Exit Function
**
**  FUNCTION         : ExitElb1BuildDelData
**
**  DESCRIPTION      : This exit is associated with the enterable list box
**                     registered as sequence number 1.
**
**                     This exit allows the application to build and assign
**                     data to be placed in window data tracking for rows
**                     that are unchanged and are being flagged for deletion.
**
**  INPUTS           : CMN_ARCH_PARMS - Standard Callback parameters.
**
**  OUTPUTS          : Return Code - SHORT (Valid: CMN_SUCCESS or CMN_FAIL).
**
**
**  CALLED FUNCTIONS : NONE
**
**  AUTHOR           : KCHASE
**
**  DATE CREATED     : 03/28/95
**
**  REVISION HISTORY :
**
**    DATE      REVISED BY   SIR #    DESCRIPTION OF CHANGE
**    --------  -----------  -------  -------------------------------------
**    03/28/95  KCHASE              Original code.
**
***************************************************************************/

AEXPROC( ExitElb1BuildDelData )
{
    USHORT            RowNumber = 0,
                      FndGenRC = 0;

	/*
	 | A deletion reduces the number of rows available for processing, and may
	 | require the disabling of the Process Menu Item.
	 */

    NumberOfRows--;

	FndGenRC = DZBA001BusProcessMNEnable( pEventInfo,
                           pEAIA,
                           pBFCD,
                           pWesMap,
                           pWindContextData,
                           pABHI);


    return CMN_SUCCESS;

} /* End of ExitElb1BuildDelData */

