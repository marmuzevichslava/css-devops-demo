AEXPROC( ExitElb5BuildDelData )
{

    _SWAT01BOUTPUT   SWAT01BOutput; /* Declare instance on ELB Child Window */
                                    /* Input Layout  SWAT01BI */

    _ExtractInsertLBRow  ExtractInsertLBRow;   /* Instance of LB Row */


    /* Initialize Input structure */
    memset(&SWAT01BOutput, 0, sizeof(_SWAT01BOUTPUT));

    /* Initialize ELB structure */
    memset(&ExtractInsertLBRow, 0, sizeof(_ExtractInsertLBRow));


    CmnElbRowQueryData(    EAB_CurrElbWidgetName,
                           EAB_CurrElbRowNumber,
                           sizeof(_ExtractInsertLBRow),
                           (void *) &ExtractInsertLBRow,
                           CMN_ARCH_PARMS );

    /* Populate each of the required fields */

    /*Format KyExtractNoA (Alphanumeric Value for KyExtractNo) */
    CmnStrCopy (SWAT01BOutput.SWAT01BData.KyExtractNoA,
                ExtractInsertLBRow._ExtractInsertLBKyExtractNoAData,
                sizeof(SWAT01BOutput.SWAT01BData.KyExtractNoA),
                CMN_ARCH_PARMS);

    /* Format KyExtractNo */ 
	SWAT01BOutput.SWAT01BData.KyExtractNo = 
		       ExtractInsertLBRow._ExtractInsertLBKyExtractNoData;


    /*Format CdAccessType */
    CmnStrCopy (SWAT01BOutput.SWAT01BData.CdAccessType,
                ExtractInsertLBRow._ExtractInsertLBCdAccessTypeData,
                sizeof(SWAT01BOutput.SWAT01BData.CdAccessType),
                CMN_ARCH_PARMS);

    /*Format KyExtractNoA */
    CmnStrCopy (SWAT01BOutput.SWAT01BData.KyExtractNoA,
                ExtractInsertLBRow._ExtractInsertLBKyExtractNoAData,
                KYEXTRACTNOA_LEN,
                CMN_ARCH_PARMS);

   /*Format TsKyExtract */
    CmnStrCopy (SWAT01BOutput.SWAT01BData.TsKyExtract,
                ExtractInsertLBRow._ExtractInsertLBTsKyExtractData,
                TSKYEXTRACT_LEN,
                CMN_ARCH_PARMS);

  /*Format TxExtractRemarks */
    CmnStrCopy (SWAT01BOutput.SWAT01BData.TxExtractRemarks2,
                ExtractInsertLBRow._ExtractInsertLBTxExtractRemarksData,
                TXEXTRACTREMARKS_LEN,
                CMN_ARCH_PARMS);

    /* Call the function CmnElbAssignDeleteData. */

    CmnElbAssignDeleteData (&SWAT01BOutput,
                            sizeof (_SWAT01BOUTPUT),
                            CMN_ARCH_PARMS);




    return CMN_SUCCESS;

} /* End of ExitElb5BuildDelData */

