/***************************************************************************
 *
 *   Window-Level Event
 *
 *   Callback Name: Xtzytjhi6229_Predisplay
 * 
 *
 *
 *   Event Name:    PREDISPLAY
 *
 *
 ***************************************************************************/
static WCBPROC(Xtzytjhi6229_Predisplay)
{
   _FND_ERROR_BLOCK      FndGenErrorBlock;
   unsigned short        FndGenRC = 0;

CMN_ARCH_EXIT_INITIALIZE

   memset(&FndGenErrorBlock, '\0', sizeof(FndGenErrorBlock));

   FndGenRC = CmnArchInit( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = Dzsf001xprdis( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   FndGenRC = FndCommandDisable( CBI_hwnd,
                                 "CMNCONT",
                                 &FndGenErrorBlock);

   FndGenRC = FndCommandDisable( CBI_hwnd,
                                 "ResetPB",
                                 &FndGenErrorBlock);

   FndGenRC = CmnArchTerm( pEventInfo,
                              pEAIA,
                              pBFCD,
                              pWesMap,
                              pWindContextData,
                              pABHI);

   return 0;

}



